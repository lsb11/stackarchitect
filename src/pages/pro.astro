    // Countdown — Shopify Stocky shutdown August 31, 2026
    function updateCountdown() {
      var target = new Date('2026-08-31T23:59:59Z');
      var now = new Date();
      var diff = target - now;
      var dEls = document.querySelectorAll('#cd-d');
      var hEls = document.querySelectorAll('#cd-h');
      var mEls = document.querySelectorAll('#cd-m');
      if (diff <= 0) {
        dEls.forEach(function(e){e.textContent='0'});
        hEls.forEach(function(e){e.textContent='0'});
        mEls.forEach(function(e){e.textContent='0'});
        return;
      }
      var days = Math.floor(diff / (1000 * 60 * 60 * 24));
      var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      var mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      dEls.forEach(function(e){e.textContent=days});
      hEls.forEach(function(e){e.textContent=String(hours).padStart(2,'0')});
      mEls.forEach(function(e){e.textContent=String(mins).padStart(2,'0')});
    }
    updateCountdown();
    setInterval(updateCountdown, 30000);

    // Scroll bar
    var shown = false, gone = false;
    window.addEventListener('scroll', function() {
      if (gone) return;
      var pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      var bar = document.getElementById('scroll-bar');
      if (!bar) return;
      if (pct > 55 && !shown) { bar.style.display = 'block'; shown = true; }
      else if (pct < 35 && shown) { bar.style.display = 'none'; shown = false; }
    }, { passive: true });
    var dismiss = document.getElementById('scroll-dismiss');
    if (dismiss) dismiss.addEventListener('click', function() {
      var bar = document.getElementById('scroll-bar');
      if (bar) bar.style.display = 'none';
      gone = true;
    });
  })();

