    .tc-store { font-family: var(--mono); font-size: 10px; color: var(--text-4); margin-top: 2px; }
    .tc-tag { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .1em; color: var(--g); margin-bottom: 8px; display: block; }

    /* WHO IS IT FOR */
    .for-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
