    /* SEO PROSE */
    .seo-prose h3 { font-size: 18px; font-weight: 700; color: var(--text); letter-spacing: -.02em; margin: 28px 0 10px; }
    .seo-prose h3:first-child { margin-top: 0; }
    .seo-prose p { font-size: 14px; color: var(--text-3); line-height: 1.8; margin-bottom: 16px; }
    .seo-prose strong { color: var(--text-2); font-weight: 600; }
    .seo-prose a { color: var(--g); text-decoration: none; }
    .seo-prose a:hover { opacity: .8; }

    /* FAQ */
    .faq-list-c { display: flex; flex-direction: column; gap: 3px; }
