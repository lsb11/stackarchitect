  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #030712;
      --bg-2: #060d1a;
      --bg-3: #0b1628;
      --border: rgba(255,255,255,0.06);
      --border-2: rgba(255,255,255,0.11);
      --text: #f1f5f9;
      --text-2: #cbd5e1;
      --text-3: #64748b;
      --text-4: #475569;
      --g: #00c864;
      --g-dim: rgba(0,200,100,0.1);
      --g-border: rgba(0,200,100,0.2);
      --sky: #38bdf8;
      --sky-dim: rgba(56,189,248,0.1);
      --sky-border: rgba(56,189,248,0.2);
      --vio: #c4b5fd;
      --vio-dim: rgba(196,181,253,0.08);
      --vio-border: rgba(196,181,253,0.2);
      --amber: #f59e0b;
      --amber-dim: rgba(245,158,11,0.1);
      --amber-border: rgba(245,158,11,0.25);
      --red: #ef4444;
      --red-dim: rgba(239,68,68,0.07);
      --red-border: rgba(239,68,68,0.2);
      --tiktok: #ff0050;
      --tiktok-dim: rgba(255,0,80,0.1);
      --mono: 'JetBrains Mono', 'Courier New', monospace;
      --sans: 'Inter', -apple-system, 'Helvetica Neue', sans-serif;
    }

    html { background: var(--bg); color: var(--text); font-family: var(--sans); scroll-behavior: smooth; }
    body {
      min-height: 100vh;
      background: radial-gradient(ellipse 80% 40% at 50% -5%, rgba(0,200,100,0.05) 0%, transparent 65%), var(--bg);
    }

    @keyframes dotPing { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.8)} }
    @keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(0,200,100,.3)} 50%{box-shadow:0 0 0 8px rgba(0,200,100,0)} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    /* NAV */
    .product-terminal-bar {
      position: sticky; top: 0; z-index: 1000;
      background: rgba(3,7,18,.94);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      transition: background .25s;
    }
    .product-terminal-bar.scrolled { background: rgba(3,7,18,.98); }
    .terminal-container {
      max-width: 1100px; margin: 0 auto; padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
    }
    .terminal-status {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      color: var(--text-4); letter-spacing: .12em; text-transform: uppercase;
      display: flex; align-items: center; gap: 8px;
      padding: 16px 0; white-space: nowrap;
    }
    .status-indicator {
      display: inline-block; width: 6px; height: 6px; border-radius: 50%;
      background: var(--g); animation: dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite;
    }
    .product-access-grid { display: flex; align-items: center; gap: 0; list-style: none; }
    .product-link {
      display: flex; flex-direction: column; padding: 18px 12px;
      font-family: var(--mono); font-size: 11px; font-weight: 700;
      color: var(--text-3); text-decoration: none; letter-spacing: .04em;
      transition: color .15s; background: none; border: none; cursor: pointer; white-space: nowrap;
    }
    .product-link:hover, .product-link.is-active { color: var(--text); }
    .product-link.home-node { color: var(--text-2); }
    .dropdown { position: relative; }
    .dropdown-menu {
      display: none; position: absolute; top: 100%; left: 0; min-width: 280px;
      background: var(--bg-3); border: 1px solid var(--border-2); border-top: none;
      z-index: 500; flex-direction: column;
    }
    .dropdown:hover .dropdown-menu { display: flex; }
    .dropdown-menu .product-link { padding: 10px 16px; border-bottom: 1px solid var(--border); flex-direction: column; gap: 2px; }
    .dropdown-menu .product-link:last-child { border-bottom: none; }
    .dropdown-menu .product-link:hover { background: rgba(255,255,255,.03); }
    .dropdown-desc { font-size: 10px; font-weight: 400; color: var(--text-4); letter-spacing: .02em; }
    .terminal-cta { display: flex; align-items: center; gap: 12px; }
    .savings-ticker { font-family: var(--mono); font-size: 10px; color: var(--g); font-weight: 700; letter-spacing: .1em; display: none; }
    @media (min-width: 1000px) { .savings-ticker { display: block; } }
    .cta-node {
      display: inline-block; padding: 8px 14px;
      background: transparent; border: 1px solid var(--g-border); color: var(--g);
      font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .08em;
      text-decoration: none; transition: background .15s, border-color .15s; white-space: nowrap;
    }
    .cta-node:hover { background: var(--g-dim); border-color: var(--g); }

    /* BREADCRUMB */
    .breadcrumb-bar {
      max-width: 860px; margin: 0 auto; padding: 14px 24px 0;
      font-family: var(--mono); font-size: 11px; color: var(--text-4);
    }
    .breadcrumb-bar a { color: var(--text-4); text-decoration: none; }
    .breadcrumb-bar a:hover { color: var(--text-3); }
    .breadcrumb-bar span { margin: 0 6px; }

    /* HERO */
    .hero {
      padding: 64px 24px 56px; text-align: center; border-bottom: 1px solid var(--border);
      background:
        repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,.015) 40px),
        repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,.015) 40px),
        var(--bg);
    }
    .hero-inner { max-width: 720px; margin: 0 auto; }
    .hero-dateline { font-family: var(--mono); font-size: 11px; color: var(--text-4); letter-spacing: .06em; margin-bottom: 14px; }
    .hero-proof { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-3); margin-bottom: 24px; }
    .hero-proof-stars { color: var(--amber); font-size: 13px; letter-spacing: .08em; }
    .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--g); animation: dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite; flex-shrink: 0; }

    h1 {
      font-family: var(--sans); font-size: clamp(32px,6vw,56px); font-weight: 900;
      line-height: 1.05; color: var(--text); letter-spacing: -.035em; margin-bottom: 20px;
    }
    h1 .green { color: var(--g); }
    .hero-sub {
      font-size: clamp(15px,2vw,17px); color: var(--text-3); line-height: 1.7;
      max-width: 580px; margin: 0 auto 28px;
    }
    .hero-sub strong { color: var(--text-2); font-weight: 600; }

    .price-row { display: flex; align-items: baseline; justify-content: center; gap: 16px; margin-bottom: 8px; flex-wrap: wrap; }
    .price-main { font-family: var(--mono); font-size: 60px; font-weight: 800; color: var(--text); letter-spacing: -.04em; line-height: 1; }
    .price-was-col { display: flex; flex-direction: column; gap: 2px; align-items: flex-start; }
    .price-strike { font-family: var(--mono); font-size: 22px; color: var(--text-4); text-decoration: line-through; line-height: 1; }
    .price-save { font-family: var(--mono); font-size: 11px; color: var(--g); font-weight: 700; letter-spacing: .06em; }
    .price-note { font-family: var(--mono); font-size: 11px; color: var(--text-4); margin-bottom: 28px; }

    .btn {
      display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px;
      background: var(--g); color: #020617; font-family: var(--sans); font-size: 14px;
      font-weight: 700; border-radius: 8px; text-decoration: none; border: none;
      cursor: pointer; transition: opacity .15s, transform .15s; letter-spacing: -.01em;
    }
    .btn:hover { opacity: .9; transform: translateY(-1px); }
    .btn.pulse { animation: pulse 2.5s ease-in-out infinite; }
    .btn-sm { padding: 10px 20px; font-size: 13px; }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 6px; padding: 13px 24px;
      background: transparent; border: 1px solid var(--border-2); color: var(--text-2);
      font-family: var(--sans); font-size: 14px; font-weight: 600; border-radius: 8px;
      text-decoration: none; transition: border-color .15s, color .15s;
    }
    .btn-outline:hover { border-color: var(--border-2); color: var(--text); }
    .btn-outline-sm { padding: 9px 18px; font-size: 13px; }

    .hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-bottom: 24px; }
    .trust-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 18px; margin-bottom: 20px; }
    .trust-item { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-3); }

    .urgency {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--mono); font-size: 11px; color: var(--text-3);
      background: var(--bg-3); border: 1px solid var(--border);
      padding: 8px 16px; border-radius: 4px;
    }

    /* TAGS */
    .tag { display: inline-flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: 4px 10px; border-radius: 3px; background: var(--g-dim); color: var(--g); border: 1px solid var(--g-border); }
    .tag-dim { background: rgba(255,255,255,.03); color: var(--text-4); border: 1px solid var(--border); }
    .tag-sky { background: var(--sky-dim); color: var(--sky); border: 1px solid var(--sky-border); }
    .tag-vio { background: var(--vio-dim); color: var(--vio); border: 1px solid var(--vio-border); }
    .tag-tiktok { background: var(--tiktok-dim); color: var(--tiktok); border: 1px solid rgba(255,0,80,.2); }
    .tag-amber { background: var(--amber-dim); color: var(--amber); border: 1px solid var(--amber-border); }
    .tag-red { background: var(--red-dim); color: var(--red); border: 1px solid var(--red-border); }

    /* STAT STRIP */
    .stat-strip {
      display: flex; border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
      margin: 32px auto; max-width: 680px;
    }
    .stat-cell { flex: 1; padding: 20px 16px; text-align: center; border-right: 1px solid var(--border); background: var(--bg-3); }
    .stat-cell:last-child { border-right: none; }
    .stat-v { font-family: var(--mono); font-size: clamp(20px,3.5vw,28px); font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 5px; }
    .stat-v.green { color: var(--g); }
    .stat-v.amber { color: var(--amber); }
    .stat-l { font-family: var(--mono); font-size: 10px; color: var(--text-4); letter-spacing: .04em; line-height: 1.4; }

    /* LAYOUT */
    .section { padding: 72px 24px; }
    .section-alt { padding: 72px 24px; background: var(--bg-3); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .inner { max-width: 860px; margin: 0 auto; }
    .inner-sm { max-width: 680px; margin: 0 auto; }
    .sec-head { text-align: center; margin-bottom: 48px; }
    .sec-head h2 { font-family: var(--sans); font-size: clamp(26px,4vw,38px); font-weight: 900; color: var(--text); letter-spacing: -.03em; line-height: 1.1; margin-bottom: 12px; margin-top: 12px; }
    .sec-head p { font-size: 15px; color: var(--text-3); line-height: 1.7; max-width: 520px; margin: 0 auto; }
    .divider { border: none; border-top: 1px solid var(--border); }

    /* CTA STRIP */
    .cta-strip { background: var(--bg-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 28px 24px; }
    .cta-strip-inner { max-width: 860px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
    .cta-strip-title { font-weight: 700; font-size: clamp(15px,2.5vw,18px); color: var(--text); letter-spacing: -.02em; margin-bottom: 4px; }
    .cta-strip-sub { font-size: 13px; color: var(--text-3); }
    .cta-strip-sub span { color: var(--g); font-weight: 600; }
    .cta-strip-actions { display: flex; gap: 10px; flex-wrap: wrap; }

    /* SOLUTION CARDS */
    .kit-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 14px; }
    @media (max-width: 600px) { .kit-grid { grid-template-columns: 1fr; } }
    .sol-card { background: var(--bg); border: 1.5px solid var(--g-border); border-radius: 12px; overflow: hidden; transition: transform .22s, box-shadow .22s; }
    .sol-card:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,.4); }
    .sol-card.t { border-color: rgba(255,0,80,.18); }
    .sol-card.s { border-color: var(--sky-border); }
    .sol-card.v { border-color: var(--vio-border); }
    .sol-card.a { border-color: var(--amber-border); }
    .sol-bar { height: 3px; background: linear-gradient(90deg,var(--g),#00a8a8); }
    .sol-card.t .sol-bar { background: linear-gradient(90deg,var(--tiktok),#ff6b9d); }
    .sol-card.s .sol-bar { background: linear-gradient(90deg,var(--sky),#38d4f8); }
    .sol-card.v .sol-bar { background: linear-gradient(90deg,var(--vio),#818cf8); }
    .sol-card.a .sol-bar { background: linear-gradient(90deg,var(--amber),#fbbf24); }
    .sol-body { padding: 20px; }
    .sol-name { font-size: 16px; font-weight: 700; color: var(--text); letter-spacing: -.02em; margin: 8px 0 5px; }
    .sol-hl { font-size: 13px; font-weight: 600; color: var(--text-2); margin-bottom: 8px; }
    .sol-desc { font-size: 13px; color: var(--text-3); line-height: 1.65; margin-bottom: 12px; }
    .sol-rep-label { font-family: var(--mono); font-size: 9px; color: var(--text-4); letter-spacing: .1em; margin-bottom: 6px; }
    .sol-reps { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 12px; }
    .sol-rep { font-family: var(--mono); font-size: 10px; color: var(--text-4); background: rgba(255,255,255,.03); border: 1px solid var(--border); padding: 2px 8px; border-radius: 3px; }
    .sol-meta { display: flex; align-items: center; gap: 12px; font-family: var(--mono); font-size: 11px; }
    .sol-save { color: var(--g); font-weight: 700; }
    .sol-save.t { color: var(--tiktok); }
    .sol-save.v { color: var(--vio); }
    .sol-save.a { color: var(--amber); }
    .sol-time { color: var(--text-4); }
    .sol-foot { padding: 13px 20px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .sol-cta { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--g); text-decoration: none; letter-spacing: .04em; transition: opacity .15s; }
    .sol-cta:hover { opacity: .75; }
    .sol-guide { font-family: var(--mono); font-size: 10px; color: var(--text-4); text-decoration: none; }
    .sol-guide:hover { color: var(--text-3); }

    /* URGENT CARD */
    .sol-urgent { border: 1.5px solid rgba(239,68,68,.25); border-radius: 12px; overflow: hidden; margin-bottom: 14px; background: rgba(239,68,68,.03); }
    .sol-urgent-bar { height: 3px; background: linear-gradient(90deg,var(--red),#f97316); }
    .sol-urgent-inner { padding: 24px; display: flex; gap: 28px; align-items: flex-start; flex-wrap: wrap; }
    .sol-urgent-badge { font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--red); letter-spacing: .1em; margin-bottom: 10px; }
    .sol-urgent-name { font-size: 22px; font-weight: 900; color: var(--text); letter-spacing: -.03em; margin: 8px 0 5px; }
    .sol-urgent-hl { font-size: 14px; font-weight: 600; color: var(--text-2); margin-bottom: 8px; }
    .sol-urgent-desc { font-size: 13px; color: var(--text-3); line-height: 1.7; margin-bottom: 14px; }
    .sol-urgent-meta { display: flex; align-items: center; gap: 12px; font-family: var(--mono); font-size: 11px; margin-bottom: 16px; }
    .sol-urgent-save { color: var(--sky); font-weight: 700; }
    .sol-urgent-time { color: var(--text-4); }
    .sol-urgent-right { display: flex; flex-direction: column; align-items: center; gap: 12px; min-width: 180px; }
    .countdown-box { background: rgba(239,68,68,.07); border: 1px solid var(--red-border); border-radius: 8px; padding: 18px 20px; text-align: center; width: 100%; }
    .countdown-label { font-family: var(--mono); font-size: 10px; color: var(--text-4); margin-bottom: 12px; letter-spacing: .06em; }
    .countdown-nums { display: flex; align-items: center; justify-content: center; gap: 8px; font-family: var(--mono); }
    .cd-unit { text-align: center; }
    .cd-val { font-size: 28px; font-weight: 800; color: var(--red); line-height: 1; display: block; }
    .cd-l { font-size: 9px; color: var(--text-4); letter-spacing: .06em; margin-top: 2px; }
    .cd-sep { font-size: 20px; color: var(--red); margin-bottom: 12px; }

    /* BONUS ITEMS GRID */
    .bonus-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 14px; margin-top: 14px; }
    @media (max-width: 600px) { .bonus-grid { grid-template-columns: 1fr; } }
    .bonus-card { background: var(--bg-3); border: 1px solid var(--border-2); border-radius: 12px; padding: 22px; display: flex; gap: 16px; align-items: flex-start; transition: border-color .2s; }
    .bonus-card:hover { border-color: rgba(255,255,255,.18); }
    .bonus-icon { width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; }
    .bonus-icon.sheets { background: rgba(52,168,83,.12); border: 1px solid rgba(52,168,83,.2); }
    .bonus-icon.loom { background: rgba(98,102,255,.12); border: 1px solid rgba(98,102,255,.2); }
    .bonus-content {}
    .bonus-tag { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .1em; color: var(--text-4); margin-bottom: 5px; }
    .bonus-name { font-size: 15px; font-weight: 700; color: var(--text); letter-spacing: -.02em; margin-bottom: 5px; }
    .bonus-desc { font-size: 13px; color: var(--text-3); line-height: 1.6; }

    /* COMPARISON */
    .compare-wrap { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    .compare-head { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1.1fr; background: var(--bg-3); border-bottom: 1px solid var(--border); }
    .compare-head-cell { padding: 14px 16px; font-family: var(--mono); font-size: 10px; color: var(--text-4); letter-spacing: .08em; text-transform: uppercase; font-weight: 700; }
    .compare-head-cell.hl { background: var(--g-dim); color: var(--g); border-left: 1px solid var(--g-border); border-right: 1px solid var(--g-border); }
    .compare-row { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1.1fr; border-bottom: 1px solid var(--border); }
    .compare-row:last-child { border-bottom: none; }
    .compare-cell { padding: 11px 16px; font-size: 13px; color: var(--text-3); display: flex; align-items: center; }
    .compare-cell:first-child { color: var(--text-2); font-weight: 500; font-size: 12px; }
    .compare-cell.hl { background: rgba(0,200,100,.025); border-left: 1px solid var(--g-border); border-right: 1px solid var(--g-border); color: var(--text); }
    .yes { color: var(--g); font-family: var(--mono); font-size: 12px; font-weight: 700; }
    .no  { color: var(--text-4); font-family: var(--mono); font-size: 12px; }
    @media (max-width: 600px) {
      .compare-head { grid-template-columns: 1.2fr 0 1fr 1fr; }
      .compare-row { grid-template-columns: 1.2fr 0 1fr 1fr; }
      .compare-head-cell:nth-child(2), .compare-cell:nth-child(2) { display: none; }
    }

    /* REPLACEMENTS */
    .rep-table { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    .rep-row { display: grid; grid-template-columns: 1fr 1.2fr auto; border-bottom: 1px solid var(--border); font-size: 13px; }
    .rep-row:last-child { border-bottom: none; }
    .rep-head { background: var(--bg-3); }
    .rep-cell { padding: 13px 18px; color: var(--text-3); display: flex; align-items: center; }
    .rep-cell:first-child { color: var(--text-2); font-weight: 500; }
    .rep-head .rep-cell { font-family: var(--mono); font-size: 10px; color: var(--text-4); letter-spacing: .08em; font-weight: 700; }
    .rep-saving { color: var(--g); font-family: var(--mono); font-size: 12px; font-weight: 700; white-space: nowrap; }
    .rep-total { background: var(--g-dim); border-top: 1px solid var(--g-border); }
    .rep-total .rep-cell:first-child { color: var(--g); font-family: var(--mono); font-size: 12px; font-weight: 700; }

    /* HOW GRID */
    .how-grid { display: grid; grid-template-columns: repeat(4,1fr); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    @media (max-width: 700px) { .how-grid { grid-template-columns: repeat(2,1fr); } }
    @media (max-width: 440px) { .how-grid { grid-template-columns: 1fr; } }
    .how-step { padding: 28px 22px; border-right: 1px solid var(--border); background: var(--bg-3); }
    .how-step:last-child { border-right: none; }
    @media (max-width: 700px) { .how-step:nth-child(2) { border-right: none; } .how-step:nth-child(3) { border-top: 1px solid var(--border); } }
    .how-n { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--g); letter-spacing: .1em; margin-bottom: 10px; }
    .how-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 8px; letter-spacing: -.02em; }
    .how-body { font-size: 12px; color: var(--text-3); line-height: 1.7; margin-bottom: 14px; }
    .how-tool { font-family: var(--mono); font-size: 10px; color: var(--text-4); letter-spacing: .06em; }

    /* TESTIMONIALS */
    .testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
    @media (max-width: 700px) { .testi-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 480px) { .testi-grid { grid-template-columns: 1fr; } }
    .tc { background: var(--bg-3); border: 1px solid var(--border); border-radius: 10px; padding: 20px; transition: border-color .2s; }
    .tc:hover { border-color: var(--border-2); }
    .tc.featured { grid-column: 1/-1; border-color: var(--g-border); background: rgba(0,200,100,.03); }
    .tc-stars { color: var(--amber); font-size: 12px; letter-spacing: .1em; margin-bottom: 10px; }
    .tc-quote { font-size: 14px; color: var(--text-3); line-height: 1.7; font-style: italic; margin-bottom: 14px; }
    .tc-quote strong { color: var(--text); font-style: normal; }
    .tc-name { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--text-2); }
    .tc-store { font-family: var(--mono); font-size: 10px; color: var(--text-4); margin-top: 2px; }
    .tc-tag { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .1em; color: var(--g); margin-bottom: 8px; display: block; }

    /* WHO IS IT FOR */
    .for-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    @media (max-width: 560px) { .for-grid { grid-template-columns: 1fr; } }
    .for-card { background: var(--bg-3); border: 1px solid var(--border); border-radius: 10px; padding: 22px; }
    .for-card.yes-card { border-color: var(--g-border); }
    .for-card-label { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em; margin-bottom: 14px; }
    .for-card.yes-card .for-card-label { color: var(--g); }
    .for-card.no-card .for-card-label { color: var(--text-4); }
    .for-item { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: var(--text-3); line-height: 1.6; margin-bottom: 10px; }
    .for-item:last-child { margin-bottom: 0; }
    .for-dot { flex-shrink: 0; margin-top: 1px; font-family: var(--mono); font-size: 12px; }
    .for-dot.y { color: var(--g); }
    .for-dot.n { color: var(--text-4); }

    /* SEO PROSE */
    .seo-prose h3 { font-size: 18px; font-weight: 700; color: var(--text); letter-spacing: -.02em; margin: 28px 0 10px; }
    .seo-prose h3:first-child { margin-top: 0; }
    .seo-prose p { font-size: 14px; color: var(--text-3); line-height: 1.8; margin-bottom: 16px; }
    .seo-prose strong { color: var(--text-2); font-weight: 600; }
    .seo-prose a { color: var(--g); text-decoration: none; }
    .seo-prose a:hover { opacity: .8; }

    /* FAQ */
    .faq-list-c { display: flex; flex-direction: column; gap: 3px; }
    .faq-item-c { border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    .faq-item-c summary {
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      padding: 15px 18px; background: var(--bg-3);
      font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--text);
      cursor: pointer; letter-spacing: .02em; list-style: none; transition: background .15s;
    }
    .faq-item-c summary:hover { background: var(--bg-2); }
    .faq-item-c summary::-webkit-details-marker { display: none; }
    .faq-ico { width: 16px; height: 16px; border-radius: 50%; border: 1px solid var(--border-2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 10px; color: var(--text-4); transition: transform .2s; }
    .faq-ico::before { content: '▶'; }
    .faq-item-c[open] .faq-ico { transform: rotate(90deg); }
    .faq-ans-c { padding: 0 18px 16px; background: var(--bg-3); font-size: 13px; color: var(--text-3); line-height: 1.75; }
    .faq-ans-c a { color: var(--g); text-decoration: none; }

    /* VALUE CALLOUT */
    .value-callout { background: var(--bg-3); border: 1px solid var(--g-border); border-radius: 12px; padding: 28px; margin-bottom: 32px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
    .value-callout-label { font-family: var(--mono); font-size: 10px; color: var(--g); font-weight: 700; letter-spacing: .1em; margin-bottom: 6px; }
    .value-callout-title { font-size: 18px; font-weight: 700; color: var(--text); letter-spacing: -.02em; margin-bottom: 6px; }
    .value-callout-desc { font-size: 13px; color: var(--text-3); line-height: 1.65; }
    .value-callout-price { text-align: center; flex-shrink: 0; }
    .value-callout-num { font-family: var(--mono); font-size: 48px; font-weight: 800; color: var(--g); line-height: 1; }
    .value-callout-sub { font-family: var(--mono); font-size: 10px; color: var(--text-4); margin-top: 4px; }

    /* BOTTOM CTA */
    .bottom-cta { text-align: center; padding: 72px 24px; background: var(--bg-3); border-top: 2px solid var(--g-border); }
    .bottom-cta h3 { font-family: var(--sans); font-size: clamp(22px,4vw,38px); font-weight: 900; color: var(--text); letter-spacing: -.03em; line-height: 1.1; margin-bottom: 12px; }
    .bottom-cta p { font-size: 15px; color: var(--text-3); line-height: 1.7; margin-bottom: 28px; max-width: 520px; margin-left: auto; margin-right: auto; }
    .bottom-cta-note { margin-top: 20px; font-family: var(--mono); font-size: 11px; color: var(--text-4); }
    .bottom-trust { display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; margin-top: 24px; }
    .bottom-trust-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-4); font-family: var(--mono); }

    /* SCROLL BAR */
    .scroll-bar { display: none; position: fixed; bottom: 0; left: 0; right: 0; background: var(--bg-3); border-top: 1px solid var(--border); padding: 14px 24px; z-index: 800; }
    .scroll-bar-inner { max-width: 860px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .scroll-bar-text { font-size: 13px; color: var(--text-3); }
    .scroll-bar-text span { color: var(--g); font-weight: 600; }
    .scroll-bar-actions { display: flex; align-items: center; gap: 10px; }
    .scroll-bar-dismiss { background: none; border: none; color: var(--text-4); font-family: var(--mono); font-size: 11px; cursor: pointer; padding: 6px; }

    /* FOOTER */
    .architect-footer { background: var(--bg); border-top: 1px solid var(--border); }
    .footer-container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
    .footer-conversion-strip { display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; padding: 24px 0; border-bottom: 1px solid var(--border); }
    .footer-conversion-text { font-size: 14px; color: var(--text-3); }
    .footer-conversion-text span { color: var(--text); font-weight: 600; }
    .footer-conversion-cta { display: inline-block; padding: 10px 20px; background: var(--g); color: #020617; font-family: var(--sans); font-size: 13px; font-weight: 700; border-radius: 6px; text-decoration: none; white-space: nowrap; }
    .footer-system-title { display: block; font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--text-4); letter-spacing: .15em; padding: 28px 0 8px; }
    .status-bar { display: flex; align-items: center; gap: 10px; margin-bottom: 24px; flex-wrap: wrap; }
    .status-item { font-family: var(--mono); font-size: 10px; color: var(--text-4); display: flex; align-items: center; gap: 6px; }
    .pulse-dot { display: inline-block; width: 5px; height: 5px; border-radius: 50%; background: var(--g); animation: dotPing 2.2s ease infinite; }
    .bar-sep { width: 1px; height: 12px; background: var(--border-2); }
    .footer-links { display: flex; flex-wrap: wrap; gap: 6px 4px; margin-bottom: 20px; }
    .footer-links a { font-family: var(--mono); font-size: 11px; color: var(--text-4); text-decoration: none; padding: 4px 10px; border: 1px solid var(--border); border-radius: 3px; transition: color .15s, border-color .15s; }
    .footer-links a:hover { color: var(--text-3); border-color: var(--border-2); }
    .nav-secondary { display: flex; flex-wrap: wrap; gap: 6px 20px; margin-bottom: 24px; }
    .nav-secondary a { font-size: 12px; color: var(--text-4); text-decoration: none; transition: color .15s; }
    .nav-secondary a:hover { color: var(--text-3); }
    .footer-trust-row { display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 28px; }
    .trust-badge { display: flex; align-items: center; gap: 7px; font-size: 12px; color: var(--text-4); }
    .trust-badge-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--g); flex-shrink: 0; }
    .footer-divider { border: none; border-top: 1px solid var(--border); margin: 0 0 20px; }
    .return-origin { display: inline-block; font-family: var(--mono); font-size: 10px; color: var(--text-4); text-decoration: none; letter-spacing: .1em; margin-bottom: 16px; }
    .return-origin:hover { color: var(--text-3); }
    .copyright { font-family: var(--mono); font-size: 10px; color: var(--text-4); margin-bottom: 12px; }
    .affiliate-disclosure { font-size: 12px; color: var(--text-4); line-height: 1.6; padding-bottom: 32px; }
    .affiliate-disclosure a { color: var(--text-4); text-decoration: none; }

    /* MOBILE NAV */
    @media (max-width: 700px) {
      .terminal-status, .product-access-grid { display: none; }
      .nav-mobile { display: flex; }
    }
    .nav-mobile { display: none; align-items: center; }
    .nav-mobile-logo { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--text-2); text-decoration: none; }

    /* RISK REVERSAL STRIP */
    .risk-strip { background: var(--bg-2); border: 1px solid var(--border); border-radius: 10px; padding: 22px 24px; display: flex; flex-wrap: wrap; gap: 20px; align-items: center; justify-content: center; margin-top: 24px; }
    .risk-item { display: flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; color: var(--text-3); }

