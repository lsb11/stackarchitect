    .bonus-name { font-size: 15px; font-weight: 700; color: var(--text); letter-spacing: -.02em; margin-bottom: 5px; }
    .bonus-desc { font-size: 13px; color: var(--text-3); line-height: 1.6; }

    /* COMPARISON */
    .compare-wrap { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    .compare-head { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1.1fr; background: var(--bg-3); border-bottom: 1px solid var(--border); }
    .compare-head-cell { padding: 14px 16px; font-family: var(--mono); font-size: 10px; color: var(--text-4); letter-spacing: .08em; text-transform: uppercase; font-weight: 700; }
    .compare-head-cell.hl { background: var(--g-dim); color: var(--g); border-left: 1px solid var(--g-border); border-right: 1px solid var(--g-border); }
    .compare-row { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1.1fr; border-bottom: 1px solid var(--border); }
    .compare-row:last-child { border-bottom: none; }
    .compare-cell { padding: 11px 16px; font-size: 13px; color: var(--text-3); display: flex; align-items: center; }
    .compare-cell:first-child { color: var(--text-2); font-weight: 500; font-size: 12px; }
    .compare-cell.hl { background: rgba(0,200,100,.025); border-left: 1px solid var(--g-border); border-right: 1px solid var(--g-border); color: var(--text); }
