    .sol-rep-label { font-family: var(--mono); font-size: 9px; color: var(--text-4); letter-spacing: .1em; margin-bottom: 6px; }
    .sol-reps { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 12px; }
    .sol-rep { font-family: var(--mono); font-size: 10px; color: var(--text-4); background: rgba(255,255,255,.03); border: 1px solid var(--border); padding: 2px 8px; border-radius: 3px; }
    .sol-meta { display: flex; align-items: center; gap: 12px; font-family: var(--mono); font-size: 11px; }
