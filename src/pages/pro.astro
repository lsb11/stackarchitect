    @media (max-width: 600px) { .bonus-grid { grid-template-columns: 1fr; } }
    .bonus-card { background: var(--bg-3); border: 1px solid var(--border-2); border-radius: 12px; padding: 22px; display: flex; gap: 16px; align-items: flex-start; transition: border-color .2s; }
