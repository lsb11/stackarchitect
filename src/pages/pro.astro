    .sol-save.v { color: var(--vio); }
    .sol-save.a { color: var(--amber); }
    .sol-time { color: var(--text-4); }
    .sol-foot { padding: 13px 20px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .sol-cta { font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--g); text-decoration: none; letter-spacing: .04em; transition: opacity .15s; }
