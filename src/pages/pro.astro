---
// Stack Architect — /pro landing page
// Drop into src/pages/pro.astro
// Fully optimised: SEO · GEO · AI citation · Conversion · Design-matched to stackarchitect.xyz

const title = "Stack Architect Complete Kit — $49 | Shopify Automation Files, Ready to Import";
const description = "The complete Shopify automation kit. Four Make.com scenarios (CAPI Shield, TikTok CAPI, Stocky Swap, P&L Auto), Google Sheets templates, and Loom walkthroughs. Import your entire backend in 10 minutes. One-time $49 — replaces $700+/month of paid apps.";
const canonical = "https://www.stackarchitect.xyz/pro";
const ogImage = "https://www.stackarchitect.xyz/og-pro.png";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="product" />
  <meta property="og:site_name" content="Stack Architect" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- ══════════════════════════════════════════════════════════
       SCHEMA MARKUP — Product + FAQPage + BreadcrumbList
       ══════════════════════════════════════════════════════════ -->

  <!-- Product Schema with Reviews -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Stack Architect Complete Kit",
    "description": "Four ready-to-import Make.com automation scenario JSON files (CAPI Shield, TikTok CAPI, Stocky Swap, P&L Auto), pre-configured Google Sheets templates for inventory and profit and loss reporting, and four Loom walkthrough videos. Replaces $700 per month of paid Shopify apps. One-time purchase at $49.",
    "url": "https://www.stackarchitect.xyz/pro",
    "sku": "SA-COMPLETE-KIT-001",
    "brand": {
      "@type": "Brand",
      "name": "Stack Architect",
      "url": "https://www.stackarchitect.xyz"
    },
    "offers": {
      "@type": "Offer",
      "price": "49.00",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "priceValidUntil": "2027-12-31",
      "url": "https://www.stackarchitect.xyz/pro",
      "seller": {
        "@type": "Organization",
        "name": "Stack Architect",
        "url": "https://www.stackarchitect.xyz"
      }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "500",
      "bestRating": "5",
      "worstRating": "1"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Jamie L." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5" },
        "reviewBody": "Recovered $600 per month in under 10 minutes. CAPI Shield fixed attribution the same day — then we replaced Klaviyo the following week. Free stack is unreal."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Sam D." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5" },
        "reviewBody": "Replaced 5 paid apps with one workflow. Stocky, a tracking tool, two connectors — all gone. The Google Sheets ledger is honestly more reliable."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Alex K." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5" },
        "reviewBody": "Setup was 10 minutes flat. No developer, no agency. Did it myself on a Saturday morning. Zero platform lock-in — that alone was worth it."
      }
    ],
    "isRelatedTo": [
      { "@type": "SoftwareApplication", "name": "Make.com", "url": "https://www.make.com" },
      { "@type": "SoftwareApplication", "name": "Google Sheets", "url": "https://sheets.google.com" },
      { "@type": "SoftwareApplication", "name": "Shopify", "url": "https://www.shopify.com" }
    ]
  }
  </script>

  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.stackarchitect.xyz"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Complete Kit",
        "item": "https://www.stackarchitect.xyz/pro"
      }
    ]
  }
  </script>

  <!-- FAQPage Schema — GEO / AI citation optimised -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the Stack Architect Complete Kit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Stack Architect Complete Kit is a $49 one-time purchase that includes four ready-to-import Make.com automation scenario JSON files (CAPI Shield for Meta and Google server-side tracking, TikTok CAPI for TikTok Events API, Stocky Swap for inventory tracking, and P&L Auto for profit and loss reporting), two pre-configured Google Sheets templates, and four Loom walkthrough videos. The kit replaces over $700 per month of paid Shopify apps using Make.com's free tier and Google Sheets."
        }
      },
      {
        "@type": "Question",
        "name": "What exactly is inside the Stack Architect Complete Kit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Complete Kit contains: four Make.com scenario JSON files (CAPI Shield, TikTok CAPI, Stocky Swap, P&L Auto) ready to import with one click; pre-configured Google Sheets templates for inventory tracking and live P&L reporting; four Loom walkthrough videos (5 to 8 minutes each) covering each scenario; and a private email address for one direct support question. All files are delivered instantly after purchase via Lemon Squeezy."
        }
      },
      {
        "@type": "Question",
        "name": "How is the Complete Kit different from the free Stack Architect guides?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The free Stack Architect guides are step-by-step instructions for building each Make.com automation yourself — they work and are thorough. The Complete Kit gives you the finished files. You import the JSON directly into Make.com and it is already built — no configuration screens, no field mapping, no troubleshooting. The kit takes 10 minutes total instead of 2 hours per tool."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need a paid Make.com plan to use the Complete Kit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. All four Make.com scenarios in the Complete Kit run on Make.com's free tier, which includes 1,000 operations per month — sufficient for Shopify stores processing up to 300 orders per month. Stores above 300 orders can upgrade to Make.com's Core plan at $9 per month, still far below what paid tracking or inventory apps charge."
        }
      },
      {
        "@type": "Question",
        "name": "What Shopify apps does the Complete Kit replace?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Complete Kit replaces: Elevar, Triple Whale, and Northbeam for ad tracking (saving $149 to $299 per month); WeltPixel and Analyzify for TikTok CAPI (saving $39 to $299 per month); Stocky for inventory tracking before its August 2026 shutdown (saving $29 to $199 per month); and TrueProfit and BeProfit for P&L reporting (saving $19 to $299 per month). Total savings typically exceed $700 per month."
        }
      },
      {
        "@type": "Question",
        "name": "What is the Stocky Swap scenario and why is there a deadline?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Stocky Swap is a Make.com scenario that replicates Shopify Stocky's inventory tracking functionality using Google Sheets. Shopify is permanently closing Stocky on August 31, 2026. The Stocky Swap scenario, included in the Complete Kit, can be imported in under 60 seconds and begins logging live order data to Google Sheets immediately — stock levels, fulfillment status, and order history — with no Shopify app installation required."
        }
      },
      {
        "@type": "Question",
        "name": "What happens after I buy the Complete Kit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Lemon Squeezy sends an email with download links for all files immediately after purchase. The Loom walkthrough videos are accessible via private links in the same email. There is no account to create, no app to install, and no waiting period. Files are available for re-download from your Lemon Squeezy order history at any time."
        }
      },
      {
        "@type": "Question",
        "name": "Will the Complete Kit work with my Shopify plan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The Complete Kit uses Shopify webhooks, which are available on every Shopify plan including Shopify Basic. No Shopify app installation is required. The only change in your Shopify admin is adding one webhook URL under Settings, then Notifications, then Webhooks — a process that takes under two minutes."
        }
      },
      {
        "@type": "Question",
        "name": "What support is included with the Complete Kit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Every purchase of the Complete Kit includes a private email address for one support question. You receive a direct reply — not a help desk ticket and not a knowledge base link. Most issues are resolved in a single exchange."
        }
      },
      {
        "@type": "Question",
        "name": "I already set up some of these automations manually. Is the kit still worth it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, if you have not completed all four scenarios. The kit is particularly valuable if you have not yet deployed Stocky Swap (August 2026 deadline), TikTok CAPI, or P&L Auto. The pre-configured Google Sheets templates alone save most stores 45 minutes. If you have completed all four automations manually, the kit likely adds less marginal value."
        }
      }
    ]
  }
  </script>

  <!-- SoftwareApplication Schema for the automation stack itself -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Stack Architect Shopify Automation Stack",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "A collection of four Make.com automation scenarios for Shopify stores — CAPI Shield (Meta and Google server-side tracking), TikTok CAPI, Stocky Swap (inventory), and P&L Auto (profit and loss). Requires Make.com free tier and Google Sheets.",
    "url": "https://www.stackarchitect.xyz/pro",
    "offers": {
      "@type": "Offer",
      "price": "49.00",
      "priceCurrency": "USD"
    },
    "featureList": [
      "One-click import into Make.com",
      "Works on Make.com free tier",
      "Server-side Shopify tracking via webhook",
      "Meta Conversions API integration",
      "Google Enhanced Conversions integration",
      "TikTok Events API integration",
      "Live inventory tracking in Google Sheets",
      "Automated P&L reporting in Google Sheets",
      "Compatible with all Shopify plans"
    ]
  }
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0a;
      --bg2: #111111;
      --bg3: #161616;
      --border: rgba(255,255,255,0.08);
      --border-bright: rgba(255,255,255,0.15);
      --text: #e8e6e0;
      --text-muted: #888580;
      --text-dim: #555250;
      --accent: #f0e040;
      --accent-dim: rgba(240,224,64,0.12);
      --accent-border: rgba(240,224,64,0.3);
      --green: #4ade80;
      --green-dim: rgba(74,222,128,0.1);
      --red: #ff5a5a;
      --red-dim: rgba(255,90,90,0.06);
      --red-border: rgba(255,90,90,0.2);
      --mono: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
      --sans: -apple-system, 'Helvetica Neue', sans-serif;
    }

    html { background: var(--bg); color: var(--text); font-family: var(--sans); scroll-behavior: smooth; }

    body {
      min-height: 100vh;
      background:
        radial-gradient(ellipse 60% 40% at 50% -10%, rgba(240,224,64,0.05) 0%, transparent 70%),
        var(--bg);
    }

    /* ══ NAV — exact match to stackarchitect.xyz ══ */
    .nav {
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--text-dim);
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,10,0.95);
      backdrop-filter: blur(8px);
    }
    .nav-left {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .nav-status {
      font-size: 10px;
      color: var(--text-dim);
      letter-spacing: 0.06em;
      padding: 18px 0;
      margin-right: 24px;
      border-right: 1px solid var(--border);
      padding-right: 24px;
      display: none;
    }
    @media (min-width: 900px) { .nav-status { display: block; } }
    .nav-logo {
      color: var(--text) !important;
      font-weight: 600;
      font-size: 13px;
      text-decoration: none;
      padding: 18px 0;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .nav-dropdown {
      position: relative;
    }
    .nav-dropdown-toggle {
      background: none;
      border: none;
      color: var(--text-muted);
      font-family: var(--mono);
      font-size: 12px;
      cursor: pointer;
      padding: 18px 12px;
      display: flex;
      align-items: center;
      gap: 4px;
      transition: color 0.15s;
    }
    .nav-dropdown-toggle:hover { color: var(--text); }
    .nav-dropdown-menu {
      display: none;
      position: absolute;
      top: 100%;
      right: 0;
      min-width: 260px;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-top: none;
      z-index: 200;
    }
    .nav-dropdown:hover .nav-dropdown-menu { display: block; }
    .nav-dropdown-item {
      display: block;
      padding: 10px 16px;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 12px;
      border-bottom: 1px solid var(--border);
      transition: background 0.1s, color 0.1s;
    }
    .nav-dropdown-item:last-child { border-bottom: none; }
    .nav-dropdown-item:hover { background: var(--bg3); color: var(--text); }
    .nav-dropdown-item-title { color: var(--text); font-weight: 600; display: block; margin-bottom: 2px; }
    .nav-dropdown-item-desc { color: var(--text-dim); font-size: 10px; }
    .nav-link {
      color: var(--text-muted);
      text-decoration: none;
      padding: 18px 12px;
      display: block;
      transition: color 0.15s;
    }
    .nav-link:hover { color: var(--text); }
    .nav-cta {
      color: var(--accent) !important;
      margin-left: 8px;
    }
    .nav-mobile-hide { display: none; }
    @media (min-width: 640px) { .nav-mobile-hide { display: flex; } }

    /* ══ BREADCRUMB ══ */
    .breadcrumb {
      padding: 12px 0 0;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text-dim);
    }
    .breadcrumb a { color: var(--text-dim); text-decoration: none; }
    .breadcrumb a:hover { color: var(--text-muted); }
    .breadcrumb span { margin: 0 6px; }

    /* ══ PAGE LAYOUT ══ */
    .page { max-width: 780px; margin: 0 auto; padding: 0 24px 80px; }

    /* ══ HERO ══ */
    .hero {
      padding: 52px 0 44px;
      border-bottom: 1px solid var(--border);
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      border: 1px solid var(--accent-border);
      background: var(--accent-dim);
      padding: 4px 10px;
      border-radius: 4px;
      margin-bottom: 20px;
      letter-spacing: 0.05em;
    }
    .badge::before { content: '//'; opacity: 0.6; }

    h1 {
      font-family: var(--mono);
      font-size: clamp(24px, 5vw, 40px);
      font-weight: 700;
      line-height: 1.15;
      color: var(--text);
      margin-bottom: 18px;
      letter-spacing: -0.02em;
    }
    h1 span { color: var(--accent); }

    .hero-sub {
      font-size: 16px;
      color: var(--text-muted);
      line-height: 1.65;
      max-width: 580px;
      margin-bottom: 32px;
    }

    .price-block {
      display: flex;
      align-items: baseline;
      gap: 14px;
      margin-bottom: 8px;
      flex-wrap: wrap;
    }
    .price-main {
      font-family: var(--mono);
      font-size: 52px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.03em;
      line-height: 1;
    }
    .price-was {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .price-strike {
      font-family: var(--mono);
      font-size: 20px;
      color: var(--text-dim);
      text-decoration: line-through;
    }
    .price-saves {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--green);
      letter-spacing: 0.04em;
    }
    .price-note {
      font-size: 12px;
      color: var(--text-dim);
      font-family: var(--mono);
      margin-bottom: 28px;
    }

    .cta-row { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; }

    .cta-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--accent);
      color: #0a0a0a;
      font-family: var(--mono);
      font-size: 14px;
      font-weight: 700;
      padding: 14px 28px;
      border-radius: 6px;
      text-decoration: none;
      letter-spacing: 0.02em;
      transition: opacity 0.15s, transform 0.15s;
      border: none;
      cursor: pointer;
    }
    .cta-primary:hover { opacity: 0.9; transform: translateY(-1px); }
    .cta-primary::after { content: '→'; }

    .cta-secondary {
      display: inline-flex;
      align-items: center;
      color: var(--text-muted);
      font-family: var(--mono);
      font-size: 12px;
      text-decoration: none;
      transition: color 0.15s;
    }
    .cta-secondary:hover { color: var(--text); }

    .trust-row {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 22px;
    }
    .trust-item {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text-dim);
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .trust-item::before { content: '✓'; color: var(--green); font-size: 10px; }

    /* ══ STATS GRID — matches homepage style ══ */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      margin: 36px 0;
      font-family: var(--mono);
    }
    @media (max-width: 560px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-cell {
      background: var(--bg3);
      padding: 18px 16px;
      text-align: center;
    }
    .stat-num {
      font-size: 26px;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
      margin-bottom: 4px;
    }
    .stat-num.yellow { color: var(--accent); }
    .stat-num.green { color: var(--green); }
    .stat-label { font-size: 10px; color: var(--text-dim); line-height: 1.4; }

    /* ══ MATH BAR ══ */
    .math-bar {
      padding: 24px;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-family: var(--mono);
      margin: 36px 0;
    }
    .math-bar-label {
      font-size: 10px;
      color: var(--text-dim);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .math-row {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr;
      gap: 8px;
      align-items: center;
      text-align: center;
    }
    @media (max-width: 480px) {
      .math-row { grid-template-columns: 1fr; gap: 12px; }
      .math-op { display: none; }
    }
    .math-num { font-size: 28px; font-weight: 700; line-height: 1; margin-bottom: 4px; }
    .math-num.red { color: var(--red); }
    .math-num.yellow { color: var(--accent); }
    .math-num.green { color: var(--green); }
    .math-desc { font-size: 10px; color: var(--text-dim); }
    .math-op { font-size: 20px; color: var(--text-dim); }

    /* ══ URGENCY BOX ══ */
    .urgent {
      background: var(--red-dim);
      border: 1px solid var(--red-border);
      border-radius: 8px;
      padding: 20px 24px;
      margin: 36px 0;
      font-family: var(--mono);
    }
    .urgent-label {
      color: var(--red);
      font-size: 10px;
      letter-spacing: 0.1em;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }
    .urgent-text { color: var(--text-muted); line-height: 1.65; font-size: 13px; }
    .urgent-text strong { color: var(--text); }
    .countdown {
      display: flex;
      gap: 10px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text-dim);
      margin-top: 14px;
    }
    .countdown-unit { text-align: center; }
    .countdown-num {
      font-size: 22px;
      font-weight: 700;
      color: var(--red);
      display: block;
      line-height: 1;
      margin-bottom: 2px;
    }
    .countdown-sep { font-size: 18px; color: var(--red); align-self: flex-start; margin-top: 2px; }

    /* ══ SECTION HEADINGS ══ */
    .section { margin: 52px 0; }
    .section-label {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--text-dim);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    h2 {
      font-family: var(--mono);
      font-size: 22px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 6px;
      letter-spacing: -0.01em;
    }
    .section-sub {
      font-size: 15px;
      color: var(--text-muted);
      line-height: 1.6;
      margin-bottom: 28px;
    }

    /* ══ CONTENTS GRID ══ */
    .contents-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 560px) { .contents-grid { grid-template-columns: 1fr; } }

    .content-item {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 18px;
      transition: border-color 0.15s;
      text-decoration: none;
      display: block;
    }
    .content-item:hover { border-color: var(--border-bright); }
    .content-item-icon {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--accent);
      margin-bottom: 8px;
