  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is the Stack Architect Complete Kit?", "acceptedAnswer": { "@type": "Answer", "text": "The Stack Architect Complete Kit is a $49 one-time purchase containing four ready-to-import Make.com automation scenario JSON files (CAPI Shield for Meta and Google server-side tracking, TikTok CAPI for TikTok Events API, Stocky Swap for inventory management, and P&L Auto for live profit and loss reporting), two pre-configured Google Sheets templates, and four Loom walkthrough videos. The kit replaces over $700 per month of paid Shopify apps and deploys in under 10 minutes." } },
      { "@type": "Question", "name": "What is a Make.com JSON scenario file?", "acceptedAnswer": { "@type": "Answer", "text": "A Make.com JSON scenario file, also called a blueprint, is an exported copy of a complete Make.com automation scenario containing every module, API connection, field mapping, and configuration setting. Importing this file recreates the entire pre-configured scenario instantly — no manual setup required. Make.com supports importing blueprints on all plan tiers including the free tier." } },
      { "@type": "Question", "name": "How is the Complete Kit different from the free Stack Architect guides?", "acceptedAnswer": { "@type": "Answer", "text": "The free guides are step-by-step instructions for building each Make.com automation yourself. The Complete Kit gives you the finished files — the JSON blueprint is the result of following the guide, packaged for one-click import. The technical outcome is identical. The difference is time: the guides take approximately 2 hours per tool. The kit takes 10 minutes total." } },
      { "@type": "Question", "name": "Do I need a paid Make.com plan to use the Complete Kit?", "acceptedAnswer": { "@type": "Answer", "text": "No. All four scenarios run on Make.com's free tier, which includes 1,000 operations per month — sufficient for Shopify stores processing up to 300 orders per month. Stores above that volume can upgrade to Make.com Core for $9 per month." } },
      { "@type": "Question", "name": "What Shopify apps does the Complete Kit replace?", "acceptedAnswer": { "@type": "Answer", "text": "CAPI Shield replaces Elevar ($150 or more per month), Triple Whale ($299 or more), and Northbeam ($300 or more). TikTok CAPI replaces WeltPixel ($39 or more) and Analyzify ($99 or more). Stocky Swap replaces Shopify Stocky, Linnworks, and Skubana ($29 to $199). P&L Auto replaces TrueProfit and BeProfit ($19 to $299). Combined monthly savings typically exceed $700." } },
      { "@type": "Question", "name": "What is the Stocky Swap scenario and why is there an August 2026 deadline?", "acceptedAnswer": { "@type": "Answer", "text": "Stocky Swap is a Make.com scenario that replicates Shopify Stocky's inventory tracking in Google Sheets, logging every order in real time with stock levels, fulfilment status, and order history. Shopify is permanently shutting down Stocky on August 31, 2026, with all data deleted. The Stocky Swap JSON file imports in under 60 seconds and begins capturing data immediately." } },
      { "@type": "Question", "name": "What happens after I buy the Complete Kit?", "acceptedAnswer": { "@type": "Answer", "text": "Lemon Squeezy sends an email with download links for all files immediately after purchase — the four Make.com JSON files, two Google Sheets template links, and four Loom video links. Files are available for re-download from your Lemon Squeezy order history permanently." } },
      { "@type": "Question", "name": "Will the Complete Kit work with my Shopify plan?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The kit uses Shopify webhooks available on every plan including Shopify Basic. No app installation is required. The only change in Shopify Admin is adding one webhook URL under Settings, Notifications, Webhooks — a two-minute step." } },
      { "@type": "Question", "name": "Does the Complete Kit work for Shopify stores outside the US?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Shopify webhooks, Make.com, Meta Conversions API, Google Enhanced Conversions, and TikTok Events API all work globally. The P&L Auto scenario supports any Shopify-supported currency. Stores in the UK, EU, Australia, Canada, and all other Shopify markets are fully compatible." } },
      { "@type": "Question", "name": "Is this a subscription?", "acceptedAnswer": { "@type": "Answer", "text": "No. The Complete Kit is a one-time $49 payment. You receive the files permanently. All four Make.com scenarios run on Make.com's free tier — there is no ongoing cost unless your store exceeds 1,000 Make.com operations per month, at which point Make.com Core costs $9 per month." } }
    ]
  }
