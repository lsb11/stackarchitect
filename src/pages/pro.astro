  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700;800&display=swap">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #030712;
      --bg-2: #060d1a;
      --bg-3: #0b1628;
      --border: rgba(255,255,255,0.06);
      --border-2: rgba(255,255,255,0.11);
      --text: #f1f5f9;
      --text-2: #cbd5e1;
      --text-3: #64748b;
      --text-4: #475569;
      --g: #00c864;
      --g-dim: rgba(0,200,100,0.1);
      --g-border: rgba(0,200,100,0.2);
      --sky: #38bdf8;
      --sky-dim: rgba(56,189,248,0.1);
      --sky-border: rgba(56,189,248,0.2);
      --vio: #c4b5fd;
      --vio-dim: rgba(196,181,253,0.08);
      --vio-border: rgba(196,181,253,0.2);
      --amber: #f59e0b;
      --amber-dim: rgba(245,158,11,0.1);
      --amber-border: rgba(245,158,11,0.25);
      --red: #ef4444;
      --red-dim: rgba(239,68,68,0.07);
      --red-border: rgba(239,68,68,0.2);
      --tiktok: #ff0050;
      --tiktok-dim: rgba(255,0,80,0.1);
      --mono: 'JetBrains Mono', 'Courier New', monospace;
      --sans: 'Inter', -apple-system, 'Helvetica Neue', sans-serif;
    }

    html { background: var(--bg); color: var(--text); font-family: var(--sans); scroll-behavior: smooth; }
    body {
      min-height: 100vh;
      background: radial-gradient(ellipse 80% 40% at 50% -5%, rgba(0,200,100,0.05) 0%, transparent 65%), var(--bg);
    }

    @keyframes dotPing { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.8)} }
    @keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(0,200,100,.3)} 50%{box-shadow:0 0 0 8px rgba(0,200,100,0)} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    /* NAV */
    .product-terminal-bar {
      position: sticky; top: 0; z-index: 1000;
      background: rgba(3,7,18,.94);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      transition: background .25s;
    }
    .product-terminal-bar.scrolled { background: rgba(3,7,18,.98); }
    .terminal-container {
      max-width: 1100px; margin: 0 auto; padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
    }
    .terminal-status {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      color: var(--text-4); letter-spacing: .12em; text-transform: uppercase;
      display: flex; align-items: center; gap: 8px;
      padding: 16px 0; white-space: nowrap;
    }
    .status-indicator {
      display: inline-block; width: 6px; height: 6px; border-radius: 50%;
      background: var(--g); animation: dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite;
    }
    .product-access-grid { display: flex; align-items: center; gap: 0; list-style: none; }
    .product-link {
      display: flex; flex-direction: column; padding: 18px 12px;
      font-family: var(--mono); font-size: 11px; font-weight: 700;
      color: var(--text-3); text-decoration: none; letter-spacing: .04em;
      transition: color .15s; background: none; border: none; cursor: pointer; white-space: nowrap;
    }
    .product-link:hover, .product-link.is-active { color: var(--text); }
    .product-link.home-node { color: var(--text-2); }
    .dropdown { position: relative; }
    .dropdown-menu {
      display: none; position: absolute; top: 100%; left: 0; min-width: 280px;
      background: var(--bg-3); border: 1px solid var(--border-2); border-top: none;
      z-index: 500; flex-direction: column;
    }
    .dropdown:hover .dropdown-menu { display: flex; }
    .dropdown-menu .product-link { padding: 10px 16px; border-bottom: 1px solid var(--border); flex-direction: column; gap: 2px; }
    .dropdown-menu .product-link:last-child { border-bottom: none; }
    .dropdown-menu .product-link:hover { background: rgba(255,255,255,.03); }
    .dropdown-desc { font-size: 10px; font-weight: 400; color: var(--text-4); letter-spacing: .02em; }
    .terminal-cta { display: flex; align-items: center; gap: 12px; }
    .savings-ticker { font-family: var(--mono); font-size: 10px; color: var(--g); font-weight: 700; letter-spacing: .1em; display: none; }
    @media (min-width: 1000px) { .savings-ticker { display: block; } }
    .cta-node {
      display: inline-block; padding: 8px 14px;
      background: transparent; border: 1px solid var(--g-border); color: var(--g);
      font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .08em;
      text-decoration: none; transition: background .15s, border-color .15s; white-space: nowrap;
    }
    .cta-node:hover { background: var(--g-dim); border-color: var(--g); }

    /* BREADCRUMB */
    .breadcrumb-bar {
      max-width: 860px; margin: 0 auto; padding: 14px 24px 0;
      font-family: var(--mono); font-size: 11px; color: var(--text-4);
    }
    .breadcrumb-bar a { color: var(--text-4); text-decoration: none; }
    .breadcrumb-bar a:hover { color: var(--text-3); }
    .breadcrumb-bar span { margin: 0 6px; }

    /* HERO */
    .hero {
      padding: 64px 24px 56px; text-align: center; border-bottom: 1px solid var(--border);
      background:
        repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,.015) 40px),
        repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,.015) 40px),
        var(--bg);
    }
    .hero-inner { max-width: 720px; margin: 0 auto; }
    .hero-dateline { font-family: var(--mono); font-size: 11px; color: var(--text-4); letter-spacing: .06em; margin-bottom: 14px; }
    .hero-proof { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-3); margin-bottom: 24px; }
    .hero-proof-stars { color: var(--amber); font-size: 13px; letter-spacing: .08em; }
    .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--g); animation: dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite; flex-shrink: 0; }

    h1 {
      font-family: var(--sans); font-size: clamp(32px,6vw,56px); font-weight: 900;
      line-height: 1.05; color: var(--text); letter-spacing: -.035em; margin-bottom: 20px;
    }
    h1 .green { color: var(--g); }
    .hero-sub {
      font-size: clamp(15px,2vw,17px); color: var(--text-3); line-height: 1.7;
      max-width: 580px; margin: 0 auto 28px;
    }
    .hero-sub strong { color: var(--text-2); font-weight: 600; }

    .price-row { display: flex; align-items: baseline; justify-content: center; gap: 16px; margin-bottom: 8px; flex-wrap: wrap; }
    .price-main { font-family: var(--mono); font-size: 60px; font-weight: 800; color: var(--text); letter-spacing: -.04em; line-height: 1; }
    .price-was-col { display: flex; flex-direction: column; gap: 2px; align-items: flex-start; }
    .price-strike { font-family: var(--mono); font-size: 22px; color: var(--text-4); text-decoration: line-through; line-height: 1; }
    .price-save { font-family: var(--mono); font-size: 11px; color: var(--g); font-weight: 700; letter-spacing: .06em; }
    .price-note { font-family: var(--mono); font-size: 11px; color: var(--text-4); margin-bottom: 8px; }
    /* NEW: price anchor below note */
    .price-anchor {
      font-family: var(--mono); font-size: 11px;
      color: var(--g); font-weight: 700; letter-spacing: .04em;
      background: var(--g-dim); border: 1px solid var(--g-border);
      display: inline-block; padding: 5px 14px; border-radius: 3px;
      margin-bottom: 22px;
    }

    .btn {
      display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px;
      background: var(--g); color: #020617; font-family: var(--sans); font-size: 14px;
      font-weight: 700; border-radius: 8px; text-decoration: none; border: none;
      cursor: pointer; transition: opacity .15s, transform .15s; letter-spacing: -.01em;
    }
    .btn:hover { opacity: .9; transform: translateY(-1px); }
    .btn.pulse { animation: pulse 2.5s ease-in-out infinite; }
    .btn-sm { padding: 10px 20px; font-size: 13px; }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 6px; padding: 13px 24px;
      background: transparent; border: 1px solid var(--border-2); color: var(--text-2);
      font-family: var(--sans); font-size: 14px; font-weight: 600; border-radius: 8px;
      text-decoration: none; transition: border-color .15s, color .15s;
    }
    .btn-outline:hover { border-color: var(--border-2); color: var(--text); }
    .btn-outline-sm { padding: 9px 18px; font-size: 13px; }

    .hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-bottom: 24px; }
    .trust-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 18px; margin-bottom: 20px; }
    .trust-item { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-3); }

    .urgency {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--mono); font-size: 11px; color: var(--text-3);
      background: var(--bg-3); border: 1px solid var(--border);
      padding: 8px 16px; border-radius: 4px;
    }

    /* TAGS */
    .tag { display: inline-flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: 4px 10px; border-radius: 3px; background: var(--g-dim); color: var(--g); border: 1px solid var(--g-border); }
    .tag-dim { background: rgba(255,255,255,.03); color: var(--text-4); border: 1px solid var(--border); }
    .tag-sky { background: var(--sky-dim); color: var(--sky); border: 1px solid var(--sky-border); }
    .tag-vio { background: var(--vio-dim); color: var(--vio); border: 1px solid var(--vio-border); }
    .tag-tiktok { background: var(--tiktok-dim); color: var(--tiktok); border: 1px solid rgba(255,0,80,.2); }
    .tag-amber { background: var(--amber-dim); color: var(--amber); border: 1px solid var(--amber-border); }
    .tag-red { background: var(--red-dim); color: var(--red); border: 1px solid var(--red-border); }

    /* STAT STRIP */
    .stat-strip {
      display: flex; border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
      margin: 32px auto; max-width: 680px;
    }
    .stat-cell { flex: 1; padding: 20px 16px; text-align: center; border-right: 1px solid var(--border); background: var(--bg-3); }
    .stat-cell:last-child { border-right: none; }
    .stat-v { font-family: var(--mono); font-size: clamp(20px,3.5vw,28px); font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 5px; }
    .stat-v.green { color: var(--g); }
    .stat-v.amber { color: var(--amber); }
    .stat-l { font-family: var(--mono); font-size: 10px; color: var(--text-4); letter-spacing: .04em; line-height: 1.4; }

    /* WHAT'S IN THE FOLDER — NEW */
    .folder-contents {
      background: var(--bg-3); border: 1px solid var(--g-border); border-radius: 10px;
      padding: 20px 24px; margin: 0 auto 28px; max-width: 560px; text-align: left;
    }
    .folder-contents-label {
      font-family: var(--mono); font-size: 9px; font-weight: 700; color: var(--g);
      letter-spacing: .14em; margin-bottom: 12px;
    }
    .folder-file-list { list-style: none; display: flex; flex-direction: column; gap: 5px; }
    .folder-file {
      display: flex; align-items: center; gap: 10px;
      font-family: var(--mono); font-size: 11px; color: var(--text-2);
    }
    .folder-file-icon { color: var(--g); flex-shrink: 0; }
    .folder-file-type { font-size: 9px; color: var(--text-4); background: var(--bg); border: 1px solid var(--border); padding: 1px 6px; border-radius: 2px; margin-left: auto; white-space: nowrap; }

    /* LAYOUT */
    .section { padding: 72px 24px; }
    .section-alt { padding: 72px 24px; background: var(--bg-3); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
