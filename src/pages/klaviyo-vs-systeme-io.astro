const description = "Klaviyo vs Systeme.io compared for Shopify email marketing. Systeme.io free plan replaces Klaviyo — 2,000 contacts, unlimited emails, automations. Save $150–$400/month.";
const canonical = "https://stackarchitect.xyz/klaviyo-vs-systeme-io/";
