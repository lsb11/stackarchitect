<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script is:inline>
var calcState={mkt:450,inv:200,trk:150,count:12,scenario:.85};
var calcChart;

var RANKS=[
  {min:20000,label:'CRITICAL WASTE',color:'var(--red)',sub:'Your app bill is severely bloated — thousands avoidable per month.',tier:'Critical'},
  {min:10000,label:'HIGH INEFFICIENCY',color:'var(--red)',sub:'Most of your app spend can be replaced for $0 with the free stack.',tier:'High'},
  {min:4000,label:'SIGNIFICANT WASTE',color:'var(--amber)',sub:'Clear opportunities to recover $300–$700/month.',tier:'Medium'},
  {min:1000,label:'MODERATE SPEND',color:'var(--amber)',sub:'Some apps could be replaced. Free stack cuts costs further.',tier:'Low'},
  {min:0,label:'LEAN OPERATOR',color:'var(--g)',sub:'Your stack is already efficient. Free tools can optimise further.',tier:'Lean'}
];

function initChart(){
  var ctx=document.getElementById('calc-chart');
  if(!ctx||!window.Chart)return;
  calcChart=new Chart(ctx.getContext('2d'),{
    type:'doughnut',
    data:{
      labels:['Marketing','Inventory','Tracking'],
      datasets:[{data:[5400,2400,1800],backgroundColor:['#34d377','#8ccfe8','#c3b8ef'],borderWidth:0,hoverOffset:6}]
    },
    options:{cutout:'72%',plugins:{legend:{display:false}},responsive:true,maintainAspectRatio:true}
  });
}

function readInputs(){
  calcState.mkt=Math.max(0,parseFloat(document.getElementById('i-mkt').value)||0);
  calcState.inv=Math.max(0,parseFloat(document.getElementById('i-inv').value)||0);
  calcState.trk=Math.max(0,parseFloat(document.getElementById('i-trk').value)||0);
  calcState.count=Math.max(0,parseInt(document.getElementById('i-count').value)||0);
  calcState.scenario=parseFloat(document.getElementById('i-scenario').value);
}

function fmt(n){return'$'+Math.round(n).toLocaleString('en-US');}

function calcUpdate(){
  readInputs();
  var mo=calcState.mkt+calcState.inv+calcState.trk;
  var annualWaste=mo*12;
  var annualSave=annualWaste*calcState.scenario;
  document.getElementById('live-mo').textContent=Math.round(mo).toLocaleString('en-US');
  document.getElementById('live-yr').textContent=Math.round(annualSave).toLocaleString('en-US');
  document.getElementById('gp-waste').textContent=fmt(annualWaste);
  document.getElementById('gp-save').textContent=fmt(annualSave);
}

function setBenchmark(m,i,t,c,id){
  document.getElementById('i-mkt').value=m;
  document.getElementById('i-inv').value=i;
  document.getElementById('i-trk').value=t;
  document.getElementById('i-count').value=c;
  document.querySelectorAll('.bench-btn').forEach(function(b){b.classList.remove('active');});
  var btn=document.querySelector('[data-id="'+id+'"]');
  if(btn)btn.classList.add('active');
  calcUpdate();
}

function showGate(){
  readInputs();
  calcUpdate();
  var gate=document.getElementById('results-gate');
  gate.style.display='block';
  setTimeout(function(){gate.scrollIntoView({behavior:'smooth',block:'start'});},50);
}

function unlockResults(){
  var e=document.getElementById('gate-email').value.trim();
  if(!e||!e.includes('@')){
    document.getElementById('gate-email').style.borderColor='var(--red)';
    document.getElementById('gate-email').focus();
    return;
  }
  try {
    fetch('https://embeds.beehiiv.com/7b5cd5ef-5cfd-4337-a011-b3b7aa9e3f17', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: e })
    }).catch(function(){});
  } catch(err){}
  try {
    gtag('event','email_capture',{
      event_category:'lead_generation',
      source_page:'app-cost-calculator',
      monthly_spend: Math.round(calcState.mkt+calcState.inv+calcState.trk)
    });
  } catch(err){}

  document.getElementById('email-gate').style.display='none';
  document.getElementById('results-panel').style.display='block';
  renderResults();
  setTimeout(function(){document.getElementById('results-panel').scrollIntoView({behavior:'smooth',block:'start'});},50);
}

function renderResults(){
  readInputs();
  var mo=calcState.mkt+calcState.inv+calcState.trk;
  var annualWaste=mo*12;
  var annualSave=annualWaste*calcState.scenario;
  var moSave=annualSave/12;
  var rank=RANKS.find(function(r){return annualWaste>=r.min;})||RANKS[RANKS.length-1];

  document.getElementById('r-monthly-waste').textContent=fmt(mo);
  document.getElementById('r-annual-waste').textContent=fmt(annualWaste);
  animVal('r-m1',0,annualWaste,700,true);
  animVal('r-m2',0,annualSave,700,true);
  animVal('r-m3',0,moSave,700,true);
  document.getElementById('r-m4').textContent=rank.tier;
  document.getElementById('r-m4').style.color=rank.color;

  document.getElementById('r-icon').textContent=annualWaste>10000?'🔴':annualWaste>4000?'🟡':'✅';
  document.getElementById('r-label').textContent=rank.label;
  document.getElementById('r-label').style.color=rank.color;
  document.getElementById('r-sub').textContent=rank.sub;

  var mktYr=calcState.mkt*12,invYr=calcState.inv*12,trkYr=calcState.trk*12;
  document.getElementById('bd-mkt-cost').textContent=fmt(mktYr)+'/yr';
  document.getElementById('bd-mkt-save').textContent='Save '+fmt(mktYr*calcState.scenario);
  document.getElementById('bd-inv-cost').textContent=fmt(invYr)+'/yr';
  document.getElementById('bd-inv-save').textContent='Save '+fmt(invYr*calcState.scenario);
  document.getElementById('bd-trk-cost').textContent=fmt(trkYr)+'/yr';
  document.getElementById('bd-trk-save').textContent='Save '+fmt(trkYr*calcState.scenario);
  document.getElementById('r-peak-save').textContent=Math.round(annualSave).toLocaleString('en-US');

  if(calcChart){calcChart.data.datasets[0].data=[mktYr,invYr,trkYr];calcChart.update();}
}

function animVal(id,start,end,dur,dollar){
  var el=document.getElementById(id);if(!el)return;
  var t0=null;
  requestAnimationFrame(function step(ts){
    if(!t0)t0=ts;
    var p=Math.min((ts-t0)/dur,1);
    var v=Math.round(start+p*(end-start));
    el.textContent=(dollar?'$':'')+v.toLocaleString('en-US');
    if(p<1)requestAnimationFrame(step);
  });
}

function shareX(){
  readInputs();
  var mo=calcState.mkt+calcState.inv+calcState.trk;
  var save=Math.round(mo*12*calcState.scenario);
  var txt='I just found $'+save.toLocaleString()+'/year in wasted Shopify app spend — all replaceable for $0. Free calculator:';
  window.open('https://twitter.com/intent/tweet?text='+encodeURIComponent(txt)+'&url='+encodeURIComponent('https://stackarchitect.xyz/shopify-app-cost-calculator/'));
}
function shareLinkedIn(){
  window.open('https://www.linkedin.com/sharing/share-offsite/?url='+encodeURIComponent('https://stackarchitect.xyz/shopify-app-cost-calculator/'));
}

document.querySelectorAll('.faq-q').forEach(function(btn){
  btn.addEventListener('click',function(){
    var item=btn.closest('.faq-item');
    var isOpen=item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(function(i){i.classList.remove('open');i.querySelector('.faq-q').setAttribute('aria-expanded','false');});
    if(!isOpen){item.classList.add('open');btn.setAttribute('aria-expanded','true');}
  });
});

window.addEventListener('load',function(){
  initChart();
  calcUpdate();
});
</script>

