<style is:inline>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --green:#00C896;--dark:#1a1a2e;--red:#e53e3e;--amber:#d97706;
  --bg:#fff;--surface:#f8f9fa;--border:#e2e8f0;
  --text:#1a202c;--muted:#64748b;--radius:8px;
  --font:'Inter',system-ui,-apple-system,sans-serif;
}
html{font-size:16px;scroll-behavior:smooth}
body{font-family:var(--font);color:var(--text);background:var(--bg);line-height:1.6}
a{color:var(--green);text-decoration:none}
a:hover{text-decoration:underline}
/* Header */
.site-header{background:var(--dark);padding:14px 20px;display:flex;align-items:center}
.brand{color:#fff;font-weight:700;font-size:1.05rem;letter-spacing:-.3px}
.brand:hover{color:var(--green);text-decoration:none}
/* Container */
.container{max-width:680px;margin:0 auto;padding:0 20px}
/* Breadcrumb */
.breadcrumb{font-size:.8rem;color:var(--muted);padding:12px 0;border-bottom:1px solid var(--border);margin-bottom:28px}
.breadcrumb a{color:var(--muted)}
.breadcrumb span{margin:0 6px}
/* Urgency tag */
.urgency-tag{display:inline-block;background:#fef3cd;color:#92400e;font-size:.78rem;font-weight:600;padding:4px 10px;border-radius:20px;margin-bottom:16px;border:1px solid #fcd34d}
/* Main layout */
main{padding:32px 0 48px}
article h1{font-size:1.75rem;font-weight:700;line-height:1.2;margin-bottom:12px;color:var(--dark)}
.intro{color:var(--muted);font-size:.97rem;margin-bottom:28px;line-height:1.7}
/* Card */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;margin-bottom:20px}
.card-title{font-size:.85rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);margin-bottom:16px}
/* Form */
.field{margin-bottom:18px}
.field label{display:block;font-size:.9rem;font-weight:500;margin-bottom:6px;color:var(--text)}
.field input,.field select,.field textarea{
  width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:var(--radius);
  font-family:var(--font);font-size:.95rem;background:#fff;color:var(--text);
  transition:border-color .15s;
}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--green)}
.field textarea{min-height:110px;resize:vertical}
.multiselect-group{display:flex;flex-direction:column;gap:8px}
.multiselect-group label{font-weight:400;display:flex;align-items:center;gap:8px;cursor:pointer}
.multiselect-group input[type=checkbox]{width:16px;height:16px;accent-color:var(--green)}
.btn-calc{
  display:block;width:100%;padding:14px;background:var(--green);color:#fff;
  border:none;border-radius:var(--radius);font-family:var(--font);font-size:1rem;
  font-weight:600;cursor:pointer;transition:opacity .15s;margin-top:4px;
}
.btn-calc:hover{opacity:.9}
/* Teaser / gate */
#teaser{margin-bottom:20px}
.teaser-card{background:var(--dark);color:#fff;border-radius:var(--radius);padding:24px;text-align:center}
.teaser-number{font-size:2.5rem;font-weight:700;color:var(--green);margin-bottom:4px}
.teaser-label{font-size:.9rem;opacity:.8;margin-bottom:20px}
.gate-box{border-top:1px solid rgba(255,255,255,.15);padding-top:18px;margin-top:4px}
.gate-box p{font-size:.88rem;opacity:.8;margin-bottom:12px}
.gate-row{display:flex;gap:8px;flex-wrap:wrap}
.gate-row input[type=email]{flex:1;min-width:200px;padding:10px 12px;border-radius:var(--radius);border:none;font-family:var(--font);font-size:.9rem}
.btn-gate{padding:10px 18px;background:var(--green);color:#fff;border:none;border-radius:var(--radius);font-family:var(--font);font-weight:600;cursor:pointer;white-space:nowrap}
.btn-gate:hover{opacity:.9}
/* Results */
#results{margin-bottom:24px}
.result-row{display:flex;justify-content:space-between;align-items:flex-start;padding:12px 0;border-bottom:1px solid var(--border);gap:12px}
.result-row:last-child{border-bottom:none}
.result-label{font-size:.88rem;color:var(--muted);flex:1}
.result-label .sub{display:block;font-size:.78rem;margin-top:2px;color:var(--muted)}
.result-value{font-size:.95rem;font-weight:600;text-align:right;flex-shrink:0;max-width:55%}
.flag-good .result-value{color:#059669}
.flag-warn .result-value{color:var(--amber)}
.flag-bad .result-value{color:var(--red)}
.flag-neutral .result-value{color:var(--text)}
/* Upsell */
.upsell{background:var(--green);border-radius:var(--radius);padding:20px 24px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.upsell-text{color:#fff;font-weight:600;font-size:.95rem;flex:1}
.upsell-btn{background:#fff;color:var(--green);padding:10px 18px;border-radius:var(--radius);font-weight:700;font-size:.88rem;white-space:nowrap;flex-shrink:0}
.upsell-btn:hover{text-decoration:none;opacity:.9}
/* FAQ */
.faq-section{margin-bottom:32px}
.faq-section h2{font-size:1.1rem;font-weight:700;margin-bottom:16px;color:var(--dark)}
details{border:1px solid var(--border);border-radius:var(--radius);margin-bottom:8px;overflow:hidden}
summary{padding:14px 16px;cursor:pointer;font-weight:500;font-size:.92rem;list-style:none;display:flex;justify-content:space-between;align-items:center}
summary::-webkit-details-marker{display:none}
summary::after{content:'+';font-size:1.1rem;color:var(--muted)}
details[open] summary::after{content:'−'}
details[open] summary{border-bottom:1px solid var(--border)}
.faq-answer{padding:14px 16px;font-size:.9rem;color:var(--muted);line-height:1.7}
/* Internal links */
.related-tools{margin-bottom:32px;padding-top:24px;border-top:1px solid var(--border)}
.related-tools h2{font-size:.85rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);margin-bottom:12px}
.related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px}
.related-link{display:block;padding:12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);font-size:.85rem;font-weight:500;color:var(--text);transition:border-color .15s}
.related-link:hover{border-color:var(--green);text-decoration:none;color:var(--green)}
/* Footer */
footer{background:var(--surface);border-top:1px solid var(--border);padding:20px;text-align:center;font-size:.83rem;color:var(--muted)}
footer a{color:var(--muted)}
/* Utility */
[hidden]{display:none!important}
@media(max-width:480px){
  article h1{font-size:1.4rem}
  .teaser-number{font-size:2rem}
  .upsell{flex-direction:column;align-items:flex-start}
  .result-row{flex-direction:column;gap:4px}
  .result-value{text-align:left;max-width:100%}
}
</style>
</head>
