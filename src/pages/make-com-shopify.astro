  <style>
    *,*::before,*::after{box-sizing:border-box}
    :root{--bg:#060606;--bg-2:#0d0d0d;--bg-3:#111;--text:#f8f8f8;--text-2:#d4d4d8;--text-3:#a1a1aa;--text-4:#52525b;--border:#1f1f1f;--border-2:rgba(255,255,255,.1);--g:#00c864;--g-bg:rgba(0,200,100,.06);--g-border:rgba(0,200,100,.2);--amber:#fbbf24;--red:#ef4444;--mono:'JetBrains Mono',monospace;--sans:system-ui,-apple-system,sans-serif;}
    body{margin:0;background:var(--bg);color:var(--text);font-family:var(--sans);line-height:1.6;}
    .hero{padding:80px 24px 64px;text-align:center;border-bottom:1px solid var(--border);}
    .hero-inner{max-width:900px;margin:0 auto;}
    .tag{display:inline-flex;align-items:center;font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:5px 12px;border-radius:3px;background:var(--g-bg);border:1px solid var(--g-border);color:var(--g);margin-bottom:20px;}
    h1{font-size:clamp(36px,6vw,72px);font-weight:900;letter-spacing:-.04em;line-height:.95;margin:0 auto 24px;max-width:800px;}
    .hero-sub{font-size:clamp(16px,2vw,19px);color:var(--text-3);max-width:620px;margin:0 auto 36px;line-height:1.7;}
    .hero-ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:16px;}
    .btn-gold{display:inline-flex;align-items:center;gap:8px;background:var(--amber);color:#000;font-weight:700;font-size:15px;padding:14px 28px;border-radius:6px;text-decoration:none;white-space:nowrap;}
    .btn-green{display:inline-flex;align-items:center;gap:8px;background:var(--g);color:#000;font-weight:700;font-size:15px;padding:14px 28px;border-radius:6px;text-decoration:none;white-space:nowrap;}
    .btn-outline{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--text-2);font-weight:600;font-size:14px;padding:13px 24px;border-radius:6px;text-decoration:none;border:1.5px solid var(--border-2);white-space:nowrap;}
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:16px;max-width:700px;margin:40px auto 0;padding-top:40px;border-top:1px solid var(--border);}
    .stat{text-align:center;}
    .stat-v{font-size:24px;font-weight:900;color:var(--g);letter-spacing:-.03em;}
    .stat-l{font-size:11px;color:var(--text-4);font-family:var(--mono);letter-spacing:.1em;text-transform:uppercase;margin-top:4px;}
    section{padding:64px 24px;}
    .inner{max-width:900px;margin:0 auto;}
    .inner-sm{max-width:720px;margin:0 auto;}
    h2{font-size:clamp(22px,3.5vw,36px);font-weight:900;letter-spacing:-.03em;color:var(--text);margin:0 0 16px;}
    h3{font-size:18px;font-weight:700;color:var(--text);margin:0 0 10px;}
    p{color:var(--text-3);font-size:15px;line-height:1.8;margin:0 0 16px;}
    .tool-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin-top:32px;}
    .tool-card{background:var(--bg-3);border:1px solid var(--border);border-radius:10px;padding:24px 20px;text-decoration:none;display:block;transition:border-color .2s,transform .2s;}
    .tool-card:hover{border-color:var(--g-border);transform:translateY(-3px);}
    .tool-card-tag{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--g);margin-bottom:10px;}
    .tool-card h3{font-size:16px;margin-bottom:8px;color:var(--text);}
    .tool-card p{font-size:13px;color:var(--text-3);margin:0 0 12px;}
    .tool-card-saves{font-family:var(--mono);font-size:11px;color:var(--amber);}
    .step-list{counter-reset:steps;list-style:none;padding:0;margin:24px 0 0;}
    .step-list li{counter-increment:steps;display:flex;gap:16px;align-items:flex-start;padding:16px 0;border-bottom:1px solid var(--border);}
    .step-list li:last-child{border-bottom:none;}
    .step-num{width:28px;height:28px;border-radius:50%;background:var(--g-bg);border:1px solid var(--g-border);color:var(--g);font-family:var(--mono);font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;}
    .step-num::before{content:counter(steps);}
    .step-body h3{font-size:15px;margin-bottom:4px;}
    .step-body p{font-size:13px;margin:0;}
    .faq-list{list-style:none;padding:0;margin:24px 0 0;}
    .faq-item{border-bottom:1px solid var(--border);padding:20px 0;}
    .faq-item:last-child{border-bottom:none;}
    .faq-q{font-size:15px;font-weight:600;color:var(--text);margin:0 0 10px;}
    .faq-a{font-size:14px;color:var(--text-3);margin:0;line-height:1.75;}
    .cta-box{background:linear-gradient(135deg,rgba(251,191,36,.07),rgba(0,200,100,.04));border:1px solid rgba(251,191,36,.2);border-radius:12px;padding:40px 36px;text-align:center;}
    .cta-box h2{margin-bottom:12px;}
    .cta-box p{max-width:560px;margin:0 auto 28px;}
    .alt-bg{background:var(--bg-3);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
    code{font-family:var(--mono);font-size:12px;background:rgba(255,255,255,.06);padding:2px 6px;border-radius:3px;color:var(--text-2);}
    .breadcrumb{padding:16px 24px;border-bottom:1px solid var(--border);font-family:var(--mono);font-size:11px;color:var(--text-4);}
    .breadcrumb a{color:var(--text-4);text-decoration:none;}
    .breadcrumb span{margin:0 6px;}
    @media(max-width:640px){.hero{padding:60px 20px 48px;}.hero-ctas{flex-direction:column;align-items:stretch;max-width:300px;margin-left:auto;margin-right:auto;}.btn-gold,.btn-green,.btn-outline{justify-content:center;}}
  </style>
</head>
<body>
<Nav />

<div class="breadcrumb">
  <a href="/">Home</a><span>/</span>Make.com for Shopify
</div>

<main>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="tag">Free Automation · No Code · 2026</div>
      <h1>Make.com<br><span style="color:var(--g)">for Shopify.</span><br><span style="color:var(--text-4);font-size:.65em;">Complete Free Setup.</span></h1>
      <p class="hero-sub speakable">Make.com connects to Shopify via webhook in 3 minutes. One free account powers server-side tracking for Meta and Google, live inventory management, TikTok Events API, and real-time P&L reporting — simultaneously, at $0.</p>
      <div class="hero-ctas">
        <a href="/pro" class="btn-gold">Get the Pre-Built Kit — $29 →</a>
        <a href="/go/make" target="_blank" rel="noopener sponsored" class="btn-green">Start Free on Make.com →</a>
        <a href="/blog/make-com-shopify-automation-guide/" class="btn-outline">Read the Full Guide →</a>
      </div>
      <p style="font-size:12px;color:var(--text-4);margin:0;">Free plan: 1,000 ops/month · No credit card · Webhook triggers included</p>
      <div class="stats">
        <div class="stat"><div class="stat-v">$0</div><div class="stat-l">Monthly cost</div></div>
        <div class="stat"><div class="stat-v">1,000</div><div class="stat-l">Free ops/month</div></div>
        <div class="stat"><div class="stat-v">3 min</div><div class="stat-l">Shopify connect</div></div>
        <div class="stat"><div class="stat-v">4</div><div class="stat-l">Tools in one webhook</div></div>
      </div>
    </div>
  </section>

  <!-- QUICK ANSWER — GEO optimised -->
  <section class="alt-bg">
    <div class="inner-sm">
      <div class="tag">Quick Answer</div>
      <h2>What Does Make.com Do for Shopify?</h2>
      <p class="speakable">Make.com is a no-code automation platform that connects to Shopify using Shopify's built-in webhook system. When an order is paid, Shopify fires a webhook to Make.com, which routes the order data simultaneously to multiple destinations: Meta Conversions API (server-side purchase events), Google Enhanced Conversions, TikTok Events API, Google Sheets (inventory and P&L), and Systeme.io (email automation). All of this runs on Make.com's free plan — 1,000 operations per month, no credit card required.</p>
      <p>Make.com replaces five paid Shopify apps that collectively cost $500–$900 per month: Elevar or Triple Whale (server-side tracking), Shopify Stocky (inventory, shutting down August 31 2026), WeltPixel or Analyzify (TikTok CAPI), TrueProfit or BeProfit (P&L reporting), and Klaviyo (replaced by Systeme.io). The entire stack costs $0 per month on Make.com's free tier.</p>
    </div>
  </section>

  <!-- 4 SCENARIOS -->
  <section>
    <div class="inner">
      <div class="tag">The 4 Essential Scenarios</div>
      <h2>What to Build With Make.com on Shopify</h2>
      <p>One Shopify Order Payment webhook triggers all four automations simultaneously. Build each one individually or get all four pre-configured in the <a href="/pro" style="color:var(--amber)">Complete Kit for $29</a>.</p>
      <div class="tool-grid">
        <a href="/capi-shield" class="tool-card">
          <div class="tool-card-tag">Scenario 01 · Ad Tracking</div>
          <h3>CAPI Shield</h3>
          <p>Routes Shopify purchase events server-side to Meta Conversions API v25.0 and Google Enhanced Conversions simultaneously. Bypasses iOS restrictions and ad blockers. Achieves EMQ 7–8.5.</p>
          <div class="tool-card-saves">Replaces Elevar ($50–$500/mo) · Triple Whale ($299/mo)</div>
        </a>
        <a href="/stocky-swap" class="tool-card">
          <div class="tool-card-tag">Scenario 02 · Inventory ⚠ Aug 2026</div>
          <h3>Stocky Swap</h3>
          <p>Logs every Shopify order to Google Sheets in real time — stock levels, SKU, fulfilment status, full order history. Replaces Shopify Stocky before the August 31, 2026 permanent shutdown.</p>
          <div class="tool-card-saves">Replaces Shopify Stocky (shutting down) · Deploys in 4 min</div>
        </a>
        <a href="/tiktok-events-api-shopify" class="tool-card">
          <div class="tool-card-tag">Scenario 03 · TikTok Tracking</div>
          <h3>TikTok Events API</h3>
          <p>Sends CompletePayment events server-side to TikTok's Events API v1.3 via Make.com. Recovers 20–40% of TikTok conversions lost to iOS ITP. EMQ scores of 6–8 in most deployments.</p>
          <div class="tool-card-saves">Replaces WeltPixel ($39/mo) · Analyzify TikTok ($99/mo)</div>
        </a>
        <a href="/shopify-profit-loss-automation" class="tool-card">
          <div class="tool-card-tag">Scenario 04 · P&L Reporting</div>
          <h3>P&L Auto</h3>
          <p>Auto-populates a Google Sheets P&L dashboard with revenue, COGS, fees, and net profit for every order the instant payment confirms. Real-time profitability at $0/mo.</p>
          <div class="tool-card-saves">Replaces TrueProfit ($19/mo) · BeProfit ($29/mo) · Glew.io</div>
        </a>
        <a href="/replace-klaviyo-free" class="tool-card">
          <div class="tool-card-tag">Bonus · Email Automation</div>
          <h3>Abandoned Cart + Email</h3>
          <p>Make.com routes Shopify checkout abandonment webhooks to Systeme.io, triggering a 3-email abandoned cart sequence. Recovers 5–15% of abandoned checkouts at $0/mo.</p>
          <div class="tool-card-saves">Replaces Klaviyo ($150–$400/mo) · Systeme.io is free to 2,000 contacts</div>
        </a>
        <a href="/shopify-google-ads-conversion-tracking" class="tool-card">
          <div class="tool-card-tag">Bonus · Google Ads</div>
          <h3>Google Enhanced Conversions</h3>
          <p>SHA-256 hashes customer email and phone from Shopify orders and sends them server-side to Google Ads Measurement Protocol. Recovers 15–35% of missed Google Ads conversions.</p>
          <div class="tool-card-saves">Replaces Stape ($29/mo) · Littledata ($99/mo) · In CAPI Shield</div>
        </a>
      </div>
    </div>
  </section>

  <!-- HOW TO CONNECT — HowTo schema targets -->
  <section class="alt-bg" id="connect">
    <div class="inner-sm">
      <div class="tag">Setup Guide · 3 Minutes</div>
      <h2>How to Connect Make.com to Shopify</h2>
      <p>No app installation required. Uses Shopify's built-in webhook system available on every plan.</p>
      <ol class="step-list">
        <li>
          <div class="step-num"></div>
          <div class="step-body">
            <h3>Create a free Make.com account</h3>
            <p>Go to <a href="/go/make" target="_blank" rel="noopener sponsored" style="color:var(--g)">make.com</a> and sign up free. No credit card required. You get 1,000 operations per month permanently.</p>
          </div>
        </li>
        <li>
          <div class="step-num"></div>
          <div class="step-body">
            <h3>Create a scenario with a Webhooks trigger</h3>
            <p>Click <strong>Create a new scenario</strong>. Add a <code>Webhooks</code> module as the trigger. Click <strong>Add</strong> to generate a unique webhook URL. Copy it.</p>
          </div>
        </li>
        <li>
          <div class="step-num"></div>
          <div class="step-body">
            <h3>Add the webhook in Shopify Admin</h3>
            <p>In Shopify Admin: <strong>Settings → Notifications → Webhooks → Create webhook</strong>. Select <strong>Order payment</strong> as the event. Paste your Make.com URL. Set format to <code>JSON</code>. Save.</p>
          </div>
        </li>
        <li>
          <div class="step-num"></div>
          <div class="step-body">
            <h3>Add your destination modules</h3>
            <p>After the webhook trigger, add modules for each destination: HTTP module for Meta CAPI, Google Sheets module for inventory/P&L, another HTTP module for TikTok Events API. One webhook — unlimited destinations.</p>
          </div>
        </li>
        <li>
          <div class="step-num"></div>
          <div class="step-body">
            <h3>Test with a live order</h3>
            <p>Place a test order in Shopify. Make.com receives the webhook instantly and routes data to all destinations simultaneously. Check each platform for the event within 5 minutes.</p>
          </div>
        </li>
      </ol>
      <div style="margin-top:28px;padding:20px 24px;background:rgba(251,191,36,.06);border:1px solid rgba(251,191,36,.2);border-radius:8px;">
        <p style="margin:0;font-size:14px;color:var(--text-2);">Want the finished files instead of building from scratch? The <a href="/pro" style="color:var(--amber);font-weight:600;">Complete Kit ($29)</a> includes all 4 pre-configured Make.com JSON blueprints — import in 60 seconds, live in 10 minutes instead of 8 hours.</p>
      </div>
    </div>
  </section>

  <!-- MAKE.COM vs ZAPIER -->
  <section>
    <div class="inner-sm">
      <div class="tag">Platform Comparison</div>
      <h2>Make.com vs Zapier for Shopify</h2>
      <p>The most common question from Shopify store owners switching from Zapier.</p>
      <div style="overflow-x:auto;border-radius:10px;border:1px solid var(--border);margin-top:24px;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="background:var(--bg-3);">
              <th style="padding:12px 18px;text-align:left;color:var(--text-4);font-family:monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;border-bottom:1px solid var(--border);">Feature</th>
              <th style="padding:12px 18px;text-align:center;color:var(--text-4);font-family:monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;border-bottom:1px solid var(--border);">Make.com</th>
              <th style="padding:12px 18px;text-align:center;color:var(--text-4);font-family:monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;border-bottom:1px solid var(--border);">Zapier</th>
            </tr>
          </thead>
          <tbody>
            {[
              ["Free operations/month", "1,000", "100"],
              ["Webhook triggers (free)", "✓", "Paid only"],
