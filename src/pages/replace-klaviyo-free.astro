     CLIENT SCRIPTS
     ════════════════════════════════════════════════════════════════════════════ -->
<script>
(function () {
  // ── Sticky nav + floating CTA ──
  const header = document.querySelector('.product-terminal-bar');
  const cta = document.getElementById('nav-cta');

  if (cta) {
    const clone = cta.cloneNode(true);
    clone.id = 'nav-cta-floating';
    Object.assign(clone.style, {
      display: 'none', position: 'fixed', top: '12px', left: '50%',
      transform: 'translateX(-50%)', zIndex: '999999',
      background: '#00a854', color: '#fff',
      boxShadow: '0 4px 15px rgba(0,168,84,.4)',
      fontFamily: '"JetBrains Mono",monospace', fontSize: '10px',
      fontWeight: '900', textDecoration: 'none', textTransform: 'uppercase',
      padding: '8px 18px', borderRadius: '4px', border: '1px solid #00c864',
      whiteSpace: 'nowrap'
    });
    clone.innerHTML = 'REPLACE KLAVIYO →';
    document.body.appendChild(clone);

    window.addEventListener('scroll', () => {
      const s = window.scrollY;
      if (header) header.classList.toggle('scrolled', s > 50);
      clone.style.display = s > 50 ? 'block' : 'none';
      cta.style.visibility = s > 50 ? 'hidden' : 'visible';
    }, { passive: true });
  }

  // ── Dropdown: hover on desktop, click on mobile ──
  const style = document.createElement('style');
  style.textContent = '.dropdown.active .dropdown-menu{display:flex;}';
  document.head.appendChild(style);

  document.querySelectorAll('.dropdown > .product-link').forEach(link => {
    link.addEventListener('click', e => {
      if (window.innerWidth <= 850) {
        e.preventDefault();
        const expanded = link.getAttribute('aria-expanded') === 'true';
        link.setAttribute('aria-expanded', String(!expanded));
        link.parentElement.classList.toggle('active');
      }
    });
  });

  document.addEventListener('click', e => {
    if (!e.target.closest('.dropdown')) {
      document.querySelectorAll('.dropdown').forEach(d => d.classList.remove('active'));
    }
  });

  // ── Dynamic copyright ──
  const cr = document.getElementById('footer-copyright-klav');
  if (cr) cr.textContent = `© ${new Date().getFullYear()} STACK_ARCHITECT // KLAVIYO_REPLACED`;

  // ── Calculator ──
  const sel = document.getElementById('contact-select');
  if (sel) {
    sel.addEventListener('change', function () {
      const result = document.getElementById('calc-result');
      const saving = document.getElementById('calc-saving');
      const context = document.getElementById('calc-context');
      if (!this.value) { result.style.display = 'none'; return; }
      const parts = this.value.split(',');
      const monthly = parseInt(parts[0]);
      const contacts = parseInt(parts[1]);
      const annual = monthly * 12;
      saving.textContent = '$' + annual.toLocaleString() + '/year saved';
      context.innerHTML = 'You are paying Klaviyo <strong>$' + monthly + '/month</strong> for ' + contacts.toLocaleString() + ' contacts. Systeme.io handles the same list for <strong>$0/month</strong> — saving you <strong>$' + annual.toLocaleString() + ' every year, forever.</strong>';
      result.style.display = 'block';
      document.getElementById('calc-capture-form').style.display = 'block';
      document.getElementById('calc-capture-done').style.display = 'none';
      document.getElementById('calc-affiliate-btn').style.display = 'none';
      if (window.innerWidth < 640) {
        setTimeout(() => result.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 100);
      }
    });
  }

  // ── Email capture ──
  const captureBtn = document.getElementById('calc-capture-submit');
  if (captureBtn) {
    captureBtn.addEventListener('click', function () {
      const inp = document.getElementById('calc-email');
      const email = (inp ? inp.value : '').trim();
      if (!email || !email.includes('@')) {
        if (inp) { inp.classList.add('error'); inp.focus(); }
        return;
      }
      if (inp) inp.classList.remove('error');

      // Beehiiv subscription (replace pub ID with yours)
      fetch('https://api.beehiiv.com/v2/publications/pub_YOUR_PUBLICATION_ID/subscriptions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: email,
          reactivate_existing: true,
          send_welcome_email: true,
          utm_source: 'klaviyo-calculator',
          utm_medium: 'website',
          utm_campaign: 'klaviyo-migration-checklist'
        })
      }).catch(function () {});

      document.getElementById('calc-capture-form').style.display = 'none';
      document.getElementById('calc-capture-done').style.display = 'block';
      document.getElementById('calc-affiliate-btn').style.display = 'inline-flex';

      setTimeout(function () {
        window.open('https://stackarchitect.beehiiv.com/subscribe?email=' + encodeURIComponent(email), '_blank');
        window.open('/go/systeme', '_blank');
      }, 800);
    });
  }
})();
</script>

