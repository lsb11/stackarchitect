---
// /embed/gap-index/ — iframe-able LIVE widget for the Shopify iOS Attribution Gap benchmark.
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---

<EmbedLayout
  title="Shopify iOS Attribution Gap — Live Benchmark — Stack Architect"
  canonical="https://stackarchitect.xyz/shopify-ios-attribution-gap-benchmark/"
>
  <div class="gapw">
    <div class="gapw-head">
      <span class="gapw-live"><span class="gapw-dot"></span>LIVE</span>
      <span class="gapw-title">Shopify iOS Attribution Gap</span>
    </div>
    <div class="gapw-num" id="gapw-num">—</div>
    <div class="gapw-sub" id="gapw-sub">loading benchmark…</div>
    <a class="gapw-credit" href="https://stackarchitect.xyz/shopify-ios-attribution-gap-benchmark/" target="_blank" rel="noopener">
      First-party benchmark · Stack Architect → methodology &amp; sources
    </a>
  </div>

  <style>
    .gapw{font-family:ui-sans-serif,system-ui,-apple-system,sans-serif;background:#0b0f14;color:#e8eef4;border:1px solid #223041;border-radius:14px;padding:1.1rem 1.25rem;max-width:340px;margin:0 auto;text-align:center}
    .gapw-head{display:flex;align-items:center;justify-content:center;gap:.6rem;font-size:.72rem;letter-spacing:.06em;text-transform:uppercase;opacity:.85}
    .gapw-live{display:inline-flex;align-items:center;gap:.3rem;color:#7ef0b2;font-weight:700}
    .gapw-dot{width:.5rem;height:.5rem;border-radius:50%;background:#38e08c;animation:gapwpulse 1.6s infinite}
    @keyframes gapwpulse{0%,100%{opacity:1}50%{opacity:.35}}
    .gapw-num{font-size:3rem;font-weight:800;line-height:1.1;margin:.35rem 0 .1rem;background:linear-gradient(90deg,#7ef0b2,#59c9ff);-webkit-background-clip:text;background-clip:text;color:transparent}
    .gapw-sub{font-size:.82rem;opacity:.8;min-height:1.2em}
    .gapw-credit{display:block;margin-top:.7rem;font-size:.72rem;color:#59c9ff;text-decoration:none;opacity:.9}
    .gapw-credit:hover{text-decoration:underline}
  </style>

  <script>
    fetch('/api/gap-stats').then(function(r){return r.json();}).then(function(d){
      var num=document.getElementById('gapw-num'), sub=document.getElementById('gapw-sub');
      if(d && d.ready){
        num.textContent=d.median_gap_pct+'%';
        sub.textContent='median gap · '+d.n+' real stores · updated '+d.updated;
      } else if(d){
        num.textContent=(d.n||0)+'/'+(d.min_n||10);
        sub.textContent='stores contributed — figure publishes at N='+(d.min_n||10);
      } else { num.textContent='—'; sub.textContent='benchmark temporarily unavailable'; }
    }).catch(function(){
      document.getElementById('gapw-sub').textContent='benchmark temporarily unavailable';
    });
  </script>
</EmbedLayout>
