    .impact-cell{background:var(--bg-3);border:1px solid var(--border);border-radius:8px;padding:16px;text-align:center;}
    .impact-cell .ic-val{font-family:var(--mono);font-size:22px;font-weight:700;line-height:1;margin-bottom:6px;}
    .impact-cell .ic-label{font-size:11px;color:var(--text-4);text-transform:uppercase;letter-spacing:.08em;font-family:var(--mono);}
    .impact-cell .ic-desc{font-size:12px;color:var(--text-3);margin-top:6px;line-height:1.5;}
    @media(max-width:600px){.impact-grid{grid-template-columns:1fr;}}
    .compare-table{width:100%;border-collapse:collapse;margin:20px 0;}
    .compare-table th{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-4);padding:12px 16px;text-align:left;background:rgba(255,255,255,.025);border-bottom:1px solid var(--border);}
    .compare-table td{font-size:13px;color:var(--text-3);padding:12px 16px;border-bottom:1px solid var(--border);}
    .compare-table tr:last-child td{border-bottom:none;}
    .compare-table .winner{color:var(--g);font-weight:600;}
    .compare-table .loser{color:var(--text-4);}
    .compare-table tr:hover td{background:rgba(255,255,255,.02);}
    .section-cta{background:rgba(0,200,100,.06);border:1.5px solid rgba(0,200,100,.2);border-radius:10px;padding:24px 28px;margin:32px 0;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;}
    .section-cta-left h4{font-weight:700;font-size:16px;color:var(--text);margin-bottom:4px;line-height:1.3;}
    .section-cta-left p{font-size:13px;color:var(--text-3);margin:0;}
    .section-divider{height:1px;background:var(--border);margin:56px 0;}
    .pdf-gate{background:var(--bg-3);border:1.5px solid var(--border-2);border-radius:12px;padding:40px;text-align:center;margin:40px 0;position:relative;overflow:hidden;}
    .pdf-gate::before{content:'';display:block;width:500px;height:120px;background:radial-gradient(ellipse,rgba(0,200,100,.07) 0%,transparent 65%);position:absolute;top:0;left:50%;transform:translateX(-50%);pointer-events:none;}
    .pdf-gate h3{font-weight:900;font-size:clamp(18px,3vw,26px);color:var(--text);letter-spacing:-.03em;margin-bottom:8px;position:relative;}
    .pdf-gate p{font-size:14px;color:var(--text-3);max-width:420px;margin:0 auto 20px;line-height:1.65;position:relative;}
    .pdf-gate-specs{display:flex;flex-wrap:wrap;justify-content:center;gap:14px;margin-bottom:24px;position:relative;}
    .pdf-spec{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-3);}
    .pdf-spec-dot{width:4px;height:4px;border-radius:50%;background:var(--g);flex-shrink:0;}
    .pdf-disc{font-size:11px;color:var(--text-4);margin-top:10px;position:relative;}
    .static-faq{display:flex;flex-direction:column;gap:8px;margin-top:40px;}
    details.faq-item-g{border-radius:10px;border:1.5px solid var(--border);background:rgba(255,255,255,.02);transition:border-color .2s;list-style:none;}
    details.faq-item-g[open]{border-color:rgba(0,200,100,.25);background:rgba(0,200,100,.025);}
    details.faq-item-g summary.faq-btn-g{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:18px 22px;cursor:pointer;list-style:none;min-height:58px;}
    details.faq-item-g summary::-webkit-details-marker{display:none;}
    details.faq-item-g[open] summary .faq-q-g{color:var(--text);}
    details.faq-item-g[open] summary .faq-ico-g{color:var(--g);}
    details.faq-item-g[open] summary .faq-ico-g::before{transform:rotate(225deg);top:7px;}
    .faq-q-g{font-size:15px;font-weight:600;color:var(--text-3);flex:1;line-height:1.45;}
    .faq-ico-g{width:18px;height:18px;min-width:18px;display:inline-block;flex-shrink:0;position:relative;opacity:.4;}
    .faq-ico-g::before{content:'';position:absolute;top:4px;left:3px;width:10px;height:10px;border-right:2px solid currentColor;border-bottom:2px solid currentColor;transform:rotate(45deg);transition:transform .25s;}
    .faq-body-g{padding:0 22px 20px;font-size:15px;color:var(--text-3);line-height:1.75;border-top:1px solid var(--border);padding-top:14px;}
    .faq-body-g p{margin:0;font-size:15px;color:var(--text-3);line-height:1.75;}
    .faq-body-g a{color:var(--g);text-decoration:underline;}
    .scroll-bar{display:none;position:fixed;bottom:0;left:0;right:0;z-index:99999;background:var(--bg-3);border-top:1px solid var(--border-2);padding:14px 24px;}
    .scroll-bar-inner{max-width:860px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;}
    .scroll-bar-text{font-size:15px;font-weight:600;color:var(--text);line-height:1.35;}
    .scroll-bar-text span{color:var(--g);}
    .scroll-bar-actions{display:flex;align-items:center;gap:10px;flex-shrink:0;}
    .scroll-bar-dismiss{font-size:11px;color:var(--text-4);background:none;border:none;cursor:pointer;padding:6px 10px;font-family:var(--mono);text-transform:uppercase;}
    @media(max-width:600px){
      .section-cta{flex-direction:column;}
      .section-cta .btn,.section-cta .btn-sm{width:100%;justify-content:center;}
      .guide-stats{grid-template-columns:repeat(2,1fr);}
      .stat-callout{flex-direction:column;gap:10px;}
    }
  </style>

  <script>
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-list .toc-item a');
    const sections  = document.querySelectorAll<HTMLElement>('.guide-section[id], header[id]');
    if (tocLinks.length && sections.length) {
      const obs = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = (entry.target as HTMLElement).id;
            tocLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + id));
          }
        });
      }, { rootMargin:'-20% 0px -70% 0px' });
      sections.forEach(s => obs.observe(s));
    }
    const scrollBar = document.getElementById('scroll-bar') as HTMLElement | null;
    const scrollDismiss = document.getElementById('scroll-dismiss') as HTMLButtonElement | null;
    let barShown = false, barDismissed = false;
    if (scrollBar) {
      window.addEventListener('scroll', () => {
        const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
        if (pct > 0.4 && !barShown && !barDismissed) { scrollBar.style.display = 'block'; barShown = true; }
      }, { passive:true });
      scrollDismiss?.addEventListener('click', () => { scrollBar.style.display = 'none'; barDismissed = true; });
    }
  </script>
</body>
</html>
