<script>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      bar.style.width = Math.min(pct, 100) + '%';
    }, { passive: true });
  }


  function calcApps() {
    const checks = [...document.querySelectorAll('#app-checks input[type=checkbox]:checked')];
    let total = 0, freeTotal = 0, killItems = [];

    const replaceableIds = ['a1','a2','a3','a4','a5','a6','a9'];

    checks.forEach(el => {
      const costInput = document.getElementById('cost-' + el.id);
      const cost = parseFloat(costInput?.value) || parseInt(el.dataset.cost) || 0;
      total += cost;
      if (replaceableIds.includes(el.id)) {
        freeTotal += cost;
        const replace = el.dataset.replace;
        const link = el.dataset.link;
        killItems.push({ name: el.parentElement.querySelector('div > div').textContent, replace, link, cost });
      }
    });

    document.getElementById('app-total').textContent = '£' + total.toLocaleString() + '/mo';
    document.getElementById('app-free').textContent = '£' + freeTotal.toLocaleString() + '/mo';
    document.getElementById('app-annual').textContent = '£' + (freeTotal * 12).toLocaleString() + '/yr';

    let killHTML = '';
    if (killItems.length) {
      killHTML = '<div style="font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#52525b;margin-bottom:12px;">// YOUR_KILL_LIST</div>';
      killItems.forEach(item => {
        killHTML += '<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border:1px solid rgba(74,222,128,.2);background:rgba(74,222,128,.04);margin-bottom:6px;gap:12px;">';
        killHTML += '<div><div style="font-size:11px;font-weight:700;color:#fff;">' + item.name.split('(')[0].trim() + '</div>';
        killHTML += '<div style="font-size:10px;color:#52525b;">Replace with: ' + item.replace + '</div></div>';
        if (item.link) killHTML += '<a href="' + item.link + '" style="font-size:10px;font-weight:700;letter-spacing:.08em;color:#4ade80;text-decoration:none;white-space:nowrap;border:1px solid rgba(74,222,128,.3);padding:6px 12px;">SET UP FREE →</a>';
        killHTML += '</div>';
      });
    }
    document.getElementById('app-kill-list').innerHTML = killHTML;
    document.getElementById('app-result').classList.add('show');
  }
  
</script>
