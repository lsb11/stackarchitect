.result-label{font-size:.88rem;color:var(--muted);flex:1}
.result-label .sub{display:block;font-size:.78rem;margin-top:2px;color:var(--muted)}
.result-value{font-size:.95rem;font-weight:600;text-align:right;flex-shrink:0;max-width:55%}
.flag-good .result-value{color:#059669}
.flag-warn .result-value{color:var(--amber)}
.flag-bad .result-value{color:var(--red)}
.flag-neutral .result-value{color:var(--text)}
/* Upsell */
.upsell{background:var(--green);border-radius:var(--radius);padding:20px 24px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
