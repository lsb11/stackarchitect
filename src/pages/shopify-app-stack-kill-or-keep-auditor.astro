  description="Audit every app in your Shopify stack. Identify which apps can be replaced for free, calculate your total monthly app bill, and get a personalised kill list."
  canonical="https://stackarchitect.xyz/shopify-app-stack-kill-or-keep-auditor/"
  schema={schemas}
  breadcrumb={breadcrumb}
>
  <Nav slot="header" />

  <main class="flex-1">
    <div id="reading-progress"></div>
    
<style>
  .tool-hero{padding:48px 24px 32px;background:#000;border-bottom:1px solid #1f1f1f;}
  .tool-hero-inner{max-width:860px;margin:0 auto;}
  .tool-badge{display:inline-flex;align-items:center;gap:6px;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:4px 12px;border:1px solid rgba(74,222,128,.3);color:#4ade80;background:rgba(74,222,128,.06);margin-bottom:18px;}
  .tool-badge .dot{width:6px;height:6px;border-radius:50%;background:#4ade80;animation:dp 2s infinite;}
  @keyframes dp{0%,100%{opacity:1;}50%{opacity:.3;}}
  .tool-hero h1{font-size:clamp(22px,4vw,38px);font-weight:900;color:#fff;letter-spacing:-.03em;line-height:1.05;margin-bottom:12px;}
  .tool-hero h1 .green{color:#4ade80;}
  .tool-hero-desc{font-size:14px;color:#a1a1aa;line-height:1.75;max-width:600px;margin-bottom:20px;}
  .tool-trust{display:flex;flex-wrap:wrap;gap:16px;}
  .tool-trust span{font-size:11px;color:#52525b;display:flex;align-items:center;gap:5px;}
  .tool-trust span::before{content:'✓';color:#4ade80;font-weight:700;}

  .calc-section{padding:40px 24px;background:#0a0a0a;border-bottom:1px solid #1f1f1f;}
  .calc-inner{max-width:860px;margin:0 auto;}
  .calc-card{border:1px solid #1f1f1f;background:#000;padding:32px;}
  .calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;}
  @media(max-width:600px){.calc-grid{grid-template-columns:1fr;}}
  .calc-field{display:flex;flex-direction:column;gap:6px;}
  .calc-field label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#52525b;}
  .calc-field input,.calc-field select{background:#0a0a0a;border:1px solid #1f1f1f;color:#fff;font-family:inherit;font-size:13px;padding:10px 14px;outline:none;transition:border-color .2s;width:100%;}
  .calc-field input:focus,.calc-field select:focus{border-color:#4ade80;}
  .calc-field input::placeholder{color:#3f3f46;}
  .calc-btn{width:100%;background:#4ade80;color:#000;font-family:inherit;font-size:12px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;padding:14px;border:none;cursor:pointer;transition:background .2s;margin-top:8px;}
  .calc-btn:hover{background:#22c55e;}
  .calc-result{display:none;margin-top:24px;border:1px solid #1f1f1f;background:#0a0a0a;padding:24px;}
  .calc-result.show{display:block;}
  .result-label{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#52525b;margin-bottom:6px;}
  .result-value{font-size:36px;font-weight:900;color:#4ade80;line-height:1;letter-spacing:-.03em;}
  .result-sub{font-size:12px;color:#52525b;margin-top:6px;line-height:1.6;}
  .result-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;margin-bottom:20px;}
  .result-cell{background:#000;border:1px solid #1f1f1f;padding:16px;}
  .result-insight{font-size:12px;color:#a1a1aa;line-height:1.7;border-top:1px solid #1f1f1f;padding-top:16px;margin-top:16px;}
  .result-insight strong{color:#fff;}
  .result-cta{display:inline-block;margin-top:16px;font-size:11px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;color:#000;background:#4ade80;padding:10px 20px;text-decoration:none;transition:background .2s;}
  .result-cta:hover{background:#22c55e;}
  .result-warn{border-left:3px solid #4ade80;padding-left:16px;margin-top:16px;}

  .aff-block{margin:24px 0;border:1px solid rgba(74,222,128,.2);background:rgba(74,222,128,.04);padding:20px 24px;display:flex;align-items:flex-start;justify-content:space-between;gap:20px;flex-wrap:wrap;}
  .aff-block-text{flex:1;}
  .aff-block-label{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:#52525b;margin-bottom:6px;}
  .aff-block-title{font-size:13px;font-weight:700;color:#fff;margin-bottom:4px;}
  .aff-block-desc{font-size:11px;color:#71717a;line-height:1.6;}
  .aff-block-link{flex-shrink:0;display:inline-flex;align-items:center;font-size:10px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;color:#4ade80;border:1px solid rgba(74,222,128,.4);padding:8px 16px;text-decoration:none;transition:all .2s;white-space:nowrap;}
  .aff-block-link:hover{background:#4ade80;color:#000;}
  .aff-disclosure{font-size:9px;color:#3f3f46;margin-top:8px;}

  .editorial{padding:48px 24px;background:#000;border-bottom:1px solid #1f1f1f;}
  .editorial-inner{max-width:720px;margin:0 auto;}
  .editorial h2{font-size:clamp(18px,3vw,26px);font-weight:900;color:#fff;letter-spacing:-.03em;margin:36px 0 12px;line-height:1.2;}
  .editorial h2:first-child{margin-top:0;}
  .editorial p{font-size:13px;color:#a1a1aa;line-height:1.85;margin-bottom:16px;}
  .editorial strong{color:#e4e4e7;}
  .editorial a{color:#4ade80;text-decoration:underline;}
  .editorial ul{list-style:none;padding:0;margin:0 0 16px;}
  .editorial ul li{font-size:13px;color:#a1a1aa;line-height:1.75;padding:6px 0 6px 20px;position:relative;border-bottom:1px solid #0a0a0a;}
  .editorial ul li::before{content:'→';position:absolute;left:0;color:#4ade80;font-size:11px;}

  .faq-section{padding:48px 24px;background:#0a0a0a;border-bottom:1px solid #1f1f1f;}
  .faq-inner{max-width:720px;margin:0 auto;}
  .faq-heading{font-size:clamp(18px,3vw,24px);font-weight:900;color:#fff;letter-spacing:-.03em;margin-bottom:28px;}
  .faq-item{border:1px solid #1f1f1f;margin-bottom:8px;background:#000;}
  .faq-item summary{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;list-style:none;font-size:12px;font-weight:700;color:#a1a1aa;letter-spacing:.02em;gap:16px;}
  .faq-item summary::-webkit-details-marker{display:none;}
  .faq-item[open] summary{color:#fff;border-bottom:1px solid #1f1f1f;}
  .faq-item[open]{border-color:rgba(74,222,128,.3);}
  .faq-arrow{flex-shrink:0;font-size:10px;color:#52525b;transition:transform .2s;}
  .faq-item[open] .faq-arrow{transform:rotate(180deg);color:#4ade80;}
  .faq-answer{padding:16px 20px;font-size:12px;color:#71717a;line-height:1.8;}
  .faq-answer a{color:#4ade80;}

  .cta-strip-tool{padding:40px 24px;background:#0a0a0a;border-top:1px solid #1f1f1f;text-align:center;}
  .cta-strip-tool h2{font-size:clamp(16px,3vw,22px);font-weight:900;color:#fff;letter-spacing:-.03em;margin-bottom:8px;}
  .cta-strip-tool p{font-size:12px;color:#52525b;margin-bottom:20px;}
  .cta-strip-tool a{display:inline-block;background:#4ade80;color:#000;font-size:11px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;padding:14px 28px;text-decoration:none;transition:background .2s;}
  .cta-strip-tool a:hover{background:#22c55e;}
  #reading-progress{position:fixed;top:0;left:0;width:0;height:2px;background:#4ade80;z-index:9999;transition:width .1s;}
</style>


