---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const schemas = [{"@context":"https://schema.org","@type":"WebApplication","name":"Shopify App Stack Kill or Keep Auditor","url":"https://stackarchitect.xyz/shopify-app-stack-kill-or-keep-auditor/","description":"Audit every app in your Shopify stack. Identify which apps can be replaced for free, calculate your total monthly app bill, and get a personalised kill list.","applicationCategory":"BusinessApplication","operatingSystem":"Any","offers":{"@type":"Offer","price":"0","priceCurrency":"GBP"},"provider":{"@type":"Organization","name":"Stack Architect","url":"https://stackarchitect.xyz"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the average Shopify app spend per store?","acceptedAnswer":{"@type":"Answer","text":"Research consistently shows that the average Shopify store above £10k/month GMV spends £300–£700/month on apps. Many store owners significantly underestimate this because apps are often billed separately and the cost is spread across multiple invoices. The most common expensive categories are tracking/attribution (£150–£299), email marketing (£100–£400), and inventory management (£29–£199)."}},{"@type":"Question","name":"Which Shopify apps can be replaced for free?","acceptedAnswer":{"@type":"Answer","text":"The most commonly replaceable paid apps are: tracking/attribution apps (replaced by CAPI Shield via Make.com), email marketing platforms like Klaviyo (replaced by Systeme.io free plan), inventory management (replaced by Stocky Swap), TikTok pixel apps (replaced by TikTok Events API free setup), P&L reporting tools (replaced by Make.com + Google Sheets), and automation connectors like Zapier (replaced by Make.com free tier)."}},{"@type":"Question","name":"How do I see all the apps I'm paying for on Shopify?","acceptedAnswer":{"@type":"Answer","text":"In Shopify Admin, go to Settings > Billing > Billing history. This shows all app charges. For a cleaner view, go to Apps > All apps in your admin — each installed app shows its billing status. Some apps bill through your Shopify invoice; others bill you directly. Check both your Shopify billing page and your credit card statement for the full picture."}},{"@type":"Question","name":"Is it safe to cancel apps I am not using?","acceptedAnswer":{"@type":"Answer","text":"Generally yes, but verify each app's function before cancelling. Some apps that appear inactive may be doing background work (like tracking or syncing). Before cancelling any app: check what it does, confirm nothing depends on it, and if it manages data (like a CRM or inventory app) export your data first. A safe practice is to uninstall rather than just cancel — this removes the app from your store and stops billing."}},{"@type":"Question","name":"What should I do before cancelling my Klaviyo account?","acceptedAnswer":{"@type":"Answer","text":"Export your complete subscriber list as a CSV including all custom properties and segments. Export your flow structures (screenshots or documentation). Save any email templates you want to reuse. Then set up your replacement platform (Systeme.io or GetResponse) and run both in parallel for 2–4 weeks before fully cancelling Klaviyo."}}]},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stackarchitect.xyz"},{"@type":"ListItem","position":2,"name":"Tools","item":"https://stackarchitect.xyz/tools/"},{"@type":"ListItem","position":3,"name":"Shopify App Stack Kill or Keep Auditor","item":"https://stackarchitect.xyz/shopify-app-stack-kill-or-keep-auditor/"}]}];

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools' },
  { label: 'Shopify App Stack Kill or Keep Auditor — Free App Cost Audit Tool' },
];
---

<Base
