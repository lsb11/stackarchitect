<script is:inline>
function fmt(n){ return Math.round(n).toLocaleString('en-GB'); }

function calculate(inp) {
  var total = parseFloat(inp.totalMonthlyApps) || 0;
  var techMap = { 'Non-technical': 0.3, 'Comfortable with Sheets/no-code': 0.6, 'Can handle Make.com': 0.8, 'Developer-level': 0.95 };
  var techMultiplier = techMap[inp.techLevel] || 0.5;
  var replaceability = {
    'klaviyo':0.95,'gorgias':0.4,'recharge':0.15,'yotpo':0.8,'okendo':0.8,
    'triple whale':0.6,'postscript':0.7,'loyaltylion':0.65,'rebuy':0.75,
    'frequently bought together':0.9,'judge.me':0.5,'bold upsell':0.8,
    'stocky':1.0,'privy':0.85
  };
  var killItems = [], keepItems = [], replaceableTotal = 0;
  if (inp.appList && inp.appList.trim()) {
    var lines = inp.appList.split('
').filter(function(l){ return l.trim(); });
    lines.forEach(function(line) {
      var parts = line.split(',');
      var appName = (parts[0] || '').trim();
      var costStr = (parts[1] || '0').replace(/[^0-9.]/g,'');
      var cost = parseFloat(costStr) || 0;
      var key = appName.toLowerCase();
      var score = 0.5;
      var keys = Object.keys(replaceability);
      for (var i = 0; i < keys.length; i++) {
        if (key.indexOf(keys[i]) !== -1) { score = replaceability[keys[i]]; break; }
      }
      if (score * techMultiplier >= 0.4) { killItems.push(appName + ' (£' + fmt(cost) + '/mo)'); replaceableTotal += cost; }
      else keepItems.push(appName);
    });
  } else {
    replaceableTotal = total * 0.6 * techMultiplier;
  }
  var annual = replaceableTotal * 12;
  return {
    teaser: { label: 'Annual saving potential', value: '£' + fmt(annual), flag: annual > 1000 ? 'good' : annual > 200 ? 'warn' : 'neutral' },
    rows: [
      { label: 'Total monthly app spend', value: '£' + fmt(total), flag: 'neutral' },
      { label: 'Replaceable monthly spend', value: '£' + fmt(replaceableTotal), flag: 'good' },
      { label: 'Annual saving potential', value: '£' + fmt(annual), flag: 'good' },
      { label: 'Apps to eliminate', value: killItems.length ? killItems.join(', ') : 'Paste app list above for detailed analysis', flag: killItems.length ? 'warn' : 'neutral' },
      { label: 'Apps to keep', value: keepItems.length ? keepItems.join(', ') : '—', flag: 'neutral' }
    ]
  };
}

var IS_GATED = true;
var form = document.getElementById('calcForm');
var resultsSection = document.getElementById('results');
var resultsContent = document.getElementById('resultsContent');
var teaserSection = document.getElementById('teaser');
var teaserValue = document.getElementById('teaserValue');
var teaserLabel = document.getElementById('teaserLabel');
var emailGate = document.getElementById('emailGate');
var gateBtn = document.getElementById('gateBtn');
var upsellBlock = document.getElementById('upsellBlock');
var lastResult = null;

function getInputs() {
  var inp = {};
  var fd = new FormData(form);
  fd.forEach(function(v, k) {
    if (inp[k]) {
      inp[k] = Array.isArray(inp[k]) ? inp[k].concat(v) : [inp[k], v];
    } else {
      inp[k] = v;
    }
  });
  // Also grab textareas by id since FormData may not pick up all
  form.querySelectorAll('textarea').forEach(function(el){
    if (!inp[el.id]) inp[el.id] = el.value;
  });
  return inp;
}

function renderRows(rows) {
  return rows.map(function(r) {
    var sub = r.sub ? '<span class="sub">' + r.sub + '</span>' : '';
    return '<div class="result-row flag-' + (r.flag||'neutral') + '">' +
      '<span class="result-label">' + r.label + sub + '</span>' +
      '<span class="result-value">' + r.value + '</span>' +
    '</div>';
  }).join('');
}

function showFullResults(rows) {
  resultsContent.innerHTML = renderRows(rows);
  resultsSection.hidden = false;
  upsellBlock.hidden = false;
  resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

form.addEventListener('submit', function(e) {
  e.preventDefault();
  var inp = getInputs();
  var result;
  try { result = calculate(inp); } catch(err) { alert('Calculation error: ' + err.message); return; }
  lastResult = result;

  if (!IS_GATED) {
    showFullResults(result.rows);
    return;
  }

  // Show teaser
  teaserValue.textContent = result.teaser.value;
  teaserLabel.textContent = result.teaser.label;
  teaserSection.hidden = false;

  // Check if already gated
  var storedEmail = localStorage.getItem('sa_email');
  if (storedEmail) {
    emailGate.hidden = true;
    showFullResults(result.rows);
  } else {
    emailGate.hidden = false;
  }
  teaserSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});

if (gateBtn) {
  gateBtn.addEventListener('click', function() {
    var emailInput = document.getElementById('emailInput');
    var email = emailInput ? emailInput.value.trim() : '';
    if (!email || !email.includes('@')) { emailInput.focus(); return; }
    localStorage.setItem('sa_email', email);
    emailGate.hidden = true;
    if (lastResult) showFullResults(lastResult.rows);
  });
}
</script>
</body>
