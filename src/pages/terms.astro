---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
// src/pages/terms.astro
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <title>Terms of Use — Stack Architect</title>
