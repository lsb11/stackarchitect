.sec-head p{font-size:15px;color:var(--text-3);max-width:520px;margin:14px auto 0;line-height:1.75;}
.bg-grid{background-color:var(--bg);background-image:radial-gradient(ellipse 80% 40% at 50% 0%,rgba(0,200,100,.05) 0%,transparent 60%),radial-gradient(circle,var(--border) 1px,transparent 1px);background-size:100% 100%,44px 44px;}
.hero{padding:90px 24px 80px;text-align:center;position:relative;overflow:hidden;}
.hero-inner{max-width:880px;margin:0 auto;}
