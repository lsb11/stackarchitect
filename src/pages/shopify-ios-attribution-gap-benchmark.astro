.big-callout{background:rgba(0,200,100,.05);border:1.5px solid var(--g-border);border-radius:12px;padding:28px;margin:24px 0;display:flex;align-items:center;gap:24px;flex-wrap:wrap;}
.big-callout-num{font-family:var(--mono);font-size:52px;font-weight:800;color:var(--g);line-height:1;flex-shrink:0;}
