.sec-head h2{font-family:var(--sans);font-weight:900;font-size:clamp(26px,4vw,40px);letter-spacing:-.03em;color:var(--text);line-height:1.05;margin-bottom:10px;}
.sec-head p{font-size:15px;color:var(--text-3);max-width:520px;margin:14px auto 0;line-height:1.75;}
.bg-grid{background-color:var(--bg);background-image:radial-gradient(ellipse 80% 40% at 50% 0%,rgba(0,200,100,.05) 0%,transparent 60%),radial-gradient(circle,var(--border) 1px,transparent 1px);background-size:100% 100%,44px 44px;}
.hero{padding:90px 24px 80px;text-align:center;position:relative;overflow:hidden;}
.hero-inner{max-width:880px;margin:0 auto;}
.hero-proof{display:inline-flex;align-items:center;gap:12px;background:rgba(255,255,255,.04);border:1px solid var(--border-2);border-radius:100px;padding:9px 22px;margin-bottom:36px;flex-wrap:wrap;justify-content:center;}
.hero-proof-txt{font-family:var(--mono);font-size:11px;color:var(--text-4);letter-spacing:.08em;}
.hero h1{font-size:clamp(34px,6vw,68px);font-weight:900;color:var(--text);line-height:1.0;letter-spacing:-.04em;margin:0 auto 24px;max-width:820px;}
.hero h1 .big-stat{color:var(--g);font-size:clamp(52px,10vw,110px);display:inline-block;line-height:1;}
