.tag-dim{background:rgba(255,255,255,.03);border-color:var(--border-2);color:var(--text-4);}
.dot{display:inline-block;width:7px;height:7px;min-width:7px;border-radius:50%;background:var(--g);animation:dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite;}
@keyframes dotPing{0%{box-shadow:0 0 0 0 rgba(0,200,100,.5);}70%{box-shadow:0 0 0 8px rgba(0,200,100,0);}100%{box-shadow:0 0 0 0 rgba(0,200,100,0);}}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;font-family:var(--sans);font-size:16px;font-weight:700;text-decoration:none;letter-spacing:-.01em;padding:16px 32px;border-radius:6px;border:none;cursor:pointer;white-space:nowrap;background:var(--g);color:#021;transition:background .2s,transform .15s,box-shadow .2s;min-height:52px;}
.btn:hover{background:#00e070;transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,200,100,.35);}
.btn.pulse{animation:btnGlow 2.8s ease-in-out infinite;}
@keyframes btnGlow{0%,100%{box-shadow:0 0 16px rgba(0,200,100,.1);}50%{box-shadow:0 0 28px rgba(0,200,100,.3);}}
.btn.pulse:hover{animation:none;}
.btn-sm{font-size:14px;padding:12px 22px;min-height:44px;}
.btn-outline{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-family:var(--sans);font-size:15px;font-weight:600;text-decoration:none;padding:15px 28px;border-radius:6px;border:1.5px solid var(--border-2);cursor:pointer;white-space:nowrap;background:transparent;color:var(--text-2);transition:border-color .2s,color .2s,background .2s;min-height:52px;}
.btn-outline:hover{border-color:var(--g);color:var(--g);background:var(--g-bg);}
.section{padding:90px 24px;}
.section-alt{padding:90px 24px;background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.inner{max-width:1000px;margin:0 auto;}
