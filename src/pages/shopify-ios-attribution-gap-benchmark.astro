<script define:vars={{ HEADLINE_LOW, HEADLINE_HIGH }}>
  (function(){
    const cbtn = document.getElementById('cite-copy');
    const ctext = document.getElementById('cite-text');
    if(cbtn && ctext){
      cbtn.addEventListener('click', async function(){
        try {
          await navigator.clipboard.writeText(ctext.innerText.trim());
          const orig = cbtn.textContent;
          cbtn.textContent = 'Copied \u2713';
          setTimeout(function(){ cbtn.textContent = orig; }, 2000);
        } catch(e){
          const r = document.createRange(); r.selectNodeContents(ctext);
          const sel = window.getSelection(); sel.removeAllRanges(); sel.addRange(r);
        }
      });
    }
  })();
  function refreshMeter(){
    fetch('/api/gap-stats').then(function(r){return r.json();}).then(function(d){
      var c=document.getElementById('gap-meter-count');
      var g=document.getElementById('gap-meter-goal');
      var f=document.getElementById('gap-meter-fill');
      var n=document.getElementById('gap-meter-note');
      if(!c) return;
      if(d && d.ready){
        c.textContent=d.median_gap_pct+'%';
        g.textContent='measured iOS attribution gap';
        f.style.width='100%';
        n.textContent='Based on '+d.n+' real stores \u00b7 updates as more contribute';
      } else if(d){
        var nn=d.n||0, mn=d.min_n||10;
        c.textContent=nn;
        g.textContent='of '+mn+' stores needed to publish';
        f.style.width=Math.min(100,(nn/mn)*100)+'%';
        n.textContent=nn===0?'Be the first store to contribute a real measurement.':((mn-nn)+' more '+((mn-nn)===1?'store':'stores')+' until the figure goes live.');
      }
    }).catch(function(){
      var n=document.getElementById('gap-meter-note'); if(n) n.textContent='Live count unavailable right now.';
    });
  }
  refreshMeter();
  (function(){
    const btn = document.getElementById('f-submit');
    if(!btn) return;
    btn.addEventListener('click', async function(){
      const reported = parseFloat(document.getElementById('f-reported').value);
      const actual   = parseFloat(document.getElementById('f-actual').value);
      const platform = document.getElementById('f-platform').value;
      const resultBox = document.getElementById('contrib-result');
      const gapEl = document.getElementById('result-gap');
      const msgEl = document.getElementById('result-msg');

      if(!reported || !actual || actual <= 0 || reported < 0){
        gapEl.textContent = '—';
        msgEl.textContent = 'Enter both numbers (actual orders must be greater than zero) to see your gap.';
        resultBox.style.display = 'block';
        return;
      }
      let gap = Math.round((1 - (reported/actual)) * 100);
      if(gap < 0) gap = 0;
      gapEl.textContent = gap + '%';

      let context;
      if(gap === 0){ context = 'Your platform is reporting at least as many conversions as you have orders — likely already on server-side tracking, or modelled conversions are filling the gap.'; }
      else if(gap < HEADLINE_LOW){ context = 'Below the typical ' + HEADLINE_LOW + '–' + HEADLINE_HIGH + '% range — better than most. Server-side tracking would still tighten matching further.'; }
      else if(gap <= HEADLINE_HIGH){ context = 'Squarely in the typical ' + HEADLINE_LOW + '–' + HEADLINE_HIGH + '% range. That is conversions your algorithm never sees — and cannot optimise toward.'; }
      else { context = 'Above the typical range — a heavy gap. Mobile/iOS-skewed stores see this most. Server-side tracking typically recovers a large share of it.'; }
      msgEl.textContent = context;
      resultBox.style.display = 'block';

      // Submit the real contribution to the first-party dataset (Cloudflare D1)
      try {
        const res = await fetch('/api/submit-gap', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            actual_orders: Math.round(actual),
            meta_reported: Math.round(reported),
            window_days: 30,
            platform_note: platform
          })
        });
        const data = await res.json();
        const thanks = document.getElementById('contrib-thanks');
        if (res.ok) {
          if (thanks) { thanks.textContent = 'Added to the dataset \u2713 Thank you \u2014 your numbers now help build the benchmark.'; thanks.style.display = 'block'; }
          refreshMeter();
        } else if (thanks) {
          thanks.textContent = (data && data.error) ? data.error : 'Could not save your contribution \u2014 please try again.';
          thanks.style.display = 'block';
        }
      } catch(e) {
        const thanks = document.getElementById('contrib-thanks');
        if (thanks) { thanks.textContent = 'Network error \u2014 your gap is shown above, but the contribution did not save. Please try again.'; thanks.style.display = 'block'; }
      }
    });
  })();
</script>

<style is:global>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
