---
import Nav from '../components/Nav.astro';
/**
 * src/pages/shopify-ios-attribution-gap-benchmark.astro
 * stackarchitect.xyz/shopify-ios-attribution-gap-benchmark
 *
 * Intent: ORIGINAL CITABLE DATA — the highest-SEO-leverage asset.
 * A maintained benchmark synthesising published research on how much Shopify
 * purchase-conversion signal is lost to iOS / ATT / ITP, expressed as one
 * quotable headline statistic with a transparent methodology and linked sources.
 * Designed to earn backlinks: journalists/bloggers cite the number, link the page.
 *
 * Honesty principles (non-negotiable for credibility):
 *  - Every figure is attributed to a named, dated, linked third-party source.
 *  - The synthesised "Stack Architect Index" is labelled as a synthesis of those
 *    sources, NOT presented as proprietary primary data.
 *  - A contribution form gathers real store data so the page can become
 *    genuinely original over time ("based on N stores") — clearly future-tense
 *    until enough is collected.
 *  - Schema: Dataset + Article + FAQPage for citability and rich results.
 */

const SITE       = "https://stackarchitect.xyz";
const CANONICAL  = `${SITE}/shopify-ios-attribution-gap-benchmark/`;
const OG         = `${SITE}/og.png`;
const datePublished = "2026-06-13";
const dateModified  = "2026-06-13";
const verified      = "13 June 2026";
const lastReviewISO = "2026-06-13";

// ── The synthesised headline range (from sourced figures below) ──
const HEADLINE_LOW  = 20;
const HEADLINE_HIGH = 40;
const HEADLINE_MOBILE_HIGH = 50;

// ── Sourced data points (every row links to a real, named source) ──
const dataPoints = [
  {
    metric: "iOS users who opted OUT of tracking after ATT",
    value: "~75%",
    detail: "Within 60 days of the April 2021 ATT prompt, the IDFA was zeroed out for roughly three-quarters of iOS users globally; opt-in stabilised near 25% and has not materially moved since.",
    source: "AdLibrary — iOS 14 ATT Five-Year Retrospective",
    sourceUrl: "https://adlibrary.com/posts/ios-14-att",
    sourceDate: "May 2026"
  },
  {
    metric: "Reduction in Meta Ads tracking accuracy from ATT",
    value: "30–40%",
    detail: "ATT reduced Meta's ability to accurately attribute conversions by an estimated 30–40%, even after Meta's modelled-conversion and CAPI recovery efforts.",
    source: "Leo Answer Library — Meta Ads privacy impact",
    sourceUrl: "https://www.leoads.ai/answers/meta-ads/meta-ads-privacy-changes-impact/",
    sourceDate: "Feb 2026"
  },
  {
    metric: "Share of Shopify traffic that is mobile",
    value: "74–78%",
    detail: "Mobile devices drive roughly three-quarters of Shopify store traffic — the exact segment most affected by iOS/Safari tracking restrictions.",
    source: "Shopify Mobile Commerce Statistics 2026",
    sourceUrl: "https://easyappsecom.com/guides/shopify-mobile-commerce-statistics",
    sourceDate: "Apr 2026"
  },
  {
    metric: "Attributable conversions lost relying on platform SDK alone (no CAPI)",
    value: "~40%",
    detail: "A documented case found a brand losing approximately 40% of attributable conversions by relying solely on the platform's SDK without a server-side Conversions API complement.",
    source: "021 Newsletter — Do You Still Need an MMP in 2025?",
    sourceUrl: "https://www.021newsletter.com/p/do-you-still-need-an-mmp-in-2025",
    sourceDate: "Jul 2025"
  },
  {
    metric: "Self-reported Meta revenue impact from ATT",
    value: "~$10B",
    detail: "Meta publicly attributed a self-reported revenue hit of around $10 billion to ATT in the year following its rollout, before rebuilding its measurement stack around modelled conversions and CAPI.",
    source: "AdLibrary — iOS 14 ATT Retrospective",
    sourceUrl: "https://adlibrary.com/posts/ios-14-att",
    sourceDate: "May 2026"
  },
  {
    metric: "iOS attribution reliability (current)",
    value: "Degrading",
    detail: "iOS 26 beta analysis in late 2025 confirmed Meta attribution is 'increasingly unreliable for iOS users' — iPhone users click, convert, and the dashboard under-reports it.",
    source: "DOJO AI — Meta Ads Attribution 2026",
    sourceUrl: "https://www.dojoai.com/blog/meta-ads-attribution-2026-changes-fixes",
    sourceDate: "Mar 2026"
  }
];

// ── Contribution form fields (collected to build original data over time) ──
const platforms = ["Meta", "Google", "TikTok", "More than one"];

const faqs = [
  {
    q: "What is the iOS attribution gap for Shopify stores?",
    a: `The iOS attribution gap is the share of real purchases that ad platforms like Meta, Google and TikTok fail to attribute because Apple's App Tracking Transparency (ATT) and Safari Intelligent Tracking Prevention (ITP) block the browser signals those platforms rely on. Synthesising published research, the typical Shopify store loses an estimated ${HEADLINE_LOW}–${HEADLINE_HIGH}% of purchase-conversion signal, rising toward ${HEADLINE_MOBILE_HIGH}% on mobile-heavy stores.`
  },
  {
    q: "How is the Stack Architect Attribution Gap Index calculated?",
    a: "It is a transparent synthesis of published third-party figures — ATT opt-out rates (~75%), measured reductions in Meta tracking accuracy (30–40%), the mobile share of Shopify traffic (74–78%), and documented conversion-loss case data (~40% without CAPI). We do not present this as proprietary primary data; every input is named, dated and linked in the methodology. As real store submissions accumulate, we will publish an original first-party figure alongside it."
  },
  {
    q: "Why does server-side tracking (CAPI) close the gap?",
    a: "Server-side tracking sends the purchase event from the store's server directly to the ad platform's Conversions API — bypassing the browser entirely, so iOS and ad blockers cannot strip it. With hashed first-party data (email, phone) attached, the platform can still match the sale to the click even when the device identifier is gone. This is why brands with clean CAPI pipelines materially out-recover those relying on browser pixels alone."
  },
  {
    q: "Can I cite this benchmark?",
    a: `Yes. This page is maintained and dated specifically so it can be cited. Use the suggested attribution in the "Citing this data" section, and link to ${CANONICAL}. If you represent a publication and want the underlying source list, every figure is linked in the methodology table.`
  }
];

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Dataset",
      "name": "Shopify iOS Attribution Gap Benchmark",
      "description": `A maintained synthesis of published research on how much Shopify purchase-conversion signal is lost to iOS ATT and Safari ITP — an estimated ${HEADLINE_LOW}–${HEADLINE_HIGH}% for the typical store, up to ${HEADLINE_MOBILE_HIGH}% on mobile-heavy stores.`,
      "url": CANONICAL,
      "keywords": ["iOS attribution gap","Shopify conversion tracking","ATT","Meta CAPI","server-side tracking","Enhanced Conversions"],
      "creator": { "@type": "Organization", "name": "Stack Architect", "url": SITE },
      "dateModified": dateModified,
      "datePublished": datePublished,
      "isAccessibleForFree": true,
      "license": "https://creativecommons.org/licenses/by/4.0/"
    },
    {
      "@type": "Article",
      "@id": `${CANONICAL}#article`,
      "headline": "Shopify iOS Attribution Gap Benchmark 2026",
      "description": `How much purchase-conversion signal the typical Shopify store loses to iOS ATT and Safari ITP — a sourced ${HEADLINE_LOW}–${HEADLINE_HIGH}% synthesis, updated and dated.`,
      "author":    { "@type": "Organization", "name": "Stack Architect", "url": SITE },
      "publisher": { "@type": "Organization", "name": "Stack Architect", "url": SITE },
      "datePublished": datePublished,
      "dateModified": dateModified,
      "inLanguage": "en-GB",
      "url": CANONICAL,
      "image": OG
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE },
        { "@type": "ListItem", "position": 2, "name": "iOS Attribution Gap Benchmark", "item": CANONICAL }
      ]
    }
  ]
};
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shopify iOS Attribution Gap Benchmark 2026 — How Much Conversion Data You Lose | Stack Architect</title>
  <meta name="description" content={`The maintained, sourced benchmark for how much purchase-conversion signal Shopify stores lose to iOS ATT and Safari ITP — an estimated ${HEADLINE_LOW}–${HEADLINE_HIGH}% (up to ${HEADLINE_MOBILE_HIGH}% mobile-heavy). Every figure cited. Updated ${verified}.`} />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="author" content="Stack Architect" />
  <link rel="canonical" href={CANONICAL} />
  <link rel="alternate" hreflang="en-GB" href={CANONICAL} />
  <link rel="alternate" hreflang="en-US" href={CANONICAL} />
  <link rel="alternate" hreflang="x-default" href={CANONICAL} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={CANONICAL} />
  <meta property="og:title" content="Shopify iOS Attribution Gap Benchmark 2026" />
  <meta property="og:description" content={`A sourced ${HEADLINE_LOW}–${HEADLINE_HIGH}% synthesis of how much conversion signal Shopify stores lose to iOS. Citable, dated, maintained.`} />
  <meta property="og:image" content={OG} />
  <meta property="og:site_name" content="Stack Architect" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Shopify iOS Attribution Gap Benchmark 2026" />
  <meta name="twitter:description" content={`How much conversion data Shopify stores lose to iOS — a sourced ${HEADLINE_LOW}–${HEADLINE_HIGH}% benchmark.`} />
  <meta name="twitter:image" content={OG} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700;800&display=swap" /></noscript>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-TE6Z6CW514"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-TE6Z6CW514');
  </script>
</head>

<body>
<Nav />

<nav aria-label="Breadcrumb" style="background:var(--bg-2);border-bottom:1px solid var(--border);padding:10px 24px;">
  <div style="max-width:1100px;margin:0 auto;">
    <ol style="display:flex;align-items:center;gap:8px;list-style:none;font-family:var(--mono);font-size:10px;color:var(--text-4);text-transform:uppercase;letter-spacing:.08em;">
      <li><a href={SITE} style="color:var(--text-4);text-decoration:none;">Home</a></li>
      <li style="opacity:.4;">/</li>
      <li><span style="color:var(--g);">iOS Attribution Gap Benchmark</span></li>
    </ol>
  </div>
</nav>

<main id="main-content">

<!-- HERO -->
<section class="hero bg-grid" aria-label="Shopify iOS attribution gap benchmark">
  <div class="hero-inner">
    <div class="hero-proof">
      <span class="dot"></span>
      <span class="hero-proof-txt">Maintained benchmark · Last verified {verified} · Every figure sourced</span>
    </div>

    <h1>
      The typical Shopify store loses<br />
      <span class="big-stat">{HEADLINE_LOW}–{HEADLINE_HIGH}%</span><br />
      <span class="dim">of its conversion signal to iOS.</span>
    </h1>

    <p class="hero-sub">
      Apple's App Tracking Transparency and Safari ITP block the browser signals Meta, Google and TikTok depend on.
      Synthesising published research, the average store loses an estimated <strong>{HEADLINE_LOW}–{HEADLINE_HIGH}% of purchase-conversion signal — rising toward {HEADLINE_MOBILE_HIGH}% on mobile-heavy stores.</strong>
      This page documents the sources, the method, and how to close the gap.
    </p>

    <div class="hero-ctas">
      <a href="#data" class="btn-outline" onclick="event.preventDefault();document.getElementById('data').scrollIntoView({behavior:'smooth'})">See the data</a>
      <a href="#contribute" class="btn pulse" onclick="event.preventDefault();document.getElementById('contribute').scrollIntoView({behavior:'smooth'})">Contribute your store's gap →</a>
    </div>
    <p class="hero-cta-note">Free to read and cite (CC BY 4.0). The fix is documented at <a href="/capi-shield/">CAPI Shield</a>.</p>
  </div>
</section>

<!-- HEADLINE STAT STRIP -->
<div style="background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:0 24px;">
  <div class="stat-strip" style="max-width:860px;margin:0 auto;" role="list">
    <div class="stat-cell" role="listitem"><div class="stat-v">~75%</div><div class="stat-l">iOS users opted out of tracking</div></div>
    <div class="stat-cell" role="listitem"><div class="stat-v">30–40%</div><div class="stat-l">Meta accuracy reduction</div></div>
    <div class="stat-cell" role="listitem"><div class="stat-v">74–78%</div><div class="stat-l">Shopify traffic is mobile</div></div>
    <div class="stat-cell" role="listitem"><div class="stat-v">{HEADLINE_LOW}–{HEADLINE_HIGH}%</div><div class="stat-l">Signal lost (synthesised)</div></div>
  </div>
</div>

<!-- THE DATA -->
<section class="section" id="data" aria-labelledby="data-h">
  <div class="inner">
    <div class="sec-head">
      <span class="tag tag-dim" style="margin-bottom:14px;display:inline-flex;">// the evidence · verified {verified}</span>
      <h2 id="data-h">What the published research actually shows</h2>
      <p>Six load-bearing figures, each from a named, dated, linked source. Together they bound the size of the gap.</p>
    </div>

    <div style="display:flex;flex-direction:column;gap:14px;">
      {dataPoints.map(d => (
        <div style="border:1px solid var(--border);border-radius:12px;background:var(--bg-2);padding:22px 24px;">
          <div style="display:flex;align-items:baseline;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:8px;">
            <div style="font-size:15px;font-weight:700;color:var(--text);">{d.metric}</div>
            <div style="font-family:var(--mono);font-size:22px;font-weight:800;color:var(--g);white-space:nowrap;">{d.value}</div>
          </div>
          <p style="font-size:14px;color:var(--text-3);line-height:1.7;margin:0 0 12px;">{d.detail}</p>
          <a href={d.sourceUrl} target="_blank" rel="noopener nofollow" style="font-family:var(--mono);font-size:11px;color:var(--text-4);text-decoration:none;">
            Source: {d.source} · {d.sourceDate} ↗
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- THE SYNTHESIS -->
<section class="section-alt" id="index" aria-labelledby="index-h">
  <div class="inner-md">
    <div class="sec-head">
      <span class="tag tag-dim" style="margin-bottom:14px;display:inline-flex;">// the synthesis</span>
      <h2 id="index-h">The Stack Architect Attribution Gap Index</h2>
    </div>
    <div class="body-text">
      <p>No single published source states "the Shopify attribution gap is X%." That number has to be <em>synthesised</em> — which is exactly the work this page does, and why it is citable.</p>
      <p>Combining the inputs above: roughly <strong>three-quarters of iOS users block tracking</strong>, iOS is <strong>~75% of mobile</strong>, mobile is <strong>~75% of Shopify traffic</strong>, and platform attribution accuracy on that affected traffic drops <strong>30–40%</strong> before server-side recovery. Documented store-level cases land near <strong>40% conversion loss without CAPI</strong>. Triangulating these gives a defensible working range:</p>
      <div class="big-callout">
        <div class="big-callout-num">{HEADLINE_LOW}–{HEADLINE_HIGH}%</div>
        <div class="big-callout-body">
          <p>of purchase-conversion signal lost by the <strong>typical</strong> Shopify store to iOS ATT + Safari ITP — before any server-side recovery. Stores where mobile/iOS traffic skews high (fashion, beauty, DTC impulse) trend toward <strong>{HEADLINE_MOBILE_HIGH}%</strong>.</p>
        </div>
      </div>
      <p style="font-size:13px;color:var(--text-4);">We label this a <strong>synthesis of published third-party figures</strong>, not proprietary primary data. That distinction matters: it is honest, and it is still citable, because the synthesis itself is the original contribution. As real store submissions accumulate below, we will publish a first-party figure ("based on N stores") alongside this range.</p>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- METHODOLOGY -->
<section class="section" id="methodology" aria-labelledby="method-h">
  <div class="inner-md">
    <div class="sec-head">
      <span class="tag tag-dim" style="margin-bottom:14px;display:inline-flex;">// methodology</span>
      <h2 id="method-h">How this benchmark is built and maintained</h2>
    </div>
    <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:12px;max-width:720px;margin:0 auto;">
      <li style="display:flex;gap:10px;align-items:baseline;font-size:14px;color:var(--text-2);line-height:1.6;"><span style="color:var(--g);flex-shrink:0;">→</span>Every figure in the evidence table is drawn from a named, dated, publicly accessible third-party source and linked directly. No figure is invented or un-attributed.</li>
      <li style="display:flex;gap:10px;align-items:baseline;font-size:14px;color:var(--text-2);line-height:1.6;"><span style="color:var(--g);flex-shrink:0;">→</span>The headline range is a transparent triangulation of those inputs, presented as a synthesis — explicitly not as proprietary measurement.</li>
      <li style="display:flex;gap:10px;align-items:baseline;font-size:14px;color:var(--text-2);line-height:1.6;"><span style="color:var(--g);flex-shrink:0;">→</span>The page is re-verified periodically; the "last verified" date at the top reflects the most recent check. Figures and sources are updated as newer research is published.</li>
      <li style="display:flex;gap:10px;align-items:baseline;font-size:14px;color:var(--text-2);line-height:1.6;"><span style="color:var(--g);flex-shrink:0;">→</span>Store submissions (below) are stored anonymously and in aggregate only. No store name or identifying data is published. Once the sample is large enough to be meaningful, a first-party figure is added alongside the synthesised range.</li>
      <li style="display:flex;gap:10px;align-items:baseline;font-size:14px;color:var(--text-2);line-height:1.6;"><span style="color:var(--g);flex-shrink:0;">→</span>Spot an out-of-date figure or a better source? <a href="mailto:support@stackarchitect.xyz" style="color:var(--g);">Tell us</a> — corrections are welcomed and dated.</li>
    </ul>
  </div>
</section>

<div class="divider"></div>

<!-- CONTRIBUTE (collects real data over time) -->
<section class="section-alt" id="contribute" aria-labelledby="contrib-h">
  <div class="inner-sm">
    <div class="sec-head">
      <span class="tag" style="margin-bottom:14px;display:inline-flex;">// build the data</span>
      <h2 id="contrib-h">Contribute your store's gap</h2>
      <p>Anonymous. Two numbers from your own dashboards. Helps turn this synthesis into original first-party data the whole industry can cite.</p>
    </div>

    <div id="contrib-card" style="border:1px solid var(--border);border-radius:12px;background:var(--bg-2);padding:26px;">
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:var(--text-2);margin-bottom:6px;">Conversions your ad platform reported last month</label>
          <input id="f-reported" type="number" inputmode="numeric" placeholder="e.g. 320" style="width:100%;background:var(--bg);border:1px solid var(--border-2);border-radius:8px;padding:12px 14px;color:var(--text);font-size:15px;font-family:var(--mono);" />
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:var(--text-2);margin-bottom:6px;">Actual paid orders in Shopify for the same period</label>
          <input id="f-actual" type="number" inputmode="numeric" placeholder="e.g. 470" style="width:100%;background:var(--bg);border:1px solid var(--border-2);border-radius:8px;padding:12px 14px;color:var(--text);font-size:15px;font-family:var(--mono);" />
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:var(--text-2);margin-bottom:6px;">Main ad platform</label>
          <select id="f-platform" style="width:100%;background:var(--bg);border:1px solid var(--border-2);border-radius:8px;padding:12px 14px;color:var(--text);font-size:15px;">
            {platforms.map(p => (<option value={p}>{p}</option>))}
          </select>
        </div>
        <button id="f-submit" class="btn pulse" style="width:100%;justify-content:center;">Calculate my gap &amp; contribute →</button>
        <p style="font-size:11px;color:var(--text-4);line-height:1.6;margin:0;">Stored anonymously and in aggregate. We never publish individual store data or any identifying detail. Your two numbers join the dataset that produces a future first-party benchmark.</p>
      </div>

      <div id="contrib-result" style="display:none;margin-top:20px;padding-top:20px;border-top:1px solid var(--border);">
        <div style="font-family:var(--mono);font-size:11px;color:var(--text-4);letter-spacing:.1em;margin-bottom:8px;">// your attribution gap</div>
        <div id="result-gap" style="font-family:var(--mono);font-size:40px;font-weight:800;color:var(--g);line-height:1;"></div>
        <p id="result-msg" style="font-size:14px;color:var(--text-3);line-height:1.7;margin:12px 0 0;"></p>
        <a href="/capi-shield/" class="btn btn-sm pulse" style="margin-top:16px;display:inline-flex;">Close the gap free with CAPI Shield →</a>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- CITE THIS -->
<section class="section" id="cite" aria-labelledby="cite-h">
  <div class="inner-sm">
    <div class="sec-head"><span class="tag tag-dim" style="margin-bottom:14px;display:inline-flex;">// citing this data</span><h2 id="cite-h">Cite this benchmark</h2></div>
    <div style="border:1px solid var(--border);border-radius:12px;padding:24px;background:var(--bg-2);">
      <p style="font-size:14px;color:var(--text-2);line-height:1.7;margin:0 0 14px;">Writing about iOS, ATT or Shopify conversion tracking? You're welcome to cite this benchmark. Suggested attribution:</p>
      <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:14px 16px;font-family:var(--mono);font-size:12px;color:var(--text-3);line-height:1.7;">
        The typical Shopify store loses an estimated {HEADLINE_LOW}–{HEADLINE_HIGH}% of purchase-conversion signal to iOS ATT and Safari ITP, up to {HEADLINE_MOBILE_HIGH}% on mobile-heavy stores (Stack Architect Attribution Gap Benchmark, {verified}). <span style="color:var(--text-4);">— stackarchitect.xyz/shopify-ios-attribution-gap-benchmark</span>
      </div>
      <p style="font-size:12px;color:var(--text-4);margin:14px 0 0;line-height:1.6;">Released under CC BY 4.0 — free to quote with a link. Publications wanting the full source list: every figure is linked in the evidence table above.</p>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- FAQ -->
<section class="section-alt" id="faq" aria-labelledby="faq-h">
  <div class="inner-sm">
    <div class="sec-head"><span class="tag tag-dim" style="margin-bottom:14px;display:inline-flex;">// FAQ</span><h2 id="faq-h">Common questions</h2></div>
    <div style="display:flex;flex-direction:column;gap:14px;">
      {faqs.map(f => (
        <details style="border:1px solid var(--border);border-radius:8px;padding:16px 18px;background:var(--bg-2);">
          <summary style="font-weight:600;color:var(--text);cursor:pointer;font-size:15px;">{f.q}</summary>
          <p style="margin:12px 0 0;font-size:14px;color:var(--text-3);line-height:1.7;">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- RELATED -->
<section class="section" id="related" aria-label="Related">
  <div class="inner">
    <div class="sec-head"><h2 style="font-size:20px;">Close the gap — free</h2></div>
    <div style="display:flex;flex-direction:column;gap:8px;max-width:760px;margin:0 auto;">
