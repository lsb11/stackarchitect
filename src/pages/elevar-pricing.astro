        <!-- Free -->
        <div style="border:1px solid var(--border);border-radius:10px;padding:22px;background:var(--bg);">
          <div style="font-family:var(--mono);font-size:10px;font-weight:700;color:var(--text-4);letter-spacing:.12em;margin-bottom:10px;">FREE</div>
          <div style="font-size:28px;font-weight:900;color:var(--text);margin-bottom:2px;">$0</div>
          <div style="font-size:12px;color:var(--text-4);margin-bottom:16px;">per month</div>
          <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:7px;">
            <li style="font-size:13px;color:var(--text-3);display:flex;gap:8px;align-items:baseline;"><span style="color:var(--g);flex-shrink:0;">✓</span>Browser-side pixel tracking</li>
            <li style="font-size:13px;color:var(--text-3);display:flex;gap:8px;align-items:baseline;"><span style="color:var(--g);flex-shrink:0;">✓</span>GA4 integration</li>
            <li style="font-size:13px;color:var(--text-3);display:flex;gap:8px;align-items:baseline;"><span style="color:var(--red);flex-shrink:0;">✗</span><span>No server-side CAPI</span></li>
            <li style="font-size:13px;color:var(--text-3);display:flex;gap:8px;align-items:baseline;"><span style="color:var(--red);flex-shrink:0;">✗</span><span>No iOS tracking recovery</span></li>
          </ul>
          <div style="margin-top:16px;padding:8px 12px;background:rgba(239,68,68,.08);border-radius:6px;font-size:11px;color:var(--red);font-weight:500;">Browser-only. iOS kills 35% of events.</div>
        </div>
        <!-- Starter -->
        <div style="border:2px solid rgba(0,200,100,.3);border-radius:10px;padding:22px;background:rgba(0,200,100,.03);">
          <div style="font-family:var(--mono);font-size:10px;font-weight:700;color:var(--g);letter-spacing:.12em;margin-bottom:10px;">STARTER — MOST COMMON</div>
          <div style="font-size:28px;font-weight:900;color:var(--text);margin-bottom:2px;">$50</div>
