              <div class="calc-field"><label>TikTok reported revenue £/$</label><input type="number" id="tt-revenue" placeholder="e.g. 12000" /></div>
              <div class="calc-field"><label>TikTok tracking method</label><select id="tt-track"><option value="pixel">Pixel only</option><option value="capi">Pixel + Events API</option><option value="capi_only">Events API only</option></select></div>
            </div>
          </div>
          <div>
            <div style="font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#4ade80;margin-bottom:12px;border-bottom:1px solid #1f1f1f;padding-bottom:8px;">Meta</div>
            <div class="calc-grid" style="grid-template-columns:1fr;">
              <div class="calc-field"><label>Meta ad spend (30 days) £/$</label><input type="number" id="meta-spend" placeholder="e.g. 8000" /></div>
              <div class="calc-field"><label>Meta reported revenue £/$</label><input type="number" id="meta-revenue" placeholder="e.g. 28000" /></div>
              <div class="calc-field"><label>Meta tracking method</label><select id="meta-track"><option value="pixel">Pixel only</option><option value="capi">Pixel + CAPI</option><option value="capi_only">CAPI only</option></select></div>
            </div>
          </div>
        </div>
        <button class="calc-btn" onclick="calcROAS()">CALCULATE TRUE ROAS →</button>
        <div class="calc-result" id="roas-result">
          <div class="result-grid">
            <div class="result-cell"><div class="result-label">TikTok Adjusted ROAS</div><div class="result-value" id="tt-roas">--</div><div class="result-sub">After tracking loss adjustment</div></div>
