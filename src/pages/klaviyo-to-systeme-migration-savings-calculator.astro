---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const schemas = [{"@context":"https://schema.org","@type":"WebApplication","name":"Klaviyo to Systeme Migration Savings Calculator","url":"https://stackarchitect.xyz/klaviyo-to-systeme-migration-savings-calculator/","description":"Calculate exactly how much you would save by migrating from Klaviyo to Systeme.io. Compare features, contacts, send limits, and automation capabilities side-by-side.","applicationCategory":"BusinessApplication","operatingSystem":"Any","offers":{"@type":"Offer","price":"0","priceCurrency":"GBP"},"provider":{"@type":"Organization","name":"Stack Architect","url":"https://stackarchitect.xyz"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Does Systeme.io replace all Klaviyo features?","acceptedAnswer":{"@type":"Answer","text":"For most Shopify stores using Klaviyo for welcome flows, abandoned cart, post-purchase, and broadcast emails — yes. Systeme.io's free plan covers unlimited emails, full automation sequences, segmentation, and CRM. What it lacks is Klaviyo's advanced predictive analytics, deep Shopify product feed sync for dynamic product recommendation emails, and the SMS channel. If you rely heavily on those specific features, factor that into your decision."}},{"@type":"Question","name":"How long does migration from Klaviyo to Systeme.io take?","acceptedAnswer":{"@type":"Answer","text":"The core migration — exporting contacts, importing to Systeme.io, recreating your main flows (welcome, abandoned cart, post-purchase) — takes approximately 2–4 hours for a standard store. Complex setups with many custom segments, advanced conditional logic, or large template libraries may take longer. Most stores can complete migration in a weekend."}},{"@type":"Question","name":"Will I lose my Klaviyo subscriber data when migrating?","acceptedAnswer":{"@type":"Answer","text":"No. Export your subscriber list from Klaviyo as a CSV, then import it into Systeme.io. Subscriber data including name, email, opt-in status, and custom properties migrates cleanly. Historical email engagement data (opens, clicks, revenue attributed) stays in Klaviyo and cannot be migrated, but is not required for ongoing operations."}},{"@type":"Question","name":"What is Klaviyo's current pricing for Shopify stores?","acceptedAnswer":{"@type":"Answer","text":"Klaviyo changed its billing model in February 2025. You now pay based on the number of active profiles (contacts who received at least one email in the past 90 days), not just your total list size. At 2,000 active profiles it's around $45/month; at 5,000 it's around $100/month; at 10,000 it's around $150/month. Prices increase significantly above 10,000 profiles."}},{"@type":"Question","name":"Is GetResponse a better alternative to Systeme.io?","acceptedAnswer":{"@type":"Answer","text":"GetResponse is a strong Klaviyo alternative for stores that need more advanced ecommerce integrations or prefer a more traditional email platform UX. It offers a free plan for up to 500 contacts, with paid plans from around £13/month for 1,000 contacts. Systeme.io's free plan is more generous (2,000 contacts, unlimited sends) for stores just replacing Klaviyo's core email function."}}]},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stackarchitect.xyz"},{"@type":"ListItem","position":2,"name":"Tools","item":"https://stackarchitect.xyz/tools/"},{"@type":"ListItem","position":3,"name":"Klaviyo to Systeme Migration Savings Calculator","item":"https://stackarchitect.xyz/klaviyo-to-systeme-migration-savings-calculator/"}]}];

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools' },
  { label: 'Klaviyo to Systeme.io Migration Savings Calculator — Free Email Cost Comparison' },
];
---

<Base
  title="Klaviyo to Systeme.io Migration Savings Calculator — Free Email Cost Comparison | Stack Architect"
  description="Calculate exactly how much you would save by migrating from Klaviyo to Systeme.io. Compare features, contacts, send limits, and automation capabilities side-by-side."
  canonical="https://stackarchitect.xyz/klaviyo-to-systeme-migration-savings-calculator/"
  schema={schemas}
  breadcrumb={breadcrumb}
>
  <Nav slot="header" />

  <main class="flex-1">
    <div id="reading-progress"></div>
    
<style>
  .tool-hero{padding:48px 24px 32px;background:#000;border-bottom:1px solid #1f1f1f;}
  .tool-hero-inner{max-width:860px;margin:0 auto;}
  .tool-badge{display:inline-flex;align-items:center;gap:6px;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:4px 12px;border:1px solid rgba(74,222,128,.3);color:#4ade80;background:rgba(74,222,128,.06);margin-bottom:18px;}
  .tool-badge .dot{width:6px;height:6px;border-radius:50%;background:#4ade80;animation:dp 2s infinite;}
  @keyframes dp{0%,100%{opacity:1;}50%{opacity:.3;}}
  .tool-hero h1{font-size:clamp(22px,4vw,38px);font-weight:900;color:#fff;letter-spacing:-.03em;line-height:1.05;margin-bottom:12px;}
  .tool-hero h1 .green{color:#4ade80;}
  .tool-hero-desc{font-size:14px;color:#a1a1aa;line-height:1.75;max-width:600px;margin-bottom:20px;}
  .tool-trust{display:flex;flex-wrap:wrap;gap:16px;}
  .tool-trust span{font-size:11px;color:#52525b;display:flex;align-items:center;gap:5px;}
  .tool-trust span::before{content:'✓';color:#4ade80;font-weight:700;}

  .calc-section{padding:40px 24px;background:#0a0a0a;border-bottom:1px solid #1f1f1f;}
  .calc-inner{max-width:860px;margin:0 auto;}
  .calc-card{border:1px solid #1f1f1f;background:#000;padding:32px;}
  .calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;}
  @media(max-width:600px){.calc-grid{grid-template-columns:1fr;}}
  .calc-field{display:flex;flex-direction:column;gap:6px;}
  .calc-field label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#52525b;}
  .calc-field input,.calc-field select{background:#0a0a0a;border:1px solid #1f1f1f;color:#fff;font-family:inherit;font-size:13px;padding:10px 14px;outline:none;transition:border-color .2s;width:100%;}
  .calc-field input:focus,.calc-field select:focus{border-color:#4ade80;}
  .calc-field input::placeholder{color:#3f3f46;}
  .calc-btn{width:100%;background:#4ade80;color:#000;font-family:inherit;font-size:12px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;padding:14px;border:none;cursor:pointer;transition:background .2s;margin-top:8px;}
  .calc-btn:hover{background:#22c55e;}
  .calc-result{display:none;margin-top:24px;border:1px solid #1f1f1f;background:#0a0a0a;padding:24px;}
  .calc-result.show{display:block;}
  .result-label{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#52525b;margin-bottom:6px;}
  .result-value{font-size:36px;font-weight:900;color:#4ade80;line-height:1;letter-spacing:-.03em;}
  .result-sub{font-size:12px;color:#52525b;margin-top:6px;line-height:1.6;}
  .result-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;margin-bottom:20px;}
  .result-cell{background:#000;border:1px solid #1f1f1f;padding:16px;}
  .result-insight{font-size:12px;color:#a1a1aa;line-height:1.7;border-top:1px solid #1f1f1f;padding-top:16px;margin-top:16px;}
  .result-insight strong{color:#fff;}
  .result-cta{display:inline-block;margin-top:16px;font-size:11px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;color:#000;background:#4ade80;padding:10px 20px;text-decoration:none;transition:background .2s;}
  .result-cta:hover{background:#22c55e;}
  .result-warn{border-left:3px solid #4ade80;padding-left:16px;margin-top:16px;}

  .aff-block{margin:24px 0;border:1px solid rgba(74,222,128,.2);background:rgba(74,222,128,.04);padding:20px 24px;display:flex;align-items:flex-start;justify-content:space-between;gap:20px;flex-wrap:wrap;}
  .aff-block-text{flex:1;}
  .aff-block-label{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:#52525b;margin-bottom:6px;}
  .aff-block-title{font-size:13px;font-weight:700;color:#fff;margin-bottom:4px;}
  .aff-block-desc{font-size:11px;color:#71717a;line-height:1.6;}
  .aff-block-link{flex-shrink:0;display:inline-flex;align-items:center;font-size:10px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;color:#4ade80;border:1px solid rgba(74,222,128,.4);padding:8px 16px;text-decoration:none;transition:all .2s;white-space:nowrap;}
  .aff-block-link:hover{background:#4ade80;color:#000;}
  .aff-disclosure{font-size:9px;color:#3f3f46;margin-top:8px;}

  .editorial{padding:48px 24px;background:#000;border-bottom:1px solid #1f1f1f;}
  .editorial-inner{max-width:720px;margin:0 auto;}
  .editorial h2{font-size:clamp(18px,3vw,26px);font-weight:900;color:#fff;letter-spacing:-.03em;margin:36px 0 12px;line-height:1.2;}
  .editorial h2:first-child{margin-top:0;}
  .editorial p{font-size:13px;color:#a1a1aa;line-height:1.85;margin-bottom:16px;}
  .editorial strong{color:#e4e4e7;}
  .editorial a{color:#4ade80;text-decoration:underline;}
  .editorial ul{list-style:none;padding:0;margin:0 0 16px;}
  .editorial ul li{font-size:13px;color:#a1a1aa;line-height:1.75;padding:6px 0 6px 20px;position:relative;border-bottom:1px solid #0a0a0a;}
  .editorial ul li::before{content:'→';position:absolute;left:0;color:#4ade80;font-size:11px;}

  .faq-section{padding:48px 24px;background:#0a0a0a;border-bottom:1px solid #1f1f1f;}
  .faq-inner{max-width:720px;margin:0 auto;}
  .faq-heading{font-size:clamp(18px,3vw,24px);font-weight:900;color:#fff;letter-spacing:-.03em;margin-bottom:28px;}
  .faq-item{border:1px solid #1f1f1f;margin-bottom:8px;background:#000;}
  .faq-item summary{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;list-style:none;font-size:12px;font-weight:700;color:#a1a1aa;letter-spacing:.02em;gap:16px;}
  .faq-item summary::-webkit-details-marker{display:none;}
  .faq-item[open] summary{color:#fff;border-bottom:1px solid #1f1f1f;}
  .faq-item[open]{border-color:rgba(74,222,128,.3);}
  .faq-arrow{flex-shrink:0;font-size:10px;color:#52525b;transition:transform .2s;}
  .faq-item[open] .faq-arrow{transform:rotate(180deg);color:#4ade80;}
  .faq-answer{padding:16px 20px;font-size:12px;color:#71717a;line-height:1.8;}
  .faq-answer a{color:#4ade80;}

  .cta-strip-tool{padding:40px 24px;background:#0a0a0a;border-top:1px solid #1f1f1f;text-align:center;}
  .cta-strip-tool h2{font-size:clamp(16px,3vw,22px);font-weight:900;color:#fff;letter-spacing:-.03em;margin-bottom:8px;}
  .cta-strip-tool p{font-size:12px;color:#52525b;margin-bottom:20px;}
  .cta-strip-tool a{display:inline-block;background:#4ade80;color:#000;font-size:11px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;padding:14px 28px;text-decoration:none;transition:background .2s;}
  .cta-strip-tool a:hover{background:#22c55e;}
  #reading-progress{position:fixed;top:0;left:0;width:0;height:2px;background:#4ade80;z-index:9999;transition:width .1s;}
</style>


  <section class="tool-hero">
    <div class="tool-hero-inner">
      <div class="tool-badge"><span class="dot"></span>FREE TOOL // Email Cost Comparison</div>
      <h1>Klaviyo to Systeme.io <span class="green">Savings Calculator</span></h1>
      <p class="tool-hero-desc">Enter your current Klaviyo costs and contact count. See exactly what you would pay on Systeme.io (spoiler: often £0/month) and how much you would save annually.</p>
      <div class="tool-trust">
        <span>Based on current Klaviyo pricing</span>
        <span>2026 data</span>
        <span>Annual savings projection included</span>
      </div>
    </div>
  </section>

  <section class="calc-section">
    <div class="calc-inner">
      <div class="calc-card">
        <div style="font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#52525b;margin-bottom:20px;">// MIGRATION_SAVINGS_CALCULATOR</div>
        <div class="calc-grid">
          <div class="calc-field">
            <label>Current monthly Klaviyo cost £/$</label>
            <input type="number" id="kl-cost" placeholder="e.g. 150" />
          </div>
          <div class="calc-field">
            <label>Active email subscribers</label>
            <input type="number" id="kl-subs" placeholder="e.g. 4500" />
          </div>
          <div class="calc-field">
            <label>Monthly email sends</label>
            <input type="number" id="kl-sends" placeholder="e.g. 25000" />
          </div>
          <div class="calc-field">
            <label>Do you use Klaviyo SMS?</label>
            <select id="kl-sms">
              <option value="0">No</option>
              <option value="1">Yes — this may affect migration</option>
            </select>
          </div>
          <div class="calc-field">
            <label>Number of active automations / flows</label>
            <select id="kl-flows">
              <option value="3">1–5 (basic: welcome, cart, post-purchase)</option>
              <option value="10">6–15 (intermediate)</option>
              <option value="20">15+ (advanced)</option>
            </select>
          </div>
          <div class="calc-field">
            <label>Klaviyo contract type</label>
            <select id="kl-contract">
              <option value="monthly">Month-to-month</option>
              <option value="annual">Annual contract</option>
            </select>
          </div>
        </div>
        <button class="calc-btn" onclick="calcKlaviyo()">CALCULATE MY SAVINGS →</button>
        <div class="calc-result" id="kl-result">
          <div class="result-grid">
            <div class="result-cell">
              <div class="result-label">Monthly Saving</div>
              <div class="result-value" id="kl-monthly">--</div>
              <div class="result-sub">vs current Klaviyo cost</div>
            </div>
            <div class="result-cell">
              <div class="result-label">Annual Saving</div>
              <div class="result-value" id="kl-annual" style="font-size:28px;">--</div>
              <div class="result-sub">12-month projection</div>
            </div>
            <div class="result-cell">
              <div class="result-label">Systeme.io Plan</div>
              <div class="result-value" id="kl-plan" style="font-size:18px;color:#4ade80;">--</div>
              <div class="result-sub" id="kl-plan-detail">--</div>
            </div>
          </div>
          <div class="result-insight" id="kl-insight"></div>
        </div>
      </div>

      
  <div class="aff-block">
    <div class="aff-block-text">
      <div class="aff-block-label">Recommended tool</div>
      <div class="aff-block-title">Systeme.io — Free Plan (2,000 contacts, unlimited emails)</div>
      <div class="aff-block-desc">Full email marketing, automation sequences, funnels, CRM, and affiliate management. Permanently free up to 2,000 contacts. No credit card required.</div>
    </div>
    <div>
      <a href="/go/systeme" target="_blank" rel="noopener sponsored" class="aff-block-link">Start Free on Systeme.io →</a>
      <div class="aff-disclosure">Affiliate link — costs you nothing extra</div>
    </div>
  </div>

      
  <div class="aff-block">
    <div class="aff-block-text">
      <div class="aff-block-label">Recommended tool</div>
      <div class="aff-block-title">GetResponse — Free Trial Available</div>
      <div class="aff-block-desc">Strong ecommerce integrations, landing pages, and email automation. Better for stores wanting a traditional platform UX. Free 30-day trial, no credit card.</div>
    </div>
    <div>
      <a href="/go/getresponse" target="_blank" rel="noopener sponsored" class="aff-block-link">Try GetResponse Free →</a>
      <div class="aff-disclosure">Affiliate link — costs you nothing extra</div>
    </div>
  </div>
    </div>
  </section>

  <section class="editorial">
    <div class="editorial-inner">
      <h2>Why Shopify Stores Are Leaving Klaviyo in 2026</h2>
      <p>Klaviyo changed its pricing model in February 2025, moving from a list-size-based model to one based on <strong>active profiles</strong> — contacts who received at least one email in the previous 90 days. For stores with clean, engaged lists this made little difference. For stores with growing lists but varied send frequency, costs increased significantly and unpredictably.</p>
      <p>The deeper issue is that Klaviyo is priced for enterprises that use its full feature set. Most Shopify stores use three to five flows: welcome series, abandoned cart, post-purchase follow-up, and occasional broadcast emails. These are standard automation features available on every email platform — and on <a href="/go/systeme" target="_blank" rel="noopener sponsored">Systeme.io</a>'s completely free plan for up to 2,000 contacts.</p>

      <h2>What Systeme.io Includes on the Free Plan</h2>
      <ul>
        <li>2,000 email contacts — unlimited email sends with no daily or monthly cap</li>
        <li>Full automation sequences with conditional branching and time delays</li>
        <li>Sales funnels and landing pages (3 on free plan)</li>
        <li>Integrated CRM for contact management and tagging</li>
        <li>Affiliate programme management</li>
        <li>No Systeme.io branding on emails (unlike some free plans)</li>
      </ul>
      <p>For stores over 2,000 contacts, Systeme.io's Startup plan at £24/month includes 5,000 contacts and unlimited everything else. This compares to Klaviyo's pricing of approximately £100/month at 5,000 active profiles — a saving of £76/month (£912/year) for the same contact count.</p>

      <h2>Migration Checklist: Klaviyo to Systeme.io</h2>
      <ul>
        <li>Export your Klaviyo subscriber list as CSV (include all custom properties)</li>
        <li>Export your Klaviyo flow structures as documentation (screenshots or notes)</li>
        <li>Import subscribers to Systeme.io and verify tags/segments map correctly</li>
        <li>Recreate your 3–5 core flows in Systeme.io's visual automation builder</li>
        <li>Update your Shopify checkout to point new subscribers to Systeme.io</li>
        <li>Run both platforms in parallel for 2 weeks before cancelling Klaviyo</li>
      </ul>
    </div>
  </section>

  
  <section class="faq-section" itemscope itemtype="https://schema.org/FAQPage">
    <div class="faq-inner">
      <h2 class="faq-heading">// COMMON_QUESTIONS</h2>
      
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">Does Systeme.io replace all Klaviyo features?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">For most Shopify stores using Klaviyo for welcome flows, abandoned cart, post-purchase, and broadcast emails — yes. Systeme.io's free plan covers unlimited emails, full automation sequences, segmentation, and CRM. What it lacks is Klaviyo's advanced predictive analytics, deep Shopify product feed sync for dynamic product recommendation emails, and the SMS channel. If you rely heavily on those specific features, factor that into your decision.</p>
      </div>
    </details>
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">How long does migration from Klaviyo to Systeme.io take?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">The core migration — exporting contacts, importing to Systeme.io, recreating your main flows (welcome, abandoned cart, post-purchase) — takes approximately 2–4 hours for a standard store. Complex setups with many custom segments, advanced conditional logic, or large template libraries may take longer. Most stores can complete migration in a weekend.</p>
      </div>
    </details>
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">Will I lose my Klaviyo subscriber data when migrating?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">No. Export your subscriber list from Klaviyo as a CSV, then import it into Systeme.io. Subscriber data including name, email, opt-in status, and custom properties migrates cleanly. Historical email engagement data (opens, clicks, revenue attributed) stays in Klaviyo and cannot be migrated, but is not required for ongoing operations.</p>
      </div>
    </details>
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">What is Klaviyo's current pricing for Shopify stores?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">Klaviyo changed its billing model in February 2025. You now pay based on the number of active profiles (contacts who received at least one email in the past 90 days), not just your total list size. At 2,000 active profiles it's around $45/month; at 5,000 it's around $100/month; at 10,000 it's around $150/month. Prices increase significantly above 10,000 profiles.</p>
      </div>
    </details>
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">Is GetResponse a better alternative to Systeme.io?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">GetResponse is a strong Klaviyo alternative for stores that need more advanced ecommerce integrations or prefer a more traditional email platform UX. It offers a free plan for up to 500 contacts, with paid plans from around £13/month for 1,000 contacts. Systeme.io's free plan is more generous (2,000 contacts, unlimited sends) for stores just replacing Klaviyo's core email function.</p>
      </div>
    </details>
    </div>
  </section>

  <section class="cta-strip-tool">
    <h2>Start Your Free Systeme.io Account</h2>
    <p>2,000 contacts. Unlimited emails. Full automation. $0/month forever.</p>
    <a href="/go/systeme" target="_blank" rel="noopener sponsored">Start Free on Systeme.io →</a>
  </section>
  </main>

  <Footer />
</Base>

<script>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      bar.style.width = Math.min(pct, 100) + '%';
    }, { passive: true });
  }


  function calcKlaviyo() {
    const cost = parseFloat(document.getElementById('kl-cost').value) || 0;
    const subs = parseInt(document.getElementById('kl-subs').value) || 0;
    const sms = document.getElementById('kl-sms').value === '1';

    let systemePlan, systemeMonthly, planDetail;
    if (subs <= 2000) { systemePlan = 'FREE'; systemeMonthly = 0; planDetail = 'Unlimited sends · 2,000 contacts'; }
    else if (subs <= 5000) { systemePlan = 'STARTUP'; systemeMonthly = 24; planDetail = 'Unlimited sends · 5,000 contacts'; }
    else if (subs <= 10000) { systemePlan = 'WEBINAR'; systemeMonthly = 47; planDetail = 'Unlimited sends · 10,000 contacts'; }
    else { systemePlan = 'UNLIMITED'; systemeMonthly = 97; planDetail = 'Unlimited sends · Unlimited contacts'; }

    const monthly = cost - systemeMonthly;
    const annual = monthly * 12;

    document.getElementById('kl-monthly').textContent = '£' + monthly.toLocaleString() + '/mo';
    document.getElementById('kl-monthly').style.color = monthly > 0 ? '#4ade80' : '#f87171';
    document.getElementById('kl-annual').textContent = '£' + annual.toLocaleString() + '/yr';
    document.getElementById('kl-annual').style.color = annual > 0 ? '#4ade80' : '#f87171';
    document.getElementById('kl-plan').textContent = systemePlan;
    document.getElementById('kl-plan-detail').textContent = planDetail;

    let insight = '';
    if (sms) insight += '<strong>Note on SMS:</strong> Systeme.io does not include SMS. Factor in a separate SMS tool cost if SMS is core to your flows. ';
    if (monthly > 200) insight += '<strong>High saving opportunity.</strong> At this Klaviyo spend level, migration should be a priority. Your annual saving of £' + annual.toLocaleString() + ' covers significant other business investments. ';
    else if (monthly > 0) insight += 'Solid saving for migrating the core email function. Most Shopify stores can complete migration in a weekend without losing capability. ';
    else insight += 'At your contact volume, a paid Systeme.io plan is needed — but it likely still represents a saving vs Klaviyo. Verify current Klaviyo pricing for your active profile count. ';
    insight += '<a href="/replace-klaviyo-free">Full migration guide →</a>';
    document.getElementById('kl-insight').innerHTML = insight;
    document.getElementById('kl-result').classList.add('show');
  }
  
</script>
