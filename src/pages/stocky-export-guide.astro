---
import Nav from '../components/Nav.astro';
import RelatedGuides from '../components/RelatedGuides.astro';
import Footer from '../components/Footer.astro';

/**
 * STOCKY EXPORT GUIDE — /stocky-export-guide/
 * Primary: "how to export stocky data" / "stocky data export"
 * Cluster spoke for: /stocky-shutdown/ (hub), /stocky-swap/, /stocky-migration-checklist/
 * Intent: urgent, irreversible how-to. Lowest competition in the cluster.
 */

const SITE_URL = "https://stackarchitect.xyz";
const PAGE_URL = `${SITE_URL}/stocky-export-guide/`;
const SHUTDOWN_DATE = "August 31, 2026";
const DATE_PUBLISHED = "2026-06-25";
const DATE_MODIFIED = "2026-06-25";
const MAKE_AFFILIATE = "/go/make";
const LINKEDIN = "https://www.linkedin.com/company/stack-architect-xyz/";

const SEO = {
  title: "How to Export Stocky Data Before August 31, 2026 — Step-by-Step | Stack Architect",
  description: "Export Stocky purchase orders, stocktakes and cost data to CSV before the August 31 2026 shutdown. Suppliers can't be exported — here's the workaround. Takes 15 minutes.",
  canonical: PAGE_URL,
  ogTitle: "How to Export Stocky Data Before August 31, 2026",
  ogDescription: "Export Stocky purchase orders, stocktakes and cost data to CSV before the shutdown. Suppliers need a manual workaround. 15 minutes.",
  ogImage: `${SITE_URL}/og.png`
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${PAGE_URL}#webpage`,
      url: PAGE_URL,
      name: SEO.title,
      description: SEO.description,
      datePublished: DATE_PUBLISHED,
      dateModified: DATE_MODIFIED,
      inLanguage: "en-GB",
      isPartOf: { "@id": `${SITE_URL}/#website` },
      author: { "@id": `${SITE_URL}/#luke` },
      speakable: { "@type": "SpeakableSpecification", cssSelector: [".speakable-answer", ".faq-ans-s p"] },
      about: [
        { "@type": "Thing", name: "Stocky data export" },
        { "@type": "Thing", name: "Shopify Stocky shutdown 2026" }
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      url: SITE_URL,
      name: "Stack Architect",
      publisher: { "@id": `${SITE_URL}/#organization` }
    },
    {
      "@type": "Organization",
      "@id": `${SITE_URL}/#organization`,
      name: "Stack Architect",
      url: SITE_URL,
      logo: { "@type": "ImageObject", url: `${SITE_URL}/icon-512.png`, width: 512, height: 512 },
      sameAs: [LINKEDIN]
    },
    {
      "@type": "Person",
      "@id": `${SITE_URL}/#luke`,
      name: "Luke",
      jobTitle: "Shopify Automation Specialist",
      url: `${SITE_URL}/about/`,
      sameAs: ["https://www.linkedin.com/in/luke-stackarchitect", LINKEDIN],
      worksFor: { "@id": `${SITE_URL}/#organization` }
    },
    {
      "@type": "HowTo",
      "@id": `${PAGE_URL}#howto`,
      name: "How to export your Stocky data before the August 31 2026 shutdown",
      description: "Export Stocky purchase orders, stocktakes and cost data to CSV, and document suppliers manually, before Stocky shuts down on August 31 2026.",
      totalTime: "PT20M",
      estimatedCost: { "@type": "MonetaryAmount", currency: "USD", value: "0" },
      step: [
        { "@type": "HowToStep", position: 1, name: "Export purchase orders", text: "In Shopify admin go to Apps, Stocky, Reports. Select the purchase order report, set the date range to your full history, and export as CSV.", url: `${PAGE_URL}#step-1` },
        { "@type": "HowToStep", position: 2, name: "Export stocktakes and cost data", text: "From the same Reports dropdown, export stocktake history, the inventory adjustment log, and ABC cost data, each as a separate CSV.", url: `${PAGE_URL}#step-2` },
        { "@type": "HowToStep", position: 3, name: "Document suppliers manually", text: "Suppliers cannot be exported from Stocky. Screenshot each supplier's details or transcribe name, contact, lead time, MOQ and payment terms into a spreadsheet.", url: `${PAGE_URL}#step-3` },
        { "@type": "HowToStep", position: 4, name: "Store the backup", text: "Save all CSVs and screenshots in one dated cloud folder, and set a calendar reminder for August 1 2026 as a final check.", url: `${PAGE_URL}#step-4` }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${PAGE_URL}#faq`,
      mainEntity: [
        { "@type": "Question", name: "Can I export Stocky suppliers to CSV?", acceptedAnswer: { "@type": "Answer", text: "No. Stocky has no supplier export function. Supplier names, contacts, lead times and minimum order quantities must be recreated manually before August 31, 2026 — screenshot them or transcribe them into a spreadsheet." } },
        { "@type": "Question", name: "Where is the export option in Stocky?", acceptedAnswer: { "@type": "Answer", text: "In your Shopify admin, go to Apps, then Stocky, then the Reports dropdown. Each report — purchase orders, stocktakes, adjustments, cost data — exports separately as CSV. There is no single export-everything button." } },
        { "@type": "Question", name: "Will I be able to export Stocky data after August 31, 2026?", acceptedAnswer: { "@type": "Answer", text: "Shopify provides read-only access for an unspecified limited period after shutdown, but the Stocky APIs stop on August 31, 2026 and no export tooling is guaranteed. Export everything before the deadline rather than relying on post-shutdown access." } },
        { "@type": "Question", name: "Does Stocky data move to Shopify automatically?", acceptedAnswer: { "@type": "Answer", text: "No. Shopify has confirmed historical Stocky data such as purchase orders and stocktakes does not migrate into Shopify Admin automatically. Manual CSV export is the only way to keep it." } },
        { "@type": "Question", name: "How long does exporting Stocky data take?", acceptedAnswer: { "@type": "Answer", text: "About 15 minutes for the CSV exports, plus 5 to 20 minutes to document suppliers manually depending on how many you have." } }
      ]
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL },
        { "@type": "ListItem", position: 2, name: "Stocky Shutdown", item: `${SITE_URL}/stocky-shutdown/` },
        { "@type": "ListItem", position: 3, name: "Stocky Export Guide", item: PAGE_URL }
      ]
    }
  ]
};
