const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I fix Shopify Meta ROAS dropping in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Three changes converged in Q1 2026 to break Meta tracking: iOS 26's Link Tracking Protection, Shopify's January 13 pixel default switching to Optimized mode, and Meta's algorithm shift. Fix: switch App Pixel to Always On in Settings → Customer Events, set Meta data sharing to Maximum, and implement server-side CAPI via Make.com. Most stores recover 20–40% of missing conversions within 7–14 days."
      }
    },
    {
      "@type": "Question",
      "name": "What replaces Shopify Stocky after it shuts down August 31 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Stocky Swap is a free Make.com webhook that automatically logs every Shopify order to a Google Sheet you own entirely — no vendor lock-in, no monthly fees. It deploys in 4 minutes and works on every Shopify plan. Shopify Stocky was removed from the App Store February 2, 2026 and stops functioning entirely August 31, 2026."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best free Klaviyo alternative for Shopify in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Systeme.io provides 2,000 contacts and unlimited email sends permanently at $0/month — plus sales funnels, CRM, course hosting, and affiliate management that Klaviyo never included. For stores over 2,000 contacts, GetResponse starts at $19/month vs Klaviyo's $100/month at 5,000 contacts."
      }
    },
    {
      "@type": "Question",
      "name": "How does TikTok Events API work with Shopify?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "TikTok's Events API sends CompletePayment events (not 'Purchase' — this is the critical naming detail) server-to-server via Make.com, bypassing iOS restrictions. This achieves EMQ scores of 6–8 and replaces WeltPixel ($39/mo) at $0. You cannot change pixel mode after creation, so verify before starting."
      }
    },
    {
      "@type": "Question",
      "name": "Is Make.com free for Shopify automation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Make.com's free plan gives 1,000 operations per month — 10× more than Zapier's 100 free tasks — and includes webhook triggers and HTTP modules. One Shopify Order Payment webhook can branch to Meta CAPI, Google Enhanced Conversions, TikTok Events API, Google Sheets inventory, and P&L simultaneously. Most stores under 250 orders/month run the complete stack on the free plan indefinitely."
      }
    },
    {
      "@type": "Question",
      "name": "Can Tidio replace Gorgias for Shopify customer support?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Tidio's Lyro AI resolves approximately 70% of inbound Shopify support queries automatically — order status, shipping, FAQs — without human intervention. Gorgias costs $80–$400/month. Tidio's free tier covers 50 Lyro AI conversations per month, sufficient for most stores under $40k/month GMV. Setup takes 30 minutes with no code required."
      }
    },
    {
      "@type": "Question",
      "name": "What are agentic storefronts on Shopify?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Shopify Agentic Storefronts enable your products to be purchased directly inside ChatGPT, Google AI Mode, and Microsoft Copilot without leaving those AI interfaces. Currently US-only and in early access. Preparation steps including the Knowledge Base App, product data optimisation, and FAQ schema apply to all stores immediately and improve AI search discoverability."
      }
    },
    {
      "@type": "Question",
      "name": "How do I track Shopify profit and loss for free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Make.com webhook auto-populates revenue, COGS, Shopify transaction fees, and net profit into a Google Sheet you own for every order within 60 seconds of purchase. Every P&L app charges $25–$299/month. If you already have CAPI Shield or Stocky Swap deployed, this adds a single branch to your existing scenario — setup takes under 3 minutes."
      }
    },
    {
      "@type": "Question",
      "name": "How do I fix iOS conversion tracking on Shopify in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iOS updates have progressively broken browser-based tracking since 2021. The cumulative effect is 30–60% of purchase events missing from Meta and Google. The fix is server-side tracking via Conversions API: purchase events sent server-to-server bypass iOS restrictions entirely. Switch your Shopify App Pixel to Always On mode first (5 minutes), then implement CAPI Shield for full server-side coverage (2–3 hours). Most stores recover 20–40% of lost events."
      }
    },
    {
      "@type": "Question",
      "name": "Which Shopify apps are a waste of money in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most commonly overpaid-for Shopify apps in 2026 are: Elevar and Triple Whale for server-side tracking (replaced free by CAPI Shield), Zapier for automation (replaced free by Make.com with 10× more operations), Klaviyo for email under 2,000 contacts (replaced free by Systeme.io), P&L apps like BeProfit and TrueProfit (replaced free by Shopify P&L Auto), and TikTok tracking apps like WeltPixel (replaced free by TikTok Events API via Make.com)."
      }
    }
  ]
};

