  const header = document.querySelector('.product-terminal-bar');
  if (!header) return;
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 50);
  }, { passive: true });
  document.querySelectorAll('.dropdown > .product-link').forEach(link => {
    link.addEventListener('click', e => {
      if (window.innerWidth <= 850) {
        e.preventDefault();
        link.parentElement.classList.toggle('active');
      }
    });
  });
})();

// ── STICKY BAR ──
(function () {
  const bar = document.getElementById('gp-sticky');
  if (!bar) return;
  window.addEventListener('scroll', () => {
    bar.classList.toggle('visible', window.scrollY > 400);
  }, { passive: true });
})();

// ── COUNTDOWN TO AUGUST 31 2026 ──
(function () {
  function tick() {
    const t = new Date('2026-08-31T23:59:59Z') - new Date();
    const cdD = document.getElementById('cd-d');
    const cdH = document.getElementById('cd-h');
    const cdM = document.getElementById('cd-m');
    if (!cdD) return;
    if (t <= 0) { cdD.textContent = '0'; cdH.textContent = '00'; cdM.textContent = '00'; return; }
    cdD.textContent = Math.floor(t / 864e5);
    cdH.textContent = String(Math.floor(t % 864e5 / 36e5)).padStart(2, '0');
    cdM.textContent = String(Math.floor(t % 36e5 / 6e4)).padStart(2, '0');
  }
  tick();
  setInterval(tick, 30000);
})();

// ── EMAIL CAPTURE ──
document.getElementById('guides-submit')?.addEventListener('click', function () {
  const el = document.getElementById('guides-email');
  const email = (el?.value || '').trim();
  if (!email || !email.includes('@')) {
    if (el) el.style.borderColor = 'var(--red)';
    return;
  }
  el.style.borderColor = '';
  fetch('https://api.systeme.io/api/contacts', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-API-Key': 'kdsymoc8fwhwwc604vrofp4jt0rb5bjosmzs5dqd4r8suo4avx4xsik4ixqvwgo4' },
    body: JSON.stringify({ email, tags: [{ name: 'guides-capture' }] })
  }).catch(() => {});
  if (typeof gtag !== 'undefined') {
    gtag('event', 'guides_email_capture', { event_category: 'conversion', event_label: 'guides_hub' });
  }
  el.value = '';
  el.placeholder = '✓ Guides on their way — check your inbox';
  el.disabled = true;
});

// ── FOOTER COPYRIGHT YEAR ──
(function () {
  const cr = document.getElementById('guides-copyright');
  if (cr) cr.textContent = `© ${new Date().getFullYear()} STACK_ARCHITECT // SHOPIFY_AUTOMATION_GUIDES`;
})();

// ── ANALYTICS ──
(function () {
  const affiliates = [
    { pattern: '/go/make',        label: 'make_com' },
    { pattern: '/go/systeme',     label: 'systeme_io' },
    { pattern: '/go/tidio',       label: 'tidio' },
    { pattern: '/go/gorgias',     label: 'gorgias' },
    { pattern: '/go/getresponse', label: 'getresponse' },
    { pattern: '/go/beehiiv',     label: 'beehiiv' },
    { pattern: '/go/workspace',   label: 'google_workspace' },
  ];

  document.addEventListener('click', e => {
    const el = e.target.closest('a[href]');
    if (!el) return;
    const href = el.getAttribute('href') || '';
    const text = (el.innerText || '').trim().substring(0, 60);

    affiliates.forEach(a => {
      if (href.includes(a.pattern)) {
        typeof gtag !== 'undefined' && gtag('event', 'affiliate_click', { event_category: 'affiliate', event_label: a.label, link_text: text, source_page: 'shopify-automation-guides' });
      }
    });

    if (href.includes('/blog/')) {
      const slug = href.split('/blog/')[1] || href;
      typeof gtag !== 'undefined' && gtag('event', 'guide_click', { event_category: 'content_navigation', event_label: slug.substring(0, 80), link_text: text });
    }
  });

  const fired = {};
  window.addEventListener('scroll', () => {
    const pct = Math.round((window.scrollY / Math.max(1, document.documentElement.scrollHeight - window.innerHeight)) * 100);
    [25, 50, 75, 90, 100].forEach(t => {
      if (pct >= t && !fired[t]) {
        fired[t] = true;
        typeof gtag !== 'undefined' && gtag('event', 'scroll_depth', { event_category: 'engagement', event_label: t + '%' });
      }
    });
  }, { passive: true });

  if ('IntersectionObserver' in window) {
    ['tracking', 'tiktok', 'inventory', 'email', 'profit', 'make', 'workflow', 'faq', 'ai', 'support'].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      const obs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) {
          typeof gtag !== 'undefined' && gtag('event', 'section_viewed', { event_category: 'engagement', event_label: id });
          obs.disconnect();
        }
      }, { threshold: 0.2 });
      obs.observe(el);
    });
  }
})();
</script>
