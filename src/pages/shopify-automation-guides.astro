    .dd-urgent-tag {
      font-family: var(--mono); font-size: 8px; font-weight: 700; color: #fcd34d;
      background: rgba(252,211,77,.08); border: 1px solid rgba(252,211,77,.25);
      padding: 1px 5px; border-radius: 2px; margin-left: 6px; flex-shrink: 0;
    }
    .dd-divider { border-top: 1px solid #1e293b; margin-top: 6px; padding-top: 6px; }
    .dd-divider-soft { height: 1px; background: #1e293b; margin: 6px 16px; list-style: none; }
    .dd-all { color: #00a854 !important; font-weight: 800; }
    .dropdown-desc { font-family: var(--mono); font-size: 8px; color: #475569; display: block; margin-top: 2px; }

    .terminal-cta { display: flex; align-items: center; margin-left: 16px; flex-shrink: 0; }
    .cta-node {
      font-family: var(--mono); font-size: 10px; font-weight: 900; color: #00a854;
      text-decoration: none; text-transform: uppercase; padding: 7px 14px;
      border: 1px solid #00a854; border-radius: 4px;
      transition: all .3s cubic-bezier(.175,.885,.32,1.275);
      display: inline-block; white-space: nowrap;
    }
    .cta-node:hover { background: #00a854; color: #fff; box-shadow: 0 6px 20px rgba(0,168,84,.5); transform: scale(1.05); }

    /* ════════════ HERO ════════════ */
    .gp-hero {
      padding: 88px 24px 72px; text-align: center; position: relative;
      overflow: hidden; border-bottom: 1px solid var(--border);
    }
    .gp-hero::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse 90% 55% at 50% -10%, rgba(0,200,100,.1) 0%, transparent 65%);
      pointer-events: none;
    }
    .gp-hero-tag {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .22em; text-transform: uppercase; color: var(--g);
      margin-bottom: 24px; display: block;
    }
    .gp-hero h1 {
      font-family: var(--sans); font-weight: 900; font-size: clamp(32px,6vw,68px);
      letter-spacing: -.045em; line-height: .93; color: var(--text); margin-bottom: 28px;
    }
    .gp-hero h1 em { color: var(--g); font-style: normal; }
    .gp-hero h1 small {
      display: block; font-size: clamp(15px,2.2vw,22px); letter-spacing: -.02em;
      color: var(--text-3); font-weight: 600; margin-top: 12px; line-height: 1.4;
    }
    .gp-hero-sub { font-size: 16px; color: var(--text-3); max-width: 640px; margin: 0 auto 40px; line-height: 1.8; }
    .gp-hero-sub strong { color: var(--text-2); }

    .gp-stats {
      display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
      gap: 0; margin-bottom: 40px; border: 1px solid var(--border);
      border-radius: var(--radius); width: fit-content; margin-left: auto; margin-right: auto;
      overflow: hidden; background: rgba(255,255,255,.02);
    }
    .gp-stat { padding: 14px 26px; text-align: center; border-right: 1px solid var(--border); }
    .gp-stat:last-child { border-right: none; }
    .gs-val { font-family: var(--mono); font-size: 20px; font-weight: 700; color: var(--g); display: block; line-height: 1; }
    .gs-label { font-size: 11px; color: var(--text-4); margin-top: 4px; display: block; }

    .gp-hero-cta { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }

    /* ════════════ STICKY BAR ════════════ */
    .gp-sticky {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 999;
      background: rgba(2,6,23,.92); backdrop-filter: blur(20px);
      border-top: 1px solid var(--border); padding: 12px 24px;
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      transform: translateY(100%); transition: transform .3s ease;
    }
    .gp-sticky.visible { transform: translateY(0); }
    .gp-sticky-text { font-size: 13px; color: var(--text-2); font-weight: 600; }
    .gp-sticky-text span { color: var(--g); }

    /* ════════════ ALERT BANNERS ════════════ */
    .gp-roas-crisis { max-width: 1100px; margin: 28px auto 0; padding: 0 24px; }
    .gp-roas-inner {
      background: var(--red-bg); border: 2px solid var(--red-border);
      border-radius: var(--radius); padding: 20px 24px; display: flex;
      align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
    }
    .grc-left { display: flex; align-items: center; gap: 14px; }
    .grc-icon { font-size: 24px; flex-shrink: 0; }
    .grc-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 3px; line-height: 1.2; }
    .grc-desc { font-size: 13px; color: var(--text-3); line-height: 1.4; }
    .grc-desc strong { color: var(--red); }

    .gp-urgent { max-width: 1100px; margin: 16px auto 0; padding: 0 24px; }
    .gp-urgent-inner {
      background: rgba(252,211,77,.05); border: 2px solid rgba(252,211,77,.3);
      border-radius: var(--radius); padding: 20px 24px; display: flex;
      align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
    }
    .gpu-left { display: flex; align-items: center; gap: 14px; }
    .gpu-icon { font-size: 24px; flex-shrink: 0; }
    .gpu-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 3px; line-height: 1.2; }
    .gpu-desc { font-size: 13px; color: var(--text-3); line-height: 1.4; }
    .gpu-cd { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
    .gpu-cd-unit { text-align: center; }
    .gpu-cd-val { font-family: var(--mono); font-size: clamp(18px,3vw,26px); font-weight: 700; color: var(--amber); line-height: 1; display: block; }
    .gpu-cd-label { font-size: 10px; color: var(--text-4); font-family: var(--mono); }
    .gpu-cd-sep { font-family: var(--mono); font-size: 18px; font-weight: 700; color: var(--amber); padding-bottom: 12px; }

    .gp-banner { max-width: 1100px; margin: 16px auto 0; padding: 0 24px; }
    .gp-banner-inner {
      background: rgba(0,200,100,.04); border: 1.5px solid rgba(0,200,100,.18);
      border-radius: var(--radius); padding: 14px 20px; display: flex;
      align-items: center; gap: 14px; flex-wrap: wrap;
    }
    .gp-banner-badge {
      font-family: var(--mono); font-size: 9px; font-weight: 700;
      letter-spacing: .14em; text-transform: uppercase; color: var(--g);
      background: var(--g-bg); border: 1px solid var(--g-border);
      padding: 3px 10px; border-radius: 3px; white-space: nowrap; flex-shrink: 0;
    }
    .gp-banner-text { font-size: 13px; color: var(--text-2); flex: 1; line-height: 1.5; }
    .gp-banner-text strong { color: var(--text); }

    /* ════════════ FEATURED GRID ════════════ */
    .gp-featured { padding: 48px 24px 0; max-width: 1100px; margin: 0 auto; }
    .gp-section-label {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase; color: var(--g);
      margin-bottom: 20px; display: block;
    }
    .gp-featured-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
    .gp-featured-grid .gfc:first-child { grid-column: span 2; }

    .gfc {
      background: var(--bg-3); border: 1.5px solid var(--border); border-radius: var(--radius);
      padding: 22px; display: flex; flex-direction: column; gap: 10px;
      text-decoration: none; position: relative; overflow: hidden;
      transition: border-color .2s, transform .2s;
    }
    .gfc:hover { border-color: var(--g-border); transform: translateY(-3px); }
    .gfc.gfc-ai { border-color: var(--ai-border); background: var(--ai-bg); }
    .gfc.gfc-ai:hover { border-color: rgba(167,139,250,.4); }
    .gfc.gfc-roas { border-color: var(--red-border); background: var(--red-bg); }
    .gfc.gfc-roas:hover { border-color: rgba(252,129,129,.4); }
    .gfc.gfc-tiktok { border-color: var(--tiktok-border); background: rgba(255,0,80,.03); }
    .gfc.gfc-email { border-color: var(--purple-border); background: var(--purple-bg); }
    .gfc.gfc-profit { border-color: var(--profit-border); background: var(--profit-bg); }
    .gfc.gfc-support { border-color: var(--support-border); background: var(--support-bg); }
    .gfc.gfc-support:hover { border-color: rgba(52,211,153,.4); }
    .gfc.gfc-make { border-color: var(--make-border); background: var(--make-bg); }
    .gfc.gfc-make:hover { border-color: rgba(109,40,217,.4); }

    .gfc-badge {
      position: absolute; top: 12px; right: 12px; font-family: var(--mono);
      font-size: 9px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
      padding: 3px 9px; border-radius: 3px;
    }
    .gfc-badge.new { color: var(--g); background: var(--g-bg); border: 1px solid var(--g-border); }
    .gfc-badge.hot { color: var(--tiktok); background: var(--tiktok-bg); border: 1px solid var(--tiktok-border); }
    .gfc-badge.save { color: var(--purple); background: var(--purple-bg); border: 1px solid var(--purple-border); }
    .gfc-badge.ai { color: var(--ai); background: var(--ai-bg); border: 1px solid var(--ai-border); }
    .gfc-badge.alert { color: var(--red); background: var(--red-bg); border: 1px solid var(--red-border); }
    .gfc-badge.support { color: var(--support); background: var(--support-bg); border: 1px solid var(--support-border); }
    .gfc-badge.make { color: var(--make); background: var(--make-bg); border: 1px solid var(--make-border); }

    .gfc-tag {
      font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 6px;
      padding: 3px 10px; border-radius: 3px; width: fit-content;
    }
    .tag-tracking { background: var(--g-bg); border: 1px solid var(--g-border); color: var(--g); }
    .tag-tiktok { background: var(--tiktok-bg); border: 1px solid var(--tiktok-border); color: var(--tiktok); }
    .tag-inventory { background: var(--sky-bg); border: 1px solid var(--sky-border); color: var(--sky); }
    .tag-email { background: var(--purple-bg); border: 1px solid var(--purple-border); color: var(--purple); }
    .tag-profit { background: var(--profit-bg); border: 1px solid var(--profit-border); color: var(--profit); }
    .tag-ai { background: var(--ai-bg); border: 1px solid var(--ai-border); color: var(--ai); }
    .tag-roas { background: var(--red-bg); border: 1px solid var(--red-border); color: var(--red); }
    .tag-support { background: var(--support-bg); border: 1px solid var(--support-border); color: var(--support); }
    .tag-make { background: var(--make-bg); border: 1px solid var(--make-border); color: var(--make); }
    .tag-workspace { background: var(--workspace-bg); border: 1px solid var(--workspace-border); color: var(--workspace); }

    .gfc-title { font-size: 15px; font-weight: 700; color: var(--text); line-height: 1.25; letter-spacing: -.01em; }
    .gfc:first-child .gfc-title { font-size: 17px; }
    .gfc-desc { font-size: 13px; color: var(--text-3); line-height: 1.65; flex: 1; }
    .gfc-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 4px; }
    .gfc-read { font-family: var(--mono); font-size: 11px; color: var(--text-4); }
    .gfc-arrow { font-family: var(--mono); font-size: 12px; color: var(--g); font-weight: 700; }

    /* ════════════ CLUSTER SECTIONS ════════════ */
    .gp-cluster {
      max-width: 1100px; margin: 0 auto; padding: 52px 24px;
      border-top: 1px solid var(--border);
    }
    .gp-cluster.cluster-ai { background: linear-gradient(180deg,rgba(167,139,250,.03) 0%,transparent 140px); }
    .gp-cluster.cluster-support { background: linear-gradient(180deg,rgba(52,211,153,.03) 0%,transparent 140px); }
    .gp-cluster.cluster-tiktok { background: linear-gradient(180deg,rgba(255,0,80,.025) 0%,transparent 120px); }
    .gp-cluster.cluster-email { background: linear-gradient(180deg,rgba(196,181,253,.025) 0%,transparent 120px); }
    .gp-cluster.cluster-profit { background: linear-gradient(180deg,rgba(251,146,60,.025) 0%,transparent 120px); }
    .gp-cluster.cluster-inventory { background: linear-gradient(180deg,rgba(125,211,252,.025) 0%,transparent 120px); }
    .gp-cluster.cluster-make { background: linear-gradient(180deg,rgba(109,40,217,.03) 0%,transparent 140px); }

    .gpc-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; flex-wrap: wrap; margin-bottom: 24px; }
    .gpc-left { flex: 1; min-width: 240px; }
    .gpc-label {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase; margin-bottom: 10px; display: block;
    }
    .label-tracking { color: var(--g); }
    .label-tiktok { color: var(--tiktok); }
    .label-inventory { color: var(--sky); }
    .label-email { color: var(--purple); }
    .label-profit { color: var(--profit); }
    .label-workflow { color: var(--text-4); }
    .label-ai { color: var(--ai); }
    .label-support { color: var(--support); }
    .label-make { color: var(--make); }
    .label-workspace { color: var(--workspace); }

    .gpc-title {
      font-family: var(--sans); font-weight: 900; font-size: clamp(19px,2.8vw,27px);
      letter-spacing: -.03em; color: var(--text); line-height: 1.1; margin-bottom: 10px;
    }
    .gpc-desc { font-size: 14px; color: var(--text-3); line-height: 1.75; max-width: 560px; }
    .gpc-cta { flex-shrink: 0; align-self: flex-start; margin-top: 4px; }

    .gpc-prose {
      background: rgba(255,255,255,.015); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 20px 24px; margin-bottom: 20px;
    }
    .gpc-prose p { font-size: 14px; color: var(--text-3); line-height: 1.8; margin-bottom: 10px; }
    .gpc-prose p:last-child { margin-bottom: 0; }
    .gpc-prose strong { color: var(--text-2); }
    .gpc-prose a { color: var(--g); text-decoration: underline; }

    /* ════════════ LIST ITEMS ════════════ */
    .gp-list { display: flex; flex-direction: column; gap: 2px; }
    .gp-item {
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; padding: 14px 17px; border-radius: 8px; border: 1px solid transparent;
      text-decoration: none; transition: background .15s, border-color .15s;
    }
    .gp-item:hover { background: rgba(0,200,100,.04); border-color: var(--g-border); }
    .gp-item.gpi-hl { background: rgba(255,255,255,.02); border-color: rgba(255,255,255,.06); }
    .gp-item.gpi-new { background: rgba(0,200,100,.03); border-color: rgba(0,200,100,.15); }
    .gp-item.gpi-ai { background: var(--ai-bg); border-color: var(--ai-border); }
    .gp-item.gpi-ai:hover { background: rgba(167,139,250,.12); }
    .gp-item.gpi-support { background: var(--support-bg); border-color: var(--support-border); }
    .gp-item.gpi-support:hover { background: rgba(52,211,153,.12); }
    .gp-item.gpi-tiktok { background: var(--tiktok-bg); border-color: var(--tiktok-border); }
    .gp-item.gpi-tiktok:hover { background: rgba(255,0,80,.1); }
    .gp-item.gpi-email { background: var(--purple-bg); border-color: var(--purple-border); }
    .gp-item.gpi-profit { background: var(--profit-bg); border-color: var(--profit-border); }
    .gp-item.gpi-roas { background: var(--red-bg); border-color: var(--red-border); }
    .gp-item.gpi-roas:hover { background: rgba(252,129,129,.12); }
    .gp-item.gpi-make { background: var(--make-bg); border-color: var(--make-border); }
    .gp-item.gpi-make:hover { background: rgba(109,40,217,.12); }
    .gp-item.gpi-workspace { background: var(--workspace-bg); border-color: var(--workspace-border); }
    .gp-item.gpi-workspace:hover { background: rgba(26,115,232,.12); }

    .gpi-left { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; }
    .gpi-arrow { font-family: var(--mono); font-size: 12px; color: var(--g); font-weight: 700; flex-shrink: 0; }
    .gpi-arrow.arr-tiktok { color: var(--tiktok); }
    .gpi-arrow.arr-email { color: var(--purple); }
    .gpi-arrow.arr-profit { color: var(--profit); }
    .gpi-arrow.arr-sky { color: var(--sky); }
    .gpi-arrow.arr-ai { color: var(--ai); }
    .gpi-arrow.arr-red { color: var(--red); }
    .gpi-arrow.arr-support { color: var(--support); }
    .gpi-arrow.arr-make { color: var(--make); }
    .gpi-arrow.arr-workspace { color: var(--workspace); }
    .gpi-content { min-width: 0; }
    .gpi-title { font-size: 14px; font-weight: 600; color: var(--text-2); margin-bottom: 3px; line-height: 1.3; }
    .gp-item:hover .gpi-title { color: var(--text); }
    .gpi-desc { font-size: 12px; color: var(--text-4); line-height: 1.4; }
    .gpi-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .gpi-pill {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .08em; padding: 2px 8px; border-radius: 3px; white-space: nowrap;
    }
    .pill-new { color: var(--g); background: var(--g-bg); border: 1px solid var(--g-border); }
    .pill-urgent { color: var(--amber); background: rgba(252,211,77,.07); border: 1px solid rgba(252,211,77,.25); }
    .pill-level { color: var(--text-4); background: rgba(255,255,255,.03); border: 1px solid var(--border); }
    .pill-ai { color: var(--ai); background: var(--ai-bg); border: 1px solid var(--ai-border); }
    .pill-alert { color: var(--red); background: var(--red-bg); border: 1px solid var(--red-border); }
    .pill-support { color: var(--support); background: var(--support-bg); border: 1px solid var(--support-border); }
    .pill-make { color: var(--make); background: var(--make-bg); border: 1px solid var(--make-border); }
    .pill-workspace { color: var(--workspace); background: var(--workspace-bg); border: 1px solid var(--workspace-border); }
    .gpi-time { font-family: var(--mono); font-size: 10px; color: var(--text-4); }

    /* ════════════ BUTTONS ════════════ */
    .btn-g {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: var(--sans); font-size: 13px; font-weight: 700; text-decoration: none;
      padding: 11px 20px; border-radius: 6px; background: var(--g); color: var(--text-inv);
      white-space: nowrap; transition: background .2s, transform .15s;
      min-height: 40px; cursor: pointer; border: none;
    }
    .btn-g:hover { background: #00e070; transform: translateY(-2px); }
    .btn-g.btn-lg { font-size: 14px; padding: 13px 26px; min-height: 46px; }
    .btn-outline {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: var(--sans); font-size: 13px; font-weight: 600; text-decoration: none;
      padding: 10px 18px; border-radius: 6px; border: 1.5px solid var(--border-2);
      background: transparent; color: var(--text-2); white-space: nowrap;
      transition: border-color .2s, color .2s; min-height: 40px;
    }
    .btn-outline:hover { border-color: var(--g); color: var(--g); }
    .btn-outline.btn-lg { font-size: 14px; padding: 12px 22px; min-height: 46px; }
    .btn-red {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: var(--sans); font-size: 13px; font-weight: 700; text-decoration: none;
      padding: 11px 20px; border-radius: 6px; background: var(--red); color: #020617;
      white-space: nowrap; transition: background .2s, transform .15s; min-height: 40px;
    }
    .btn-red:hover { background: #fca5a5; transform: translateY(-2px); }
    .btn-support {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: var(--sans); font-size: 13px; font-weight: 700; text-decoration: none;
      padding: 11px 20px; border-radius: 6px; background: var(--support); color: #020617;
      white-space: nowrap; transition: background .2s, transform .15s; min-height: 40px;
    }
    .btn-support:hover { background: #6ee7b7; transform: translateY(-2px); }
    .btn-make {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: var(--sans); font-size: 13px; font-weight: 700; text-decoration: none;
      padding: 11px 20px; border-radius: 6px; background: var(--make); color: #fff;
      white-space: nowrap; transition: background .2s, transform .15s; min-height: 40px;
    }
    .btn-make:hover { background: #7c3aed; transform: translateY(-2px); }
    .btn-workspace {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: var(--sans); font-size: 13px; font-weight: 700; text-decoration: none;
      padding: 11px 20px; border-radius: 6px; background: var(--workspace); color: #fff;
      white-space: nowrap; transition: background .2s, transform .15s; min-height: 40px;
    }
    .btn-workspace:hover { background: #1557b0; transform: translateY(-2px); }

    /* ════════════ EMAIL CAPTURE ════════════ */
    .gp-capture { max-width: 1100px; margin: 0 auto; padding: 0 24px 40px; }
    .gpc-inner {
      background: var(--g-bg); border: 1.5px solid var(--g-border);
      border-radius: var(--radius); padding: 28px 32px; display: flex;
      align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap;
    }
    .gpc-text h3 { font-size: 17px; font-weight: 700; color: var(--text); margin-bottom: 6px; line-height: 1.2; }
    .gpc-text p { font-size: 14px; color: var(--text-3); margin: 0; }
    .gpc-form { display: flex; gap: 10px; flex-wrap: wrap; }
    .gpc-input {
