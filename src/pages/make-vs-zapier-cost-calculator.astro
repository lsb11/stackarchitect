  .editorial{padding:48px 24px;background:#000;border-bottom:1px solid #1f1f1f;}
  .editorial-inner{max-width:720px;margin:0 auto;}
  .editorial h2{font-size:clamp(18px,3vw,26px);font-weight:900;color:#fff;letter-spacing:-.03em;margin:36px 0 12px;line-height:1.2;}
  .editorial h2:first-child{margin-top:0;}
  .editorial p{font-size:13px;color:#a1a1aa;line-height:1.85;margin-bottom:16px;}
  .editorial strong{color:#e4e4e7;}
  .editorial a{color:#4ade80;text-decoration:underline;}
  .editorial ul{list-style:none;padding:0;margin:0 0 16px;}
  .editorial ul li{font-size:13px;color:#a1a1aa;line-height:1.75;padding:6px 0 6px 20px;position:relative;border-bottom:1px solid #0a0a0a;}
  .editorial ul li::before{content:'→';position:absolute;left:0;color:#4ade80;font-size:11px;}

  .faq-section{padding:48px 24px;background:#0a0a0a;border-bottom:1px solid #1f1f1f;}
  .faq-inner{max-width:720px;margin:0 auto;}
  .faq-heading{font-size:clamp(18px,3vw,24px);font-weight:900;color:#fff;letter-spacing:-.03em;margin-bottom:28px;}
  .faq-item{border:1px solid #1f1f1f;margin-bottom:8px;background:#000;}
  .faq-item summary{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;list-style:none;font-size:12px;font-weight:700;color:#a1a1aa;letter-spacing:.02em;gap:16px;}
  .faq-item summary::-webkit-details-marker{display:none;}
  .faq-item[open] summary{color:#fff;border-bottom:1px solid #1f1f1f;}
  .faq-item[open]{border-color:rgba(74,222,128,.3);}
  .faq-arrow{flex-shrink:0;font-size:10px;color:#52525b;transition:transform .2s;}
  .faq-item[open] .faq-arrow{transform:rotate(180deg);color:#4ade80;}
  .faq-answer{padding:16px 20px;font-size:12px;color:#71717a;line-height:1.8;}
  .faq-answer a{color:#4ade80;}

  .cta-strip-tool{padding:40px 24px;background:#0a0a0a;border-top:1px solid #1f1f1f;text-align:center;}
  .cta-strip-tool h2{font-size:clamp(16px,3vw,22px);font-weight:900;color:#fff;letter-spacing:-.03em;margin-bottom:8px;}
  .cta-strip-tool p{font-size:12px;color:#52525b;margin-bottom:20px;}
  .cta-strip-tool a{display:inline-block;background:#4ade80;color:#000;font-size:11px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;padding:14px 28px;text-decoration:none;transition:background .2s;}
  .cta-strip-tool a:hover{background:#22c55e;}
  #reading-progress{position:fixed;top:0;left:0;width:0;height:2px;background:#4ade80;z-index:9999;transition:width .1s;}
</style>


  <section class="tool-hero">
    <div class="tool-hero-inner">
      <div class="tool-badge"><span class="dot"></span>FREE TOOL // Automation Cost Comparison</div>
      <h1>Make.com vs Zapier <span class="green">Cost Calculator</span></h1>
      <p class="tool-hero-desc">Enter your automation volume and see the exact monthly cost difference between Make.com and Zapier. Calculate your annual saving from switching.</p>
      <div class="tool-trust">
        <span>2026 pricing</span>
        <span>Operations vs tasks explained</span>
        <span>Annual saving projection</span>
      </div>
    </div>
  </section>

  <section class="calc-section">
    <div class="calc-inner">
      <div class="calc-card">
        <div style="font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#52525b;margin-bottom:20px;">// AUTOMATION_COST_CALCULATOR</div>
        <div class="calc-grid">
          <div class="calc-field">
            <label>Monthly automation runs (workflow executions)</label>
            <input type="number" id="mz-runs" placeholder="e.g. 500" />
          </div>
          <div class="calc-field">
            <label>Average steps per workflow</label>
            <select id="mz-steps">
              <option value="2">1–3 steps (simple trigger → action)</option>
              <option value="5">4–6 steps (intermediate)</option>
              <option value="9">7–12 steps (complex)</option>
              <option value="15">12+ steps (advanced)</option>
            </select>
          </div>
          <div class="calc-field">
            <label>Current platform</label>
            <select id="mz-current">
              <option value="zapier">Zapier</option>
              <option value="make">Make.com</option>
              <option value="neither">Neither (evaluating)</option>
            </select>
          </div>
          <div class="calc-field">
            <label>Current monthly cost £/$</label>
            <input type="number" id="mz-cost" placeholder="e.g. 49" />
          </div>
        </div>
        <button class="calc-btn" onclick="calcMakeZapier()">COMPARE PLATFORM COSTS →</button>
        <div class="calc-result" id="mz-result">
          <div class="result-grid">
            <div class="result-cell"><div class="result-label">Make.com Monthly Cost</div><div class="result-value" id="mz-make">--</div><div class="result-sub" id="mz-make-plan">--</div></div>
            <div class="result-cell"><div class="result-label">Zapier Monthly Cost</div><div class="result-value" id="mz-zapier" style="font-size:28px;color:#f87171;">--</div><div class="result-sub" id="mz-zapier-plan">--</div></div>
            <div class="result-cell"><div class="result-label">Monthly Saving (Make)</div><div class="result-value" id="mz-saving" style="font-size:28px;">--</div><div class="result-sub">Annual: <span id="mz-annual">--</span></div></div>
          </div>
          <div class="result-insight" id="mz-insight"></div>
        </div>
      </div>

      
  <div class="aff-block">
    <div class="aff-block-text">
      <div class="aff-block-label">Recommended tool</div>
      <div class="aff-block-title">Make.com — 1,000 free operations/month</div>
      <div class="aff-block-desc">Free tier includes unlimited scenarios, all core integrations, Shopify webhooks, Google Sheets, Meta CAPI, TikTok Events API, and more. No credit card required.</div>
    </div>
    <div>
      <a href="https://www.make.com/en/register?pc=techie123" target="_blank" rel="noopener sponsored" class="aff-block-link">Start Free on Make.com →</a>
      <div class="aff-disclosure">Affiliate link — costs you nothing extra</div>
    </div>
  </div>
    </div>
  </section>

  <section class="editorial">
    <div class="editorial-inner">
      <h2>Make.com vs Zapier: Which Is Right for Shopify Stores?</h2>
      <p>Both platforms connect Shopify to other apps and automate workflows without code. The difference is in pricing model, operation limits, and capability ceiling. For Shopify stores specifically, Make.com wins on nearly every dimension: more generous free tier, lower paid tier pricing, and significantly more powerful data transformation for complex webhook handling.</p>

      <h2>The Free Tier Difference</h2>
      <p>This is the most significant practical difference for small and growing stores. Make.com's free tier includes 1,000 operations per month — enough for a store processing 200–400 orders/month with standard webhook routing. Zapier's free tier offers only 100 tasks per month — barely enough for testing. A Shopify store processing just 50 orders/month with a 3-step Zap consumes 150 tasks, exceeding Zapier's free limit entirely.</p>

      <h2>Scenario Builder vs Zap Editor</h2>
      <p>Make.com uses a visual canvas where you build scenarios by dragging and connecting modules. This allows for complex branching logic, iterators, aggregators, and multi-path routing that Zapier's linear Zap structure cannot handle. For the specific workflows used in the <a href="/">$0 Automation Stack</a> — routing Shopify order data to Meta CAPI, TikTok Events API, and Google Sheets simultaneously — Make.com's multi-path routing is essential and not replicable in Zapier without multiple separate Zaps.</p>
    </div>
  </section>

  
  <section class="faq-section" itemscope itemtype="https://schema.org/FAQPage">
    <div class="faq-inner">
      <h2 class="faq-heading">// COMMON_QUESTIONS</h2>
      
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">Is Make.com genuinely free for Shopify automation?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">Make.com's free tier includes 1,000 operations per month with unlimited scenarios and all core integrations. For a Shopify store processing under 500 orders per month with basic webhook routing (each order webhook = 1–3 operations depending on complexity), the free tier is sufficient. Above 500 orders/month or with complex multi-step scenarios, the Core plan at £9/month handles up to 10,000 operations.</p>
      </div>
    </details>
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">What is the difference between Make.com operations and Zapier tasks?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">These are equivalent concepts but counted differently. Zapier counts each "task" as one action step in a Zap — a 3-step Zap counts as 3 tasks per run. Make.com counts each "operation" as one step execution — a 5-module scenario counts as 5 operations per run. Both platforms count each step, not each workflow run. Make.com's free tier (1,000 ops) is significantly more generous than Zapier's (100 tasks).</p>
      </div>
    </details>
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">Can Make.com do everything Zapier can for Shopify?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">For Shopify-specific workflows, yes. Make.com has native Shopify modules for orders, products, customers, and inventory. It handles webhooks (including Shopify webhooks), HTTP requests to any API, Google Sheets, Meta CAPI, TikTok Events API, email services, and hundreds of other apps. The visual scenario builder is more powerful than Zapier's for complex conditional logic and data transformation.</p>
      </div>
    </details>
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">Is Zapier better than Make.com for non-technical users?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">Zapier is often considered simpler for very basic linear automations (A triggers B). Make.com's visual canvas is slightly steeper to learn initially but significantly more powerful for multi-step, branching, or iterative workflows. For Shopify store owners doing anything more complex than a single-step automation, Make.com's visual builder becomes an advantage once the learning curve is overcome.</p>
      </div>
    </details>
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">How do I migrate from Zapier to Make.com?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">List all active Zaps and document what each does (trigger, actions, filters). Recreate each in Make.com as a scenario. Test with sample data before activating. Then deactivate the Zapier version. The process takes roughly 30–60 minutes per complex Zap. Simple single-action Zaps migrate in 5–10 minutes each. Once migrated, cancel your Zapier subscription from the billing settings.</p>
      </div>
    </details>
    </div>
  </section>

  <section class="cta-strip-tool">
    <h2>Start Free on Make.com</h2>
    <p>1,000 operations/month. All integrations. No credit card.</p>
    <a href="https://www.make.com/en/register?pc=techie123" target="_blank" rel="noopener sponsored">Start Free on Make.com →</a>
  </section>
  </main>

  <Footer />
</Base>

<script>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      bar.style.width = Math.min(pct, 100) + '%';
    }, { passive: true });
  }


  function calcMakeZapier() {
    const runs = parseInt(document.getElementById('mz-runs').value) || 0;
    const steps = parseInt(document.getElementById('mz-steps').value);
    const currentCost = parseFloat(document.getElementById('mz-cost').value) || 0;

    const ops = runs * steps;

    // Make.com pricing (GBP approx)
    let makeCost, makePlan;
    if (ops <= 1000) { makeCost = 0; makePlan = 'Free tier'; }
    else if (ops <= 10000) { makeCost = 9; makePlan = 'Core — 10k ops'; }
    else if (ops <= 40000) { makeCost = 16; makePlan = 'Pro — 40k ops'; }
    else if (ops <= 150000) { makeCost = 29; makePlan = 'Teams — 150k ops'; }
    else { makeCost = 99; makePlan = 'Enterprise'; }

    // Zapier pricing (GBP approx)
    let zapierCost, zapierPlan;
    if (ops <= 100) { zapierCost = 0; zapierPlan = 'Free tier'; }
    else if (ops <= 750) { zapierCost = 17; zapierPlan = 'Starter — 750 tasks'; }
    else if (ops <= 2000) { zapierCost = 44; zapierPlan = 'Professional — 2k tasks'; }
    else if (ops <= 50000) { zapierCost = 89; zapierPlan = 'Team — 50k tasks'; }
    else { zapierCost = 299; zapierPlan = 'Company'; }

    const saving = zapierCost - makeCost;

    document.getElementById('mz-make').textContent = makeCost === 0 ? 'FREE' : '£' + makeCost + '/mo';
    document.getElementById('mz-make').style.color = '#4ade80';
    document.getElementById('mz-make-plan').textContent = makePlan + ' (' + ops.toLocaleString() + ' ops needed)';
    document.getElementById('mz-zapier').textContent = zapierCost === 0 ? 'FREE' : '£' + zapierCost + '/mo';
    document.getElementById('mz-zapier-plan').textContent = zapierPlan;
    document.getElementById('mz-saving').textContent = saving > 0 ? '£' + saving + '/mo' : '£0';
    document.getElementById('mz-saving').style.color = saving > 0 ? '#4ade80' : '#52525b';
    document.getElementById('mz-annual').textContent = saving > 0 ? '£' + (saving*12).toLocaleString() : '£0';

    let insight = saving > 0
      ? '<strong>Switch to Make.com saves £' + saving + '/month</strong> (£' + (saving*12) + '/year) at your automation volume. Make.com also handles the multi-path routing required for Shopify CAPI, TikTok Events API, and Google Sheets simultaneously — which Zapier cannot do in a single workflow.'
      : 'At this volume both platforms are in a similar price bracket. Make.com\'s advantage is in capability — complex multi-path scenarios, data transformation, and the ability to run the full $0 Shopify automation stack in a single scenario.';
    document.getElementById('mz-insight').innerHTML = insight;
    document.getElementById('mz-result').classList.add('show');
  }
  
</script>
