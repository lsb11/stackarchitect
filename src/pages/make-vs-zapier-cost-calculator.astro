  .tool-trust span{font-size:11px;color:#52525b;display:flex;align-items:center;gap:5px;}
  .tool-trust span::before{content:'✓';color:#4ade80;font-weight:700;}

  .calc-section{padding:40px 24px;background:#0a0a0a;border-bottom:1px solid #1f1f1f;}
  .calc-inner{max-width:860px;margin:0 auto;}
  .calc-card{border:1px solid #1f1f1f;background:#000;padding:32px;}
  .calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;}
  @media(max-width:600px){.calc-grid{grid-template-columns:1fr;}}
  .calc-field{display:flex;flex-direction:column;gap:6px;}
  .calc-field label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#52525b;}
  .calc-field input,.calc-field select{background:#0a0a0a;border:1px solid #1f1f1f;color:#fff;font-family:inherit;font-size:13px;padding:10px 14px;outline:none;transition:border-color .2s;width:100%;}
  .calc-field input:focus,.calc-field select:focus{border-color:#4ade80;}
  .calc-field input::placeholder{color:#3f3f46;}
  .calc-btn{width:100%;background:#4ade80;color:#000;font-family:inherit;font-size:12px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;padding:14px;border:none;cursor:pointer;transition:background .2s;margin-top:8px;}
  .calc-btn:hover{background:#22c55e;}
  .calc-result{display:none;margin-top:24px;border:1px solid #1f1f1f;background:#0a0a0a;padding:24px;}
  .calc-result.show{display:block;}
  .result-label{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#52525b;margin-bottom:6px;}
  .result-value{font-size:36px;font-weight:900;color:#4ade80;line-height:1;letter-spacing:-.03em;}
  .result-sub{font-size:12px;color:#52525b;margin-top:6px;line-height:1.6;}
  .result-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;margin-bottom:20px;}
