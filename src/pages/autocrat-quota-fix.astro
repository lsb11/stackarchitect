.error-detail{font-size:13px;color:var(--text-3);line-height:1.55;}
.error-detail strong{color:var(--text-2);}
/* Flow grid */
.flow-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:32px;}
