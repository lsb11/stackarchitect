---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label: 'Tools' },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'WebPage',
        '@id': 'https://stackarchitect.xyz/tools#webpage',
        'url': 'https://stackarchitect.xyz/tools',
        'name': 'Free Shopify Automation Tools & Calculators 2026 — Replace Paid Apps at $0',
        'headline': 'The Complete Free Shopify Automation Tool Stack — No Monthly Fees',
        'description': 'Free Shopify automation tools and calculators that replace paid apps. CAPI Shield, Stocky Swap, plus 15 free diagnostic calculators. $0 forever — no subscriptions.',
        'inLanguage': 'en-GB',
        'dateModified': '2026-04-11',
        'isPartOf': { '@id': 'https://stackarchitect.xyz/#website' },
        'breadcrumb': {
          '@type': 'BreadcrumbList',
          'itemListElement': [
            { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://stackarchitect.xyz' },
            { '@type': 'ListItem', 'position': 2, 'name': 'Tools', 'item': 'https://stackarchitect.xyz/tools' }
          ]
        }
      },
      {
        '@type': 'ItemList',
        'name': 'Free Shopify Automation Tools & Calculators',
        'numberOfItems': 21,
        'itemListElement': [
          { '@type': 'ListItem', 'position': 1, 'name': 'CAPI Shield', 'url': 'https://stackarchitect.xyz/capi-shield' },
          { '@type': 'ListItem', 'position': 2, 'name': 'Stocky Swap', 'url': 'https://stackarchitect.xyz/stocky-swap' },
          { '@type': 'ListItem', 'position': 3, 'name': 'Autocrat Quota Fix', 'url': 'https://stackarchitect.xyz/autocrat-quota-fix' },
          { '@type': 'ListItem', 'position': 4, 'name': 'Shopify Automation Scanner', 'url': 'https://stackarchitect.xyz/shopify-automation-scanner' },
          { '@type': 'ListItem', 'position': 5, 'name': 'App Cost Calculator', 'url': 'https://stackarchitect.xyz/shopify-app-cost-calculator' },
          { '@type': 'ListItem', 'position': 6, 'name': 'Meta EMQ Score Estimator', 'url': 'https://stackarchitect.xyz/meta-emq-score-estimator' },
          { '@type': 'ListItem', 'position': 7, 'name': 'Shopify vs Meta Attribution Gap Calculator', 'url': 'https://stackarchitect.xyz/shopify-vs-meta-attribution-gap-calculator' },
          { '@type': 'ListItem', 'position': 8, 'name': 'Klaviyo Migration Savings Calculator', 'url': 'https://stackarchitect.xyz/klaviyo-to-systeme-migration-savings-calculator' },
          { '@type': 'ListItem', 'position': 9, 'name': 'Stocky Migration Risk Scorer', 'url': 'https://stackarchitect.xyz/stocky-migration-risk-scorer' },
          { '@type': 'ListItem', 'position': 10, 'name': 'Shopify P&L Leak Finder', 'url': 'https://stackarchitect.xyz/shopify-profit-loss-leak-finder' },
          { '@type': 'ListItem', 'position': 11, 'name': 'Shopify Plan Upgrade Break-Even Calculator', 'url': 'https://stackarchitect.xyz/shopify-plan-upgrade-break-even-calculator' },
          { '@type': 'ListItem', 'position': 12, 'name': 'TikTok vs Meta ROAS Bridge Calculator', 'url': 'https://stackarchitect.xyz/tiktok-vs-meta-roas-bridge-calculator' },
          { '@type': 'ListItem', 'position': 13, 'name': 'Make vs Zapier Cost Calculator', 'url': 'https://stackarchitect.xyz/make-vs-zapier-cost-calculator' },
          { '@type': 'ListItem', 'position': 14, 'name': 'Shopify App Stack Kill or Keep Auditor', 'url': 'https://stackarchitect.xyz/shopify-app-stack-kill-or-keep-auditor' },
          { '@type': 'ListItem', 'position': 15, 'name': 'Agentic Storefront Readiness Checker', 'url': 'https://stackarchitect.xyz/shopify-agentic-storefront-readiness-checker' },
          { '@type': 'ListItem', 'position': 16, 'name': 'Shopify Shipping Margin Calculator', 'url': 'https://stackarchitect.xyz/shopify-shipping-margin-calculator' },
          { '@type': 'ListItem', 'position': 17, 'name': 'GA4 vs Shopify Revenue Reconciler', 'url': 'https://stackarchitect.xyz/ga4-vs-shopify-revenue-reconciler' },
          { '@type': 'ListItem', 'position': 18, 'name': 'Shopify Influencer Gifting ROI Calculator', 'url': 'https://stackarchitect.xyz/shopify-influencer-gifting-roi-calculator' },
          { '@type': 'ListItem', 'position': 19, 'name': 'Shopify Plus Break-Even Revenue Calculator', 'url': 'https://stackarchitect.xyz/shopify-plus-break-even-revenue-calculator' },
          { '@type': 'ListItem', 'position': 20, 'name': 'Autocrat vs Native Google Sheets Speed Calculator', 'url': 'https://stackarchitect.xyz/autocrat-vs-native-google-sheets-speed-calculator' },
          { '@type': 'ListItem', 'position': 21, 'name': 'Ultimate Shopify Automation Guide', 'url': 'https://stackarchitect.xyz/ultimate-shopify-automation-guide' },
        ]
      },
      {
        '@type': 'FAQPage',
        'mainEntity': [
          { '@type': 'Question', 'name': 'What free Shopify automation tools does Stack Architect offer?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Stack Architect offers six free deployment tools — CAPI Shield for server-side conversion tracking, Stocky Swap for inventory management replacing the Stocky app, Autocrat Quota Fix for Google Apps Script errors, a Shopify Automation Scanner, a Shopify App Cost Calculator, and the Ultimate Shopify Automation Guide — plus 15 free diagnostic calculators. All tools are permanently free.' } },
          { '@type': 'Question', 'name': 'What are the free Shopify calculators and diagnostic tools?', 'acceptedAnswer': { '@type': 'Answer', 'text': "Stack Architect's 15 free diagnostic calculators cover: Meta EMQ Score Estimator, Attribution Gap Calculator, Klaviyo Migration Savings Calculator, Stocky Migration Risk Scorer, P&L Leak Finder, Shopify Plan Upgrade Break-Even Calculator, TikTok vs Meta ROAS Bridge Calculator, Make vs Zapier Cost Calculator, App Stack Kill or Keep Auditor, Agentic Storefront Readiness Checker, Shipping Margin Calculator, GA4 vs Shopify Revenue Reconciler, Influencer Gifting ROI Calculator, Shopify Plus Break-Even Calculator, and Autocrat vs Native Sheets Speed Calculator. All free at stackarchitect.xyz — no signup required." } },
          { '@type': 'Question', 'name': 'Is Make.com really free for Shopify automation?', 'acceptedAnswer': { '@type': 'Answer', 'text': "Yes. Make.com's free plan includes 1,000 operations per month — enough to handle automation for most Shopify stores. All Stack Architect tools are built to run within the free plan limits. There are no hidden costs." } },
          { '@type': 'Question', 'name': 'What paid Shopify apps can I replace for free?', 'acceptedAnswer': { '@type': 'Answer', 'text': "Stack Architect's free tools replace: Klaviyo and Mailchimp (replaced by Systeme.io), Triple Whale and Elevar (replaced by CAPI Shield), Stocky and Inventory Planner (replaced by Stocky Swap), Zapier (replaced by Make.com), and document generation tools. Average saving: $1,428/year per store." } },
        ]
      }
    ]
  }
];
---

<div id="reading-progress" style="position:fixed;top:0;left:0;width:0;height:2px;background:#4ade80;z-index:9999;transition:width .1s;"></div>

<Base
  title="Free Shopify Tools & Calculators 2026 — 21 Free Tools"
  description="21 free Shopify tools — 6 app replacements, 15 diagnostic calculators. CAPI Shield, Stocky Swap, EMQ estimator, attribution gap calculator, Klaviyo savings calc. $0 forever, no signup."
  canonical="https://stackarchitect.xyz/tools"
  schema={schemas}
  breadcrumb={breadcrumb}
>
  <Nav slot="header" />

  <main class="flex-1">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=JetBrains+Mono:wght@500;800&display=swap');
      :root {
        --green:#00a854;--green-dim:rgba(0,168,84,.12);--green-border:rgba(0,168,84,.3);
        --red:#ff4d4d;--obsidian:#020617;--slate:#0f172a;
        --inter:'Inter',sans-serif;--mono:'JetBrains Mono',monospace;
      }
      *{box-sizing:border-box;}
      .hub-page{background:var(--obsidian);color:#f8fafc;font-family:var(--inter);line-height:1.6;overflow-x:hidden;}
      .hub-hero{background:radial-gradient(ellipse at 50% -10%,#1e293b 0%,var(--obsidian) 65%);padding:90px 40px 80px;text-align:center;position:relative;overflow:hidden;}
      .hub-hero::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(0,168,84,.06) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;}
      .hub-hero-inner{max-width:900px;margin:0 auto;position:relative;z-index:2;}
      .hub-tag{font-family:var(--mono);font-size:10px;font-weight:800;color:var(--green);letter-spacing:4px;text-transform:uppercase;margin-bottom:24px;display:block;}
      .hub-h1{font-size:clamp(40px,7.5vw,88px);font-weight:900;letter-spacing:-4px;line-height:1;margin-bottom:24px;background:linear-gradient(180deg,#fff 0%,#94a3b8 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
      .hub-h1 .g{background:linear-gradient(135deg,#00a854,#00d46a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
      .hub-sub{font-size:clamp(16px,2vw,21px);color:#64748b;max-width:700px;margin:0 auto 40px;line-height:1.6;letter-spacing:-.3px;}
      .hero-pills{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:40px;}
      .hero-pill{font-family:var(--mono);font-size:9px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#64748b;border:1px solid rgba(255,255,255,.08);padding:8px 16px;border-radius:20px;display:flex;align-items:center;gap:8px;}
      .hero-pill .pill-dot{width:5px;height:5px;background:var(--green);border-radius:50%;}
      .hero-pill strong{color:#f8fafc;}
      .btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--green);color:#fff;text-decoration:none;padding:18px 44px;border-radius:10px;font-weight:900;font-size:15px;text-transform:uppercase;letter-spacing:.5px;transition:all .3s ease;}
      .btn-primary:hover{background:#00c464;transform:translateY(-3px);box-shadow:0 12px 30px rgba(0,168,84,.4);}
      .hub-stats{background:rgba(15,23,42,.8);border-top:1px solid rgba(255,255,255,.05);border-bottom:1px solid rgba(255,255,255,.05);padding:32px 40px;display:grid;grid-template-columns:repeat(4,1fr);}
      .hub-stat{text-align:center;border-right:1px solid rgba(255,255,255,.05);padding:0 20px;}
      .hub-stat:last-child{border-right:none;}
      .hub-stat-num{font-size:clamp(28px,4vw,48px);font-weight:900;letter-spacing:-2px;color:var(--green);line-height:1;display:block;margin-bottom:6px;}
      .hub-stat-label{font-family:var(--mono);font-size:9px;color:#475569;letter-spacing:2px;text-transform:uppercase;}
      .hub-section{max-width:1200px;margin:0 auto;padding:90px 40px;}
      .section-tag{font-family:var(--mono);font-size:10px;font-weight:800;color:var(--green);letter-spacing:3px;text-transform:uppercase;margin-bottom:20px;display:block;}
      .section-h2{font-size:clamp(30px,4.5vw,56px);font-weight:900;letter-spacing:-2.5px;line-height:1.05;margin-bottom:16px;color:#fff;}
      .section-h2 .accent{color:var(--green);}
      .section-sub{font-size:18px;color:#64748b;max-width:600px;line-height:1.65;margin-bottom:60px;letter-spacing:-.2px;}
      .divider{width:100%;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.06),transparent);}
      .tools-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
      .tool-card{background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:20px;padding:36px 32px;text-decoration:none;color:inherit;display:flex;flex-direction:column;transition:all .3s ease;position:relative;overflow:hidden;}
      .tool-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--green),transparent);opacity:0;transition:opacity .3s ease;}
      .tool-card:hover{background:rgba(0,168,84,.05);border-color:var(--green-border);transform:translateY(-6px);box-shadow:0 20px 50px rgba(0,0,0,.3);}
      .tool-card:hover::before{opacity:1;}
      .tool-card-tag{font-family:var(--mono);font-size:9px;font-weight:800;color:var(--green);letter-spacing:2px;text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
      .tool-tag-dot{width:5px;height:5px;background:var(--green);border-radius:50%;flex-shrink:0;}
      .tool-card-title{font-size:22px;font-weight:900;color:#fff;letter-spacing:-.8px;margin-bottom:12px;line-height:1.2;}
      .tool-card-desc{font-size:14px;color:#64748b;line-height:1.65;flex-grow:1;margin-bottom:28px;}
      .tool-card-desc strong{color:#94a3b8;}
      .tool-card-saving{font-family:var(--mono);font-size:10px;font-weight:800;color:var(--green);letter-spacing:1px;text-transform:uppercase;margin-bottom:16px;}
      .tool-card-cta{font-family:var(--mono);font-size:10px;font-weight:800;color:var(--green);letter-spacing:1.5px;text-transform:uppercase;border:1px solid var(--green-border);padding:10px 20px;border-radius:6px;text-align:center;transition:all .3s ease;display:block;}
      .tool-card:hover .tool-card-cta{background:var(--green);color:#fff;border-color:var(--green);}
      .tool-card.featured{grid-column:span 3;flex-direction:row;align-items:center;gap:40px;background:rgba(0,168,84,.04);border-color:var(--green-border);padding:40px 48px;}
      .tool-card.featured::before{opacity:1;}
      .tool-card.featured .tool-card-desc{margin-bottom:0;}
      .featured-badge{font-family:var(--mono);font-size:8px;font-weight:800;color:#fff;background:var(--red);padding:4px 10px;border-radius:3px;letter-spacing:1.5px;text-transform:uppercase;margin-left:10px;}
      /* Calc cards */
      .calc-accent{color:#38bdf8;}
      .calc-tag{color:#38bdf8!important;}
      .calc-tag .tool-tag-dot{background:#38bdf8!important;}
      .tool-card.calc-card{border-color:rgba(56,189,248,.12);}
      .tool-card.calc-card:hover{background:rgba(56,189,248,.04);border-color:rgba(56,189,248,.3);}
      .tool-card.calc-card:hover::before{background:linear-gradient(90deg,transparent,#38bdf8,transparent);}
      .tool-card.calc-card .tool-card-cta{color:#38bdf8;border-color:rgba(56,189,248,.3);}
      .tool-card.calc-card:hover .tool-card-cta{background:#38bdf8;color:#020617;border-color:#38bdf8;}
      .tool-card.calc-featured{background:rgba(56,189,248,.04);border-color:rgba(56,189,248,.3);grid-column:span 3;}
      .tool-card.calc-featured::before{opacity:1;background:linear-gradient(90deg,transparent,#38bdf8,transparent);}
      .tool-card.calc-featured .tool-card-cta{color:#38bdf8;border-color:rgba(56,189,248,.3);}
      .tool-card.calc-featured:hover .tool-card-cta{background:#38bdf8;color:#020617;}
      .calc-saving{color:#38bdf8!important;}
      .section-tag.calc-tag-section{color:#38bdf8;}
      /* Comparison */
      .comp-wrap{background:rgba(15,23,42,.5);border:1px solid rgba(255,255,255,.06);border-radius:24px;overflow:hidden;}
      .comp-header{display:grid;grid-template-columns:1.5fr 1fr 1fr;padding:20px 32px;border-bottom:1px solid rgba(255,255,255,.06);background:rgba(255,255,255,.02);}
      .comp-label{font-family:var(--mono);font-size:10px;font-weight:800;letter-spacing:2px;text-transform:uppercase;}
      .comp-label.bad{color:var(--red);}
      .comp-label.good{color:var(--green);}
      .comp-label.neutral{color:#475569;}
      .comp-row{display:grid;grid-template-columns:1.5fr 1fr 1fr;padding:16px 32px;border-bottom:1px solid rgba(255,255,255,.04);align-items:center;transition:background .2s;}
      .comp-row:last-child{border-bottom:none;}
      .comp-row:hover{background:rgba(255,255,255,.02);}
      .comp-metric{font-size:13px;color:#64748b;font-weight:600;}
      .comp-bad{font-family:var(--mono);font-size:12px;color:var(--red);font-weight:800;}
      .comp-good{font-family:var(--mono);font-size:12px;color:var(--green);font-weight:800;}
      /* How */
      .how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:rgba(255,255,255,.04);border-radius:20px;overflow:hidden;border:1px solid rgba(255,255,255,.06);}
      .how-card{background:var(--slate);padding:44px 32px;}
      .how-num{font-family:var(--mono);font-size:52px;font-weight:800;color:rgba(255,255,255,.05);line-height:1;margin-bottom:20px;letter-spacing:-4px;}
      .how-title{font-size:20px;font-weight:900;color:#fff;letter-spacing:-.6px;margin-bottom:10px;}
      .how-desc{font-size:14px;color:#64748b;line-height:1.65;margin-bottom:20px;}
      .how-link{font-family:var(--mono);font-size:10px;font-weight:800;color:var(--green);text-decoration:none;text-transform:uppercase;letter-spacing:1px;border:1px solid var(--green-border);padding:9px 16px;border-radius:6px;display:inline-block;transition:all .3s ease;}
      .how-link:hover{background:var(--green);color:#fff;}
      /* SEO/FAQ */
      .seo-wrap{max-width:800px;margin:0 auto;}
      .seo-accordion{border-bottom:1px solid rgba(255,255,255,.06);}
      .seo-trigger{width:100%;display:flex;align-items:center;justify-content:space-between;padding:22px 0;background:none;border:none;cursor:pointer;text-align:left;gap:16px;}
      .seo-trigger h2{font-size:clamp(15px,2vw,18px);font-weight:900;color:#f8fafc;letter-spacing:-.5px;margin:0;flex:1;line-height:1.3;}
      .seo-icon{font-family:var(--mono);font-size:20px;color:var(--green);flex-shrink:0;transition:transform .3s;}
      .seo-accordion.open .seo-icon{transform:rotate(45deg);}
      .seo-body{max-height:0;overflow:hidden;transition:max-height .4s cubic-bezier(.4,0,.2,1);}
      .seo-accordion.open .seo-body{max-height:600px;}
      .seo-content{padding:0 0 24px;font-size:15px;color:#64748b;line-height:1.75;}
      .seo-content strong{color:#94a3b8;}
      .seo-content a{color:var(--green);text-decoration:none;}
      .seo-content a:hover{text-decoration:underline;}
      .faq-item{border-bottom:1px solid rgba(255,255,255,.06);}
      .faq-trigger{width:100%;display:flex;align-items:flex-start;justify-content:space-between;padding:22px 0;background:none;border:none;cursor:pointer;text-align:left;gap:16px;}
      .faq-q{font-size:16px;font-weight:700;color:#f8fafc;letter-spacing:-.3px;flex:1;line-height:1.4;}
      .faq-plus{font-family:var(--mono);font-size:20px;color:var(--green);flex-shrink:0;transition:transform .3s;margin-top:2px;}
      .faq-item.open .faq-plus{transform:rotate(45deg);}
      .faq-ans{max-height:0;overflow:hidden;transition:max-height .4s cubic-bezier(.4,0,.2,1);}
      .faq-item.open .faq-ans{max-height:400px;}
      .faq-ans-inner{padding:0 0 22px;font-size:14px;color:#64748b;line-height:1.7;}
      .faq-ans-inner strong{color:#94a3b8;}
      .faq-ans-inner a{color:var(--green);}
      /* Final CTA */
      .final-cta{background:linear-gradient(135deg,rgba(0,168,84,.12) 0%,rgba(0,168,84,.04) 100%);border:1px solid var(--green-border);border-radius:32px;padding:80px 60px;text-align:center;margin:0 40px;position:relative;overflow:hidden;}
      .final-cta::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(0,168,84,.07) 1px,transparent 1px);background-size:24px 24px;pointer-events:none;}
      .final-cta-inner{position:relative;z-index:2;}
      .final-cta h2{font-size:clamp(30px,5vw,60px);font-weight:900;letter-spacing:-3px;line-height:1.05;color:#fff;margin-bottom:16px;}
      .final-cta p{font-size:18px;color:#64748b;max-width:560px;margin:0 auto 36px;line-height:1.6;}
      .final-bullets{display:flex;justify-content:center;gap:28px;flex-wrap:wrap;margin-bottom:36px;}
      .final-bullet{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:10px;color:var(--green);font-weight:800;letter-spacing:1px;text-transform:uppercase;}
      .final-trust{font-family:var(--mono);font-size:9px;color:#334155;letter-spacing:1.5px;text-transform:uppercase;margin-top:16px;display:block;}
      /* Responsive */
      @media(max-width:1024px){.tools-grid{grid-template-columns:repeat(2,1fr);}.tool-card.featured,.tool-card.calc-featured{grid-column:span 2;flex-direction:column;}}
      @media(max-width:768px){
        .hub-hero{padding:60px 24px 50px;}
        .hub-stats{grid-template-columns:repeat(2,1fr);padding:24px;}
        .hub-stat{border-right:none;border-bottom:1px solid rgba(255,255,255,.05);padding:16px 0;}
        .hub-stat:last-child{border-bottom:none;}
        .hub-section{padding:60px 24px;}
        .tools-grid{grid-template-columns:1fr;}
        .tool-card.featured,.tool-card.calc-featured{grid-column:span 1;}
        .how-grid{grid-template-columns:1fr;}
        .comp-header,.comp-row{grid-template-columns:1fr 1fr 1fr;font-size:11px;padding:12px 16px;}
        .final-cta{margin:0 16px;padding:50px 24px;}
        .hero-pills{flex-direction:column;align-items:center;}
      }
    </style>

    <div class="hub-page" itemscope itemtype="https://schema.org/CollectionPage">
      <meta itemprop="name" content="Free Shopify Automation Tools & Calculators — Stack Architect" />
      <meta itemprop="description" content="The complete free Shopify automation tool stack plus 15 free diagnostic calculators — replacing paid apps at $0." />

      <!-- HERO -->
      <section class="hub-hero" aria-label="Free Shopify automation tools and calculators">
        <div class="hub-hero-inner">
          <span class="hub-tag">// Live_Tool_Suite // 21_Free_Tools</span>
          <h1 class="hub-h1">Free Shopify<br><span class="g">Tools &amp; Calculators</span></h1>
          <p class="hub-sub">Six free automation tools that replace paid apps — plus 15 free diagnostic calculators. Run the numbers first, then deploy the fix. Everything costs $0, forever.</p>
          <div class="hero-pills">
            <div class="hero-pill"><span class="pill-dot"></span><strong>6</strong>&nbsp;Automation tools</div>
            <div class="hero-pill"><span class="pill-dot"></span><strong>15</strong>&nbsp;Free calculators</div>
            <div class="hero-pill"><span class="pill-dot"></span><strong>500+</strong>&nbsp;stores running</div>
            <div class="hero-pill"><span class="pill-dot"></span><strong>$0</strong>&nbsp;monthly fees — forever</div>
          </div>
          <a href="https://www.make.com/en/register?pc=techie123" class="btn-primary" target="_blank" rel="noopener sponsored">Replace My Apps Free &rarr;</a>
          <p style="font-family:var(--mono);font-size:9px;color:#334155;letter-spacing:1.5px;text-transform:uppercase;margin-top:16px;">No credit card &middot; No monthly fees &middot; Live in 5 minutes</p>
        </div>
      </section>

      <!-- STATS -->
