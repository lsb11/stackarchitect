---
import Nav from '../components/Nav.astro';
---
<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page Not Found (404) — Stack Architect</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href="https://stackarchitect.xyz/404" />
    <style>
      :root { color-scheme: dark; }
      body { margin: 0; min-height: 100vh; background: #0a0a0f; color: #e8e8ee; font-family: 'Inter', system-ui, sans-serif; display: flex; flex-direction: column; }
      main { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; gap: 1.25rem; }
      .code { font-family: 'JetBrains Mono', monospace; font-size: clamp(3rem, 12vw, 6rem); font-weight: 800; color: #34d377; letter-spacing: 0.05em; margin: 0; }
      h1 { font-size: clamp(1.25rem, 4vw, 1.75rem); margin: 0; font-weight: 700; }
      p { color: #9999a8; max-width: 32rem; line-height: 1.6; margin: 0; }
      .links { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-top: 0.5rem; }
      .links a { color: #0a0a0f; background: #34d377; padding: 0.7rem 1.2rem; border-radius: 0.5rem; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
      .links a.secondary { background: transparent; color: #34d377; border: 1px solid #2a2a35; }
    </style>
  </head>
  <body>
    <Nav />
    <main>
      <p class="code">404</p>
      <h1>That page doesn't exist.</h1>
      <p>The page you're looking for has moved or never existed. Here are the things people come here for.</p>
      <div class="links">
        <a href="/stocky-swap/">Free Stocky Replacement</a>
        <a href="/capi-shield/" class="secondary">Server-Side Tracking</a>
        <a href="/tools/" class="secondary">All Free Tools</a>
        <a href="/">Home</a>
      </div>
    </main>
  </body>
</html>
