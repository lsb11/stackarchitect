<div class="field"><label for="shopifyPlan">Shopify plan (for fee calculation)</label><select id="shopifyPlan" name="shopifyPlan"><option value="">Select…</option><option value="Basic">Basic</option><option value="Shopify">Shopify</option><option value="Advanced">Advanced</option></select></div>
