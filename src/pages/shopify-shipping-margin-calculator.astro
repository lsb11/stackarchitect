<script is:inline>
function fmt(n){ return Math.round(n).toLocaleString('en-GB'); }

function calculate(inp) {
  var aov = parseFloat(inp.averageOrderValue) || 0;
  var shipCost = parseFloat(inp.averageShippingCost) || 0;
  var cogs = parseFloat(inp.averageProductCost) || 0;
  var threshold = parseFloat(inp.currentFreeShippingThreshold) || 0;
  var txnRate = 0.005;
  var grossProfit = aov - cogs - shipCost - aov * txnRate;
  var currentMargin = aov > 0 ? grossProfit / aov * 100 : 0;
  var breakEven = (cogs + shipCost) / (1 - txnRate);
  var recommended = cogs + shipCost * 2.5;
  var rows = [
    { label: 'Current gross margin per order', value: currentMargin.toFixed(1) + '%', flag: currentMargin >= 30 ? 'good' : currentMargin >= 15 ? 'warn' : 'bad' },
    { label: 'Break-even free shipping threshold', value: '£' + fmt(breakEven), flag: 'neutral' },
    { label: 'Recommended free shipping threshold', value: '£' + fmt(recommended), flag: 'good' }
  ];
  if (threshold > 0) {
    var profitAtThreshold = threshold - cogs - shipCost - threshold * txnRate;
    rows.push({ label: 'Profit per order at your threshold', value: profitAtThreshold >= 0 ? '£' + fmt(profitAtThreshold) : '-£' + fmt(Math.abs(profitAtThreshold)), flag: profitAtThreshold > 0 ? 'good' : 'bad' });
    if (profitAtThreshold < 0) rows.push({ label: 'Annual loss from current threshold', value: '-£' + fmt(Math.abs(profitAtThreshold * 12 * 30)), flag: 'bad', sub: 'Estimated at 30 orders/month' });
  }
  return {
    teaser: { label: 'Recommended free shipping threshold', value: '£' + fmt(recommended), flag: 'good' },
    rows: rows
  };
}

var IS_GATED = false;
var form = document.getElementById('calcForm');
var resultsSection = document.getElementById('results');
var resultsContent = document.getElementById('resultsContent');
var teaserSection = document.getElementById('teaser');
var teaserValue = document.getElementById('teaserValue');
var teaserLabel = document.getElementById('teaserLabel');
var emailGate = document.getElementById('emailGate');
var gateBtn = document.getElementById('gateBtn');
var upsellBlock = document.getElementById('upsellBlock');
var lastResult = null;

function getInputs() {
  var inp = {};
  var fd = new FormData(form);
  fd.forEach(function(v, k) {
    if (inp[k]) {
      inp[k] = Array.isArray(inp[k]) ? inp[k].concat(v) : [inp[k], v];
    } else {
      inp[k] = v;
    }
  });
  // Also grab textareas by id since FormData may not pick up all
  form.querySelectorAll('textarea').forEach(function(el){
    if (!inp[el.id]) inp[el.id] = el.value;
  });
  return inp;
}

function renderRows(rows) {
  return rows.map(function(r) {
    var sub = r.sub ? '<span class="sub">' + r.sub + '</span>' : '';
    return '<div class="result-row flag-' + (r.flag||'neutral') + '">' +
      '<span class="result-label">' + r.label + sub + '</span>' +
      '<span class="result-value">' + r.value + '</span>' +
    '</div>';
  }).join('');
}

function showFullResults(rows) {
  resultsContent.innerHTML = renderRows(rows);
  resultsSection.hidden = false;
  upsellBlock.hidden = false;
  resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

form.addEventListener('submit', function(e) {
  e.preventDefault();
  var inp = getInputs();
  var result;
  try { result = calculate(inp); } catch(err) { alert('Calculation error: ' + err.message); return; }
  lastResult = result;

  if (!IS_GATED) {
    showFullResults(result.rows);
    return;
  }

  // Show teaser
  teaserValue.textContent = result.teaser.value;
  teaserLabel.textContent = result.teaser.label;
  teaserSection.hidden = false;

  // Check if already gated
  var storedEmail = localStorage.getItem('sa_email');
  if (storedEmail) {
    emailGate.hidden = true;
    showFullResults(result.rows);
  } else {
    emailGate.hidden = false;
  }
  teaserSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});

if (gateBtn) {
  gateBtn.addEventListener('click', function() {
    var emailInput = document.getElementById('emailInput');
    var email = emailInput ? emailInput.value.trim() : '';
    if (!email || !email.includes('@')) { emailInput.focus(); return; }
    localStorage.setItem('sa_email', email);
    emailGate.hidden = true;
    if (lastResult) showFullResults(lastResult.rows);
  });
}
</script>
</body>
