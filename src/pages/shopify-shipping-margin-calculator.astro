/* FAQ */
.faq-section{margin-bottom:32px}
.faq-section h2{font-size:1.1rem;font-weight:700;margin-bottom:16px;color:var(--dark)}
details{border:1px solid var(--border);border-radius:var(--radius);margin-bottom:8px;overflow:hidden}
summary{padding:14px 16px;cursor:pointer;font-weight:500;font-size:.92rem;list-style:none;display:flex;justify-content:space-between;align-items:center}
summary::-webkit-details-marker{display:none}
summary::after{content:'+';font-size:1.1rem;color:var(--muted)}
details[open] summary::after{content:'−'}
details[open] summary{border-bottom:1px solid var(--border)}
.faq-answer{padding:14px 16px;font-size:.9rem;color:var(--muted);line-height:1.7}
/* Internal links */
.related-tools{margin-bottom:32px;padding-top:24px;border-top:1px solid var(--border)}
.related-tools h2{font-size:.85rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);margin-bottom:12px}
.related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px}
.related-link{display:block;padding:12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);font-size:.85rem;font-weight:500;color:var(--text);transition:border-color .15s}
.related-link:hover{border-color:var(--green);text-decoration:none;color:var(--green)}
/* Footer */
footer{background:var(--surface);border-top:1px solid var(--border);padding:20px;text-align:center;font-size:.83rem;color:var(--muted)}
footer a{color:var(--muted)}
/* Utility */
[hidden]{display:none!important}
@media(max-width:480px){
  article h1{font-size:1.4rem}
  .teaser-number{font-size:2rem}
  .upsell{flex-direction:column;align-items:flex-start}
  .result-row{flex-direction:column;gap:4px}
  .result-value{text-align:left;max-width:100%}
}
</style>
