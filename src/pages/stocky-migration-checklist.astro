---
import Nav from '../components/Nav.astro';
import RelatedGuides from '../components/RelatedGuides.astro';
import Footer from '../components/Footer.astro';

/**
 * STOCKY MIGRATION CHECKLIST — /stocky-migration-checklist/
 * Primary: "stocky migration checklist" / "how to migrate from stocky"
 * Cluster spoke for: /stocky-shutdown/ (hub), /blog/shopify-stocky-data-export-before-shutdown/, /stocky-swap/
 * Intent: procedural / sequenced. Distinct from shutdown explainer and export how-to.
 */

const SITE_URL = "https://stackarchitect.xyz";
const PAGE_URL = `${SITE_URL}/stocky-migration-checklist/`;
const SHUTDOWN_DATE = "August 31, 2026";
const DATE_PUBLISHED = "2026-06-25";
const DATE_MODIFIED = "2026-06-25";
const MAKE_AFFILIATE = "/go/make";
const LINKEDIN = "https://www.linkedin.com/company/stack-architect-xyz/";

const SEO = {
  title: "Shopify Stocky Migration Checklist 2026 — Every Step Before Aug 31 | Stack Architect",
  description: "The complete Stocky migration checklist: export data, rebuild suppliers, deploy a replacement, verify, and cut over — in the right order, before the August 31 2026 shutdown.",
  canonical: PAGE_URL,
  ogTitle: "Shopify Stocky Migration Checklist 2026 — Every Step Before Aug 31",
  ogDescription: "Export, choose a replacement, deploy in parallel, verify, cut over. The sequenced Stocky migration checklist before the August 31 2026 shutdown.",
  ogImage: `${SITE_URL}/og.png`
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${PAGE_URL}#webpage`,
      url: PAGE_URL,
      name: SEO.title,
      description: SEO.description,
      datePublished: DATE_PUBLISHED,
      dateModified: DATE_MODIFIED,
      inLanguage: "en-GB",
      isPartOf: { "@id": `${SITE_URL}/#website` },
      author: { "@id": `${SITE_URL}/#luke` },
      speakable: { "@type": "SpeakableSpecification", cssSelector: [".speakable-answer", ".faq-ans-s p"] },
      about: [
        { "@type": "Thing", name: "Stocky migration" },
        { "@type": "Thing", name: "Shopify Stocky shutdown 2026" }
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      url: SITE_URL,
      name: "Stack Architect",
      publisher: { "@id": `${SITE_URL}/#organization` }
    },
    {
      "@type": "Organization",
      "@id": `${SITE_URL}/#organization`,
      name: "Stack Architect",
      url: SITE_URL,
      logo: { "@type": "ImageObject", url: `${SITE_URL}/icon-512.png`, width: 512, height: 512 },
      sameAs: [LINKEDIN]
    },
    {
      "@type": "Person",
      "@id": `${SITE_URL}/#luke`,
      name: "Luke",
      jobTitle: "Shopify Automation Specialist",
      url: `${SITE_URL}/about/`,
      sameAs: ["https://www.linkedin.com/in/luke-stackarchitect", LINKEDIN],
      worksFor: { "@id": `${SITE_URL}/#organization` }
    },
    {
      "@type": "HowTo",
      "@id": `${PAGE_URL}#howto`,
      name: "Shopify Stocky migration checklist before August 31 2026",
      description: "A sequenced checklist to migrate off Stocky before it shuts down: preserve data, choose a replacement, deploy in parallel, verify, and cut over.",
      totalTime: "P28D",
      step: [
        { "@type": "HowToStep", position: 1, name: "Preserve your data", text: "Export purchase orders, stocktakes, adjustments and cost data as CSV. Document suppliers and reorder settings manually because they cannot be exported. Store everything in one dated cloud folder.", url: `${PAGE_URL}#phase-1` },
        { "@type": "HowToStep", position: 2, name: "Choose your replacement", text: "Audit what you actually used Stocky for. Pick free tracking if that is all you need, or a paid forecasting tool if you relied on demand planning and automated purchase orders.", url: `${PAGE_URL}#phase-2` },
        { "@type": "HowToStep", position: 3, name: "Deploy in parallel", text: "Set up the new system while Stocky is still live, confirm new orders flow into it, import your historical CSVs, and rebuild supplier records.", url: `${PAGE_URL}#phase-3` },
        { "@type": "HowToStep", position: 4, name: "Verify over 2 to 4 weeks", text: "Run both systems in parallel, reconcile order counts and stock levels weekly, fix any third-party integrations that used the Stocky API, and train your team.", url: `${PAGE_URL}#phase-4` },
        { "@type": "HowToStep", position: 5, name: "Cut over before August 31", text: "Do a final export check, switch your team fully to the new system as the source of truth, and decommission Stocky from your workflow.", url: `${PAGE_URL}#phase-5` }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": `${PAGE_URL}#faq`,
      mainEntity: [
        { "@type": "Question", name: "How long does a Stocky migration take?", acceptedAnswer: { "@type": "Answer", text: "The critical work — exporting data and deploying a replacement — takes about an hour. The full process spans two to four weeks because you should run the new system in parallel to verify it before the August 31 deadline." } },
        { "@type": "Question", name: "What is the first thing I should do to migrate off Stocky?", acceptedAnswer: { "@type": "Answer", text: "Export your data. It is the only irreversible step — purchase orders, stocktakes, and cost data are deleted after the deadline, and suppliers must be documented manually because they cannot be exported at all." } },
        { "@type": "Question", name: "Can I just wait until August to migrate from Stocky?", acceptedAnswer: { "@type": "Answer", text: "No. Migrations need a verification period, forecasting tools need weeks of data to calibrate, and a cold cutover on September 1 risks a gap in inventory tracking. Start the parallel run now." } },
        { "@type": "Question", name: "Do I need a paid tool to replace Stocky?", acceptedAnswer: { "@type": "Answer", text: "Only if you used Stocky for forecasting, multi-location, or automated purchase orders. For basic order and stock tracking — what most stores used it for — the free Stocky Swap covers it." } }
      ]
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL },
        { "@type": "ListItem", position: 2, name: "Stocky Shutdown", item: `${SITE_URL}/stocky-shutdown/` },
        { "@type": "ListItem", position: 3, name: "Migration Checklist", item: PAGE_URL }
      ]
    }
  ]
};
