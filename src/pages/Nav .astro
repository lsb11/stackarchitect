<style>
.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}

/* Top bar */
.sa-topbar{display:flex;align-items:center;justify-content:space-between;background:#0a0a0a;border-bottom:1px solid #1f1f1f;padding:6px 24px;font-size:10px;color:#52525b;}
.sa-topbar-right{color:#4ade80;}
.sa-pulse{display:inline-block;width:6px;height:6px;border-radius:50%;background:#4ade80;animation:tpulse 2s infinite;margin-right:6px;vertical-align:middle;}
@keyframes tpulse{0%,100%{opacity:1;}50%{opacity:.3;}}
.sa-mono{font-family:'JetBrains Mono',monospace;}

/* Nav shell */
.sa-nav{background:#000;border-bottom:1px solid #1f1f1f;position:sticky;top:0;z-index:10000;transition:box-shadow .3s;}
.sa-nav.scrolled{box-shadow:0 4px 24px rgba(0,0,0,.5);}
.sa-nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center;gap:0;height:48px;}

/* Logo */
.sa-logo{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;color:#fff;text-decoration:none;letter-spacing:.08em;margin-right:24px;white-space:nowrap;transition:color .2s;flex-shrink:0;}
.sa-logo:hover{color:#4ade80;}

/* Desktop links */
.sa-nav-links{display:flex;align-items:center;gap:2px;flex:1;}

/* Dropdown */
.sa-drop{position:relative;}
.sa-drop-btn{display:flex;align-items:center;gap:4px;background:none;border:none;cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;color:#71717a;letter-spacing:.08em;text-transform:uppercase;padding:14px 12px;white-space:nowrap;transition:color .2s;line-height:1;}
.sa-drop-btn:hover,.sa-drop.open .sa-drop-btn{color:#fff;}
.sa-caret{font-size:8px;transition:transform .2s;margin-top:1px;}
.sa-drop.open .sa-caret{transform:rotate(180deg);}

/* Dropdown panel */
.sa-drop-panel{display:none;position:absolute;top:calc(100% + 4px);left:0;background:#050505;border:1px solid #1f1f1f;border-radius:6px;padding:6px 0;min-width:260px;max-width:320px;z-index:10001;box-shadow:0 16px 48px rgba(0,0,0,.6);max-height:80vh;overflow-y:auto;}
.sa-drop.open .sa-drop-panel{display:block;}

/* Panel scrollbar */
.sa-drop-panel::-webkit-scrollbar{width:3px;}
.sa-drop-panel::-webkit-scrollbar-track{background:transparent;}
.sa-drop-panel::-webkit-scrollbar-thumb{background:#1f1f1f;border-radius:2px;}

.sa-drop-item{display:flex;flex-direction:column;padding:10px 16px;text-decoration:none;transition:background .15s;gap:2px;}
.sa-drop-item:hover{background:rgba(74,222,128,.06);}
.sa-drop-item--pro{background:rgba(74,222,128,.04);}
.sa-drop-item--pro:hover{background:rgba(74,222,128,.1);}
.sa-drop-title{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;color:#e4e4e7;letter-spacing:.06em;transition:color .15s;line-height:1.3;}
.sa-drop-item:hover .sa-drop-title{color:#4ade80;}
.sa-drop-item--pro .sa-drop-title{color:#4ade80;}
.sa-drop-desc{font-size:10px;color:#52525b;line-height:1.4;margin-top:1px;}
.sa-drop-divider{height:1px;background:#1f1f1f;margin:4px 0;}
.sa-drop-group-label{font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;color:#3f3f46;letter-spacing:.18em;text-transform:uppercase;padding:8px 16px 4px;line-height:1;}
.sa-pro-badge{display:inline-block;background:#4ade80;color:#000;font-size:8px;font-weight:900;padding:2px 5px;border-radius:2px;margin-left:6px;letter-spacing:.08em;vertical-align:middle;}

/* Right CTAs */
.sa-nav-right{display:flex;align-items:center;gap:8px;margin-left:auto;flex-shrink:0;}
.sa-pro-cta{font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:900;color:#000;background:#4ade80;text-decoration:none;padding:7px 12px;border-radius:3px;letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;transition:background .2s;line-height:1;}
.sa-pro-cta:hover{background:#22c55e;}
.sa-free-cta{font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:900;color:#4ade80;border:1px solid rgba(74,222,128,.4);text-decoration:none;padding:6px 12px;border-radius:3px;letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;transition:all .2s;line-height:1;}
.sa-free-cta:hover{background:#4ade80;color:#000;}

/* Hamburger */
.sa-hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;margin-left:12px;}
.sa-hamburger span{display:block;width:20px;height:1.5px;background:#fff;transition:all .25s;}
.sa-hamburger.open span:nth-child(1){transform:rotate(45deg) translate(4px,4px);}
.sa-hamburger.open span:nth-child(2){opacity:0;}
.sa-hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(4px,-4px);}

/* Mobile menu */
.sa-mobile-menu{display:none;background:#050505;border-top:1px solid #1f1f1f;padding:16px 24px 24px;max-height:80vh;overflow-y:auto;}
.sa-mobile-menu.open{display:block;}
.sa-mobile-section-label{font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;color:#3f3f46;letter-spacing:.18em;text-transform:uppercase;padding:16px 0 8px;border-top:1px solid #1f1f1f;margin-top:8px;}
.sa-mobile-section-label:first-child{margin-top:0;border-top:none;padding-top:4px;}
.sa-mobile-link{display:block;font-family:'JetBrains Mono',monospace;font-size:10px;color:#71717a;text-decoration:none;padding:7px 0;transition:color .2s;letter-spacing:.06em;}
.sa-mobile-link:hover{color:#fff;}
.sa-mobile-link--pro{color:#4ade80 !important;}
.sa-mobile-ctas{display:flex;flex-direction:column;gap:10px;margin-top:20px;padding-top:16px;border-top:1px solid #1f1f1f;}
.sa-mobile-cta-pro{display:block;text-align:center;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:900;color:#000;background:#4ade80;text-decoration:none;padding:12px;border-radius:4px;letter-spacing:.1em;text-transform:uppercase;}
.sa-mobile-cta-free{display:block;text-align:center;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:900;color:#4ade80;border:1px solid rgba(74,222,128,.4);text-decoration:none;padding:12px;border-radius:4px;letter-spacing:.1em;text-transform:uppercase;}

/* Responsive */
@media(max-width:900px){
  .sa-nav-links,.sa-nav-right{display:none;}
  .sa-hamburger{display:flex;}
  .sa-topbar-right{display:none;}
}
@media(max-width:480px){
