footer{background:var(--dark);border-top:1px solid var(--border);padding:20px 24px;text-align:center;font-size:.78rem;color:var(--dim);font-family:var(--mono)}
footer a{color:var(--dim)}
.back{color:var(--muted);font-size:.85rem;display:inline-flex;align-items:center;gap:6px;margin-bottom:28px}
.back:hover{color:var(--green);text-decoration:none}
@media(max-width:600px){.grid{grid-template-columns:1fr}.sitemap-meta{margin-left:0}.header-nav{display:none}}
