.section-label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--green);font-family:var(--mono);margin-bottom:12px;display:flex;align-items:center;gap:10px}
.section-label::after{content:'';flex:1;height:1px;background:var(--border)}
.section-count{color:var(--dim);font-size:.68rem}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:6px}
.item{display:flex;align-items:flex-start;gap:8px;padding:10px 14px;border:1px solid var(--border);border-radius:6px;background:var(--dark2);transition:border-color .15s}
.item:hover{border-color:var(--green)}
