  .tc-pros .tc-list li::before { content: '✓'; color: var(--g); font-family: var(--mono); font-size: 10px; flex-shrink: 0; margin-top: 1px; }
  .tc-cons .tc-list li { font-size: 13px; color: var(--text3); display: flex; gap: 8px; line-height: 1.5; }
