<script>
(function() {

  // Copyright year
  var c = document.getElementById('footer-copyright');
  if (c) c.textContent = '© ' + new Date().getFullYear() + ' STACK_ARCHITECT // CORE_DEPLOYMENT';

  // Sticky nav state
  var nav = document.getElementById('top-nav');
  window.addEventListener('scroll', function() {
    if (nav) nav.classList.toggle('scrolled', window.scrollY > 50);
  }, { passive: true });

  // Floating CTA
  var navCta = document.getElementById('nav-main-cta');
  if (navCta) {
    var floatCta = navCta.cloneNode(true);
    floatCta.id = 'float-cta';
    floatCta.style.cssText = 'display:none;position:fixed;top:12px;left:50%;transform:translateX(-50%);z-index:99999;background:#00a854;color:#fff;border-color:#00c864;box-shadow:0 4px 15px rgba(0,168,84,.4);font-family:"JetBrains Mono",monospace;font-size:10px;font-weight:900;text-decoration:none;text-transform:uppercase;padding:8px 18px;border-radius:4px;border:1px solid #00c864;white-space:nowrap;';
    floatCta.textContent = 'REPLACE MY APPS →';
    document.body.appendChild(floatCta);
    window.addEventListener('scroll', function() {
      var show = window.scrollY > 50;
      floatCta.style.display = show ? 'block' : 'none';
      navCta.style.visibility = show ? 'hidden' : 'visible';
    }, { passive: true });
  }

  // Mobile dropdowns
  document.querySelectorAll('.dropdown > .nav-link').forEach(function(link) {
    link.addEventListener('click', function(e) {
      if (window.innerWidth <= 768) {
        e.preventDefault();
        this.parentElement.classList.toggle('open');
      }
    });
  });
  var mobileStyle = document.createElement('style');
  mobileStyle.textContent = '@media(max-width:768px){.dropdown.open .dropdown-menu{display:flex;}}';
  document.head.appendChild(mobileStyle);
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.dropdown')) {
      document.querySelectorAll('.dropdown').forEach(function(d) { d.classList.remove('open'); });
    }
  });

  // Active nav link highlight
  var path = window.location.pathname;
  document.querySelectorAll('.nav-link').forEach(function(link) {
    var href = link.getAttribute('href');
    if (href && (href === path || (path === '/' && href.endsWith('/')))) link.classList.add('active');
  });

  // GA4 — affiliate click tracking
  var affiliatePatterns = [
    { pattern: 'make.com',      label: 'make_com_ai_tools' },
    { pattern: 'systeme.io',    label: 'systeme_io_ai_tools' },
    { pattern: 'beehiiv.com',   label: 'beehiiv_ai_tools' },
    { pattern: 'tidio.com',     label: 'tidio_ai_tools' },
    { pattern: 'workspace.google.com', label: 'google_workspace_ai_tools' },
    { pattern: 'writesonic.com', label: 'writesonic_ai_tools' },
    { pattern: 'adcreative.ai', label: 'adcreative_ai_tools' },
  ];
  document.addEventListener('click', function(e) {
    var el = e.target.closest('a[href]');
    if (!el) return;
    var href = el.getAttribute('href') || '';
    if (typeof gtag === 'undefined') return;
    affiliatePatterns.forEach(function(a) {
      if (href.indexOf(a.pattern) !== -1) {
        gtag('event', 'affiliate_click', {
          event_category: 'affiliate',
          event_label: a.label,
          link_url: href,
          page_url: window.location.pathname
        });
      }
    });
    // Outbound tracking (non-affiliate)
    if (href.startsWith('http') && !href.includes('stackarchitect.xyz')) {
      gtag('event', 'outbound_click', {
        event_category: 'outbound',
        event_label: href
      });
    }
  });

  // Scroll depth
  var fired = {};
  window.addEventListener('scroll', function() {
    var pct = Math.round((window.scrollY / Math.max(1, document.documentElement.scrollHeight - window.innerHeight)) * 100);
    [25, 50, 75, 100].forEach(function(t) {
      if (pct >= t && !fired[t]) {
        fired[t] = true;
        if (typeof gtag !== 'undefined') gtag('event', 'scroll_depth', { event_category: 'engagement', event_label: t + '%', page_url: window.location.pathname });
      }
    });
  }, { passive: true });

  // Time on page
  var start = Date.now(); var timeFired = {};
  setInterval(function() {
    var s = Math.floor((Date.now() - start) / 1000);
    [{s:30,l:'30s'},{s:60,l:'60s'},{s:120,l:'2m'},{s:300,l:'5m'}].forEach(function(e) {
      if (!timeFired[e.l] && s >= e.s && typeof gtag !== 'undefined') {
        timeFired[e.l] = true;
        gtag('event', 'time_on_page', { event_category: 'engagement', event_label: e.l, page_url: window.location.pathname });
      }
    });
  }, 5000);

  // Intersection observer — tool card views
  if (window.IntersectionObserver) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          var id = e.target.getAttribute('id');
          if (id && typeof gtag !== 'undefined') gtag('event', 'tool_view', { event_category: 'content', event_label: id });
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.4 });
    ['systeme','make','beehiiv','tidio','getresponse','writesonic','adcreative','hypotenuse','synthesia','photoroom','jasper','octane'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) io.observe(el);
    });
  }

})();
</script>

