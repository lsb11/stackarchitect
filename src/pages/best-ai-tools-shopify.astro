  /* ── CSS VARS ──────────────────────────────────────────────── */
  :root {
    --bg:        #020617;
    --bg2:       #06101e;
    --bg3:       #0a1628;
    --bg4:       #0f1f35;
    --border:    #1e293b;
    --border2:   #263548;
    --text:      #f1f5f9;
    --text2:     #cbd5e1;
    --text3:     #94a3b8;
    --text4:     #64748b;
    --g:         #00c864;
    --g-dim:     #00a854;
    --g-bg:      rgba(0,200,100,.08);
    --g-border:  rgba(0,200,100,.2);
    --sky:       #7dd3fc;
    --sky-bg:    rgba(125,211,252,.07);
    --sky-border:rgba(125,211,252,.18);
    --amber:     #fcd34d;
    --amber-bg:  rgba(252,211,77,.08);
    --amber-border:rgba(252,211,77,.2);
    --red:       #fc8181;
    --red-bg:    rgba(252,129,129,.07);
    --red-border:rgba(252,129,129,.18);
    --purple:    #c4b5fd;
    --purple-bg: rgba(196,181,253,.07);
    --purple-border:rgba(196,181,253,.18);
    --mono:      'JetBrains Mono', monospace;
    --max-w:     900px;
  }

  /* ── NAV ───────────────────────────────────────────────────── */
  .nav {
    width: 100%; background: #020617; padding: 12px 0;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 1000;
    transition: all .3s;
  }
  .nav.scrolled {
    background: rgba(2,6,23,.95);
    backdrop-filter: blur(12px);
    border-bottom-color: rgba(0,168,84,.3);
    box-shadow: 0 4px 20px rgba(0,0,0,.4);
  }
  .nav-inner {
    max-width: 1100px; margin: 0 auto;
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 24px;
  }
  .nav-status {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: 9px;
    color: var(--text4); letter-spacing: 1.5px; font-weight: 800;
  }
  .pulse { width: 5px; height: 5px; background: var(--g-dim); border-radius: 50%;
    box-shadow: 0 0 8px var(--g-dim); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{box-shadow:0 0 8px var(--g-dim);} 50%{box-shadow:0 0 16px var(--g-dim);} }
  .nav-links { display: flex; gap: clamp(15px,3vw,28px); list-style: none; align-items: center; }
  .nav-link {
    font-family: var(--mono); font-size: 10px; font-weight: 800;
    color: var(--text3); text-transform: uppercase; letter-spacing: 1px;
    transition: color .2s;
  }
  .nav-link::before { content: '['; color: #334155; transition: color .2s; }
  .nav-link::after  { content: ']'; color: #334155; transition: color .2s; }
  .nav-link:hover, .nav-link.active { color: #fff; }
  .nav-link:hover::before, .nav-link:hover::after,
  .nav-link.active::before, .nav-link.active::after { color: var(--g-dim); }
  .nav-cta {
    font-family: var(--mono); font-size: 10px; font-weight: 900;
    color: var(--g-dim); text-transform: uppercase; letter-spacing: 1px;
    padding: 6px 14px; border: 1px solid var(--g-dim); border-radius: 4px;
    transition: all .3s; white-space: nowrap;
  }
  .nav-cta:hover { background: var(--g-dim); color: #fff; box-shadow: 0 4px 14px rgba(0,168,84,.4); }

  /* ── DROPDOWN ──────────────────────────────────────────────── */
  .dropdown { position: relative; cursor: pointer; }
  .dropdown-menu {
    display: none; position: absolute; top: calc(100% + 8px); left: 0;
    background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    padding: 8px 0; min-width: 280px; z-index: 1001;
    box-shadow: 0 20px 40px rgba(0,0,0,.5); flex-direction: column; list-style: none;
  }
  .dropdown:hover .dropdown-menu { display: flex; }
  .dropdown-menu .nav-link { display: block; padding: 10px 16px; font-size: 10px; color: var(--text3); }
  .dropdown-menu .nav-link::before, .dropdown-menu .nav-link::after { content: ''; }
  .dropdown-menu .nav-link:hover { color: #fff; background: rgba(0,168,84,.1); }
  .nav-sub { display: block; font-size: 10px; font-weight: 400; color: var(--text4);
    letter-spacing: 0; text-transform: none; margin-top: 2px; font-family: 'Inter',sans-serif; }

  /* ── LAYOUT ────────────────────────────────────────────────── */
  .page-wrap { max-width: var(--max-w); margin: 0 auto; padding: 0 24px 80px; }

  /* ── BREADCRUMBS ───────────────────────────────────────────── */
  .breadcrumbs {
    display: flex; gap: 6px; align-items: center;
    font-family: var(--mono); font-size: 10px; color: var(--text4);
    padding: 20px 0 12px; flex-wrap: wrap;
  }
  .breadcrumbs a { color: var(--text4); transition: color .15s; }
  .breadcrumbs a:hover { color: var(--g); }
  .bc-sep { color: #334155; }
  .bc-current { color: var(--text3); }

  /* ── HERO ──────────────────────────────────────────────────── */
  .hero {
    padding: 56px 28px 44px; text-align: center;
    border: 1px solid var(--border); border-radius: 14px;
    background: var(--bg); position: relative; overflow: hidden;
    margin-bottom: 44px;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(ellipse 100% 60% at 50% -5%, rgba(0,200,100,.06) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 80% 100%, rgba(125,211,252,.04) 0%, transparent 50%);
  }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--g-bg); border: 1px solid var(--g-border);
    border-radius: 100px; padding: 7px 18px; margin-bottom: 28px; position: relative;
  }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--g);
    box-shadow: 0 0 10px var(--g); animation: pulse-g 2s infinite; }
  @keyframes pulse-g { 0%,100%{opacity:1;} 50%{opacity:.4;} }
  .eyebrow-txt { font-family: var(--mono); font-size: 10px; font-weight: 700;
    letter-spacing: .14em; text-transform: uppercase; color: var(--g); }
  .hero h1 {
    font-size: clamp(26px, 5vw, 52px); font-weight: 900;
    color: var(--text); letter-spacing: -.04em; line-height: .94;
    margin: 0 auto 20px; max-width: 780px; position: relative;
  }
  .h1-g { color: var(--g); }
  .h1-sky { color: var(--sky); }
  .hero-deck {
    font-size: clamp(15px, 2vw, 18px); color: var(--text3);
    max-width: 600px; margin: 0 auto 28px; line-height: 1.8; position: relative;
  }
  .hero-deck strong { color: var(--text2); font-weight: 600; }

  /* ── QUICK ANSWER BOX ──────────────────────────────────────── */
  .quick-answer {
    background: var(--g-bg); border: 1.5px solid var(--g-border);
    border-radius: 12px; padding: 20px 24px; margin-bottom: 40px;
    text-align: left;
  }
  .qa-label { font-family: var(--mono); font-size: 9px; font-weight: 700;
    letter-spacing: .16em; text-transform: uppercase; color: var(--g); margin-bottom: 10px; display: block; }
  .quick-answer p { font-size: 14px; color: var(--text2); line-height: 1.7; }
  .quick-answer p strong { color: var(--text); }

  /* ── STAT STRIP ────────────────────────────────────────────── */
  .stats {
    display: grid; grid-template-columns: repeat(4,1fr);
    gap: 1px; background: var(--border);
    border: 1px solid var(--border); border-radius: 10px;
    overflow: hidden; margin: 0 auto 28px; max-width: 680px; position: relative;
  }
  .stat { background: var(--bg); padding: 14px 10px; text-align: center; }
  .stat-v { font-family: var(--mono); font-size: 18px; font-weight: 700; line-height: 1; display: block; }
  .sv-g   { color: var(--g); }
  .sv-sky { color: var(--sky); }
  .sv-a   { color: var(--amber); }
  .sv-p   { color: var(--purple); }
  .stat-l { font-family: var(--mono); font-size: 9px; letter-spacing: .1em;
    text-transform: uppercase; color: var(--text4); margin-top: 5px; display: block; }

  /* ── PARTNER STRIP ─────────────────────────────────────────── */
  .partner-strip {
    display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;
    margin-bottom: 28px; position: relative;
  }
  .p-badge {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--mono); font-size: 10px; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase;
    padding: 7px 14px; border-radius: 6px; text-decoration: none;
    transition: transform .2s, box-shadow .2s;
  }
  .p-badge:hover { transform: translateY(-2px); }
  .pb-g   { background: var(--g-bg); border: 1px solid var(--g-border); color: var(--g); }
  .pb-sky { background: var(--sky-bg); border: 1px solid var(--sky-border); color: var(--sky); }
  .pb-p   { background: var(--purple-bg); border: 1px solid var(--purple-border); color: var(--purple); }
  .pb-a   { background: var(--amber-bg); border: 1px solid var(--amber-border); color: var(--amber); }
  .pb-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; opacity: .7; }

  /* ── HERO CTAs ─────────────────────────────────────────────── */
  .hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; position: relative; }
  .btn {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 14px; font-weight: 700; padding: 12px 22px;
    border-radius: 7px; transition: all .2s; min-height: 44px; white-space: nowrap;
    text-decoration: none;
  }
  .btn-g   { background: var(--g); color: #020617; }
