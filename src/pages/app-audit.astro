  } else if (r.v === 'CHECK_CHEAPER' && r.sm > 0) {
    html += '<div class="igrid"><div class="iblk"><div class="iblabel">Potential saving</div><div class="ibval cw">$'+Math.round(r.sm).toLocaleString()+'/mo</div><div class="ibsub">if you switch</div></div><div class="iblk"><div class="iblabel">Annual potential</div><div class="ibval cw">$'+Math.round(ann).toLocaleString()+'/yr</div><div class="ibsub">worth evaluating</div></div></div>';
  }
  if ((r.k && r.k.length) || (r.l && r.l.length)) {
    html += '<div class="kl">';
    if (r.k && r.k.length) { html += '<div class="klb klkeep"><div class="kllabel">&#10003; What you keep</div>'; for (var i=0;i<r.k.length;i++) html += '<div class="kli">'+h(r.k[i])+'</div>'; html += '</div>'; }
    if (r.l && r.l.length) { html += '<div class="klb kllose"><div class="kllabel">&#10005; What you lose</div>'; for (var i=0;i<r.l.length;i++) html += '<div class="kli">'+h(r.l[i])+'</div>'; html += '</div>'; }
    html += '</div>';
  }
  if (r.wsk) html += '<div class="wsk"><span class="wsklabel">&#9432; Who should keep this</span>' + h(r.wsk) + '</div>';
  if (r.d > 0) {
    var dl = ['','Easy','Medium','Hard'], dc = ['','easy','medium','hard'];
    html += '<div class="drow"><span class="dlabel">Setup difficulty</span><div class="ddots">';
    for (var d=1;d<=3;d++) html += '<div class="ddot' + (d<=r.d ? ' '+dc[r.d] : '') + '"></div>';
    html += '</div><span class="dtext">'+dl[r.d]+'</span></div>';
  }
  if (r.qw && r.qw.length) {
    html += '<div class="qw"><div class="qwlabel">Quick wins</div>';
    for (var i=0;i<r.qw.length;i++) html += '<div class="qwi"><span class="qwn">'+(i+1)+'.</span><span>'+h(r.qw[i])+'</span></div>';
    html += '</div>';
  }
  html += '<div class="rcactions">';
  if (sUrl) html += '<a href="' + sUrl + '" target="_blank" rel="noopener" class="rcbtn rcprimary" onclick="trk(\'sa_' + (r.sa||'') + '\',\'card\')">View Free Setup Guide &rarr;</a>';
  if (aUrl) html += '<a href="' + aUrl + '" target="_blank" rel="noopener sponsored" class="rcbtn rcsecondary" onclick="trk(\'' + (r.af||'') + '\',\'card\')">Get ' + h(r.rep||'Free Tool') + '</a>';
  html += '</div></div>';
  return html;
}

// Email capture
function buildEC(savings) {
  var sub = savings > 0 ? 'You have got <strong style="color:var(--green)">$' + Math.round(savings*12).toLocaleString() + '/yr</strong> on the table. Get the step-by-step Make.com setup guides sent to your inbox free.' : 'Get step-by-step Make.com blueprints for your Shopify stack sent to your inbox.';
  return '<div class="ecap"><div class="eceyebrow">Free setup guide &mdash; sent to your inbox</div><div class="ectitle">Get the exact blueprints to deploy your free stack.</div><div class="ecsub">'+sub+'</div><div id="ecform"><div class="ecform"><input id="ecemail" class="ecinp" type="email" placeholder="your@email.com" autocomplete="email" onkeydown="if(event.key===\'Enter\')sendEmail()"/><button id="ecbtn" class="ecbtn" onclick="sendEmail()" type="button">Send me the guide &rarr;</button></div><div class="ecdisc">Via Stack Architect newsletter on Beehiiv &middot; Unsubscribe anytime &middot; No spam</div></div><div id="ecsuccess" class="ecsuccess"><span class="ecsicon">&#10003;</span><div class="ecstitle">You are in &mdash; check your inbox.</div><div class="ecssub">Your setup guide is on its way. Start with your biggest win below.</div></div></div>';
}

function sendEmail() {
  var inp = document.getElementById('ecemail');
  var em = inp ? inp.value.trim() : '';
  if (!em || em.indexOf('@') === -1) {
    if (inp) { inp.style.borderColor='var(--red)'; setTimeout(function(){inp.style.borderColor='';},1500); }
    return;
  }
  var btn = document.getElementById('ecbtn');
  if (btn) { btn.disabled=true; btn.textContent='Sending...'; }
  fetch(AFF.beehiiv, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:em})})
    .then(function(){ecOk();}).catch(function(){ecOk();});
  try { gtag('event','email_capture',{event_category:'lead_generation',source_page:'app-audit'}); } catch(e){}
}
function ecOk() {
  var f=document.getElementById('ecform'), s=document.getElementById('ecsuccess');
  if(f) f.style.display='none'; if(s) s.style.display='block';
}

// GA4
function trk(k,p) { try { gtag('event','affiliate_click',{event_category:'affiliate',event_label:k,cta_position:p,source_page:'app-audit'}); } catch(e){} }

// Reset
function reset() {
  sel = {}; rowId = 0;
  var pr = document.getElementById('phase-results'); if(pr) pr.innerHTML = '';
  var ab = document.getElementById('audit-btn'); if(ab) ab.disabled = false;
  document.getElementById('card-chips').style.display = 'block';
  document.getElementById('card-costs').style.display = 'none';
  document.getElementById('total-bar-main').style.display = 'none';
  document.getElementById('ctx-grid').style.display = 'none';
  document.getElementById('audit-btn').style.display = 'none';
  document.getElementById('next-btn').style.display = 'none';
  document.getElementById('sel-summary').style.display = 'none';
  var si = document.getElementById('chip-search'); if(si) si.value = '';
  var lf = document.getElementById('load-fill'); if(lf) lf.style.width = '0%';
  initChips();
  showPhase('input');
  scrollTo();
}

// Nav scroll
window.addEventListener('scroll', function() {
  var n = document.getElementById('main-nav');
  if (n) n.classList.toggle('scrolled', window.scrollY > 50);
}, {passive:true});

// Dropdown mobile
document.querySelectorAll('.dd > .nl').forEach(function(link) {
  link.addEventListener('click', function(e) {
    if (window.innerWidth <= 850) {
      e.preventDefault();
      link.parentElement.classList.toggle('active');
    }
  });
});
var ds = document.createElement('style');
ds.textContent = '.dd.active .ddm{display:flex}';
document.head.appendChild(ds);
document.addEventListener('click', function(e) {
  if (!e.target.closest('.dd')) document.querySelectorAll('.dd').forEach(function(d){d.classList.remove('active');});
});

// Init
var fc = document.getElementById('fcopy');
if (fc) fc.textContent = '\u00a9 ' + new Date().getFullYear() + ' Stack Architect';
initChips();
</script>
</body>
</html>
