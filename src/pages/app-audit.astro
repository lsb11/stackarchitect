// Chips to display by default
var CHIPS = ['Klaviyo','Triple Whale','Gorgias','Loox','Northbeam','Elevar','Omnisend','Zapier','Stocky','Yotpo','Analyzify','Privy','Glew.io','ReCharge','PageFly','ShipStation','Attentive','BeProfit','Shogun','Postscript','LoyaltyLion','Linnworks','Freshdesk','Stamped.io'];

// State
var sel = {}, rowId = 0;

// Escape HTML
function h(s) {
  return String(s).replace(/[&<>"']/g, function(c) {
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  });
}

// Find in KB
function find(name) {
  var n = name.toLowerCase().trim();
  for (var i = 0; i < KB.length; i++) {
    var k = KB[i];
    if (k.n.toLowerCase() === n) return k;
    for (var j = 0; j < k.a.length; j++) {
      if (n.indexOf(k.a[j]) !== -1 || k.a[j].indexOf(n) !== -1) return k;
    }
  }
  return null;
}

// Category fallback
function catFind(name, cost) {
  var n = name.toLowerCase();
  for (var i = 0; i < CAT.length; i++) {
    for (var j = 0; j < CAT[i].kw.length; j++) {
      if (n.indexOf(CAT[i].kw[j]) !== -1) {
        var r = CAT[i];
        return {n:name,p:cost,v:r.v,sa:r.sa,af:r.af,rep:r.rep,sm:Math.min(cost,r.sm),su:r.su,d:r.d,hl:r.hl,ex:r.ex,k:[],l:[],wsk:null,qw:[]};
      }
    }
  }
  return null;
}

// Audit single app
function audit(name, cost) {
  var kb = find(name);
  if (kb) {
    var sav = (kb.v === 'REPLACE_FREE' || kb.v === 'CHECK_CHEAPER') ? Math.min(cost, kb.sm) : 0;
    return {n:name,p:cost,v:kb.v,sa:kb.sa||null,af:kb.af||null,rep:kb.rep||null,sm:sav,su:kb.su||null,d:kb.d||0,hl:kb.hl,ex:kb.ex,k:kb.k||[],l:kb.l||[],wsk:kb.wsk||null,qw:kb.qw||[]};
  }
  var cat = catFind(name, cost);
  if (cat) return cat;
  return {n:name,p:cost,v:'KEEP',sa:null,af:null,rep:null,sm:0,su:null,d:0,
    hl:name+' — no verified free replacement found yet.',
    ex:'We do not have a verified free replacement for '+name+' in our database. Keep using it if it generates value. Email support@stackarchitect.xyz if you think a free alternative exists.',
    k:[],l:[],wsk:null,qw:[]};
}

// Init chips
function initChips() {
  var g = document.getElementById('chip-grid');
  if (!g) return;
  g.innerHTML = '';
  for (var i = 0; i < CHIPS.length; i++) {
    (function(name) {
      var kb = find(name), cost = kb ? kb.p : 0;
      var b = document.createElement('button');
      b.type = 'button';
      b.className = 'chip';
      b.setAttribute('data-name', name);
      b.innerHTML = h(name) + '<span class="chipcost">~$' + cost + '/mo</span>';
      b.addEventListener('click', function() { toggleChip(name, cost, b); });
      g.appendChild(b);
    }(CHIPS[i]));
  }
}

// Toggle chip
function toggleChip(name, cost, el) {
  if (sel.hasOwnProperty(name)) {
    delete sel[name];
    el.classList.remove('on');
  } else {
    sel[name] = cost;
    el.classList.add('on');
  }
  updateSummary();
}

// Update summary bar
function updateSummary() {
  var keys = Object.keys(sel), total = 0;
  for (var i = 0; i < keys.length; i++) total += sel[keys[i]];
  var ss = document.getElementById('sel-summary');
  var nb = document.getElementById('next-btn');
  var sc = document.getElementById('sel-count');
  var st = document.getElementById('sel-total');
  if (keys.length > 0) {
    if (ss) ss.style.display = 'block';
    if (nb) nb.style.display = 'block';
    if (sc) sc.textContent = keys.length;
    if (st) { st.textContent = '$' + Math.round(total).toLocaleString() + ' / mo'; st.className = 'totval' + (total > 499 ? ' high' : ''); }
  } else {
    if (ss) ss.style.display = 'none';
    if (nb) nb.style.display = 'none';
  }
}

// Search
function filterSearch(val) {
  var dd = document.getElementById('search-dd');
  if (!dd) return;
  var q = val.trim().toLowerCase();
  if (!q) { dd.classList.remove('on'); dd.innerHTML = ''; return; }
  var matches = [];
  for (var i = 0; i < KB.length && matches.length < 8; i++) {
    if (KB[i].n.toLowerCase().indexOf(q) !== -1) matches.push(KB[i]);
  }
  dd.innerHTML = '';
  if (!matches.length) {
    var ci = document.createElement('div');
    ci.className = 'sdi';
    ci.innerHTML = h(val) + '<span class="sdi-badge">Add custom</span>';
    (function(v) { ci.addEventListener('click', function() { addCustom(v); }); }(val));
    dd.appendChild(ci);
    dd.classList.add('on');
    return;
  }
  for (var j = 0; j < matches.length; j++) {
    (function(k) {
      var added = sel.hasOwnProperty(k.n);
      var item = document.createElement('div');
      item.className = 'sdi' + (added ? ' added' : '');
      item.innerHTML = '<span>' + h(k.n) + '<span class="sdi-cat">' + h(k.c) + '</span></span><span class="sdi-cost">' + (added ? '&#10003; added' : '$' + k.p + '/mo') + '</span>';
      if (!added) { item.addEventListener('click', function() { pickSearch(k.n, k.p); }); }
      dd.appendChild(item);
    }(matches[j]));
  }
  dd.classList.add('on');
}

function pickSearch(name, cost) {
  sel[name] = cost;
  var c = document.querySelector('.chip[data-name="' + name + '"]');
  if (c) c.classList.add('on');
  var si = document.getElementById('chip-search'); if (si) si.value = '';
  var dd = document.getElementById('search-dd'); if (dd) { dd.classList.remove('on'); dd.innerHTML = ''; }
  updateSummary();
}

function addCustom(name) {
  if (!name.trim()) return;
  if (!sel.hasOwnProperty(name)) sel[name] = 0;
  var si = document.getElementById('chip-search'); if (si) si.value = '';
  var dd = document.getElementById('search-dd'); if (dd) { dd.classList.remove('on'); dd.innerHTML = ''; }
  updateSummary();
}

function searchKey(e) {
  if (e.key === 'Enter') { var v = e.target.value.trim(); if (v) addCustom(v); }
  if (e.key === 'Escape') { var dd = document.getElementById('search-dd'); if (dd) dd.classList.remove('on'); }
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('.swrap')) { var dd = document.getElementById('search-dd'); if (dd) dd.classList.remove('on'); }
});

// Go to cost step
function goToCosts() {
  var list = document.getElementById('app-list');
  if (!list) return;
  list.innerHTML = '';
  rowId = 0;
  var keys = Object.keys(sel);
  if (!keys.length) { showErr('Please select at least one app before continuing.'); return; }
  for (var i = 0; i < keys.length; i++) addRow(keys[i], sel[keys[i]]);
  document.getElementById('card-chips').style.display = 'none';
  document.getElementById('sel-summary').style.display = 'none';
  document.getElementById('next-btn').style.display = 'none';
  document.getElementById('card-costs').style.display = 'block';
  document.getElementById('total-bar-main').style.display = 'flex';
  document.getElementById('ctx-grid').style.display = 'grid';
  document.getElementById('audit-btn').style.display = 'block';
  document.getElementById('s1').className = 'step done';
  document.getElementById('s2').className = 'step active';
  recalc(); scrollTo();
}

function showErr(msg) {
  var e = document.getElementById('errmsg');
  if (!e) return;
  e.textContent = msg;
  e.style.display = 'block';
  setTimeout(function() { e.style.display = 'none'; }, 4000);
}

// Row management
function addRow(name, cost) {
  var id = rowId++, list = document.getElementById('app-list');
  if (!list) return;
  var row = document.createElement('div');
  row.className = 'arow'; row.id = 'row-' + id;
  row.innerHTML = '<input class="ainp" type="text" placeholder="App name" value="' + h(String(name||'')) + '" oninput="recalc()" autocomplete="off"/>' +
    '<div class="cwrap"><input class="ainp" type="number" placeholder="0" value="' + (cost||'') + '" min="0" step="1" oninput="recalc()"/></div>' +
    '<button class="rmbtn" type="button" onclick="removeRow(' + id + ')">&times;</button>';
  list.appendChild(row); recalc();
}
function removeRow(id) { var e = document.getElementById('row-' + id); if (e) e.remove(); recalc(); }
function getApps() {
  var rows = document.querySelectorAll('#app-list .arow'), apps = [];
  for (var i = 0; i < rows.length; i++) {
    var inp = rows[i].querySelectorAll('.ainp');
    var name = inp[0].value.trim(), cost = parseFloat(inp[1].value) || 0;
    if (name) apps.push({name:name, cost:cost});
  }
  return apps;
}
function recalc() {
  var apps = getApps(), total = 0;
  for (var i = 0; i < apps.length; i++) total += apps[i].cost;
  var el = document.getElementById('total-main');
  if (!el) return;
  el.textContent = '$' + Math.round(total).toLocaleString() + ' / mo';
  el.className = 'totval' + (total === 0 ? ' zero' : total > 499 ? ' high' : '');
}

// Phase control
function showPhase(p) {
  var ps = ['input','loading','results'];
  for (var i = 0; i < ps.length; i++) {
    var el = document.getElementById('phase-' + ps[i]);
    if (el) el.className = 'phase' + (ps[i] === p ? ' on' : '');
  }
  var s1 = document.getElementById('s1'), s2 = document.getElementById('s2'), s3 = document.getElementById('s3');
  if (p === 'input')   { s1.className = 'step active'; s2.className = 'step'; s3.className = 'step'; }
  if (p === 'loading') { s1.className = 'step done'; s2.className = 'step active'; s3.className = 'step'; }
  if (p === 'results') { s1.className = 'step done'; s2.className = 'step done'; s3.className = 'step active'; }
}
function scrollTo() {
  var t = document.getElementById('step-bar');
  if (!t) return;
  var nav = document.getElementById('main-nav');
  var off = nav ? nav.offsetHeight : 60;
  window.scrollTo({ top: t.getBoundingClientRect().top + window.pageYOffset - off - 16, behavior: 'smooth' });
}

// Loading animation
function loadAnim(cb) {
  showPhase('loading');
  var pct = 0, mi = 0;
  var msgs = ['Matching apps to database...','Calculating savings...','Scoring your stack...','Building action plan...'];
  var fill = document.getElementById('load-fill');
  var stat = document.getElementById('load-status');
  var iv = setInterval(function() {
    pct = Math.min(pct + 25, 100);
    if (fill) fill.style.width = pct + '%';
    if (stat && mi < msgs.length) stat.textContent = msgs[mi++];
    if (pct >= 100) { clearInterval(iv); setTimeout(cb, 200); }
  }, 160);
}

// Main audit
function runAudit() {
  var apps = getApps();
  if (!apps.length) { showErr('Please add at least one app before running the audit.'); return; }
  var btn = document.getElementById('audit-btn');
  if (btn) btn.disabled = true;
  var total = 0;
  for (var i = 0; i < apps.length; i++) total += apps[i].cost;
  try { gtag('event','audit_started',{event_category:'tool_engagement',app_count:apps.length,total_spend:Math.round(total),source_page:'app-audit'}); } catch(e){}
  loadAnim(function() {
    var results = [];
    for (var i = 0; i < apps.length; i++) results.push(audit(apps[i].name, apps[i].cost));
    var ts = 0, rc = 0;
    for (var j = 0; j < results.length; j++) { ts += results[j].sm || 0; if (results[j].v === 'REPLACE_FREE') rc++; }
    try { gtag('event','audit_completed',{event_category:'tool_engagement',app_count:apps.length,replace_count:rc,total_savings:Math.round(ts),annual_savings:Math.round(ts*12),source_page:'app-audit'}); } catch(e){}
    renderResults(results, total);
  });
}

// Render results
function renderResults(results, totalSpend) {
  var ts = 0, rc = 0, cc = 0, kc = 0;
  for (var i = 0; i < results.length; i++) {
    ts += results[i].sm || 0;
    if (results[i].v === 'REPLACE_FREE') rc++;
    else if (results[i].v === 'CHECK_CHEAPER') cc++;
    else kc++;
  }
  var remaining = Math.max(0, totalSpend - ts);
  var annual = ts * 12;
  var rf = results.length ? rc / results.length : 0;
  var cf = results.length ? cc / results.length : 0;
  var score = Math.max(5, Math.min(100, Math.round(100 - rf*60 - cf*25)));
  var grade = score >= 75 ? 'A' : score >= 45 ? 'B' : 'C';
  var gc = grade === 'A' ? 'ga' : grade === 'B' ? 'gb' : 'gc';
  var gm = grade === 'A' ? 'Your stack is reasonably lean. Focus on the recommendations below to optimise further.'
    : grade === 'B' ? 'Your stack has meaningful savings available. The action plan below will recover significant monthly spend.'
    : 'Your stack has significant overspend. The free replacements below could transform your margins.';
  var sorted = results.slice().sort(function(a,b) { var o={REPLACE_FREE:0,CHECK_CHEAPER:1,KEEP:2}; return (o[a.v]||0)-(o[b.v]||0); });
  var topAct = [];
  for (var i = 0; i < sorted.length && topAct.length < 4; i++) { if (sorted[i].v === 'REPLACE_FREE') topAct.push(sorted[i]); }

  var html = '<div class="reyebrow">// Audit complete &mdash; ' + results.length + ' app' + (results.length > 1 ? 's' : '') + ' analysed</div>';
  html += '<div class="rtitle">' + (rc > 0 ? rc + ' app' + (rc > 1 ? 's' : '') + ' you can replace for <span style="color:var(--green)">$0</span>.' : 'Here is your full stack analysis.') + '</div>';
  html += '<div class="tiles"><div class="tile"><div class="tv cr">$' + Math.round(totalSpend).toLocaleString() + '</div><div class="tl">Current / mo</div></div><div class="tile"><div class="tv cg">$' + Math.round(ts).toLocaleString() + '</div><div class="tl">Recoverable / mo</div></div><div class="tile"><div class="tv cw">$' + Math.round(remaining).toLocaleString() + '</div><div class="tl">Remaining / mo</div></div></div>';
  html += '<div class="scorebar"><div class="ring ' + gc + '">' + grade + '</div><div class="sbody"><div class="slabel">Stack Efficiency Score</div><div class="shead">' + score + '/100 &mdash; Grade ' + grade + '</div><div class="ssub">' + gm + '</div><div class="sbd"><span class="sstat"><strong style="color:var(--green)">' + rc + '</strong> replaceable</span><span class="sstat"><strong style="color:var(--warn)">' + cc + '</strong> worth reviewing</span><span class="sstat"><strong style="color:var(--muted)">' + kc + '</strong> worth keeping</span>' + (annual > 0 ? '<span class="sstat"><strong style="color:var(--green)">$' + Math.round(annual).toLocaleString() + '/yr</strong> annual saving</span>' : '') + '</div></div></div>';
  if (annual > 0) {
    html += '<div class="rbanner"><span class="rblabel">Annual recovery</span><span class="rbval">$' + Math.round(annual).toLocaleString() + ' / yr</span><span class="rbsub">Deploy the free alternatives below and keep this in your business.</span><a href="' + AFF.make + '" target="_blank" rel="noopener sponsored" class="rbbtn" onclick="trk(\'make\',\'banner\')">Start for Free &rarr;</a></div>';
  }
  html += buildEC(ts);
  if (topAct.length > 0) {
    html += '<div class="sl">// Priority action plan &mdash; do these first</div><div class="ckl"><div class="ckltitle">&#9889; Highest-impact replacements, in order</div>';
    for (var i = 0; i < topAct.length; i++) {
      var r = topAct[i];
      var link = (r.sa && SA[r.sa]) ? SA[r.sa] : (r.af && AFF[r.af]) ? AFF[r.af] : '#';
      html += '<div class="cki"><span class="cknum">' + (i+1) + '</span><div class="ckbody"><div class="ckaction">' + h(r.n) + ' &rarr; ' + h(r.rep||'Free alternative') + '</div><div class="ckdetail">' + (r.su ? '~'+h(r.su)+' to deploy' : 'Quick setup') + (r.ex ? ' &middot; ' + h(r.ex.split('.')[0]+'.') : '') + '</div>' + (r.sm > 0 ? '<div class="cksaving">Saves $' + Math.round(r.sm).toLocaleString() + '/mo &mdash; $' + Math.round(r.sm*12).toLocaleString() + '/yr</div>' : '') + '</div><a href="' + link + '" target="_blank" rel="noopener sponsored" class="rcbtn rcprimary" style="margin-left:auto;flex-shrink:0;align-self:center;" onclick="trk(\'' + (r.af||'sa') + '\',\'checklist\')">Start &rarr;</a></div>';
    }
    html += '</div>';
  }
  html += '<div class="sl">// Full app-by-app breakdown</div>';
  for (var i = 0; i < sorted.length; i++) html += renderCard(sorted[i], i);
  html += '<div class="bcta"><div class="bctaey">// Full deployment guides</div><div class="bctat">Get the complete $0 automation stack</div><div class="bctas">All six free tools, step-by-step Make.com blueprints, and setup guides &mdash; free forever.</div><a href="' + AFF.make + '" target="_blank" rel="noopener sponsored" class="bctabtn" onclick="trk(\'make\',\'bottom_cta\')">Get Make.com Free &rarr;</a></div>';
  html += '<div class="rwrap"><button class="rbtn" type="button" onclick="reset()">&larr; Run another audit</button></div>';
  html += '<div class="affnotice">Affiliate links keep this tool free &mdash; at no extra cost to you.<br><a href="https://www.stackarchitect.xyz/privacy" style="color:var(--hint);text-decoration:underline;">Privacy policy</a></div>';
  var el = document.getElementById('phase-results');
  if (el) el.innerHTML = html;
  showPhase('results');
  scrollTo();
}

// Render single card
function renderCard(r, idx) {
  var cls = r.v === 'REPLACE_FREE' ? 'free' : r.v === 'KEEP' ? 'keep' : 'check';
  var bc  = r.v === 'REPLACE_FREE' ? 'bfree' : r.v === 'KEEP' ? 'bkeep' : 'bcheck';
  var bt  = r.v === 'REPLACE_FREE' ? 'Replace Free' : r.v === 'KEEP' ? 'Worth Keeping' : 'Review Cost';
  var sUrl = r.sa && SA[r.sa] ? SA[r.sa] : null;
  var aUrl = r.af && AFF[r.af] ? AFF[r.af] : null;
  var ann  = (r.sm || 0) * 12;
  var html = '<div class="rcard ' + cls + '" style="animation-delay:' + (idx*50) + 'ms">';
