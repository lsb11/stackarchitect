---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const SITE    = 'https://www.stackarchitect.xyz';
const pageUrl = `${SITE}/blog/google-apps-script-quotas-explained-how-to-avoid-limits-and-scale-your-automations`;

// Improved title targets the exact queries driving 11,313 impressions:
// "execution time limit 6 minutes consumer accounts 2026" (top query cluster)
const title       = 'Google Apps Script Execution Time Limit 2026 — Official Quotas for Consumer & Workspace';
const description = 'Google Apps Script execution time limit is 6 minutes for consumer accounts in 2026. Full official quota table: daily runtime, UrlFetch caps, email limits, and the structural fix for Autocrat workflows that hit them.';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: title,
      description,
      url: pageUrl,
      datePublished: '2026-03-22',
      dateModified:  '2026-04-14',
      mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
      author:    { '@type': 'Organization', name: 'Stack Architect', url: SITE },
      publisher: { '@type': 'Organization', name: 'Stack Architect', url: SITE },
      inLanguage: 'en-GB',
      speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.answer-box', '.quota-numbers', '.faq-wrap'] },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',   item: SITE },
        { '@type': 'ListItem', position: 2, name: 'Guides', item: `${SITE}/shopify-automation-guides` },
        { '@type': 'ListItem', position: 3, name: 'Google Apps Script Quotas 2026' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: 'What is the Google Apps Script execution time limit in 2026?',    acceptedAnswer: { '@type': 'Answer', text: 'Consumer (free) Google accounts are capped at 6 minutes per execution. Google Workspace accounts get 30 minutes per execution. Scripts that exceed the limit are hard-stopped mid-run with no graceful shutdown.' } },
        { '@type': 'Question', name: 'What is the daily runtime limit for Google Apps Script in 2026?', acceptedAnswer: { '@type': 'Answer', text: 'Consumer accounts get 90 minutes of combined runtime per day. Google Workspace accounts get 6 hours per day. Quotas reset at midnight Pacific Time.' } },
        { '@type': 'Question', name: 'What is the Google Apps Script UrlFetch daily limit?',            acceptedAnswer: { '@type': 'Answer', text: 'Consumer accounts can make 20,000 UrlFetch calls per day. Google Workspace accounts get 100,000 per day.' } },
        { '@type': 'Question', name: 'Can Google Apps Script quotas be increased?',                     acceptedAnswer: { '@type': 'Answer', text: 'No. The limits are set by Google at the infrastructure level and cannot be increased by request, payment, or configuration. The only way to operate above the hard ceilings is to move the work outside of Apps Script execution.' } },
        { '@type': 'Question', name: 'Why does my script work in the morning but fail in the afternoon?',acceptedAnswer: { '@type': 'Answer', text: 'This is the clearest sign of a daily quota problem. Your automations are exhausting the 90-minute daily runtime in the first half of the day, leaving nothing for afternoon processing. The quota resets at midnight Pacific Time.' } },
        { '@type': 'Question', name: 'Have Google Apps Script quotas changed for 2026?',                acceptedAnswer: { '@type': 'Answer', text: 'The core limits — 6-minute consumer execution, 30-minute Workspace execution, 90-minute daily consumer runtime — have remained consistent. If you are seeing new failures in 2026, it is more likely that your volume has grown into the limits rather than that Google has tightened them.' } },
      ],
    },
    {
      '@type': 'HowTo',
      name: 'How to Stay Under Google Apps Script Quotas Without Breaking Your Workflow',
      description: 'Six techniques to reduce quota pressure and sustain medium-volume automations on consumer Google accounts.',
      step: [
        { '@type': 'HowToStep', position: 1, name: 'Batch smaller chunks',          text: 'Process 50–100 rows per run instead of everything at once.' },
        { '@type': 'HowToStep', position: 2, name: 'Reduce API calls aggressively', text: 'Cache sheet values at the start using getValues() once, operate in memory, then write back with a single setValues() call.' },
        { '@type': 'HowToStep', position: 3, name: 'Stagger time-based triggers',   text: 'Separate triggers by at least 5–10 minutes to prevent overlapping executions.' },
        { '@type': 'HowToStep', position: 4, name: 'Persist state',                 text: 'Save progress checkpoints with PropertiesService so a timed-out script can resume.' },
        { '@type': 'HowToStep', position: 5, name: 'Add exponential backoff',       text: 'When a service call fails, wait and retry with increasing delays.' },
        { '@type': 'HowToStep', position: 6, name: 'Use LockService deliberately',  text: 'Acquire a lock at the start of any execution touching shared spreadsheet data.' },
      ],
    },
  ],
};
