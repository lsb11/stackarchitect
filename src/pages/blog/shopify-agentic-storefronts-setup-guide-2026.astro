  <!-- JSON-LD Schema: Article + HowTo + FAQPage + BreadcrumbList -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "headline": "Shopify Agentic Storefronts 2026 — Sell on ChatGPT & Google AI Mode (Complete Setup Guide)",
        "description": "Shopify stores can now sell directly inside ChatGPT, Google AI Mode, and Copilot. Complete free setup guide — eligibility requirements, Knowledge Base App, product data optimisation, and what to do if you're not eligible yet.",
        "datePublished": "2026-03-21",
        "dateModified": "2026-03-31",
        "author": {"@type": "Organization", "name": "Stack Architect", "url": "https://stackarchitect.xyz"},
        "publisher": {"@type": "Organization", "name": "Stack Architect", "url": "https://stackarchitect.xyz"},
        "mainEntityOfPage": {"@type": "WebPage", "@id": "https://stackarchitect.xyz/blog/shopify-agentic-storefronts-setup-guide-2026"},
        "url": "https://stackarchitect.xyz/blog/shopify-agentic-storefronts-setup-guide-2026",
        "inLanguage": "en-GB",
        "image": "https://d1yei2z3i6k35z.cloudfront.net/16370908/69a093a668d36_Gemini_Generated_Image_3i6wmo3i6wmo3i6w.png",
        "articleSection": "AI & Automation",
        "keywords": ["shopify agentic storefronts","shopify chatgpt setup","shopify google ai mode","shopify sell on chatgpt","agentic storefronts setup guide 2026","shopify agentic commerce","shopify AI sales channel","shopify knowledge base app","shopify winter 26 edition"]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stackarchitect.xyz"},
          {"@type": "ListItem", "position": 2, "name": "Blog", "item": "https://stackarchitect.xyz/blog"},
          {"@type": "ListItem", "position": 3, "name": "Shopify Agentic Storefronts Setup Guide 2026", "item": "https://stackarchitect.xyz/blog/shopify-agentic-storefronts-setup-guide-2026"}
        ]
      },
      {
        "@type": "HowTo",
        "name": "How to Set Up Shopify Agentic Storefronts in 2026",
        "description": "Complete step-by-step guide to enabling Shopify Agentic Storefronts for ChatGPT, Google AI Mode, and Microsoft Copilot.",
        "totalTime": "PT45M",
        "step": [
          {"@type": "HowToStep", "position": 1, "name": "Check Eligibility", "text": "Go to Shopify Admin → Settings → Apps and sales channels. Look for an Agentic Storefronts section. If visible, your store is eligible. Currently requires a US-based store selling to US customers."},
          {"@type": "HowToStep", "position": 2, "name": "Add Store Policies", "text": "Ensure your store has Terms of Service, Privacy Policy, and Refund Policy added. Go to Settings → Policies. These are required before you can activate Agentic Storefronts."},
          {"@type": "HowToStep", "position": 3, "name": "Install the Knowledge Base App", "text": "Search 'Knowledge Base' in the Shopify App Store. Free for Shopify Plus. $50/month for standard plans. Activate and create your first knowledge base with FAQs, return policies, and brand voice guidelines."},
          {"@type": "HowToStep", "position": 4, "name": "Optimise Your Product Catalog", "text": "Ensure every product has a complete title, detailed description, all variants defined, accurate pricing, current inventory, and high-quality images. Add relevant metafields."},
          {"@type": "HowToStep", "position": 5, "name": "Enable Agentic Storefront Channels", "text": "Go to Settings → Apps and sales channels → Agentic Storefronts. Agree to Supplemental Terms. Toggle on each AI channel: ChatGPT, Google AI Mode and Gemini, Microsoft Copilot."},
          {"@type": "HowToStep", "position": 6, "name": "Verify and Monitor", "text": "Go to Agentic Storefronts → Test Agent to verify products appear correctly. Monitor AI-attributed orders in your Orders list, filtered by channel."}
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What are Shopify Agentic Storefronts?",
            "acceptedAnswer": {"@type": "Answer", "text": "Shopify Agentic Storefronts allow customers to discover and purchase your products directly inside AI platforms like ChatGPT, Google AI Mode and Gemini, and Microsoft Copilot — without leaving the conversation. Launched as part of Shopify's Winter '26 Edition, they connect your Shopify product catalog to AI platforms through a single setup in your Shopify admin, with no separate integrations required. Orders appear in your Shopify admin with full channel attribution."}
          },
          {
            "@type": "Question",
            "name": "Who is eligible for Shopify Agentic Storefronts?",
            "acceptedAnswer": {"@type": "Answer", "text": "As of March 2026, Agentic Storefronts are in early access and require: (1) A US-based store selling to US customers; (2) Store policies including Terms of Service; (3) Guest checkout enabled; (4) Agreement to the Shopify Agentic Storefronts Supplemental Terms of Service. Sign up for early access at shopify.com/chatgpt."}
          },
          {
            "@type": "Question",
            "name": "Is the Shopify Knowledge Base App free?",
            "acceptedAnswer": {"@type": "Answer", "text": "The Knowledge Base App is free for Shopify Plus merchants. For standard Shopify plans (Basic, Shopify, Advanced), it costs $50/month. It is only visible to AI agents — it does not appear on your storefront."}
          },
          {
            "@type": "Question",
            "name": "Can customers still find my products on ChatGPT if I don't enable Agentic Storefronts?",
            "acceptedAnswer": {"@type": "Answer", "text": "Yes. Your products can still be discovered via web crawling and Shopify Catalog. The difference is checkout: with Agentic Storefronts active, customers can purchase directly inside the AI chat. Without it, they are redirected to your store."}
          },
          {
            "@type": "Question",
            "name": "What are the limitations of Shopify Agentic Storefronts?",
            "acceptedAnswer": {"@type": "Answer", "text": "Key limitations as of March 2026: (1) US-only; (2) No Google Analytics or custom pixel tracking in agentic checkout — only server-side pixels fire; (3) Subscriptions and product bundles are not supported; (4) Discount codes may not work; (5) Some checkout blocks do not display; (6) Local delivery and store pickup are not available."}
          },
          {
            "@type": "Question",
            "name": "What should I do if my store isn't eligible for Agentic Storefronts yet?",
            "acceptedAnswer": {"@type": "Answer", "text": "Four things to do now: (1) Install and populate the Knowledge Base App; (2) Clean your product catalog — complete titles, detailed descriptions, all variants, accurate pricing; (3) Add FAQ schema markup to your blog posts and product pages; (4) Sign up at shopify.com/chatgpt to be notified when your store becomes eligible."}
          }
        ]
      }
    ]
  }
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; overscroll-behavior-x: none; -webkit-font-smoothing: antialiased; }
    body { margin: 0; background: #020617; color: #94a3b8; font-family: 'Inter', -apple-system, sans-serif; }
    a { text-decoration: none; }
    h1,h2,h3,h4,h5,h6 { margin: 0; font-weight: normal; }
    p { margin: 0; }
    ul { margin: 0; }

    /* ── NAV ── */
    .product-terminal-bar {
      width: 100%; background: #020617; padding: 12px 0;
      border-bottom: 1px solid #1e293b; position: sticky; top: 0;
      z-index: 10002; transition: all .3s ease;
    }
    .product-terminal-bar.scrolled {
      background: rgba(2,6,23,.95); backdrop-filter: blur(12px);
      padding: 8px 0; border-bottom: 1px solid rgba(0,168,84,.3);
      box-shadow: 0 4px 20px rgba(0,0,0,.4);
    }
    .terminal-container {
      max-width: 1100px; margin: 0 auto; display: flex;
      justify-content: space-between; align-items: center;
      padding: 0 24px; box-sizing: border-box;
    }
    .terminal-status {
      display: flex; align-items: center; gap: 10px;
      font-family: 'JetBrains Mono', monospace; font-size: 9px;
      color: #475569; letter-spacing: 1.5px; font-weight: 800;
    }
    .status-indicator {
      width: 5px; height: 5px; background: #00a854; border-radius: 50%;
      box-shadow: 0 0 8px #00a854; animation: statusPulse 2s infinite;
    }
    @keyframes statusPulse {
      0%,100% { box-shadow: 0 0 8px #00a854; }
      50%      { box-shadow: 0 0 16px #00a854; }
    }
    .product-access-grid {
      display: flex; gap: clamp(15px,3vw,30px); list-style: none;
      margin: 0; padding: 0; align-items: center;
    }
    .product-link {
      font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 800;
      color: #94a3b8; text-decoration: none; text-transform: uppercase;
      letter-spacing: 1px; transition: all .3s cubic-bezier(.16,1,.3,1);
      display: flex; align-items: center; gap: 4px;
    }
    .product-link::before { content: '['; color: #334155; transition: color .3s; }
    .product-link::after  { content: ']'; color: #334155; transition: color .3s; }
    .product-link:hover, .product-link.is-active { color: #fff; transform: translateY(-1px); }
    .product-link:hover::before, .product-link:hover::after,
    .product-link.is-active::before, .product-link.is-active::after { color: #00a854; }
    .product-link.is-active { color: #00a854; }
    .dropdown { position: relative; cursor: pointer; }
    .dropdown-menu {
      display: none; position: absolute; top: calc(100% + 8px); left: 0;
      background: #020617; border: 1px solid #1e293b; border-radius: 6px;
      padding: 8px 0; min-width: 280px; z-index: 10003; flex-direction: column;
      list-style: none; margin: 0; box-shadow: 0 20px 40px rgba(0,0,0,.5);
    }
    .dropdown-menu .product-link::before, .dropdown-menu .product-link::after { content: ''; }
    .dropdown-menu .product-link {
      display: block; padding: 10px 16px; font-size: 10px; color: #94a3b8; transition: all .15s;
    }
    .dropdown-menu .product-link:hover { color: #fff; background: rgba(0,168,84,.1); transform: none; }
    .dropdown-desc {
      display: block; font-family: 'Inter', -apple-system, sans-serif; font-size: 10px;
      font-weight: 400; color: #475569; letter-spacing: 0; text-transform: none;
      margin-top: 2px; line-height: 1.4;
    }
    @media (min-width: 851px) { .dropdown:hover .dropdown-menu { display: flex; } }
    .terminal-cta { display: flex; align-items: center; margin-left: 20px; }
    .savings-ticker {
      font-family: 'JetBrains Mono', monospace; font-size: 8px; font-weight: 800;
      color: #00a854; letter-spacing: 1px; margin-right: 12px; white-space: nowrap; opacity: .8;
    }
    .cta-node {
      font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 900;
      color: #00a854; text-decoration: none; text-transform: uppercase;
      padding: 6px 14px; border: 1px solid #00a854; border-radius: 4px;
      transition: all .3s cubic-bezier(.175,.885,.32,1.275); display: inline-block; white-space: nowrap;
    }
    .cta-node:hover { background: #00a854; color: #fff; box-shadow: 0 6px 20px rgba(0,168,84,.5); transform: scale(1.05); }
    @media (max-width: 850px) {
      .terminal-status, .savings-ticker { display: none; }
      .terminal-container { flex-direction: column; gap: 15px; }
      .product-access-grid { display: grid; grid-template-columns: repeat(2, auto); gap: 12px 20px; }
      .terminal-cta { margin-left: 0; order: -1; width: 100%; justify-content: center; }
      .cta-node { background: #00a854; color: #fff; width: 80%; text-align: center; }
    }

    /* ── BREADCRUMB ── */
    .sa-breadcrumb {
      max-width: 1100px; margin: 0 auto; padding: 10px 24px;
      display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
      font-family: 'Inter', sans-serif; font-size: 12px; color: #64748b;
    }
    .sa-breadcrumb a { color: #64748b; text-decoration: none; transition: color .2s; }
    .sa-breadcrumb a:hover { color: #f1f5f9; }
    .sa-breadcrumb .bc-sep { color: #334155; }
    .sa-breadcrumb .bc-current { color: #94a3b8; }

    /* ── BLOG TITLE BAND ── */
    .blog-title-band {
      background: rgb(2,6,23); padding: 40px 24px 0; text-align: center;
    }
    .blog-title-band h1 {
      font-family: 'Inter', sans-serif; font-size: 32px; font-weight: 700;
      color: #fff; max-width: 900px; margin: 0 auto; line-height: 1.2;
    }
    @media (max-width: 600px) { .blog-title-band h1 { font-size: 20px; } }

    /* ── ARTICLE WRAPPER ── */
    .article-outer {
      background: rgb(2,6,23); padding: 40px 40px 80px;
    }
    @media (max-width: 600px) { .article-outer { padding: 5px 5px 60px; } }

    /* ── SA-AGENTIC COMPONENT ── */
    .sa-agentic {
      font-family: 'Inter', -apple-system, sans-serif; color: #94a3b8;
      line-height: 1.75; -webkit-font-smoothing: antialiased;
      background: transparent; max-width: 900px; margin: 0 auto;
      --bg:     #020617; --bg-2:   #06101e; --bg-3:   #0a1628; --bg-4:   #0f1f35;
      --border:   #1e293b; --border-2: #263548;
      --text:   #f1f5f9; --text-2: #cbd5e1; --text-3: #94a3b8; --text-4: #64748b;
      --g:        #00c864; --g-dim:    #00a854; --g-bg: rgba(0,200,100,.08); --g-border: rgba(0,200,100,.2);
      --sky:      #7dd3fc; --sky-bg: rgba(125,211,252,.07); --sky-border: rgba(125,211,252,.18);
      --amber:    #fcd34d; --amber-bg: rgba(252,211,77,.08); --amber-border: rgba(252,211,77,.2);
      --red:      #fc8181; --red-bg: rgba(252,129,129,.07); --red-border: rgba(252,129,129,.18);
      --purple:   #c4b5fd; --purple-bg: rgba(196,181,253,.07); --purple-border: rgba(196,181,253,.18);
      --mono: 'JetBrains Mono', monospace;
    }
    .sa-agentic .hero {
      padding: 60px 24px 44px; text-align: center; position: relative;
      overflow: hidden; background: var(--bg); border-radius: 14px;
      border: 1px solid var(--border); margin-bottom: 44px;
    }
    .sa-agentic .hero::before {
      content: ''; position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(ellipse 100% 60% at 50% -5%, rgba(196,181,253,.08) 0%, transparent 55%),
                  radial-gradient(ellipse 50% 40% at 20% 100%, rgba(0,200,100,.04) 0%, transparent 50%);
    }
    .sa-agentic .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      background: rgba(196,181,253,.06); border: 1px solid var(--purple-border);
      border-radius: 100px; padding: 7px 18px; margin-bottom: 28px; position: relative;
    }
    .sa-agentic .hero-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--purple);
      box-shadow: 0 0 10px var(--purple); animation: pulse-p 2s infinite;
    }
    @keyframes pulse-p { 0%,100%{opacity:1;box-shadow:0 0 10px var(--purple);} 50%{opacity:.4;box-shadow:0 0 4px var(--purple);} }
    .sa-agentic .hero-eyebrow-txt {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .14em; text-transform: uppercase; color: var(--purple);
    }
    .sa-agentic .hero h1 {
      font-size: clamp(26px, 5.2vw, 54px); font-weight: 900; color: var(--text);
      letter-spacing: -.04em; line-height: .94; margin: 0 auto 20px; max-width: 800px; position: relative;
    }
    .sa-agentic .hero h1 .p { color: var(--purple); }
    .sa-agentic .hero h1 .g { color: var(--g); }
    .sa-agentic .hero h1 .sky { color: var(--sky); }
    .sa-agentic .hero-deck {
      font-size: clamp(15px, 2vw, 18px); color: var(--text-3); max-width: 620px;
      margin: 0 auto 30px; line-height: 1.8; position: relative;
    }
    .sa-agentic .hero-deck strong { color: var(--text-2); font-weight: 600; }
    .sa-agentic .channels-strip {
      display: flex; justify-content: center; align-items: center;
      gap: 10px; flex-wrap: wrap; margin-bottom: 28px; position: relative;
    }
    .sa-agentic .ch-badge {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase; padding: 6px 14px; border-radius: 6px;
    }
    .sa-agentic .ch-gpt   { background: var(--g-bg);      border: 1px solid var(--g-border);      color: var(--g); }
    .sa-agentic .ch-goog  { background: var(--sky-bg);    border: 1px solid var(--sky-border);    color: var(--sky); }
    .sa-agentic .ch-ms    { background: var(--purple-bg); border: 1px solid var(--purple-border); color: var(--purple); }
    .sa-agentic .ch-perp  { background: var(--amber-bg);  border: 1px solid var(--amber-border);  color: var(--amber); }
    .sa-agentic .ch-dot   { width: 5px; height: 5px; border-radius: 50%; background: currentColor; opacity: .7; }
    .sa-agentic .stat-strip {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 1px;
      background: var(--border); border: 1px solid var(--border); border-radius: 10px;
      overflow: hidden; max-width: 680px; margin: 0 auto 30px; position: relative;
    }
    .sa-agentic .stat-cell { background: var(--bg); padding: 14px 10px; text-align: center; }
    .sa-agentic .stat-v { font-family: var(--mono); font-size: 18px; font-weight: 700; line-height: 1; display: block; }
    .sa-agentic .stat-v.p { color: var(--purple); }
    .sa-agentic .stat-v.g { color: var(--g); }
    .sa-agentic .stat-v.sky { color: var(--sky); }
    .sa-agentic .stat-v.a { color: var(--amber); }
    .sa-agentic .stat-l { font-family: var(--mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; color: var(--text-4); margin-top: 5px; display: block; }
    .sa-agentic .hero-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; position: relative; }
    .sa-agentic .btn {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 700;
      text-decoration: none; padding: 12px 22px; border-radius: 7px;
      transition: all .2s; min-height: 44px; white-space: nowrap;
    }
    .sa-agentic .btn-p   { background: var(--purple); color: #020617; }
    .sa-agentic .btn-p:hover { background: #d8b4fe; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(196,181,253,.25); }
    .sa-agentic .btn-g   { background: var(--g); color: #020617; }
    .sa-agentic .btn-g:hover { background: #00e070; transform: translateY(-2px); }
    .sa-agentic .btn-o   { background: transparent; color: var(--text-2); border: 1.5px solid var(--border-2); }
    .sa-agentic .btn-o:hover { border-color: var(--purple); color: var(--purple); }
    .sa-agentic .toc {
      background: var(--bg-3); border: 1.5px solid var(--purple-border);
      border-radius: 12px; padding: 22px 26px; margin-bottom: 48px;
    }
    .sa-agentic .toc-head { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: var(--purple); margin-bottom: 16px; }
    .sa-agentic .toc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px 28px; }
    .sa-agentic .toc-item { display: flex; align-items: baseline; gap: 8px; font-size: 13px; color: var(--text-3); text-decoration: none; padding: 4px 0; transition: color .15s; line-height: 1.4; }
    .sa-agentic .toc-item:hover { color: var(--purple); }
