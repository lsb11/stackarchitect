  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "headline": "Shopify Server-Side Tracking: Free Setup Guide 2026 — Meta, Google & TikTok",
        "description": "The complete free guide to Shopify server-side tracking in 2026. Set up Meta CAPI, Google Enhanced Conversions, and TikTok Events API via Make.com — no code, under 20 minutes. Recover 20–40% of invisible conversions.",
        "datePublished": "2026-04-06",
        "dateModified": "2026-04-26",
        "inLanguage": "en-GB",
        "author": {"@type": "Person", "@id": "https://stackarchitect.xyz/#luke", "name": "Luke", "jobTitle": "Shopify Automation Specialist", "url": "https://stackarchitect.xyz/about"},
        "publisher": {"@type": "Organization", "name": "Stack Architect", "url": "https://stackarchitect.xyz"},
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": "https://stackarchitect.xyz/blog/shopify-server-side-tracking-complete-setup-guide"
        },
        "url": "https://stackarchitect.xyz/blog/shopify-server-side-tracking-complete-setup-guide",
        "image": "https://d1yei2z3i6k35z.cloudfront.net/16370908/69b2fbee2e5344.74350835_StackArchitectLogo.png",
        "articleSection": "Tracking",
        "keywords": ["shopify server-side tracking","meta conversions api","google enhanced conversions","tiktok events api","shopify capi","server-side tracking make.com","shopify conversion tracking 2026"],
        "speakable": {
          "@type": "SpeakableSpecification",
          "cssSelector": ["#tldr-section", "#faq-section", ".hero-deck"]
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stackarchitect.xyz"},
          {"@type": "ListItem", "position": 2, "name": "Guides", "item": "https://stackarchitect.xyz/shopify-automation-guides"},
          {"@type": "ListItem", "position": 3, "name": "Shopify Server-Side Tracking Free Setup Guide 2026", "item": "https://stackarchitect.xyz/blog/shopify-server-side-tracking-complete-setup-guide"}
        ]
      },
      {
        "@type": "HowTo",
        "name": "How to Set Up Free Shopify Server-Side Tracking (Meta + Google + TikTok)",
        "description": "Seven-step process to implement server-side tracking for Meta Conversions API, Google Enhanced Conversions, and TikTok Events API via Make.com at zero cost.",
        "totalTime": "PT18M",
        "estimatedCost": {"@type": "MonetaryAmount", "currency": "USD", "value": "0"},
        "step": [
          {"@type": "HowToStep", "position": 1, "name": "Create your free Make.com account", "text": "Sign up at Make.com — no credit card required. The free plan covers 1,000 operations per month, enough for stores processing up to 300 orders per month."},
          {"@type": "HowToStep", "position": 2, "name": "Create a scenario with Webhooks trigger", "text": "In Make.com, create a new scenario. Add a Webhooks Custom webhook module as the trigger. Click Save and copy the generated webhook URL."},
          {"@type": "HowToStep", "position": 3, "name": "Add Order Payment webhook in Shopify", "text": "In Shopify Admin → Settings → Notifications → Webhooks, click Create webhook. Select Order payment as the event, paste your Make.com webhook URL, set format to JSON, save."},
          {"@type": "HowToStep", "position": 4, "name": "Add Meta CAPI HTTP module", "text": "Add an HTTP module after the webhook trigger. POST to https://graph.facebook.com/v18.0/&#123;PIXEL_ID&#125;/events with your access_token. Send event_name Purchase, event_id, event_time, value, currency, and SHA-256 hashed email and phone. The event_id must match your browser pixel for deduplication."},
          {"@type": "HowToStep", "position": 5, "name": "Add Google Enhanced Conversions HTTP module", "text": "Add a second HTTP module. POST hashed email, hashed phone, conversion value and order ID to Google's Enhanced Conversions endpoint via the Google Ads API or GTM Server-Side container."},
          {"@type": "HowToStep", "position": 6, "name": "Add TikTok Events API HTTP module", "text": "Add a third HTTP module. POST to https://business-api.tiktok.com/open_api/v1.3/event/track/ using event_name CompletePayment — not Purchase. Include hashed email, hashed phone, IP address, and user agent for maximum Event Match Quality."},
          {"@type": "HowToStep", "position": 7, "name": "Activate scenario and verify all three platforms", "text": "Switch the scenario on. Place a test order. Verify in Meta Events Manager Test Events (Purchase, server source), Google Ads Conversions Diagnostics, and TikTok Events Manager Test Events (CompletePayment). Events appear within 60 seconds."}
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is Shopify server-side tracking and how does it work?",
            "acceptedAnswer": {"@type": "Answer", "text": "Shopify server-side tracking sends purchase events directly from your server to ad platforms (Meta, Google, TikTok) without going through the customer's browser. When a Shopify order is paid, a webhook fires to Make.com which routes the event to each platform's API endpoint — bypassing iOS restrictions, ad blockers, and cookie limitations. It works alongside your existing browser pixel, not instead of it."}
          },
          {
            "@type": "Question",
            "name": "Do I need to remove my browser pixel when setting up server-side tracking?",
            "acceptedAnswer": {"@type": "Answer", "text": "No — keep your browser pixel running alongside server-side tracking. The pixel captures upper-funnel events (ViewContent, AddToCart, InitiateCheckout) that server webhooks don't cover since they only fire on confirmed payment. Set a matching event_id in both your pixel and server events so each platform deduplicates and you see one conversion, not two."}
          },
          {
            "@type": "Question",
            "name": "How much of my lost Shopify conversion data will server-side tracking recover?",
            "acceptedAnswer": {"@type": "Answer", "text": "Most Shopify stores recover 20–40% of previously invisible conversions after deploying server-side tracking. TikTok's own data shows a 19% average increase in attributed events. The exact figure depends on your traffic mix — stores with high iOS and mobile traffic typically see higher recovery rates. The gap between your Shopify dashboard and ad platform reports should narrow significantly within 24–72 hours."}
          },
          {
            "@type": "Question",
            "name": "Is server-side tracking GDPR compliant?",
            "acceptedAnswer": {"@type": "Answer", "text": "The data flows through your own Make.com workspace — you control what is sent and can delete the scenario at any time. All personally identifiable information (email, phone) is SHA-256 hashed before transmission as required by each platform's API specification. Ensure your store privacy policy discloses server-side conversion data sharing with advertising platforms. For GDPR-specific advice consult a legal professional."}
          },
          {
            "@type": "Question",
            "name": "How long before I see results after setting up server-side tracking?",
            "acceptedAnswer": {"@type": "Answer", "text": "Server events start flowing immediately after your first paid order. More conversions will appear in your ad platform reporting within 24–48 hours. Meaningful CPA and ROAS improvement typically takes 7–14 days as ad platform algorithms recalibrate delivery optimisation using the more complete conversion signal."}
          },
          {
            "@type": "Question",
            "name": "What is the difference between Meta CAPI and Shopify's native data sharing?",
            "acceptedAnswer": {"@type": "Answer", "text": "Shopify's native Maximum data sharing setting enables their own CAPI integration, but it is still partially browser-triggered — if the thank-you page pixel fails to execute, the server event may not fire. The Make.com webhook method fires directly from Shopify's backend on payment confirmation with zero browser dependency, making it more reliable."}
          },
          {
            "@type": "Question",
            "name": "Can I set up Shopify server-side tracking without a developer?",
            "acceptedAnswer": {"@type": "Answer", "text": "Yes. The Make.com webhook setup requires no code. You configure a Shopify webhook in Settings, build an HTTP module in Make.com's visual drag-and-drop interface, and paste your API credentials. Most store owners complete the setup in under 20 minutes. No developer, no agency, no Shopify app installation required."}
          },
          {
            "@type": "Question",
            "name": "Does server-side tracking work with Shopify's native Maximum data sharing?",
            "acceptedAnswer": {"@type": "Answer", "text": "Yes — the Make.com webhook method works independently of and alongside Shopify's native data sharing. You do not need to disable native CAPI. Running both adds redundancy: if one delivery method has a transient failure, the other ensures the event still reaches the platform. Use matching event_id values in both so platforms deduplicate correctly."}
          }
          ,{
            "@type": "Question",
            "name": "How much does Shopify server-side tracking cost?",
            "acceptedAnswer": {"@type": "Answer", "text": "The Make.com webhook method costs zero pounds per month for Shopify stores under 250 orders per month. Higher volume requires Make.com Core at 9 dollars per month for 10,000 operations. Managed alternatives like Elevar cost 400 to 2000 pounds per month for the same tracking outcome."}
          },
          {
            "@type": "Question",
            "name": "What Event Match Quality score is good for Meta CAPI?",
            "acceptedAnswer": {"@type": "Answer", "text": "Meta Event Match Quality is scored 1 to 10. Scores of 7 to 8 are very good and represent the realistic ceiling for guest-checkout Shopify stores. Scores of 9 to 10 are excellent and require logged-in customer data. Below 5 indicates missing match keys and should be investigated, starting with email format, phone E.164 format, and external_id."}
          },
          {
            "@type": "Question",
            "name": "Why is TikTok event match quality low on my Shopify store?",
            "acceptedAnswer": {"@type": "Answer", "text": "The most common cause is sending the event name Purchase instead of CompletePayment. TikTok Events API requires CompletePayment for purchase events. Other causes include missing hashed email, missing IP address mapped from the Shopify order browser_ip field, and missing TikTok Click ID for paid traffic events."}
          }
        ]
      }
    ]
  }
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; overscroll-behavior-x: none; -webkit-font-smoothing: antialiased; }
    body { margin: 0; background: #020617; color: #94a3b8; font-family: 'Inter', -apple-system, sans-serif; }
    a { text-decoration: none; }
    h1,h2,h3,h4,h5,h6 { margin: 0; font-weight: normal; }
    p { margin: 0; }
    ul { margin: 0; }

    /* NAV */
    .product-terminal-bar {
      width: 100%; background: #020617; padding: 12px 0;
      border-bottom: 1px solid #1e293b; position: sticky; top: 0;
      z-index: 10002; transition: all .3s ease;
    }
    .product-terminal-bar.scrolled {
      background: rgba(2,6,23,.95); backdrop-filter: blur(12px);
      padding: 8px 0; border-bottom: 1px solid rgba(0,168,84,.3);
      box-shadow: 0 4px 20px rgba(0,0,0,.4);
    }
    .terminal-container {
      max-width: 1100px; margin: 0 auto; display: flex;
      justify-content: space-between; align-items: center;
      padding: 0 24px; box-sizing: border-box;
    }
    .terminal-status {
      display: flex; align-items: center; gap: 10px;
      font-family: 'JetBrains Mono', monospace; font-size: 9px;
      color: #475569; letter-spacing: 1.5px; font-weight: 800;
    }
    .status-indicator {
      width: 5px; height: 5px; background: #00a854; border-radius: 50%;
      box-shadow: 0 0 8px #00a854; animation: statusPulse 2s infinite;
    }
    @keyframes statusPulse {
      0%,100% { box-shadow: 0 0 8px #00a854; }
      50%      { box-shadow: 0 0 16px #00a854; }
    }
    .product-access-grid {
      display: flex; gap: clamp(15px,3vw,30px); list-style: none;
      margin: 0; padding: 0; align-items: center;
    }
    .product-link {
      font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 800;
      color: #94a3b8; text-decoration: none; text-transform: uppercase;
      letter-spacing: 1px; transition: all .3s cubic-bezier(.16,1,.3,1);
      display: flex; align-items: center; gap: 4px;
    }
    .product-link::before { content: '['; color: #334155; transition: color .3s; }
    .product-link::after  { content: ']'; color: #334155; transition: color .3s; }
    .product-link:hover, .product-link.is-active { color: #fff; transform: translateY(-1px); }
    .product-link:hover::before, .product-link:hover::after,
    .product-link.is-active::before, .product-link.is-active::after { color: #00a854; }
    .product-link.is-active { color: #00a854; }
    .dropdown { position: relative; cursor: pointer; }
    .dropdown-menu {
      display: none; position: absolute; top: calc(100% + 8px); left: 0;
      background: #020617; border: 1px solid #1e293b; border-radius: 6px;
      padding: 8px 0; min-width: 280px; z-index: 10003; flex-direction: column;
      list-style: none; margin: 0; box-shadow: 0 20px 40px rgba(0,0,0,.5);
    }
    .dropdown-menu .product-link::before, .dropdown-menu .product-link::after { content: ''; }
    .dropdown-menu .product-link {
      display: block; padding: 10px 16px; font-size: 10px; color: #94a3b8; transition: all .15s;
    }
    .dropdown-menu .product-link:hover { color: #fff; background: rgba(0,168,84,.1); transform: none; }
    .dropdown-desc {
      display: block; font-family: 'Inter', -apple-system, sans-serif; font-size: 10px;
      font-weight: 400; color: #475569; letter-spacing: 0; text-transform: none;
      margin-top: 2px; line-height: 1.4;
    }
    @media (min-width: 851px) { .dropdown:hover .dropdown-menu { display: flex; } }
    .terminal-cta { display: flex; align-items: center; margin-left: 20px; }
    .savings-ticker {
      font-family: 'JetBrains Mono', monospace; font-size: 8px; font-weight: 800;
      color: #00a854; letter-spacing: 1px; margin-right: 12px; white-space: nowrap; opacity: .8;
    }
    .cta-node {
      font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 900;
      color: #00a854; text-decoration: none; text-transform: uppercase;
      padding: 6px 14px; border: 1px solid #00a854; border-radius: 4px;
      transition: all .3s cubic-bezier(.175,.885,.32,1.275); display: inline-block; white-space: nowrap;
    }
    .cta-node:hover { background: #00a854; color: #fff; box-shadow: 0 6px 20px rgba(0,168,84,.5); transform: scale(1.05); }
    @media (max-width: 850px) {
      .terminal-status, .savings-ticker { display: none; }
      .terminal-container { flex-direction: column; gap: 15px; }
      .product-access-grid { display: grid; grid-template-columns: repeat(2, auto); gap: 12px 20px; }
      .terminal-cta { margin-left: 0; order: -1; width: 100%; justify-content: center; }
      .cta-node { background: #00a854; color: #fff; width: 80%; text-align: center; }
    }

    /* BREADCRUMB */
    .sa-breadcrumb {
      max-width: 1100px; margin: 0 auto; padding: 10px 24px;
      display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
      font-family: 'Inter', sans-serif; font-size: 12px; color: #64748b;
    }
    .sa-breadcrumb a { color: #64748b; text-decoration: none; transition: color .2s; }
    .sa-breadcrumb a:hover { color: #f1f5f9; }
    .sa-breadcrumb .bc-sep { color: #334155; }
    .sa-breadcrumb .bc-current { color: #94a3b8; }

    /* ARTICLE WRAPPER */
    .article-outer { background: rgb(2,6,23); padding: 40px 40px 80px; }
    @media (max-width: 600px) { .article-outer { padding: 5px 5px 60px; } }

    /* SA-ARTICLE */
    .sa-article {
      font-family: 'Inter', -apple-system, sans-serif; color: #94a3b8;
      line-height: 1.75; -webkit-font-smoothing: antialiased;
      background: transparent; max-width: 900px; margin: 0 auto;
      --bg:     #020617; --bg-2:   #06101e; --bg-3:   #0a1628; --bg-4:   #0f1f35;
      --border:   #1e293b; --border-2: #263548;
      --text:   #f1f5f9; --text-2: #cbd5e1; --text-3: #94a3b8; --text-4: #64748b;
      --g:        #00c864; --g-dim:    #00a854; --g-bg: rgba(0,200,100,.08); --g-border: rgba(0,200,100,.2);
      --sky:      #7dd3fc; --sky-bg: rgba(125,211,252,.07); --sky-border: rgba(125,211,252,.18);
      --amber:    #fcd34d; --amber-bg: rgba(252,211,77,.08); --amber-border: rgba(252,211,77,.2);
      --red:      #fc8181; --red-bg: rgba(252,129,129,.07); --red-border: rgba(252,129,129,.18);
      --tiktok:   #00f2ea; --tiktok-bg: rgba(0,242,234,.07); --tiktok-border: rgba(0,242,234,.18);
      --mono: 'JetBrains Mono', monospace;
      --sans: 'Inter', -apple-system, sans-serif;
    }

    /* HERO */
    .sa-article .hero {
      padding: 60px 24px 44px; text-align: center; position: relative;
      overflow: hidden; background: var(--bg); border-radius: 14px;
      border: 1px solid var(--border); margin-bottom: 44px;
    }
    .sa-article .hero::before {
      content: ''; position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(ellipse 100% 60% at 50% -5%, rgba(0,200,100,.07) 0%, transparent 55%),
                  radial-gradient(ellipse 50% 40% at 80% 100%, rgba(0,242,234,.04) 0%, transparent 50%);
    }
    .sa-article .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--g-bg); border: 1px solid var(--g-border);
      border-radius: 100px; padding: 7px 18px; margin-bottom: 28px; position: relative;
    }
    .sa-article .hero-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--g);
      box-shadow: 0 0 10px var(--g); animation: pulse-g 2s infinite;
    }
    @keyframes pulse-g { 0%,100%{opacity:1;box-shadow:0 0 10px var(--g);} 50%{opacity:.4;box-shadow:0 0 4px var(--g);} }
    .sa-article .hero-eyebrow-txt {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .14em; text-transform: uppercase; color: var(--g);
    }
    .sa-article .hero h1 {
      font-size: clamp(26px, 5.2vw, 54px); font-weight: 900; color: var(--text);
      letter-spacing: -.04em; line-height: .94; margin: 0 auto 20px; max-width: 800px; position: relative;
    }
    .sa-article .hero h1 .g { color: var(--g); }
    .sa-article .hero h1 .sky { color: var(--sky); }
    .sa-article .hero h1 .tt { color: var(--tiktok); }
    .sa-article .hero-deck {
      font-size: clamp(15px, 2vw, 18px); color: var(--text-3); max-width: 620px;
      margin: 0 auto 30px; line-height: 1.8; position: relative;
    }
    .sa-article .hero-deck strong { color: var(--text-2); font-weight: 600; }

    /* PLATFORM BADGES */
    .sa-article .platform-strip {
      display: flex; justify-content: center; align-items: center;
      gap: 10px; flex-wrap: wrap; margin-bottom: 28px; position: relative;
    }
    .sa-article .platform-badge {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase; padding: 6px 14px; border-radius: 6px;
    }
    .sa-article .pb-meta   { background: var(--sky-bg);    border: 1px solid var(--sky-border);    color: var(--sky); }
    .sa-article .pb-google { background: var(--g-bg);      border: 1px solid var(--g-border);      color: var(--g); }
    .sa-article .pb-tiktok { background: var(--tiktok-bg); border: 1px solid var(--tiktok-border); color: var(--tiktok); }
    .sa-article .pb-dot   { width: 5px; height: 5px; border-radius: 50%; background: currentColor; opacity: .7; }

    /* STAT STRIP */
    .sa-article .stat-strip {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 1px;
      background: var(--border); border: 1px solid var(--border); border-radius: 10px;
      overflow: hidden; max-width: 680px; margin: 0 auto 30px; position: relative;
    }
    .sa-article .stat-cell { background: var(--bg); padding: 14px 10px; text-align: center; }
    .sa-article .stat-v { font-family: var(--mono); font-size: 18px; font-weight: 700; line-height: 1; display: block; }
    .sa-article .stat-v.g { color: var(--g); }
    .sa-article .stat-v.sky { color: var(--sky); }
    .sa-article .stat-v.tt { color: var(--tiktok); }
    .sa-article .stat-v.r { color: var(--red); }
    .sa-article .stat-v.a { color: var(--amber); }
    .sa-article .stat-l { font-family: var(--mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; color: var(--text-4); margin-top: 5px; display: block; }
