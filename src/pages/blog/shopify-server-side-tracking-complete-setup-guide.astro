        "image": "https://d1yei2z3i6k35z.cloudfront.net/16370908/69b2fbee2e5344.74350835_StackArchitectLogo.png",
        "articleSection": "Tracking",
        "keywords": ["shopify server-side tracking","meta conversions api","google enhanced conversions","tiktok events api","shopify capi","server-side tracking make.com","shopify conversion tracking 2026"],
        "speakable": {
          "@type": "SpeakableSpecification",
          "cssSelector": ["#tldr-section", "#faq-section", ".hero-deck"]
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.stackarchitect.xyz"},
          {"@type": "ListItem", "position": 2, "name": "Guides", "item": "https://www.stackarchitect.xyz/shopify-automation-guides"},
          {"@type": "ListItem", "position": 3, "name": "Shopify Server-Side Tracking: Free Setup Guide 2026", "item": "https://www.stackarchitect.xyz/blog/shopify-server-side-tracking-complete-setup-guide"}
        ]
      },
      {
        "@type": "HowTo",
        "name": "How to Set Up Free Shopify Server-Side Tracking (Meta + Google + TikTok)",
        "description": "Seven-step process to implement server-side tracking for Meta Conversions API, Google Enhanced Conversions, and TikTok Events API via Make.com at zero cost.",
        "totalTime": "PT18M",
        "estimatedCost": {"@type": "MonetaryAmount", "currency": "USD", "value": "0"},
        "step": [
          {"@type": "HowToStep", "position": 1, "name": "Create your free Make.com account", "text": "Sign up at Make.com — no credit card required. The free plan covers 1,000 operations per month, enough for stores processing up to 300 orders per month."},
          {"@type": "HowToStep", "position": 2, "name": "Create a scenario with Webhooks trigger", "text": "In Make.com, create a new scenario. Add a Webhooks Custom webhook module as the trigger. Click Save and copy the generated webhook URL."},
          {"@type": "HowToStep", "position": 3, "name": "Add Order Payment webhook in Shopify", "text": "In Shopify Admin → Settings → Notifications → Webhooks, click Create webhook. Select Order payment as the event, paste your Make.com webhook URL as the destination, set format to JSON, save."},
          {"@type": "HowToStep", "position": 4, "name": "Add Meta CAPI HTTP module", "text": "Add an HTTP module after the webhook trigger. Set Method to POST, URL to the Meta Graph API events endpoint with your Pixel ID and Access Token. In the body, send event_name Purchase, event_id, event_time, value, currency, and SHA-256 hashed email. The event_id must match the event_id your browser pixel sends for deduplication."},
          {"@type": "HowToStep", "position": 5, "name": "Add Google Enhanced Conversions HTTP module", "text": "Add a second HTTP module branching from the same webhook trigger. POST to Google's Enhanced Conversions endpoint with your Conversion ID, hashed email, hashed phone number where available, and order value."},
          {"@type": "HowToStep", "position": 6, "name": "Add TikTok Events API HTTP module", "text": "Add a third HTTP module. Set Method to POST, URL to business-api.tiktok.com/open_api/v1.3/event/track/. Use event_name CompletePayment — not Purchase. Include hashed email, hashed phone, IP address, and user agent for maximum Event Match Quality."},
          {"@type": "HowToStep", "position": 7, "name": "Turn on your scenario and verify all three platforms", "text": "Switch the scenario on in Make.com. Place a test order. Verify in Meta Events Manager Test Events (Purchase event, server source), Google Ads Conversions Diagnostics, and TikTok Events Manager Test Events (CompletePayment event). Events should appear within 60 seconds."}
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is Shopify server-side tracking and how does it work?",
            "acceptedAnswer": {"@type": "Answer", "text": "Shopify server-side tracking sends purchase events directly from your server to ad platforms (Meta, Google, TikTok) without going through the customer's browser. When a Shopify order is paid, a webhook fires to Make.com which routes the event to each platform's API endpoint — bypassing iOS restrictions, ad blockers, and cookie limitations. It works alongside your existing browser pixel, not instead of it."}
          },
          {
            "@type": "Question",
            "name": "Do I need to remove my browser pixel when setting up server-side tracking?",
            "acceptedAnswer": {"@type": "Answer", "text": "No — keep your browser pixel running alongside server-side tracking. The pixel captures upper-funnel events (ViewContent, AddToCart, InitiateCheckout) that server webhooks don't cover since they only fire on confirmed payment. Set a matching event_id in both your pixel and server events so each platform deduplicates and you see one conversion, not two."}
          },
          {
            "@type": "Question",
            "name": "How much of my lost Shopify conversion data will server-side tracking recover?",
            "acceptedAnswer": {"@type": "Answer", "text": "Most Shopify stores recover 20–40% of previously invisible conversions after deploying server-side tracking. TikTok's own data shows a 19% average increase in attributed events. The exact figure depends on your traffic mix — stores with high iOS and mobile traffic typically see higher recovery rates. The gap between your Shopify dashboard and ad platform reports should narrow significantly within 24–72 hours."}
          },
          {
            "@type": "Question",
            "name": "Is server-side tracking GDPR compliant?",
            "acceptedAnswer": {"@type": "Answer", "text": "The data flows through your own Make.com workspace — you control what is sent and can delete the scenario at any time. All personally identifiable information (email, phone) is SHA-256 hashed before transmission as required by each platform's API specification. Ensure your store privacy policy discloses server-side conversion data sharing with advertising platforms. For GDPR-specific advice consult a legal professional."}
          },
          {
            "@type": "Question",
            "name": "How long before I see results after setting up server-side tracking?",
            "acceptedAnswer": {"@type": "Answer", "text": "Server events start flowing immediately after your first paid order. More conversions will appear in your ad platform reporting within 24–48 hours. Meaningful CPA and ROAS improvement typically takes 7–14 days as ad platform algorithms recalibrate delivery optimisation using the more complete conversion signal."}
          },
          {
            "@type": "Question",
            "name": "What is the difference between Meta CAPI and Shopify's native data sharing?",
            "acceptedAnswer": {"@type": "Answer", "text": "Shopify's native Maximum data sharing setting enables their own CAPI integration, but it is still partially browser-triggered — if the thank-you page pixel fails to execute, the server event may not fire. The Make.com webhook method fires directly from Shopify's backend on payment confirmation with zero browser dependency, making it more reliable."}
          },
          {
            "@type": "Question",
            "name": "Can I set up Shopify server-side tracking without a developer?",
            "acceptedAnswer": {"@type": "Answer", "text": "Yes. The Make.com webhook setup requires no code. You configure a Shopify webhook in Settings, build an HTTP module in Make.com's visual drag-and-drop interface, and paste your API credentials. Most store owners complete the setup in under 20 minutes. No developer, no agency, no Shopify app installation required."}
          },
          {
            "@type": "Question",
            "name": "Does server-side tracking work with Shopify's native Maximum data sharing?",
            "acceptedAnswer": {"@type": "Answer", "text": "Yes — the Make.com webhook method works independently of and alongside Shopify's native data sharing. You do not need to disable native CAPI. Running both adds redundancy: if one delivery method has a transient failure, the other ensures the event still reaches the platform. Use matching event_id values in both so platforms deduplicate correctly."}
          }
        ]
      }
    ]
  }
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; overscroll-behavior-x: none; -webkit-font-smoothing: antialiased; }
    body { margin: 0; background: #020617; color: #94a3b8; font-family: 'Inter', -apple-system, sans-serif; }
    a { text-decoration: none; }
    h1,h2,h3,h4,h5,h6 { margin: 0; font-weight: normal; }
    p { margin: 0; }
    ul { margin: 0; }

    /* NAV */
    .product-terminal-bar {
      width: 100%; background: #020617; padding: 12px 0;
      border-bottom: 1px solid #1e293b; position: sticky; top: 0;
      z-index: 10002; transition: all .3s ease;
    }
    .product-terminal-bar.scrolled {
      background: rgba(2,6,23,.95); backdrop-filter: blur(12px);
      padding: 8px 0; border-bottom: 1px solid rgba(0,168,84,.3);
      box-shadow: 0 4px 20px rgba(0,0,0,.4);
    }
    .terminal-container {
      max-width: 1100px; margin: 0 auto; display: flex;
      justify-content: space-between; align-items: center;
      padding: 0 24px; box-sizing: border-box;
    }
    .terminal-status {
      display: flex; align-items: center; gap: 10px;
      font-family: 'JetBrains Mono', monospace; font-size: 9px;
      color: #475569; letter-spacing: 1.5px; font-weight: 800;
    }
    .status-indicator {
      width: 5px; height: 5px; background: #00a854; border-radius: 50%;
      box-shadow: 0 0 8px #00a854; animation: statusPulse 2s infinite;
    }
    @keyframes statusPulse {
      0%,100% { box-shadow: 0 0 8px #00a854; }
      50%      { box-shadow: 0 0 16px #00a854; }
    }
    .product-access-grid {
      display: flex; gap: clamp(15px,3vw,30px); list-style: none;
      margin: 0; padding: 0; align-items: center;
    }
    .product-link {
      font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 800;
      color: #94a3b8; text-decoration: none; text-transform: uppercase;
      letter-spacing: 1px; transition: all .3s cubic-bezier(.16,1,.3,1);
      display: flex; align-items: center; gap: 4px;
    }
    .product-link::before { content: '['; color: #334155; transition: color .3s; }
    .product-link::after  { content: ']'; color: #334155; transition: color .3s; }
    .product-link:hover, .product-link.is-active { color: #fff; transform: translateY(-1px); }
    .product-link:hover::before, .product-link:hover::after,
    .product-link.is-active::before, .product-link.is-active::after { color: #00a854; }
    .product-link.is-active { color: #00a854; }
    .dropdown { position: relative; cursor: pointer; }
    .dropdown-menu {
      display: none; position: absolute; top: calc(100% + 8px); left: 0;
      background: #020617; border: 1px solid #1e293b; border-radius: 6px;
      padding: 8px 0; min-width: 280px; z-index: 10003; flex-direction: column;
      list-style: none; margin: 0; box-shadow: 0 20px 40px rgba(0,0,0,.5);
    }
    .dropdown-menu .product-link::before, .dropdown-menu .product-link::after { content: ''; }
    .dropdown-menu .product-link {
      display: block; padding: 10px 16px; font-size: 10px; color: #94a3b8; transition: all .15s;
    }
    .dropdown-menu .product-link:hover { color: #fff; background: rgba(0,168,84,.1); transform: none; }
    .dropdown-desc {
      display: block; font-family: 'Inter', -apple-system, sans-serif; font-size: 10px;
      font-weight: 400; color: #475569; letter-spacing: 0; text-transform: none;
      margin-top: 2px; line-height: 1.4;
    }
    @media (min-width: 851px) { .dropdown:hover .dropdown-menu { display: flex; } }
    .terminal-cta { display: flex; align-items: center; margin-left: 20px; }
    .savings-ticker {
      font-family: 'JetBrains Mono', monospace; font-size: 8px; font-weight: 800;
      color: #00a854; letter-spacing: 1px; margin-right: 12px; white-space: nowrap; opacity: .8;
    }
    .cta-node {
      font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 900;
      color: #00a854; text-decoration: none; text-transform: uppercase;
      padding: 6px 14px; border: 1px solid #00a854; border-radius: 4px;
      transition: all .3s cubic-bezier(.175,.885,.32,1.275); display: inline-block; white-space: nowrap;
    }
    .cta-node:hover { background: #00a854; color: #fff; box-shadow: 0 6px 20px rgba(0,168,84,.5); transform: scale(1.05); }
    @media (max-width: 850px) {
      .terminal-status, .savings-ticker { display: none; }
      .terminal-container { flex-direction: column; gap: 15px; }
      .product-access-grid { display: grid; grid-template-columns: repeat(2, auto); gap: 12px 20px; }
      .terminal-cta { margin-left: 0; order: -1; width: 100%; justify-content: center; }
      .cta-node { background: #00a854; color: #fff; width: 80%; text-align: center; }
    }

    /* BREADCRUMB */
    .sa-breadcrumb {
      max-width: 1100px; margin: 0 auto; padding: 10px 24px;
      display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
      font-family: 'Inter', sans-serif; font-size: 12px; color: #64748b;
    }
    .sa-breadcrumb a { color: #64748b; text-decoration: none; transition: color .2s; }
    .sa-breadcrumb a:hover { color: #f1f5f9; }
    .sa-breadcrumb .bc-sep { color: #334155; }
    .sa-breadcrumb .bc-current { color: #94a3b8; }

    /* ARTICLE WRAPPER */
    .article-outer { background: rgb(2,6,23); padding: 40px 40px 80px; }
    @media (max-width: 600px) { .article-outer { padding: 5px 5px 60px; } }

    /* SA-ARTICLE */
    .sa-article {
      font-family: 'Inter', -apple-system, sans-serif; color: #94a3b8;
      line-height: 1.75; -webkit-font-smoothing: antialiased;
      background: transparent; max-width: 900px; margin: 0 auto;
      --bg:     #020617; --bg-2:   #06101e; --bg-3:   #0a1628; --bg-4:   #0f1f35;
      --border:   #1e293b; --border-2: #263548;
      --text:   #f1f5f9; --text-2: #cbd5e1; --text-3: #94a3b8; --text-4: #64748b;
      --g:        #00c864; --g-dim:    #00a854; --g-bg: rgba(0,200,100,.08); --g-border: rgba(0,200,100,.2);
      --sky:      #7dd3fc; --sky-bg: rgba(125,211,252,.07); --sky-border: rgba(125,211,252,.18);
      --amber:    #fcd34d; --amber-bg: rgba(252,211,77,.08); --amber-border: rgba(252,211,77,.2);
      --red:      #fc8181; --red-bg: rgba(252,129,129,.07); --red-border: rgba(252,129,129,.18);
      --tiktok:   #00f2ea; --tiktok-bg: rgba(0,242,234,.07); --tiktok-border: rgba(0,242,234,.18);
      --mono: 'JetBrains Mono', monospace;
      --sans: 'Inter', -apple-system, sans-serif;
    }

    /* HERO */
    .sa-article .hero {
      padding: 60px 24px 44px; text-align: center; position: relative;
      overflow: hidden; background: var(--bg); border-radius: 14px;
      border: 1px solid var(--border); margin-bottom: 44px;
    }
    .sa-article .hero::before {
      content: ''; position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(ellipse 100% 60% at 50% -5%, rgba(0,200,100,.07) 0%, transparent 55%),
                  radial-gradient(ellipse 50% 40% at 80% 100%, rgba(0,242,234,.04) 0%, transparent 50%);
    }
    .sa-article .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--g-bg); border: 1px solid var(--g-border);
      border-radius: 100px; padding: 7px 18px; margin-bottom: 28px; position: relative;
    }
    .sa-article .hero-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--g);
      box-shadow: 0 0 10px var(--g); animation: pulse-g 2s infinite;
    }
    @keyframes pulse-g { 0%,100%{opacity:1;box-shadow:0 0 10px var(--g);} 50%{opacity:.4;box-shadow:0 0 4px var(--g);} }
    .sa-article .hero-eyebrow-txt {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .14em; text-transform: uppercase; color: var(--g);
    }
    .sa-article .hero h1 {
      font-size: clamp(26px, 5.2vw, 54px); font-weight: 900; color: var(--text);
      letter-spacing: -.04em; line-height: .94; margin: 0 auto 20px; max-width: 800px; position: relative;
    }
    .sa-article .hero h1 .g { color: var(--g); }
    .sa-article .hero h1 .sky { color: var(--sky); }
    .sa-article .hero h1 .tt { color: var(--tiktok); }
    .sa-article .hero-deck {
      font-size: clamp(15px, 2vw, 18px); color: var(--text-3); max-width: 620px;
      margin: 0 auto 30px; line-height: 1.8; position: relative;
    }
    .sa-article .hero-deck strong { color: var(--text-2); font-weight: 600; }

    /* PLATFORM BADGES */
    .sa-article .platform-strip {
      display: flex; justify-content: center; align-items: center;
      gap: 10px; flex-wrap: wrap; margin-bottom: 28px; position: relative;
    }
    .sa-article .platform-badge {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase; padding: 6px 14px; border-radius: 6px;
    }
    .sa-article .pb-meta   { background: var(--sky-bg);    border: 1px solid var(--sky-border);    color: var(--sky); }
    .sa-article .pb-google { background: var(--g-bg);      border: 1px solid var(--g-border);      color: var(--g); }
    .sa-article .pb-tiktok { background: var(--tiktok-bg); border: 1px solid var(--tiktok-border); color: var(--tiktok); }
    .sa-article .pb-dot   { width: 5px; height: 5px; border-radius: 50%; background: currentColor; opacity: .7; }

    /* STAT STRIP */
    .sa-article .stat-strip {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 1px;
      background: var(--border); border: 1px solid var(--border); border-radius: 10px;
      overflow: hidden; max-width: 680px; margin: 0 auto 30px; position: relative;
    }
    .sa-article .stat-cell { background: var(--bg); padding: 14px 10px; text-align: center; }
    .sa-article .stat-v { font-family: var(--mono); font-size: 18px; font-weight: 700; line-height: 1; display: block; }
    .sa-article .stat-v.g { color: var(--g); }
    .sa-article .stat-v.sky { color: var(--sky); }
    .sa-article .stat-v.tt { color: var(--tiktok); }
    .sa-article .stat-v.r { color: var(--red); }
    .sa-article .stat-v.a { color: var(--amber); }
    .sa-article .stat-l { font-family: var(--mono); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; color: var(--text-4); margin-top: 5px; display: block; }
    .sa-article .hero-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; position: relative; }
    .sa-article .btn {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 700;
      text-decoration: none; padding: 12px 22px; border-radius: 7px;
      transition: all .2s; min-height: 44px; white-space: nowrap;
    }
    .sa-article .btn-g   { background: var(--g); color: #020617; }
    .sa-article .btn-g:hover { background: #00e070; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,200,100,.25); }
    .sa-article .btn-o   { background: transparent; color: var(--text-2); border: 1.5px solid var(--border-2); }
    .sa-article .btn-o:hover { border-color: var(--g); color: var(--g); }

    /* TLDR */
    .sa-article .tldr {
      background: var(--bg-3); border: 1.5px solid var(--g-border);
      border-radius: 12px; padding: 22px 26px; margin-bottom: 28px;
    }
    .sa-article .tldr-head { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: var(--g); margin-bottom: 14px; }
    .sa-article .tldr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .sa-article .tldr-item { display: flex; align-items: baseline; gap: 10px; font-size: 13px; color: var(--text-3); line-height: 1.5; }
    .sa-article .tldr-n { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--g); flex-shrink: 0; min-width: 18px; }
    @media (max-width: 600px) { .sa-article .tldr-grid { grid-template-columns: 1fr; } }

    /* TABLE OF CONTENTS */
    .sa-article .toc {
      background: var(--bg-2); border: 1px solid var(--border-2);
      border-radius: 12px; padding: 20px 22px 16px; margin-bottom: 40px;
    }
    .sa-article .toc-label {
      font-family: var(--mono); font-size: 10px; font-weight: 800;
      text-transform: uppercase; letter-spacing: .16em; color: var(--g); margin-bottom: 14px; display: block;
    }
    .sa-article .toc-list { list-style: none; padding: 0; margin: 0; columns: 2; column-gap: 24px; }
    .sa-article .toc-list li { break-inside: avoid; padding: 5px 0; }
    .sa-article .toc-list li a {
      color: var(--text-4); font-size: 13px; font-weight: 500;
      transition: color .2s; display: flex; align-items: flex-start; gap: 8px; line-height: 1.4; text-decoration: none;
    }
    .sa-article .toc-list li a::before { content: "→"; color: var(--g); font-size: 11px; flex-shrink: 0; margin-top: 2px; }
    .sa-article .toc-list li a:hover { color: var(--text-2); }
    @media (max-width: 600px) { .sa-article .toc-list { columns: 1; } }

    /* SECTION MARKER */
    .sa-article .sec-mark {
      display: flex; align-items: center; gap: 14px;
      font-family: var(--mono); font-size: 9px; letter-spacing: .2em;
      text-transform: uppercase; color: var(--text-4); margin: 60px 0 24px;
    }
    .sa-article .sec-mark::before { content: ''; width: 32px; height: 1px; background: var(--g); flex-shrink: 0; }
    .sa-article .sec-mark::after  { content: ''; flex: 1; height: 1px; background: var(--border); }

    /* PROSE */
    .sa-article .prose { font-size: 16px; color: var(--text-3); line-height: 1.85; }
    .sa-article .prose h2 { font-size: clamp(19px, 2.8vw, 27px); font-weight: 900; color: var(--text); letter-spacing: -.028em; margin: 52px 0 14px; line-height: 1.08; }
    .sa-article .prose h3 { font-size: clamp(15px, 2vw, 20px); font-weight: 700; color: var(--text-2); letter-spacing: -.015em; margin: 34px 0 10px; }
    .sa-article .prose p { margin-bottom: 18px; }
    .sa-article .prose p:last-child { margin-bottom: 0; }
    .sa-article .prose strong { color: var(--text-2); font-weight: 600; }
    .sa-article .prose a { color: var(--g); text-decoration: underline; }
    .sa-article .prose ul, .sa-article .prose ol { padding-left: 20px; margin-bottom: 18px; display: flex; flex-direction: column; gap: 8px; }
    .sa-article .prose li { font-size: 15px; color: var(--text-3); line-height: 1.65; }
    .sa-article .prose li::marker { color: var(--g); }

    /* CALLOUT */
    .sa-article .callout {
      border-radius: 10px; padding: 17px 21px 17px 23px; margin: 22px 0;
      border-left: 3px solid var(--g); background: var(--g-bg);
      border-right: 1px solid var(--g-border); border-top: 1px solid var(--g-border); border-bottom: 1px solid var(--g-border);
    }
    .sa-article .callout.warn  { border-left-color: var(--amber); background: var(--amber-bg); border-color: var(--amber-border); border-left-width: 3px; }
    .sa-article .callout.tiktok { border-left-color: var(--tiktok); background: var(--tiktok-bg); border-color: var(--tiktok-border); border-left-width: 3px; }
    .sa-article .callout.sky   { border-left-color: var(--sky); background: var(--sky-bg); border-color: var(--sky-border); border-left-width: 3px; }
    .sa-article .callout-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; color: var(--g); margin-bottom: 6px; display: block; }
    .sa-article .callout.warn   .callout-label { color: var(--amber); }
    .sa-article .callout.tiktok .callout-label { color: var(--tiktok); }
    .sa-article .callout.sky    .callout-label { color: var(--sky); }
    .sa-article .callout p { font-size: 14px; color: var(--text-2); line-height: 1.7; margin: 0; }
    .sa-article .callout p strong { color: var(--text); }
    .sa-article .callout p a { color: var(--g); text-decoration: underline; }
    .sa-article .callout.sky p a { color: var(--sky); }
    .sa-article .callout.tiktok p a { color: var(--tiktok); }

    /* DATA LOSS BAR */
    .sa-article .data-loss-bar {
      background: var(--bg-2); border: 1.5px solid var(--border);
      border-radius: 12px; padding: 20px 24px; margin: 24px 0;
    }
    .sa-article .dlb-title { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: var(--text-4); margin-bottom: 16px; }
    .sa-article .dlb-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .sa-article .dlb-row:last-child { margin-bottom: 0; }
    .sa-article .dlb-label { font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--text-4); min-width: 80px; flex-shrink: 0; }
    .sa-article .dlb-track { flex: 1; height: 6px; background: var(--bg-4); border-radius: 3px; overflow: hidden; }
    .sa-article .dlb-fill { height: 100%; border-radius: 3px; }
    .sa-article .dlb-fill.meta   { background: var(--sky); width: 60%; }
    .sa-article .dlb-fill.google { background: var(--g); width: 43%; }
    .sa-article .dlb-fill.tiktok { background: var(--tiktok); width: 26%; }
    .sa-article .dlb-val { font-family: var(--mono); font-size: 11px; font-weight: 700; min-width: 40px; text-align: right; flex-shrink: 0; }
    .sa-article .dlb-val.meta   { color: var(--sky); }
    .sa-article .dlb-val.google { color: var(--g); }
    .sa-article .dlb-val.tiktok { color: var(--tiktok); }

    /* FLOW COMPARE */
    .sa-article .flow-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 20px 0 28px; }
    .sa-article .flow-card { background: var(--bg-2); border: 1.5px solid var(--border); border-radius: 10px; padding: 18px; }
    .sa-article .flow-card.broken { border-color: var(--red-border); background: var(--red-bg); }
    .sa-article .flow-card.fixed  { border-color: var(--g-border); background: var(--g-bg); }
    .sa-article .flow-title { font-size: 13px; font-weight: 700; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
    .sa-article .flow-card.broken .flow-title { color: var(--red); }
    .sa-article .flow-card.fixed  .flow-title { color: var(--g); }
    .sa-article .flow-steps { display: flex; flex-direction: column; gap: 6px; }
    .sa-article .flow-step { font-size: 12px; color: var(--text-3); display: flex; align-items: flex-start; gap: 8px; line-height: 1.5; }
    .sa-article .flow-step-n { font-family: var(--mono); font-size: 9px; font-weight: 700; color: var(--text-4); flex-shrink: 0; padding-top: 2px; }
    .sa-article .flow-step.blocked .flow-step-n { color: var(--red); }
    .sa-article .flow-step.ok      .flow-step-n { color: var(--g); }
    .sa-article .flow-step.blocked { color: var(--red); opacity: .85; }
    .sa-article .flow-step.ok      { color: var(--g); }
    @media (max-width: 600px) { .sa-article .flow-compare { grid-template-columns: 1fr; } }

    /* STEP CARDS */
    .sa-article .step-cards { display: flex; flex-direction: column; gap: 0; margin: 24px 0 32px; }
    .sa-article .step-card { display: flex; gap: 0; border: 1px solid var(--border); border-bottom: none; background: var(--bg-2); position: relative; transition: background .15s; }
    .sa-article .step-card:first-child { border-radius: 10px 10px 0 0; }
    .sa-article .step-card:last-child  { border-radius: 0 0 10px 10px; border-bottom: 1px solid var(--border); }
    .sa-article .step-card:hover { background: rgba(0,200,100,.02); border-color: rgba(0,200,100,.15); }
    .sa-article .step-card.meta:hover   { background: rgba(125,211,252,.02); border-color: rgba(125,211,252,.15); }
    .sa-article .step-card.google:hover { background: rgba(0,200,100,.03); border-color: rgba(0,200,100,.2); }
    .sa-article .step-card.tiktok:hover { background: rgba(0,242,234,.02); border-color: rgba(0,242,234,.15); }
    .sa-article .step-num-col { width: 56px; min-width: 56px; display: flex; align-items: flex-start; justify-content: center; padding: 20px 0; border-right: 1px solid var(--border); flex-shrink: 0; }
    .sa-article .step-n { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--g); width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--g-border); background: var(--g-bg); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .sa-article .step-card.meta   .step-n { color: var(--sky);    border-color: var(--sky-border);    background: var(--sky-bg); }
    .sa-article .step-card.google .step-n { color: var(--g);      border-color: var(--g-border);      background: var(--g-bg); }
    .sa-article .step-card.tiktok .step-n { color: var(--tiktok); border-color: var(--tiktok-border); background: var(--tiktok-bg); }
    .sa-article .step-body { padding: 18px 20px; flex: 1; }
    .sa-article .step-title { font-size: 15px; font-weight: 700; color: var(--text-2); margin-bottom: 6px; display: flex; align-items: center; gap: 8px; line-height: 1.3; }
    .sa-article .step-desc { font-size: 14px; color: var(--text-3); line-height: 1.7; }
    .sa-article .step-desc strong { color: var(--text-2); font-weight: 600; }
    .sa-article .step-desc a { color: var(--g); text-decoration: underline; }
    .sa-article .step-time { font-family: var(--mono); font-size: 9px; color: var(--text-4); margin-top: 8px; display: block; }
    .sa-article .step-path { font-family: var(--mono); font-size: 9px; color: var(--text-4); margin-top: 4px; display: block; line-height: 1.5; }
    .sa-article .step-platform-tag { font-family: var(--mono); font-size: 8px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: 2px 7px; border-radius: 3px; }
    .sa-article .spt-meta   { background: var(--sky-bg); border: 1px solid var(--sky-border); color: var(--sky); }
    .sa-article .spt-google { background: var(--g-bg); border: 1px solid var(--g-border); color: var(--g); }
    .sa-article .spt-tiktok { background: var(--tiktok-bg); border: 1px solid var(--tiktok-border); color: var(--tiktok); }
    .sa-article .code-ref {
      font-family: var(--mono); font-size: 12px; background: var(--bg-3);
      border: 1px solid var(--border); border-radius: 4px;
      padding: 2px 7px; color: var(--text-2); display: inline-block; margin: 2px 0;
    }

    /* COMPARISON TABLE */
    .sa-article .comp-table-wrap { overflow-x: auto; margin: 8px 0 26px; border-radius: 10px; }
    .sa-article .comp-table { width: 100%; border-collapse: collapse; font-size: 13px; min-width: 420px; }
    .sa-article .comp-table thead tr { background: var(--bg-3); }
    .sa-article .comp-table th { font-family: var(--mono); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; color: var(--text-4); padding: 11px 14px; border-bottom: 1px solid var(--border-2); text-align: left; white-space: nowrap; }
    .sa-article .comp-table td { padding: 12px 14px; border-bottom: 1px solid var(--border); color: var(--text-3); vertical-align: top; line-height: 1.5; }
    .sa-article .comp-table tr:hover td { background: rgba(255,255,255,.015); }
    .sa-article .comp-table .col-label { color: var(--text-2); font-weight: 600; }
    .sa-article .comp-table .col-bad   { color: var(--red); font-size: 13px; }
    .sa-article .comp-table .col-good  { color: var(--g); font-size: 13px; }
    .sa-article .comp-table .col-cost  { font-family: var(--mono); font-size: 11px; color: var(--g); font-weight: 700; }

    /* EMQ GRID */
    .sa-article .emq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 16px 0 24px; }
    .sa-article .emq-item { background: var(--bg-2); border: 1px solid var(--border); border-radius: 8px; padding: 14px; }
    .sa-article .emq-item.high { border-color: var(--g-border); background: var(--g-bg); }
    .sa-article .emq-item.mid  { border-color: var(--amber-border); background: var(--amber-bg); }
    .sa-article .emq-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; margin-bottom: 6px; display: block; }
    .sa-article .emq-item.high .emq-label { color: var(--g); }
    .sa-article .emq-item.mid  .emq-label { color: var(--amber); }
    .sa-article .emq-item      .emq-label { color: var(--text-4); }
    .sa-article .emq-name { font-size: 13px; font-weight: 600; color: var(--text-2); margin-bottom: 3px; }
    .sa-article .emq-note { font-size: 12px; color: var(--text-3); line-height: 1.5; }
    @media (max-width: 600px) { .sa-article .emq-grid { grid-template-columns: 1fr; } }

    /* ARTICLE CTA */
    .sa-article .article-cta {
