        "author": {"@type": "Organization", "name": "Stack Architect", "url": "https://www.stackarchitect.xyz"},
        "publisher": {"@type": "Organization", "name": "Stack Architect", "url": "https://www.stackarchitect.xyz"},
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": "https://www.stackarchitect.xyz/blog/shopify-server-side-tracking-complete-setup-guide"
        },
