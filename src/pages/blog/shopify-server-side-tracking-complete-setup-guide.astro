    <div class="emq-item mid">
      <span class="emq-label">Medium Impact</span>
      <div class="emq-name">IP Address (ip)</div>
      <div class="emq-note">Available directly in the Shopify webhook payload. Include it.</div>
    </div>
    <div class="emq-item mid">
      <span class="emq-label">Medium Impact</span>
      <div class="emq-name">User Agent (ua)</div>
      <div class="emq-note">Available in the Shopify webhook payload. Include it.</div>
    </div>
