const title = "What is the Shopify CAPI?";
const description = "The Shopify CAPI (Conversions API) is Shopify's server-side tracking system that sends purchase and conversion events from Shopify's servers to Meta, Google, TikTok, and other ad platforms — bypassing browser privacy restrictions and recovering missing conversion data.";
const canonical = "https://www.stackarchitect.xyz/faq/what-is-the-shopify-capi";
const datePublished = "2026-04-01";
const dateModified = "2026-04-01";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the Shopify CAPI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Shopify CAPI refers to Shopify's server-side Conversions API integration — a system that sends purchase and conversion event data directly from Shopify's servers to ad platforms like Meta (Facebook), Google, and TikTok, bypassing browser privacy restrictions. It ensures ad platforms receive accurate conversion data even when browser pixels are blocked by iOS, Safari ITP, or ad blockers."
      }
    },
    {
      "@type": "Question",
      "name": "What does CAPI stand for in Shopify?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CAPI stands for Conversions API — originally Meta's (Facebook's) term for their server-side event tracking endpoint. In the Shopify context, 'Shopify CAPI' is commonly used to describe both Meta's Conversions API as implemented on Shopify, and more broadly any server-side conversion tracking system used to send Shopify order events to ad platforms."
      }
    },
    {
      "@type": "Question",
      "name": "Why does Shopify need a CAPI setup?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Shopify's default browser-based pixel tracking misses 30–50% of conversions on stores with significant iOS and mobile traffic, due to Apple's App Tracking Transparency framework and Safari's Intelligent Tracking Prevention. The CAPI sends purchase events server-side, recovering these missing conversions and restoring accurate ROAS reporting in Meta Ads and Google Ads."
      }
    },
    {
      "@type": "Question",
      "name": "Is the Shopify CAPI free to set up?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Meta's Conversions API itself is free — it is an API endpoint that any developer or tool can connect to. Setting it up manually requires developer knowledge. CAPI Shield by Stack Architect provides a free, no-code implementation of Meta CAPI and Google Enhanced Conversions for Shopify stores, with setup under one hour and no monthly subscription."
      }
    },
    {
      "@type": "Question",
      "name": "Does Shopify have a native CAPI integration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Shopify has a partial native CAPI integration via the Meta Sales Channel app, but it requires the Meta Business Suite integration and does not give merchants control over event configuration, deduplication settings, or custom event parameters. For complete CAPI implementation with full control, a dedicated tool like CAPI Shield or a manual developer setup is required."
      }
    }
  ]
};
