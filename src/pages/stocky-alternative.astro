<script>
(function() {
  var header = document.querySelector('.product-terminal-bar');
  var cta = document.getElementById('nav-cta');
  if (cta) {
    var clone = cta.cloneNode(true);
    clone.id = 'nav-cta-floating';
    clone.style.cssText = 'display:none;position:fixed;top:12px;left:50%;transform:translateX(-50%);z-index:999999;background:#00a854;color:#fff;border-color:#00c864;box-shadow:0 4px 15px rgba(0,168,84,.4);font-family:"JetBrains Mono",monospace;font-size:10px;font-weight:900;text-decoration:none;text-transform:uppercase;padding:8px 18px;border-radius:4px;border:1px solid #00c864;white-space:nowrap;';
    clone.innerHTML = 'REPLACE STOCKY FREE &rarr;';
    clone.href = 'https://stackarchitect.xyz/stocky-swap';
    document.body.appendChild(clone);
    window.addEventListener('scroll', function() {
      var s = window.scrollY;
      if (header) header.classList.toggle('scrolled', s > 50);
      clone.style.display = s > 50 ? 'block' : 'none';
      cta.style.visibility = s > 50 ? 'hidden' : 'visible';
    });
  }
  document.querySelectorAll('.dropdown > .product-link').forEach(function(l) {
    l.addEventListener('click', function(e) {
      if (window.innerWidth <= 850) {
        e.preventDefault();
        var exp = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', !exp);
        this.parentElement.classList.toggle('active');
      }
    });
  });
  var s = document.createElement('style');
  s.textContent = '.dropdown.active .dropdown-menu{display:flex;}';
  document.head.appendChild(s);
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.dropdown')) {
      document.querySelectorAll('.dropdown').forEach(function(d) { d.classList.remove('active'); });
    }
  });
  (function() {
    var el = document.getElementById('footer-copyright');
    if (el) el.textContent = '© ' + new Date().getFullYear() + ' STACK_ARCHITECT // CORE_DEPLOYMENT';
  })();

  // Countdown logic (shared across page)
  function calcCountdown() {
    var target = new Date('2026-08-31T23:59:59Z');
    var now = new Date();
    var diff = target - now;
    if (diff <= 0) return { d: 0, h: 0, m: 0, label: 'DEADLINE PASSED' };
    var d = Math.floor(diff / (1000 * 60 * 60 * 24));
    var h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    var m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    return { d: d, h: h, m: m, label: d + ' days ' + h + ' hrs ' + m + ' min' };
  }
  function updateAll() {
    var c = calcCountdown();
    var hero = document.getElementById('hero-countdown');
    if (hero) hero.textContent = c.label;
    var bd = document.getElementById('big-cd-d');
    var bh = document.getElementById('big-cd-h');
    var bm = document.getElementById('big-cd-m');
    if (bd) bd.textContent = c.d;
    if (bh) bh.textContent = String(c.h).padStart(2,'0');
    if (bm) bm.textContent = String(c.m).padStart(2,'0');
  }
  updateAll();
  setInterval(updateAll, 30000);

  // Scroll bar
  var shown = false, gone = false;
  window.addEventListener('scroll', function() {
    if (gone) return;
    var pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
    var bar = document.getElementById('scroll-bar');
    if (pct > 60 && !shown) { bar.style.display = 'block'; shown = true; }
    else if (pct < 40 && shown) { bar.style.display = 'none'; shown = false; }
  }, { passive: true });
  var dismiss = document.getElementById('scroll-dismiss');
  if (dismiss) dismiss.addEventListener('click', function() {
    document.getElementById('scroll-bar').style.display = 'none'; gone = true;
  });
})();

