    var target = new Date('2026-08-31T23:59:59Z');
    var now = new Date();
    var diff = target - now;
    if (diff <= 0) { ['cd-d','cd-h','cd-m'].forEach(function(id){var e=document.getElementById(id);if(e)e.textContent='0';}); return; }
    var days = Math.floor(diff / 86400000);
    var hours = Math.floor((diff % 86400000) / 3600000);
    var mins = Math.floor((diff % 3600000) / 60000);
    var d=document.getElementById('cd-d'); if(d) d.textContent=days;
    var h=document.getElementById('cd-h'); if(h) h.textContent=String(hours).padStart(2,'0');
    var m=document.getElementById('cd-m'); if(m) m.textContent=String(mins).padStart(2,'0');
  }
  updateCountdown();
  setInterval(updateCountdown, 30000);

  // Scroll bar reveal
  var shown = false, gone = false;
  window.addEventListener('scroll', function() {
    if (gone) return;
    var pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
    var bar = document.getElementById('scroll-bar');
    if (!bar) return;
    if (pct > 55 && !shown) { bar.style.display = 'block'; shown = true; }
    else if (pct < 35 && shown) { bar.style.display = 'none'; shown = false; }
  }, { passive: true });
  var dismiss = document.getElementById('scroll-dismiss');
  if (dismiss) dismiss.addEventListener('click', function() {
    var bar = document.getElementById('scroll-bar');
    if (bar) bar.style.display = 'none';
