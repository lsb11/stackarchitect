      "offers": { "@type": "Offer", "price": "29", "priceCurrency": "USD", "availability": "https://schema.org/InStock" },
      "description": "Four ready-to-import Make.com JSON blueprints that deploy Shopify server-side tracking, TikTok Events API, inventory management, and live P&L reporting in 10 minutes. Includes Google Sheets templates and Loom walkthroughs.",
