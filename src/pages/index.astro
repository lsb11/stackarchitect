        { "@type": "ListItem", "position": 5, "name": "Shopify P&L Automation", "url": "https://stackarchitect.xyz/shopify-profit-loss-automation", "description": "Free live profit and loss reporting in Google Sheets. Replaces TrueProfit, BeProfit. Saves $19–$299/month." },
        { "@type": "ListItem", "position": 6, "name": "Autocrat Quota Fix", "url": "https://stackarchitect.xyz/autocrat-quota-fix", "description": "Fix Google Apps Script quota errors. Keeps the entire free stack running. Saves $49–$99/month." }
