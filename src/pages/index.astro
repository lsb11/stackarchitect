---
// FAQ index page — /faq
// Lists all FAQ pages, helps internal linking and sitewide navigation
const title = "Shopify FAQ — Direct Answers to Common Questions";
const description = "Direct answers to the most common Shopify tool questions — Stocky replacement, Klaviyo pricing, Triple Whale cost, server-side tracking, Make.com, Shopify CAPI, and TikTok Events API.";
const canonical = "https://www.stackarchitect.xyz/faq";

const faqs = [
  {
    slug: "what-replaces-stocky-after-august-2026",
    question: "What replaces Stocky after August 2026?",
    summary: "Shopify is shutting Stocky down in August 2026. Free replacement options and how to migrate.",
    category: "Inventory",
    readTime: "3 min"
  },
  {
    slug: "is-klaviyo-free",
    question: "Is Klaviyo free?",
    summary: "Free plan limited to 500 contacts. Pricing breakdown and free alternatives for Shopify.",
    category: "Email Marketing",
    readTime: "3 min"
  },
  {
    slug: "how-much-does-triple-whale-cost",
    question: "How much does Triple Whale cost?",
    summary: "Starter $129/mo · Growth $299/mo · Pro $599/mo — full plan breakdown and free alternatives.",
    category: "Analytics",
    readTime: "3 min"
  },
  {
    slug: "what-is-server-side-tracking-for-shopify",
    question: "What is server-side tracking for Shopify?",
    summary: "Server-side tracking bypasses iOS privacy restrictions that cause 30-50% of conversions to go missing.",
    category: "Tracking",
    readTime: "4 min"
  },
  {
    slug: "does-make-com-work-with-shopify",
    question: "Does Make.com work with Shopify?",
    summary: "Yes. 100+ triggers and actions, 1,000 free operations/month. Replaces $400+/mo of Shopify apps.",
    category: "Automation",
    readTime: "4 min"
  },
  {
    slug: "what-is-the-shopify-capi",
    question: "What is the Shopify CAPI?",
    summary: "The Conversions API sends purchase events server-side to Meta and Google, bypassing browser blocks.",
    category: "Tracking",
    readTime: "4 min"
  },
  {
    slug: "how-do-i-set-up-tiktok-events-api-on-shopify-without-code",
    question: "How do I set up TikTok Events API on Shopify without code?",
    summary: "Free tool, 10-minute setup, no developer required. Sends purchase events server-side to TikTok.",
    category: "TikTok Ads",
    readTime: "4 min"
  }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Stack Architect</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.stackarchitect.xyz/" },
      { "@type": "ListItem", "position": 2, "name": "FAQ", "item": canonical }
    ]
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #080c0a; --surface: #0d1410; --border: #162018;
      --accent: #22c55e; --accent-dim: #16a34a;
      --text: #d1fae5; --muted: #4b7a5a;
      --font: 'JetBrains Mono', 'Courier New', monospace;
    }
    html { background: var(--bg); color: var(--text); font-family: var(--font); font-size: 14px; line-height: 1.7; }
    body { min-height: 100vh; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .nav { border-bottom: 1px solid var(--border); padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 52px; background: var(--bg); position: sticky; top: 0; z-index: 100; }
    .nav-logo { font-weight: 700; font-size: 13px; color: var(--accent); letter-spacing: 0.05em; }
    .nav-links { display: flex; gap: 1.5rem; list-style: none; }
    .nav-links a { color: var(--muted); font-size: 12px; }
    .nav-links a:hover { color: var(--accent); text-decoration: none; }
    .nav-cta { background: var(--accent); color: #080c0a; font-size: 11px; font-weight: 700; padding: 6px 14px; letter-spacing: 0.08em; }
    .nav-cta:hover { background: var(--accent-dim); text-decoration: none; color: #080c0a; }
    .breadcrumb { padding: 1rem 1.5rem 0; font-size: 11px; color: var(--muted); }
    .breadcrumb a { color: var(--muted); }
    .breadcrumb span { margin: 0 0.4rem; }
    .container { max-width: 760px; margin: 0 auto; padding: 2.5rem 1.5rem 5rem; }
    .page-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.15em; color: var(--muted); margin-bottom: 1rem; }
    .page-tag span { color: var(--accent); }
    h1 { font-size: clamp(1.25rem, 4vw, 1.75rem); font-weight: 700; color: var(--text); line-height: 1.3; margin-bottom: 1rem; }
    .intro { font-size: 14px; color: var(--muted); margin-bottom: 2.5rem; }
    .faq-list { display: flex; flex-direction: column; gap: 0.75rem; }
    .faq-card { background: var(--surface); border: 1px solid var(--border); padding: 1.25rem 1.5rem; display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; transition: border-color 0.15s; }
    .faq-card:hover { border-color: var(--accent); }
    .faq-card-left { flex: 1; }
    .faq-meta { display: flex; gap: 1rem; font-size: 10px; color: var(--muted); margin-bottom: 0.4rem; }
    .faq-meta .cat { color: var(--accent); font-weight: 700; }
    .faq-q { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 0.4rem; }
    .faq-summary { font-size: 12px; color: var(--muted); }
    .faq-arrow { color: var(--muted); font-size: 16px; flex-shrink: 0; margin-top: 2px; }
    .faq-card:hover .faq-arrow { color: var(--accent); }
    footer { border-top: 1px solid var(--border); padding: 2rem 1.5rem; font-size: 11px; color: var(--muted); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
    footer a { color: var(--muted); }
    footer a:hover { color: var(--accent); }
  </style>
</head>
<body>

<nav class="nav">
  <a class="nav-logo" href="/">STACK_ARCHITECT</a>
  <ul class="nav-links">
    <li><a href="/stocky-swap">Stocky_Swap</a></li>
    <li><a href="/capi-shield">CAPI_Shield</a></li>
    <li><a href="/tools">Tools</a></li>
    <li><a href="/shopify-automation-guides">Guides</a></li>
  </ul>
  <a class="nav-cta" href="/pro">GO PRO →</a>
</nav>

<div class="breadcrumb">
  <a href="/">~/HOME</a><span>//</span>
  FAQ
</div>

<main class="container">

  <div class="page-tag">FAQ // <span>DIRECT ANSWERS</span> // SHOPIFY_TOOLS</div>

  <h1>Shopify Tool FAQ</h1>
  <p class="intro">
    One-question pages with direct answers. No padding, no fluff — just the answer and where to go next.
  </p>

  <div class="faq-list">
    {faqs.map(faq => (
      <a class="faq-card" href={`/faq/${faq.slug}`}>
        <div class="faq-card-left">
          <div class="faq-meta">
            <span class="cat">{faq.category}</span>
            <span>{faq.readTime}</span>
          </div>
          <div class="faq-q">{faq.question}</div>
          <div class="faq-summary">{faq.summary}</div>
        </div>
        <div class="faq-arrow">→</div>
      </a>
    ))}
  </div>

</main>

<footer>
  <div>© 2026 STACK ARCHITECT // ALL SYSTEMS FREE</div>
  <div>
    <a href="/tools">Tools</a> &nbsp;·&nbsp;
    <a href="/shopify-automation-guides">Guides</a> &nbsp;·&nbsp;
    <a href="/about">About</a>
  </div>
</footer>

</body>
</html>
