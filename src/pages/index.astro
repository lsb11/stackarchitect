<style is:global>
/* ── Design tokens ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
:root{
  --g:#00c864;--g-dim:#00a854;--g-bg:rgba(0,200,100,.08);--g-border:rgba(0,200,100,.2);
  --bg:#020617;--bg-2:#06101e;--bg-3:#0a1628;--bg-4:#0f1f35;
  --border:#1e293b;--border-2:#263548;
  --text:#f1f5f9;--text-2:#cbd5e1;--text-3:#94a3b8;--text-4:#64748b;--text-inv:#020617;
  --red:#fc8181;--red-bg:rgba(252,129,129,.07);--red-border:rgba(252,129,129,.18);
  --sky:#7dd3fc;--sky-bg:rgba(125,211,252,.07);--sky-border:rgba(125,211,252,.18);
  --amber:#fcd34d;--vio:#c4b5fd;--vio-bg:rgba(196,181,253,.07);--vio-border:rgba(196,181,253,.18);
  --tiktok:#ff0050;--tiktok-bg:rgba(255,0,80,.07);--tiktok-border:rgba(255,0,80,.2);
  --mono:'JetBrains Mono',monospace;--sans:'Inter',-apple-system,sans-serif;
  --sp:100px;--card-pad:32px;
}
body{font-family:var(--sans);background:var(--bg);color:var(--text-3);line-height:1.75;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:rgba(0,200,100,.3);border-radius:2px;}
::selection{background:rgba(0,200,100,.2);color:var(--text);}
.tag{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:5px 12px;border-radius:3px;background:var(--g-bg);border:1px solid var(--g-border);color:var(--g);}
.tag-dim{background:rgba(255,255,255,.03);border-color:var(--border-2);color:var(--text-4);}
.tag-sky{background:var(--sky-bg);border-color:var(--sky-border);color:var(--sky);}
.tag-vio{background:var(--vio-bg);border-color:var(--vio-border);color:var(--vio);}
.tag-red{background:var(--red-bg);border-color:var(--red-border);color:var(--red);}
.tag-tiktok{background:var(--tiktok-bg);border-color:var(--tiktok-border);color:var(--tiktok);}
.dot{display:inline-block;width:7px;height:7px;min-width:7px;border-radius:50%;background:var(--g);animation:dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite;}
@keyframes dotPing{0%{box-shadow:0 0 0 0 rgba(0,200,100,.5);}70%{box-shadow:0 0 0 8px rgba(0,200,100,0);}100%{box-shadow:0 0 0 0 rgba(0,200,100,0);}}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;font-family:var(--sans);font-size:16px;font-weight:700;text-decoration:none;letter-spacing:-.01em;padding:16px 32px;border-radius:6px;border:none;cursor:pointer;white-space:nowrap;background:var(--g);color:var(--text-inv);transition:background .2s,transform .15s,box-shadow .2s;min-height:52px;}
.btn:hover{background:#00e070;transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,200,100,.3);}
.btn.pulse{animation:btnGlow 2.8s ease-in-out infinite;}
@keyframes btnGlow{0%,100%{box-shadow:0 0 16px rgba(0,200,100,.1);}50%{box-shadow:0 0 28px rgba(0,200,100,.28);}}
.btn.pulse:hover{animation:none;}
.btn-sm{font-size:14px;padding:12px 22px;min-height:44px;}
.btn-outline{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-family:var(--sans);font-size:15px;font-weight:600;text-decoration:none;letter-spacing:-.01em;padding:15px 28px;border-radius:6px;border:1.5px solid var(--border-2);cursor:pointer;white-space:nowrap;background:transparent;color:var(--text-2);transition:border-color .2s,color .2s,background .2s;min-height:52px;}
.btn-outline:hover{border-color:var(--g);color:var(--g);background:var(--g-bg);}
.btn-outline-sm{font-size:13px;padding:11px 20px;min-height:44px;}
.section{padding:var(--sp) 24px;}
.section-alt{padding:var(--sp) 24px;background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.inner{max-width:1000px;margin:0 auto;}
.inner-sm{max-width:720px;margin:0 auto;}
.inner-md{max-width:880px;margin:0 auto;}
.sec-head{text-align:center;margin-bottom:56px;}
.sec-head h2{font-family:var(--sans);font-weight:900;font-size:clamp(26px,4vw,40px);letter-spacing:-.03em;color:var(--text);line-height:1.05;margin-bottom:10px;}
.sec-head p{font-size:15px;color:var(--text-3);max-width:480px;margin:14px auto 0;line-height:1.75;}
.bg-grid{background-color:var(--bg);background-image:radial-gradient(ellipse 80% 40% at 50% 0%,rgba(0,200,100,.06) 0%,transparent 60%),radial-gradient(circle,var(--border) 1px,transparent 1px);background-size:100% 100%,44px 44px;}
.stat-strip{display:grid;grid-template-columns:repeat(4,1fr);background:var(--border);gap:1px;border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.stat-cell{background:var(--bg);padding:20px 12px;text-align:center;}
.stat-v{font-family:var(--mono);font-size:22px;font-weight:700;color:var(--g);line-height:1;}
.stat-l{font-size:11px;color:var(--text-4);text-transform:uppercase;letter-spacing:.12em;margin-top:6px;font-family:var(--mono);}
.divider{height:1px;background:var(--border);}
.product-terminal-bar{width:100%;background:#020617;padding:12px 0;border-bottom:1px solid #1e293b;position:sticky;top:0;z-index:10002;transition:all .3s ease;}
.product-terminal-bar.scrolled{background:rgba(2,6,23,.95);backdrop-filter:blur(12px);padding:8px 0;border-bottom:1px solid rgba(0,168,84,.3);box-shadow:0 4px 20px rgba(0,0,0,.4);}
.terminal-container{max-width:1100px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;padding:0 24px;}
.terminal-status{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:9px;color:#475569;letter-spacing:1.5px;font-weight:800;}
.status-indicator{width:5px;height:5px;background:#00a854;border-radius:50%;box-shadow:0 0 8px #00a854;animation:sPulse 2s infinite;}
@keyframes sPulse{0%,100%{box-shadow:0 0 8px #00a854;}50%{box-shadow:0 0 16px #00a854;}}
.product-access-grid{display:flex;gap:clamp(12px,2.5vw,24px);list-style:none;align-items:center;}
.product-link{font-family:var(--mono);font-size:10px;font-weight:800;color:#94a3b8;text-decoration:none;text-transform:uppercase;letter-spacing:1px;transition:all .3s cubic-bezier(.16,1,.3,1);display:flex;align-items:center;gap:4px;}
.product-link::before{content:'[';color:#334155;transition:color .3s;}
.product-link::after{content:']';color:#334155;transition:color .3s;}
.product-link:hover,.product-link.is-active{color:#fff;transform:translateY(-1px);}
.product-link:hover::before,.product-link:hover::after,.product-link.is-active::before,.product-link.is-active::after{color:#00a854;}
.product-link.is-active{color:#00a854;}
.terminal-cta{display:flex;align-items:center;margin-left:16px;}
.savings-ticker{font-family:var(--mono);font-size:8px;font-weight:800;color:#00a854;letter-spacing:1px;margin-right:12px;white-space:nowrap;opacity:.8;}
.cta-node{font-family:var(--mono);font-size:10px;font-weight:900;color:#00a854;text-decoration:none;text-transform:uppercase;padding:6px 14px;border:1px solid #00a854;border-radius:4px;transition:all .3s cubic-bezier(.175,.885,.32,1.275);display:inline-block;white-space:nowrap;}
.cta-node:hover{background:#00a854;color:#fff;box-shadow:0 6px 20px rgba(0,168,84,.5);transform:scale(1.05);}
.dropdown{position:relative;cursor:pointer;}
.dropdown-menu{display:none;position:absolute;top:calc(100% + 8px);left:0;background:#020617;border:1px solid #1e293b;border-radius:6px;padding:8px 0;min-width:280px;z-index:10003;flex-direction:column;list-style:none;box-shadow:0 20px 40px rgba(0,0,0,.5);}
.dropdown-menu .product-link::before,.dropdown-menu .product-link::after{content:'';}
.dropdown-menu .product-link{display:block;padding:10px 16px;font-size:10px;color:#94a3b8;transition:all .15s;}
.dropdown-menu .product-link:hover{color:#fff;background:rgba(0,168,84,.1);transform:none;}
.dropdown-desc{display:block;font-family:var(--sans);font-size:10px;font-weight:400;color:#475569;letter-spacing:0;text-transform:none;margin-top:2px;line-height:1.4;}
.dropdown-divider{height:1px;background:#1e293b;margin:4px 0;}
@media(min-width:851px){.dropdown:hover .dropdown-menu{display:flex;}}
@media(max-width:850px){
  .terminal-status,.savings-ticker{display:none;}
  .terminal-container{flex-direction:column;gap:14px;}
  .product-access-grid{display:grid;grid-template-columns:repeat(2,auto);gap:10px 18px;}
  .terminal-cta{margin-left:0;order:-1;width:100%;justify-content:center;}
  .cta-node{background:#00a854;color:#fff;width:80%;text-align:center;}
}
.hero{padding:96px 24px 80px;text-align:center;position:relative;overflow:hidden;}
.hero-inner{max-width:960px;margin:0 auto;position:relative;}
.hero-dateline{font-family:var(--mono);font-size:10px;color:var(--text-4);letter-spacing:.1em;text-transform:uppercase;margin-bottom:16px;opacity:.6;}
.hero-proof{display:inline-flex;align-items:center;gap:12px;background:rgba(255,255,255,.04);border:1px solid var(--border-2);border-radius:100px;padding:9px 22px;margin-bottom:44px;flex-wrap:wrap;justify-content:center;}
.hero-proof-stars{color:var(--amber);font-size:14px;letter-spacing:2px;}
.hero-proof-txt{font-family:var(--mono);font-size:11px;color:var(--text-4);letter-spacing:.08em;}
.hero h1{font-size:clamp(46px,8vw,86px);font-weight:900;color:var(--text);line-height:.95;letter-spacing:-.04em;margin:0 auto 28px;max-width:840px;}
.hero h1 .green{color:var(--g);}
.hero h1 .dim{color:var(--text-4);}
.hero-sub{font-size:clamp(17px,2.2vw,21px);color:var(--text-3);max-width:620px;margin:0 auto 32px;line-height:1.7;}
.hero-sub strong{color:var(--text-2);font-weight:600;}
.cost-row{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin-bottom:36px;}
.cost-pill{background:var(--red-bg);border:1px solid var(--red-border);border-radius:8px;padding:12px 18px;text-align:center;}
.cost-v{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--red);line-height:1;}
.cost-l{font-size:11px;color:var(--text-4);margin-top:4px;}
.trust-row{display:flex;flex-wrap:wrap;justify-content:center;gap:20px;margin-bottom:36px;}
.trust-item{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--text-3);}
.urgency{display:inline-flex;align-items:center;gap:8px;background:rgba(252,211,77,.06);border:1px solid rgba(252,211,77,.18);border-radius:4px;padding:8px 18px;margin-bottom:36px;font-size:13px;color:var(--amber);font-weight:500;}
.hero-ctas{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:14px;margin-bottom:14px;}
.hero-cta-note{font-size:13px;color:var(--text-4);line-height:1.6;margin-bottom:44px;}
.hero-cta-note a{color:rgba(0,200,100,.6);text-decoration:underline;}
.hero-quote{display:block;max-width:500px;margin:0 auto 52px;text-align:left;background:rgba(255,255,255,.03);border:1px solid var(--border-2);border-left:3px solid var(--g);border-radius:0 8px 8px 0;padding:24px 28px;}
.hero-quote blockquote{font-size:15px;color:var(--text-2);font-style:italic;line-height:1.65;margin-bottom:10px;}
.hero-quote cite{font-family:var(--mono);font-size:11px;color:var(--text-4);letter-spacing:.1em;text-transform:uppercase;font-style:normal;}
.pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;max-width:800px;margin:0 auto 16px;}
.pillar{background:rgba(255,255,255,.025);border:1.5px solid var(--border);border-radius:10px;padding:22px 20px;text-align:left;text-decoration:none;display:block;transition:border-color .2s,background .2s,transform .2s;}
.pillar:hover{border-color:var(--g-border);background:var(--g-bg);transform:translateY(-4px);}
.pillar .ptag{display:block;margin-bottom:10px;}
.pillar .pname{font-size:16px;font-weight:700;color:var(--text);margin-bottom:4px;line-height:1.2;}
.pillar .pdesc{font-size:12px;color:var(--text-3);line-height:1.5;}
.pillar .psave{font-family:var(--mono);font-size:12px;margin-top:10px;font-weight:700;}
.pillars-more{text-align:center;margin-bottom:52px;}
.pillars-more a{font-family:var(--mono);font-size:11px;color:var(--text-4);text-decoration:none;letter-spacing:.1em;text-transform:uppercase;transition:color .2s;}
.pillars-more a:hover{color:var(--g);}
.scan-card{background:var(--bg-3);border:1px solid var(--border-2);border-radius:14px;overflow:hidden;}
.pain-list{display:flex;flex-direction:column;gap:10px;padding:28px 28px 0;}
.pain-btn{width:100%;display:flex;align-items:center;justify-content:space-between;gap:14px;padding:16px 18px;border-radius:10px;border:1.5px solid var(--border);background:rgba(255,255,255,.025);text-align:left;cursor:pointer;transition:all .2s;outline:none;font-family:var(--sans);min-height:56px;}
.pain-btn:hover{border-color:var(--border-2);background:rgba(255,255,255,.04);}
.pain-btn:focus-visible{outline:2px solid var(--g);outline-offset:2px;}
.pain-btn.on{background:rgba(0,200,100,.06);border-color:rgba(0,200,100,.3);}
.pain-chk{width:20px;height:20px;min-width:20px;border-radius:5px;border:2px solid var(--border-2);display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0;}
.pain-btn.on .pain-chk{background:var(--g);border-color:var(--g);}
.pain-label-wrap{flex:1;}
.pain-label{font-size:14px;font-weight:500;color:var(--text-3);line-height:1.4;transition:color .15s;}
.pain-btn.on .pain-label{color:var(--text);}
.pain-badge{font-family:var(--mono);font-size:10px;color:rgba(0,200,100,.6);letter-spacing:.1em;text-transform:uppercase;display:block;margin-top:3px;}
.pain-cost{font-family:var(--mono);font-size:13px;font-weight:700;color:rgba(252,129,129,.4);flex-shrink:0;transition:color .15s;white-space:nowrap;}
.pain-btn.on .pain-cost{color:var(--red);}
.scan-result{margin:20px 28px 0;border-radius:10px;padding:22px;background:rgba(255,255,255,.025);border:1.5px solid var(--border);transition:all .35s;}
.scan-result.leak{background:rgba(252,129,129,.04);border-color:rgba(252,129,129,.2);}
.sr-inner{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;}
.sr-label{font-family:var(--mono);font-size:11px;color:var(--text-4);text-transform:uppercase;letter-spacing:.15em;margin-bottom:6px;}
.sr-total{font-weight:900;font-size:40px;color:var(--text);line-height:1;letter-spacing:-.04em;}
.sr-mo{font-size:20px;color:var(--text-4);font-weight:400;}
.sr-year{font-family:var(--mono);font-size:13px;color:rgba(252,129,129,.6);margin-top:5px;display:none;}
.sr-recs-label{font-family:var(--mono);font-size:11px;color:var(--text-4);text-transform:uppercase;letter-spacing:.12em;margin-bottom:6px;text-align:right;}
.sr-recs-item{font-size:13px;font-weight:600;color:var(--g);line-height:1.5;text-align:right;}
.scan-cta-wrap{padding:18px 28px 28px;}
.scan-cta{display:block;width:100%;padding:17px 20px;border-radius:8px;font-family:var(--sans);font-size:15px;font-weight:700;text-align:center;border:none;cursor:not-allowed;background:rgba(255,255,255,.05);color:rgba(255,255,255,.25);transition:all .2s;min-height:52px;}
.scan-cta.ready{background:var(--g);color:var(--text-inv);cursor:pointer;animation:ctaGlow 2.5s ease-in-out infinite;}
@keyframes ctaGlow{0%,100%{box-shadow:0 0 16px rgba(0,200,100,.12);}50%{box-shadow:0 0 28px rgba(0,200,100,.28);}}
.scan-cta.ready:hover{background:#00e070;animation:none;box-shadow:0 8px 24px rgba(0,200,100,.3);}
.scan-meta{text-align:center;font-size:13px;color:var(--text-4);margin-top:10px;}
.plan-step{display:none;padding:28px;}
.plan-hd{margin-bottom:18px;}
.plan-hd h3{font-weight:900;font-size:22px;color:var(--text);letter-spacing:-.03em;margin-bottom:5px;line-height:1.2;}
.plan-hd p{font-size:13px;color:var(--text-3);line-height:1.6;}
.plan-items{display:flex;flex-direction:column;gap:10px;margin-bottom:24px;}
.plan-item{display:flex;gap:14px;background:rgba(255,255,255,.025);border:1px solid var(--border);border-radius:10px;padding:16px;}
.plan-num{width:24px;height:24px;min-width:24px;border-radius:50%;background:rgba(0,200,100,.1);border:1px solid rgba(0,200,100,.25);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;font-weight:700;color:var(--g);margin-top:1px;}
.plan-sol{font-size:15px;font-weight:700;color:var(--text);margin-bottom:3px;}
.plan-fix{font-size:13px;color:var(--text-3);}
.plan-rec{font-family:var(--mono);font-size:11px;color:var(--g);margin-top:5px;}
.email-block{background:rgba(255,255,255,.025);border:1px solid var(--border);border-radius:10px;padding:22px;}
.email-block h4{font-size:15px;font-weight:700;color:var(--text);margin-bottom:5px;line-height:1.3;}
.email-block p{font-size:13px;color:var(--text-3);margin-bottom:16px;line-height:1.6;}
.email-row{display:flex;flex-wrap:wrap;gap:10px;}
.email-inp{flex:1;min-width:170px;background:rgba(255,255,255,.05);border:1.5px solid var(--border);border-radius:8px;padding:13px 16px;color:var(--text);font-size:15px;font-family:var(--sans);outline:none;transition:border-color .2s;min-height:48px;}
.email-inp:focus{border-color:var(--g);}
.email-inp::placeholder{color:var(--text-4);}
.email-go{font-family:var(--sans);font-size:13px;font-weight:700;background:var(--g);color:var(--text-inv);border:none;padding:13px 22px;border-radius:8px;cursor:pointer;white-space:nowrap;transition:background .2s;min-height:48px;}
.email-go:hover{background:#00e070;}
.email-disc{font-size:11px;color:var(--text-4);margin-top:10px;line-height:1.5;}
.done-step{display:none;padding:52px 28px;text-align:center;}
.done-icon{width:56px;height:56px;border-radius:50%;background:rgba(0,200,100,.1);border:1px solid rgba(0,200,100,.25);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;}
.done-step h3{font-weight:900;font-size:22px;color:var(--text);letter-spacing:-.02em;margin-bottom:8px;}
.done-step p{font-size:15px;color:var(--text-3);margin-bottom:24px;line-height:1.65;max-width:340px;margin-left:auto;margin-right:auto;}
.how-grid{display:grid;grid-template-columns:repeat(3,1fr);background:var(--border);gap:1px;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:12px;}
.how-step{background:var(--bg);padding:36px 30px;}
.how-n{font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.18em;color:var(--g);margin-bottom:20px;text-transform:uppercase;}
.how-title{font-weight:700;font-size:18px;color:var(--text);letter-spacing:-.02em;margin-bottom:12px;line-height:1.25;}
.how-body{font-size:15px;color:var(--text-3);line-height:1.75;margin-bottom:18px;}
.how-tool{font-family:var(--mono);font-size:11px;color:var(--text-4);background:rgba(255,255,255,.03);border:1px solid var(--border);padding:5px 11px;border-radius:3px;display:inline-block;}
.cta-strip{background:var(--bg-3);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:36px 24px;}
.cta-strip-inner{max-width:860px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;}
.cta-strip-title{font-weight:700;font-size:clamp(16px,2.5vw,22px);color:var(--text);letter-spacing:-.02em;margin-bottom:5px;line-height:1.3;}
.cta-strip-sub{font-size:13px;color:var(--text-3);}
.cta-strip-sub span{color:var(--g);font-weight:600;}
.cta-strip-actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.sol-urgent{background:var(--bg-3);border:2px solid rgba(252,211,77,.25);border-radius:14px;overflow:hidden;margin-bottom:20px;position:relative;}
.sol-urgent-bar{height:3px;background:linear-gradient(90deg,var(--amber),rgba(252,211,77,.3));}
.sol-urgent-inner{padding:32px 36px;display:flex;align-items:flex-start;justify-content:space-between;gap:32px;flex-wrap:wrap;}
.sol-urgent-badge{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--amber);background:rgba(252,211,77,.08);border:1px solid rgba(252,211,77,.2);padding:4px 10px;border-radius:3px;display:inline-block;margin-bottom:10px;}
.sol-urgent-name{font-weight:900;font-size:clamp(22px,4vw,32px);color:var(--text);letter-spacing:-.03em;line-height:1.05;margin-bottom:8px;}
.sol-urgent-hl{font-size:14px;font-weight:600;color:var(--amber);margin-bottom:14px;}
.sol-urgent-desc{font-size:15px;color:var(--text-3);line-height:1.75;max-width:540px;margin-bottom:20px;}
.sol-urgent-reps{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;}
.sol-rep{background:rgba(255,255,255,.03);border:1px solid var(--border);color:var(--text-4);font-size:11px;padding:3px 9px;border-radius:3px;text-decoration:line-through;text-decoration-color:rgba(252,129,129,.5);}
.sol-urgent-right{display:flex;flex-direction:column;align-items:flex-end;gap:16px;min-width:200px;}
.countdown-box{background:rgba(252,211,77,.06);border:1px solid rgba(252,211,77,.2);border-radius:10px;padding:20px 24px;text-align:center;}
.countdown-label{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--amber);margin-bottom:8px;}
.countdown-nums{display:flex;gap:8px;justify-content:center;}
.cd-unit{text-align:center;}
.cd-val{font-family:var(--mono);font-size:22px;font-weight:700;color:var(--text);line-height:1;}
.cd-l{font-size:10px;color:var(--text-4);margin-top:2px;}
.cd-sep{font-family:var(--mono);font-size:20px;font-weight:700;color:var(--text-4);padding-top:2px;}
.sol-urgent-meta{display:flex;align-items:center;justify-content:space-between;padding-top:16px;border-top:1px solid rgba(252,211,77,.15);}
.sol-urgent-save{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--amber);}
.sol-urgent-time{font-family:var(--mono);font-size:11px;color:var(--text-4);background:rgba(255,255,255,.03);border:1px solid var(--border);padding:4px 9px;border-radius:3px;}
.sol-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;}
.sol-card{border-radius:12px;display:flex;flex-direction:column;overflow:hidden;border:1.5px solid;transition:transform .25s,box-shadow .25s;}
.sol-card:hover{transform:translateY(-6px);}
.sol-card.g{border-color:rgba(0,200,100,.2);background:rgba(0,200,100,.03);}
.sol-card.s{border-color:rgba(125,211,252,.2);background:rgba(125,211,252,.03);}
.sol-card.v{border-color:rgba(196,181,253,.2);background:rgba(196,181,253,.03);}
.sol-card.t{border-color:rgba(255,0,80,.18);background:rgba(255,0,80,.03);}
.sol-card.e{border-color:rgba(0,200,100,.15);background:rgba(0,200,100,.02);}
.sol-card.g:hover{box-shadow:0 20px 48px rgba(0,200,100,.1);}
.sol-card.s:hover{box-shadow:0 20px 48px rgba(125,211,252,.08);}
.sol-card.v:hover{box-shadow:0 20px 48px rgba(196,181,253,.08);}
.sol-card.t:hover{box-shadow:0 20px 48px rgba(255,0,80,.08);}
.sol-card.e:hover{box-shadow:0 20px 48px rgba(0,200,100,.08);}
.sol-bar{height:3px;}
.sol-card.g .sol-bar{background:var(--g);}
.sol-card.s .sol-bar{background:var(--sky);}
.sol-card.v .sol-bar{background:var(--vio);}
.sol-card.t .sol-bar{background:var(--tiktok);}
.sol-card.e .sol-bar{background:linear-gradient(90deg,var(--g),var(--sky));}
.sol-body{padding:var(--card-pad);flex:1;}
.sol-name{font-weight:900;font-size:22px;color:var(--text);letter-spacing:-.02em;margin-bottom:5px;margin-top:14px;line-height:1.2;}
.sol-hl{font-size:13px;font-weight:600;margin-bottom:14px;}
.sol-card.g .sol-hl{color:var(--g);}
.sol-card.s .sol-hl{color:var(--sky);}
.sol-card.v .sol-hl{color:var(--vio);}
.sol-card.t .sol-hl{color:var(--tiktok);}
.sol-card.e .sol-hl{color:var(--g);}
.sol-desc{font-size:14px;color:var(--text-3);line-height:1.7;margin-bottom:18px;}
.sol-rep-label{font-family:var(--mono);font-size:11px;color:var(--text-4);text-transform:uppercase;letter-spacing:.12em;margin-bottom:8px;}
.sol-reps{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;}
.sol-meta{display:flex;align-items:center;justify-content:space-between;padding-top:16px;border-top:1px solid var(--border);}
.sol-save{font-family:var(--mono);font-size:13px;font-weight:700;}
.sol-card.g .sol-save{color:var(--g);}
.sol-card.s .sol-save{color:var(--sky);}
.sol-card.v .sol-save{color:var(--vio);}
.sol-card.t .sol-save{color:var(--tiktok);}
.sol-card.e .sol-save{color:var(--g);}
.sol-time{font-family:var(--mono);font-size:11px;color:var(--text-4);background:rgba(255,255,255,.03);border:1px solid var(--border);padding:4px 9px;border-radius:3px;}
.sol-foot{padding:0 var(--card-pad) var(--card-pad);display:flex;flex-direction:column;gap:10px;}
.sol-cta{display:flex;align-items:center;justify-content:center;text-align:center;text-decoration:none;font-family:var(--sans);font-size:13px;font-weight:700;padding:14px;border-radius:8px;background:var(--text);color:var(--bg);transition:background .2s;min-height:48px;}
.sol-cta:hover{background:#e2e8f0;}
.sol-guide{display:block;text-align:center;text-decoration:none;font-size:11px;font-family:var(--mono);letter-spacing:.08em;color:var(--text-4);transition:color .2s;padding:4px 0;}
.sol-guide:hover{color:var(--text-3);}
.testi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:14px;margin-top:56px;}
.tc{background:var(--bg-3);border:1.5px solid var(--border);border-radius:12px;padding:28px 24px;transition:border-color .2s;}
.tc:hover{border-color:var(--border-2);}
.tc.featured{border-color:rgba(0,200,100,.22);background:rgba(0,200,100,.025);}
.tc-stars{color:var(--amber);font-size:15px;letter-spacing:.1em;margin-bottom:16px;}
.tc-quote{font-size:15px;color:var(--text-2);font-style:italic;line-height:1.7;margin-bottom:20px;}
.tc-name{font-size:15px;font-weight:700;color:var(--text);}
.tc-store{font-family:var(--mono);font-size:11px;color:var(--text-4);margin-top:3px;}
.seo-prose{max-width:860px;margin:0 auto;}
.seo-prose p{font-size:15px;color:var(--text-3);line-height:1.8;margin-bottom:18px;}
.seo-prose p strong{color:var(--text-2);font-weight:600;}
.seo-prose p a{color:var(--g);text-decoration:underline;}
.seo-prose h3{font-weight:700;font-size:clamp(17px,2.2vw,21px);color:var(--text-2);letter-spacing:-.02em;margin:32px 0 12px;}
.guide-card{background:var(--bg-3);border:1.5px solid var(--border-2);border-radius:14px;padding:56px 48px;text-align:center;position:relative;overflow:hidden;}
.guide-card::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:500px;height:180px;background:radial-gradient(ellipse,rgba(0,200,100,.07) 0%,transparent 65%);pointer-events:none;}
.guide-title{font-weight:900;color:var(--text);font-size:clamp(22px,4vw,36px);letter-spacing:-.03em;line-height:1.05;margin-bottom:16px;text-transform:uppercase;}
.guide-desc{font-size:15px;color:var(--text-3);max-width:520px;margin:0 auto 10px;line-height:1.75;}
.guide-proof{font-family:var(--mono);font-size:13px;color:var(--text-4);margin-bottom:32px;}
.guide-proof span{color:var(--g);font-weight:700;}
.guide-specs{display:flex;flex-wrap:wrap;justify-content:center;gap:18px;margin-bottom:36px;}
.gs{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--text-3);}
.gs-dot{width:5px;height:5px;border-radius:50%;background:var(--g);flex-shrink:0;}
.gf-wrap{max-width:480px;margin:0 auto;}
.gf-label{font-size:15px;font-weight:600;color:var(--text-2);margin-bottom:5px;}
.gf-sub{font-size:13px;color:var(--text-3);margin-bottom:18px;line-height:1.6;}
.gf-row{display:flex;flex-wrap:wrap;gap:10px;}
.gf-inp{flex:1;min-width:190px;background:rgba(255,255,255,.05);border:1.5px solid var(--border);border-radius:8px;padding:14px 16px;color:var(--text);font-size:15px;font-family:var(--sans);outline:none;transition:border-color .2s;min-height:52px;}
.gf-inp:focus{border-color:var(--g);}
.gf-inp::placeholder{color:var(--text-4);}
.gf-go{font-family:var(--sans);font-size:13px;font-weight:700;background:var(--g);color:var(--text-inv);border:none;padding:14px 24px;border-radius:8px;cursor:pointer;white-space:nowrap;transition:background .2s;min-height:52px;}
.gf-go:hover{background:#00e070;}
.gf-priv{font-size:11px;color:var(--text-4);margin-top:12px;line-height:1.6;}
.gf-priv a{color:var(--text-3);text-decoration:underline;}
.guide-trust{font-family:var(--mono);font-size:11px;color:var(--border-2);margin-top:22px;letter-spacing:.1em;text-transform:uppercase;}
.guide-done{display:none;text-align:center;}
.guide-done-icon{width:52px;height:52px;border-radius:50%;background:rgba(0,200,100,.1);border:1px solid rgba(0,200,100,.25);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;}
.guide-done-msg{font-size:15px;color:var(--g);font-weight:600;}
.faq-list-c{display:flex;flex-direction:column;gap:8px;margin-top:40px;}
details.faq-item-c{border-radius:10px;border:1.5px solid var(--border);background:rgba(255,255,255,.02);transition:border-color .2s;}
details.faq-item-c[open]{border-color:rgba(0,200,100,.25);background:rgba(0,200,100,.025);}
details.faq-item-c summary{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:18px 22px;cursor:pointer;list-style:none;min-height:58px;font-size:15px;font-weight:600;color:var(--text-3);}
details.faq-item-c summary::-webkit-details-marker{display:none;}
details.faq-item-c[open] summary{color:var(--text);}
.faq-ico{width:16px;height:16px;min-width:16px;display:inline-block;flex-shrink:0;position:relative;opacity:.4;}
.faq-ico::before{content:'';position:absolute;top:3px;left:2px;width:10px;height:10px;border-right:2px solid currentColor;border-bottom:2px solid currentColor;transform:rotate(45deg);transition:transform .25s;}
details.faq-item-c[open] summary .faq-ico{opacity:1;color:var(--g);}
details.faq-item-c[open] summary .faq-ico::before{transform:rotate(225deg);top:6px;}
.faq-ans-c{padding:0 22px 20px;font-size:14px;color:var(--text-3);line-height:1.75;border-top:1px solid var(--border);padding-top:14px;}
.faq-ans-c strong{color:var(--text-2);}
.faq-ans-c a{color:var(--g);text-decoration:underline;}
.scroll-bar{display:none;position:fixed;bottom:0;left:0;right:0;z-index:99999;background:var(--bg-3);border-top:1px solid var(--border-2);padding:16px 24px;}
.scroll-bar-inner{max-width:860px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;}
.scroll-bar-text{font-size:15px;font-weight:600;color:var(--text);line-height:1.35;}
.scroll-bar-text span{color:var(--g);}
.scroll-bar-actions{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.scroll-bar-dismiss{font-size:11px;color:var(--text-4);background:none;border:none;cursor:pointer;padding:6px 10px;font-family:var(--mono);text-transform:uppercase;}
.scroll-bar-dismiss:hover{color:var(--text-3);}
.architect-footer{background:#020617;position:relative;padding:60px 24px 30px;font-family:var(--sans);color:#475569;text-align:center;border-top:1px solid #1e293b;}
.architect-footer::before{content:"";position:absolute;top:0;left:0;right:0;bottom:0;background-image:radial-gradient(#00a854 0.5px,transparent 0.5px);background-size:30px 30px;opacity:.1;pointer-events:none;}
.footer-container{max-width:900px;margin:0 auto;position:relative;z-index:2;}
.footer-conversion-strip{background:rgba(0,168,84,.06);border:1px solid rgba(0,168,84,.15);border-radius:8px;padding:20px 30px;margin-bottom:40px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;}
.footer-conversion-text{font-size:14px;font-weight:700;color:#94a3b8;letter-spacing:-.3px;text-align:left;}
.footer-conversion-text span{color:#fff;}
.footer-conversion-cta{font-family:var(--mono);font-size:10px;font-weight:900;color:#00a854;text-decoration:none;text-transform:uppercase;letter-spacing:2px;border:1px solid rgba(0,168,84,.4);padding:8px 16px;border-radius:4px;white-space:nowrap;transition:all .3s;flex-shrink:0;}
.footer-conversion-cta:hover{background:#00a854;color:#fff;border-color:#00a854;}
.footer-system-title{font-size:22px;font-weight:900;color:#f8fafc;letter-spacing:-1.5px;margin-bottom:20px;display:block;}
.status-bar{display:inline-flex;align-items:center;gap:15px;background:rgba(15,23,42,.5);border:1px solid #1e293b;padding:6px 15px;border-radius:4px;margin-bottom:40px;}
.status-item{font-family:var(--mono);font-size:8px;letter-spacing:1.2px;text-transform:uppercase;color:#64748b;display:flex;align-items:center;gap:8px;text-decoration:none;transition:color .3s;}
.engine-link:hover{color:#00a854;}
.bar-sep{width:1px;height:10px;background:#334155;}
.pulse-dot{height:4px;width:4px;background:#00a854;border-radius:50%;animation:ps 2s infinite;}
@keyframes ps{0%{opacity:1;}50%{opacity:.3;}100%{opacity:1;}}
.footer-links{display:flex;justify-content:center;gap:20px;margin-bottom:30px;flex-wrap:wrap;}
.footer-links a{font-size:12px;font-weight:900;color:#f8fafc;text-decoration:none;letter-spacing:-.3px;transition:all .3s;}
.footer-links a:hover{color:#00a854;transform:translateY(-1px);}
.nav-secondary{display:flex;justify-content:center;gap:20px;margin-bottom:30px;flex-wrap:wrap;}
.nav-secondary a{font-family:var(--mono);font-size:9px;color:#475569;text-decoration:none;transition:color .3s;}
.nav-secondary a:hover{color:#f8fafc;}
.footer-trust-row{display:flex;justify-content:center;align-items:center;gap:24px;margin-bottom:30px;flex-wrap:wrap;}
.trust-badge{font-family:var(--mono);font-size:8px;font-weight:700;color:#334155;letter-spacing:1px;text-transform:uppercase;display:flex;align-items:center;gap:6px;}
.trust-badge-dot{width:4px;height:4px;background:#00a854;border-radius:50%;flex-shrink:0;}
.footer-divider{width:40px;height:1px;background:#1e293b;margin:30px auto;}
.return-origin{font-family:var(--mono);font-size:10px;color:#00a854;text-decoration:none;font-weight:800;letter-spacing:2px;transition:all .3s;display:inline-block;}
.return-origin:hover{letter-spacing:4px;}
.copyright{font-family:var(--mono);font-size:8px;color:#1e293b;margin-top:20px;text-transform:uppercase;}
.affiliate-disclosure{font-size:10px;color:#334155;margin-top:12px;line-height:1.5;max-width:600px;margin-left:auto;margin-right:auto;}
.affiliate-disclosure a{color:#475569;text-decoration:underline;}
@media(max-width:640px){
  :root{--sp:64px;--card-pad:24px;}
  .hero{padding:72px 20px 60px;}
  .hero-ctas{flex-direction:column;align-items:stretch;max-width:340px;margin-left:auto;margin-right:auto;}
  .btn,.btn-outline{width:100%;justify-content:center;}
  .stat-strip{grid-template-columns:repeat(2,1fr);}
  .cost-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
  .pillars{grid-template-columns:1fr;}
  .how-grid{grid-template-columns:1fr;}
  .sol-urgent-inner{flex-direction:column;}
  .sol-urgent-right{align-items:flex-start;min-width:auto;width:100%;}
  .cta-strip-inner{flex-direction:column;text-align:center;}
  .cta-strip-actions{justify-content:center;width:100%;}
  .sol-grid{grid-template-columns:1fr;}
