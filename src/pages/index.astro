  --sky:#8ccfe8;--sky-bg:rgba(140,207,232,.06);--sky-border:rgba(140,207,232,.16);
  --amber:#f5b64d;--vio:#c3b8ef;--vio-bg:rgba(195,184,239,.06);--vio-border:rgba(195,184,239,.16);
  --tiktok:#ff2e63;--tiktok-bg:rgba(255,46,99,.06);--tiktok-border:rgba(255,46,99,.16);
  --pro:#f5b64d;--pro-bg:rgba(245,182,77,.07);--pro-border:rgba(245,182,77,.2);
  --mono:'JetBrains Mono',ui-monospace,monospace;--sans:'Inter',-apple-system,sans-serif;--disp:'Sora','Inter',-apple-system,sans-serif;
  --sp:100px;--card-pad:32px;
}
body{font-family:var(--sans);background:var(--bg);color:var(--text-3);line-height:1.75;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:rgba(52,211,119,.3);border-radius:2px;}
::selection{background:rgba(52,211,119,.2);color:var(--text);}
.tag{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:5px 12px;border-radius:3px;background:var(--g-bg);border:1px solid var(--g-border);color:var(--g);}
.tag-dim{background:rgba(255,255,255,.03);border-color:var(--border-2);color:var(--text-4);}
.tag-sky{background:var(--sky-bg);border-color:var(--sky-border);color:var(--sky);}
.tag-vio{background:var(--vio-bg);border-color:var(--vio-border);color:var(--vio);}
.tag-red{background:var(--red-bg);border-color:var(--red-border);color:var(--red);}
.tag-tiktok{background:var(--tiktok-bg);border-color:var(--tiktok-border);color:var(--tiktok);}
.tag-pro{background:var(--pro-bg);border-color:var(--pro-border);color:var(--pro);}
.dot{display:inline-block;width:7px;height:7px;min-width:7px;border-radius:50%;background:var(--g);animation:dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite;}
@keyframes dotPing{0%{box-shadow:0 0 0 0 rgba(52,211,119,.5);}70%{box-shadow:0 0 0 8px rgba(52,211,119,0);}100%{box-shadow:0 0 0 0 rgba(52,211,119,0);}}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;font-family:var(--sans);font-size:16px;font-weight:700;text-decoration:none;letter-spacing:-.01em;padding:18px 34px;border-radius:6px;border:none;cursor:pointer;white-space:nowrap;background:linear-gradient(135deg,#3bdc84 0%,#28c06c 100%);color:var(--text-inv);box-shadow:inset 0 1px 0 rgba(255,255,255,.22),0 1px 2px rgba(0,0,0,.4);transition:transform .16s cubic-bezier(.2,.7,.3,1.4),box-shadow .2s,filter .2s;min-height:56px;position:relative;overflow:hidden;}
.btn:hover{background:#34d377;transform:translateY(-2px);box-shadow:0 8px 28px rgba(52,211,119,.3);}

@keyframes btnGlow{0%,100%{box-shadow:0 0 16px rgba(52,211,119,.1);}50%{box-shadow:0 0 32px rgba(52,211,119,.32);}}

.btn-lg{font-size:18px;padding:20px 40px;min-height:62px;}
.btn-sm{font-size:14px;padding:12px 22px;min-height:44px;}
.btn-pro{display:inline-flex;align-items:center;justify-content:center;gap:10px;font-family:var(--sans);font-size:16px;font-weight:700;text-decoration:none;letter-spacing:-.01em;padding:16px 32px;border-radius:6px;border:none;cursor:pointer;white-space:nowrap;background:var(--pro);color:#0c0f0d;transition:background .2s,transform .15s,box-shadow .2s;min-height:52px;}
.btn-pro:hover{background:#f59e0b;transform:translateY(-2px);box-shadow:0 8px 28px rgba(245,182,77,.3);}
.btn-pro-sm{font-size:14px;padding:12px 22px;min-height:44px;}
.btn-outline{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-family:var(--sans);font-size:15px;font-weight:600;text-decoration:none;letter-spacing:-.01em;padding:15px 28px;border-radius:6px;border:1.5px solid var(--border-2);cursor:pointer;white-space:nowrap;background:transparent;color:var(--text-2);transition:border-color .2s,color .2s,background .2s;min-height:52px;}
.btn-outline:hover{border-color:var(--g);color:var(--g);background:var(--g-bg);}
.btn-outline-sm{font-size:13px;padding:11px 20px;min-height:44px;}
.section{padding:var(--sp) 24px;}
.section-alt{padding:var(--sp) 24px;background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.inner{max-width:1000px;margin:0 auto;}
.inner-sm{max-width:720px;margin:0 auto;}
.inner-md{max-width:880px;margin:0 auto;}
.inner-lg{max-width:1120px;margin:0 auto;}
.sec-head{text-align:center;margin-bottom:56px;}
.sec-head h2{font-family:var(--disp);font-weight:700;font-size:clamp(26px,4vw,40px);letter-spacing:-.03em;color:var(--text);line-height:1.05;margin-bottom:10px;}
.sec-head h2::after{content:"";display:block;width:52px;height:3px;border-radius:2px;margin:18px auto 0;background:linear-gradient(90deg,#34d377,#2dd4bf);opacity:.85;}
.sec-head p{font-size:15px;color:var(--text-3);max-width:540px;margin:14px auto 0;line-height:1.75;}
.bg-grid{background-color:var(--bg);position:relative;}
.bg-grid::before{content:"";position:absolute;inset:0;pointer-events:none;background:
  radial-gradient(ellipse 62% 42% at 50% -6%,rgba(52,211,119,.14) 0%,transparent 62%),
  radial-gradient(ellipse 34% 26% at 82% 6%,rgba(45,212,191,.08) 0%,transparent 60%),
  radial-gradient(ellipse 30% 24% at 12% 14%,rgba(52,211,119,.05) 0%,transparent 60%);}
.bg-grid::after{content:"";position:absolute;inset:0;pointer-events:none;background-image:radial-gradient(circle,var(--border-2) 1px,transparent 1px);background-size:40px 40px;-webkit-mask-image:radial-gradient(ellipse 70% 56% at 50% 0%,#000 20%,transparent 78%);mask-image:radial-gradient(ellipse 70% 56% at 50% 0%,#000 20%,transparent 78%);opacity:.6;}
.stat-strip{display:grid;grid-template-columns:repeat(4,1fr);background:var(--border);gap:1px;border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.stat-cell{background:var(--bg);padding:20px 12px;text-align:center;}
.stat-v{font-family:var(--mono);font-size:22px;font-weight:700;color:var(--g);line-height:1;}
.stat-l{font-size:11px;color:var(--text-4);text-transform:uppercase;letter-spacing:.12em;margin-top:6px;font-family:var(--mono);}
.divider{height:1px;background:var(--border);}

/* HERO — simplified, single primary CTA */
.hero{padding:88px 24px 56px;text-align:center;position:relative;overflow:hidden;}
.hero-inner{max-width:920px;margin:0 auto;position:relative;z-index:1;}
.hero-dateline{font-family:var(--mono);font-size:10px;color:var(--text-4);letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px;opacity:.7;}
.hero h1{font-family:var(--disp);font-size:clamp(42px,6.8vw,72px);font-weight:700;color:var(--text);line-height:.98;letter-spacing:-.025em;margin:0 auto 24px;max-width:860px;}
.hero h1 .green{background:linear-gradient(115deg,#34d377 0%,#7ee2a8 48%,#2dd4bf 100%);-webkit-background-clip:text;background-clip:text;color:transparent;}
.hero h1 .dim{color:var(--text-4);}
.hero-sub{font-size:clamp(17px,2.2vw,20px);color:var(--text-2);max-width:640px;margin:0 auto 36px;line-height:1.65;}
.hero-sub strong{color:var(--text);font-weight:700;}
.hero-primary-cta{display:flex;flex-direction:column;align-items:center;gap:14px;margin-bottom:28px;}
.hero-secondary{font-size:14px;color:var(--text-3);}
.hero-secondary a{color:var(--pro);text-decoration:none;font-weight:600;border-bottom:1px solid rgba(245,182,77,.3);padding-bottom:1px;transition:border-color .2s;}
.hero-secondary a:hover{border-color:var(--pro);}
.trust-row{display:flex;flex-wrap:wrap;justify-content:center;gap:18px;margin-bottom:40px;}
.trust-item{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--text-3);}
.urgency{display:inline-flex;align-items:center;gap:8px;background:rgba(245,182,77,.06);border:1px solid rgba(245,182,77,.18);border-radius:4px;padding:9px 20px;margin-bottom:40px;font-size:13px;color:var(--amber);font-weight:500;}
.press-line{margin:26px auto 0;font-size:12.5px;color:var(--text-4);text-align:center;}
.press-line a{color:var(--text-3);text-decoration:underline;text-underline-offset:3px;}
.press-line a:hover{color:var(--g);}
.ledger{max-width:620px;margin:0 auto;border:1px solid var(--border);border-radius:10px;background:var(--bg-3);padding:8px 20px;text-align:left;}
.ledger-row{display:flex;align-items:baseline;gap:12px;padding:11px 0;border-bottom:1px solid var(--border);font-family:var(--mono);font-size:13.5px;font-variant-numeric:tabular-nums;}
.ledger-row:last-child{border-bottom:none;}
.ledger-app{color:var(--text-2);font-family:var(--sans);font-weight:500;white-space:nowrap;}
.ledger-app em{font-style:normal;color:var(--text-4);font-weight:400;}
.ledger-fill{flex:1;border-bottom:1px dotted var(--border-2);transform:translateY(-4px);min-width:24px;}
.ledger-was{color:var(--text-4);text-decoration:line-through;text-decoration-color:rgba(240,138,138,.5);}
.ledger-gone{text-decoration:none;color:var(--amber);font-size:12px;}
.ledger-now{color:var(--g);font-weight:700;min-width:34px;text-align:right;}
.ledger-total{border-top:1px solid var(--border-2);margin-top:2px;}
.ledger-total .ledger-app{color:var(--text);font-weight:600;}
.ledger-total .ledger-was{font-size:14px;}
.ledger-total .ledger-now{font-size:16px;text-shadow:0 0 18px rgba(52,211,119,.45);}
.sol-card,.calc-card,.scan-card{transition:transform .25s cubic-bezier(.2,.7,.3,1),border-color .25s,box-shadow .25s;}
.sol-card:hover,.calc-card:hover{transform:translateY(-4px);border-color:rgba(52,211,119,.35);box-shadow:0 16px 40px -14px rgba(0,0,0,.6),0 0 0 1px rgba(52,211,119,.12);}
@media(max-width:560px){.ledger{padding:4px 14px;}.ledger-row{font-size:12px;gap:8px;}.ledger-app em{display:none;}}

/* HERO VIDEO — now directly under CTA */
.hero-video-wrap{max-width:720px;margin:8px auto 40px;position:relative;}
.hero-video-glow{position:absolute;inset:-2px;border-radius:20px;background:linear-gradient(135deg,rgba(52,211,119,.4),rgba(52,211,119,.2),rgba(52,211,119,.1));z-index:0;filter:blur(1px);}
.hero-video-box{position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:18px;border:1px solid rgba(52,211,119,.25);background:var(--bg-3);z-index:1;box-shadow:0 24px 60px rgba(0,0,0,.5),0 0 40px rgba(52,211,119,.08);}
.hero-video-box iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:0;border-radius:18px;}
.hero-video-box video{position:absolute;top:0;left:0;width:100%;height:100%;border:0;border-radius:18px;object-fit:contain;background:#000;}
.hero-video-transcript{margin-top:16px;font-size:14px;color:rgba(255,255,255,0.7);}
.hero-video-transcript summary{cursor:pointer;padding:8px 12px;background:rgba(52,211,119,0.08);border:1px solid rgba(52,211,119,0.2);border-radius:6px;display:inline-block;font-weight:500;user-select:none;}
.hero-video-transcript summary:hover{background:rgba(52,211,119,0.15);}
.hero-video-transcript[open] summary{margin-bottom:12px;}
.hero-video-transcript .transcript-body{padding:16px;background:rgba(255,255,255,0.03);border-radius:8px;line-height:1.6;}
.hero-video-transcript .transcript-body p{margin:0 0 8px 0;}
.hero-video-transcript .transcript-body p:last-child{margin-bottom:0;}

/* WebVTT caption styling — YouTube Short feel, tuned for conversion */
.hero-video-box video::cue {
  background-color: rgba(2, 6, 23, 0.85);
  color: #ffffff;
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  font-weight: 700;
  font-size: 18px;
  line-height: 1.35;
  padding: 4px 10px;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.95), 0 0 6px rgba(0, 0, 0, 0.8);
  letter-spacing: 0.01em;
}

.hero-video-caption{text-align:center;font-family:var(--mono);font-size:11px;color:var(--text-4);letter-spacing:.1em;text-transform:uppercase;margin-top:14px;}

/* SCANNER — promoted to position #2 */
.scan-card{background:var(--bg-3);border:1px solid var(--border-2);border-radius:14px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.2);}
.pain-list{display:flex;flex-direction:column;gap:10px;padding:28px 28px 0;}
.pain-btn{width:100%;display:flex;align-items:center;justify-content:space-between;gap:14px;padding:16px 18px;border-radius:10px;border:1.5px solid var(--border);background:rgba(255,255,255,.025);text-align:left;cursor:pointer;transition:all .2s;outline:none;font-family:var(--sans);min-height:56px;}
.pain-btn:hover{border-color:var(--border-2);background:rgba(255,255,255,.04);}
.pain-btn:focus-visible{outline:2px solid var(--g);outline-offset:2px;}
.pain-btn.on{background:rgba(52,211,119,.06);border-color:rgba(52,211,119,.3);}
.pain-chk{width:20px;height:20px;min-width:20px;border-radius:5px;border:2px solid var(--border-2);display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0;}
.pain-btn.on .pain-chk{background:var(--g);border-color:var(--g);}
.pain-label-wrap{flex:1;}
.pain-label{font-size:14px;font-weight:500;color:var(--text-3);line-height:1.4;transition:color .15s;}
.pain-btn.on .pain-label{color:var(--text);}
.pain-badge{font-family:var(--mono);font-size:10px;color:rgba(52,211,119,.6);letter-spacing:.1em;text-transform:uppercase;display:block;margin-top:3px;}
.pain-cost{font-family:var(--mono);font-size:13px;font-weight:700;color:rgba(240,138,138,.4);flex-shrink:0;transition:color .15s;white-space:nowrap;}
.pain-btn.on .pain-cost{color:var(--red);}
.scan-result{margin:20px 28px 0;border-radius:10px;padding:22px;background:rgba(255,255,255,.025);border:1.5px solid var(--border);transition:all .35s;}
.scan-result.leak{background:rgba(240,138,138,.04);border-color:rgba(240,138,138,.2);}
.sr-inner{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;}
.sr-label{font-family:var(--mono);font-size:11px;color:var(--text-4);text-transform:uppercase;letter-spacing:.15em;margin-bottom:6px;}
.sr-total{font-weight:700;font-size:40px;color:var(--text);line-height:1;letter-spacing:-.025em;}
.sr-mo{font-size:20px;color:var(--text-4);font-weight:400;}
.sr-year{font-family:var(--mono);font-size:13px;color:rgba(240,138,138,.6);margin-top:5px;display:none;}
.sr-recs-label{font-family:var(--mono);font-size:11px;color:var(--text-4);text-transform:uppercase;letter-spacing:.12em;margin-bottom:6px;text-align:right;}
.sr-recs-item{font-size:13px;font-weight:600;color:var(--g);line-height:1.5;text-align:right;}
.scan-cta-wrap{padding:18px 28px 28px;}
.scan-cta{display:block;width:100%;padding:17px 20px;border-radius:8px;font-family:var(--sans);font-size:15px;font-weight:700;text-align:center;border:none;cursor:not-allowed;background:rgba(255,255,255,.05);color:rgba(255,255,255,.25);transition:all .2s;min-height:52px;}
.scan-cta.ready{background:var(--g);color:var(--text-inv);cursor:pointer;animation:ctaGlow 2.5s ease-in-out infinite;}
@keyframes ctaGlow{0%,100%{box-shadow:0 0 16px rgba(52,211,119,.12);}50%{box-shadow:0 0 28px rgba(52,211,119,.28);}}
.scan-cta.ready:hover{background:#34d377;animation:none;box-shadow:0 8px 24px rgba(52,211,119,.3);}
.scan-meta{text-align:center;font-size:13px;color:var(--text-4);margin-top:10px;}
.plan-step{display:none;padding:28px;}
.plan-hd{margin-bottom:18px;}
.plan-hd h3{font-weight:700;font-size:22px;color:var(--text);letter-spacing:-.03em;margin-bottom:5px;line-height:1.2;}
.plan-hd p{font-size:13px;color:var(--text-3);line-height:1.6;}
.plan-items{display:flex;flex-direction:column;gap:10px;margin-bottom:24px;}
.plan-item{display:flex;gap:14px;background:rgba(255,255,255,.025);border:1px solid var(--border);border-radius:10px;padding:16px;}
.plan-num{width:24px;height:24px;min-width:24px;border-radius:50%;background:rgba(52,211,119,.1);border:1px solid rgba(52,211,119,.25);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;font-weight:700;color:var(--g);margin-top:1px;}
.plan-sol{font-size:15px;font-weight:700;color:var(--text);margin-bottom:3px;}
.plan-fix{font-size:13px;color:var(--text-3);}
.plan-rec{font-family:var(--mono);font-size:11px;color:var(--g);margin-top:5px;}
.email-block{background:rgba(255,255,255,.025);border:1px solid var(--border);border-radius:10px;padding:22px;}
.email-block h4{font-size:15px;font-weight:700;color:var(--text);margin-bottom:5px;line-height:1.3;}
.email-block p{font-size:13px;color:var(--text-3);margin-bottom:16px;line-height:1.6;}
.email-row{display:flex;flex-wrap:wrap;gap:10px;}
.email-inp{flex:1;min-width:170px;background:rgba(255,255,255,.05);border:1.5px solid var(--border);border-radius:8px;padding:13px 16px;color:var(--text);font-size:15px;font-family:var(--sans);outline:none;transition:border-color .2s;min-height:48px;}
.email-inp:focus{border-color:var(--g);}
.email-inp::placeholder{color:var(--text-4);}
.email-go{font-family:var(--sans);font-size:13px;font-weight:700;background:var(--g);color:var(--text-inv);border:none;padding:13px 22px;border-radius:8px;cursor:pointer;white-space:nowrap;transition:background .2s;min-height:48px;}
.email-go:hover{background:#34d377;}
.email-disc{font-size:11px;color:var(--text-4);margin-top:10px;line-height:1.5;}
.done-step{display:none;padding:52px 28px;text-align:center;}
.done-icon{width:56px;height:56px;border-radius:50%;background:rgba(52,211,119,.1);border:1px solid rgba(52,211,119,.25);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;}
.done-step h3{font-weight:700;font-size:22px;color:var(--text);letter-spacing:-.02em;margin-bottom:8px;}
.done-step p{font-size:15px;color:var(--text-3);margin-bottom:24px;line-height:1.65;max-width:340px;margin-left:auto;margin-right:auto;}

/* SOLUTIONS */
.sol-urgent{background:var(--bg-3);border:2px solid rgba(245,182,77,.25);border-radius:14px;overflow:hidden;margin-bottom:20px;position:relative;}
.sol-urgent-bar{height:3px;background:linear-gradient(90deg,var(--amber),rgba(245,182,77,.3));}
.sol-urgent-inner{padding:32px 36px;display:flex;align-items:flex-start;justify-content:space-between;gap:32px;flex-wrap:wrap;}
.sol-urgent-badge{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--amber);background:rgba(245,182,77,.08);border:1px solid rgba(245,182,77,.2);padding:4px 10px;border-radius:3px;display:inline-block;margin-bottom:10px;}
.sol-urgent-name{font-weight:700;font-size:clamp(22px,4vw,32px);color:var(--text);letter-spacing:-.03em;line-height:1.05;margin-bottom:8px;}
.sol-urgent-hl{font-size:14px;font-weight:600;color:var(--amber);margin-bottom:14px;}
.sol-urgent-desc{font-size:15px;color:var(--text-3);line-height:1.75;max-width:540px;margin-bottom:20px;}
.sol-urgent-reps{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;}
.sol-rep{background:rgba(255,255,255,.03);border:1px solid var(--border);color:var(--text-4);font-size:11px;padding:3px 9px;border-radius:3px;text-decoration:line-through;text-decoration-color:rgba(240,138,138,.5);}
.sol-urgent-right{display:flex;flex-direction:column;align-items:flex-end;gap:16px;min-width:200px;}
.countdown-box{background:rgba(245,182,77,.06);border:1px solid rgba(245,182,77,.2);border-radius:10px;padding:20px 24px;text-align:center;}
.countdown-label{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--amber);margin-bottom:8px;}
.countdown-nums{display:flex;gap:8px;justify-content:center;}
.cd-unit{text-align:center;}
.cd-val{font-family:var(--mono);font-size:22px;font-weight:700;color:var(--text);line-height:1;}
.cd-l{font-size:10px;color:var(--text-4);margin-top:2px;}
.cd-sep{font-family:var(--mono);font-size:20px;font-weight:700;color:var(--text-4);padding-top:2px;}
.sol-urgent-meta{display:flex;align-items:center;justify-content:space-between;padding-top:16px;border-top:1px solid rgba(245,182,77,.15);}
.sol-urgent-save{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--amber);}
.sol-urgent-time{font-family:var(--mono);font-size:11px;color:var(--text-4);background:rgba(255,255,255,.03);border:1px solid var(--border);padding:4px 9px;border-radius:3px;}
.sol-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;}
