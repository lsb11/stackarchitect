          <div class="field"><label for="monthlyRevenue">Current monthly revenue (£/$/€)</label><input type="number" id="monthlyRevenue" name="monthlyRevenue" placeholder="e.g. 80000" min="0" required></div>
<div class="field"><label for="useShopifyPayments">Do you use Shopify Payments?</label><select id="useShopifyPayments" name="useShopifyPayments" required><option value="">Select…</option><option value="Yes">Yes</option><option value="No — third-party gateway">No — third-party gateway</option></select></div>
