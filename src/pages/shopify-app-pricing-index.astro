// /shopify-app-pricing-index/ — THE SHOPIFY APP PRICING INDEX
// One canonical, structured, dated index of what popular Shopify apps actually
// cost, with the free replacement for each. Every figure is one already
// published and sourced elsewhere on this site; each row links the vendor's
// official pricing page for verification.
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const updated = "2026-07-03";
const apps = [
  { app:"Klaviyo", cat:"Email marketing", cost:"$45–$400+/mo (contact-based)", free:"250 contacts / 500 sends", repl:"Systeme.io (free)", replUrl:"/replace-klaviyo-free/", src:"https://www.klaviyo.com/pricing" },
  { app:"Elevar", cat:"Server-side tracking", cost:"$0–$200/mo", free:"Limited free plan", repl:"CAPI Shield (free)", replUrl:"/capi-shield/", src:"https://www.getelevar.com/pricing/" },
  { app:"Analyzify", cat:"Tracking / analytics", cost:"$99 or $299/mo", free:"None", repl:"CAPI Shield (free)", replUrl:"/analyzify-alternative/", src:"https://analyzify.com/pricing" },
  { app:"Triple Whale", cat:"Attribution / analytics", cost:"$129–$599+/mo", free:"Limited free plan", repl:"CAPI Shield (free)", replUrl:"/triple-whale-alternative/", src:"https://www.triplewhale.com/pricing" },
  { app:"Northbeam", cat:"Enterprise attribution", cost:"~$1,000–$10,000+/mo (custom)", free:"None", repl:"CAPI Shield (free)", replUrl:"/northbeam-alternative/", src:"https://www.northbeam.io/" },
  { app:"Stocky", cat:"Inventory (shutting down Aug 31, 2026)", cost:"$0 (POS Pro) — discontinued", free:"—", repl:"Stocky Swap (free)", replUrl:"/stocky-swap/", src:"https://help.shopify.com/en/manual/products/inventory/stocky" },
  { app:"Inventory Planner", cat:"Inventory / forecasting", cost:"from ~$120/mo", free:"Trial only", repl:"Stocky Swap (free)", replUrl:"/stocky-alternative/", src:"https://www.inventory-planner.com/pricing/" },
  { app:"Tidio", cat:"Live chat / support AI", cost:"from ~$24–$29/mo", free:"Free plan available", repl:"Setup guide (free tier)", replUrl:"/tidio-shopify-guide/", src:"https://www.tidio.com/pricing/" },
  { app:"Gorgias", cat:"Helpdesk", cost:"from ~$50–$60/mo", free:"None", repl:"Tidio free tier compared", replUrl:"/blog/tidio-vs-gorgias-shopify/", src:"https://www.gorgias.com/pricing" },
  { app:"Zapier", cat:"Automation", cost:"Free tier: 100 tasks/mo; paid tiers above", free:"100 tasks/mo", repl:"Make.com (1,000 free ops/mo)", replUrl:"/make-com-shopify/", src:"https://zapier.com/pricing" },
  { app:"Make.com", cat:"Automation", cost:"Free: 1,000 ops/mo; paid from low tiers", free:"1,000 ops/mo", repl:"— (this is the free engine)", replUrl:"/make-com-shopify/", src:"https://www.make.com/en/pricing" },
  { app:"Systeme.io", cat:"Email / funnels / CRM", cost:"Free: 2,000 contacts, unlimited sends", free:"2,000 contacts", repl:"— (this is the free replacement)", replUrl:"/replace-klaviyo-free/", src:"https://systeme.io/pricing" },
];

const faqs = [
  { q:"How much do Shopify apps cost per month in 2026?", a:"Across the 12 widely-used apps tracked in this index, typical costs range from $0 (free tiers of Tidio, Make.com, Systeme.io) to $45–$599/mo for email and attribution tools (Klaviyo, Triple Whale), up to $1,000–$10,000+/mo for enterprise attribution (Northbeam). A store running paid email, tracking, helpdesk, and inventory apps commonly pays $300–$700+/mo combined." },
  { q:"Which paid Shopify apps have genuinely free replacements?", a:"Klaviyo can be replaced by Systeme.io's permanently free plan (2,000 contacts, unlimited sends). Elevar, Analyzify, and Triple Whale's core server-side tracking can be replaced by a free Make.com + Conversions API setup (CAPI Shield). Stocky — which Shopify shuts down on August 31, 2026 — is replaceable with a free Make.com + Google Sheets inventory system (Stocky Swap)." },
  { q:"How is this pricing index maintained?", a:"Every figure links to the vendor's official pricing page and is re-verified when vendors change plans. Prices shown are the publicly listed monthly rates as of the 'last verified' date on this page; usage-based and contact-based plans are shown as ranges. If a figure is out of date, the linked official page is authoritative." },
];

const ld = {
  "@context":"https://schema.org",
  "@graph":[
    { "@type":"WebPage","@id":"https://stackarchitect.xyz/shopify-app-pricing-index/#webpage",
      "url":"https://stackarchitect.xyz/shopify-app-pricing-index/",
      "name":"Shopify App Pricing Index 2026 — 12 Popular Apps, Real Costs, Free Replacements",
      "dateModified": updated, "inLanguage":"en-GB",
      "isPartOf":{"@id":"https://stackarchitect.xyz/#website"} },
    { "@type":"Dataset",
      "name":"Shopify App Pricing Index 2026",
      "description":"Maintained index of publicly listed monthly pricing for 12 widely-used Shopify apps (email, tracking/attribution, inventory, helpdesk, automation), each verified against the vendor's official pricing page, with free replacement options.",
      "url":"https://stackarchitect.xyz/shopify-app-pricing-index/",
      "creator":{"@type":"Organization","name":"Stack Architect","url":"https://stackarchitect.xyz"},
      "dateModified": updated,
      "license":"https://creativecommons.org/licenses/by/4.0/",
      "keywords":["Shopify app pricing","Shopify app costs 2026","Klaviyo pricing","Triple Whale pricing","free Shopify apps"] },
    { "@type":"FAQPage","mainEntity": faqs.map(f => ({"@type":"Question","name":f.q,"acceptedAnswer":{"@type":"Answer","text":f.a}})) },
    { "@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://stackarchitect.xyz/"},
      {"@type":"ListItem","position":2,"name":"Shopify App Pricing Index","item":"https://stackarchitect.xyz/shopify-app-pricing-index/"}]}
  ]
};
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Shopify App Pricing Index 2026 — 12 Popular Apps, Real Costs, Free Replacements</title>
  <meta name="description" content="What Shopify apps actually cost in 2026: Klaviyo, Triple Whale, Elevar, Analyzify, Gorgias, Tidio, Inventory Planner and more — every price verified against official pricing pages, with the free replacement for each. Last verified July 2026." />
  <link rel="canonical" href="https://stackarchitect.xyz/shopify-app-pricing-index/" />
  <meta property="og:title" content="Shopify App Pricing Index 2026 — Real Costs + Free Replacements" />
  <meta property="og:description" content="12 popular Shopify apps, verified monthly pricing, and the free replacement for each. Maintained and dated." />
  <meta property="og:url" content="https://stackarchitect.xyz/shopify-app-pricing-index/" />
  <meta property="og:type" content="article" />
  <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  <style>
    :root{color-scheme:dark}
    body{font-family:ui-sans-serif,system-ui,-apple-system,sans-serif;background:#0b0f14;color:#e8eef4;margin:0;line-height:1.6}
    main{max-width:960px;margin:0 auto;padding:2.5rem 1.25rem 3rem}
    h1{font-size:clamp(1.6rem,4vw,2.4rem);line-height:1.2;margin:.2rem 0 .6rem}
    .lede{opacity:.85;max-width:70ch}
    .meta{font-size:.85rem;opacity:.7;margin:.6rem 0 1.6rem}
    .tblwrap{overflow-x:auto;border:1px solid #223041;border-radius:12px}
    table{border-collapse:collapse;width:100%;min-width:760px;font-size:.92rem}
    th,td{padding:.7rem .8rem;text-align:left;border-bottom:1px solid #1a2634;vertical-align:top}
    th{font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;opacity:.75;background:#0e141b}
    tr:last-child td{border-bottom:0}
    td a{color:#59c9ff;text-decoration:none}
    td a:hover{text-decoration:underline}
    .cost{white-space:nowrap;font-weight:600}
    .src{font-size:.8rem;opacity:.85}
    h2{margin:2.2rem 0 .6rem;font-size:1.25rem}
    .faq p{margin:.2rem 0 1rem;opacity:.9}
    .note{border:1px solid #223041;border-radius:12px;padding:1rem 1.25rem;font-size:.9rem;opacity:.9;margin:1.6rem 0}
    .cta{display:inline-block;margin-top:.4rem;padding:.6rem 1.1rem;border-radius:10px;border:1px solid #2c6;color:#7ef0b2;text-decoration:none}
  </style>
</head>
<body>
<Nav />
<main>
  <h1>Shopify App Pricing Index <span style="opacity:.6">2026</span></h1>
  <p class="lede">One maintained table of what 12 widely-used Shopify apps actually cost per month — every figure verified against the vendor's <em>official</em> pricing page — and the free replacement for each where one genuinely exists.</p>
  <p class="meta">Last verified: <strong>3 July 2026</strong> · Prices are publicly listed monthly rates; contact- and usage-based plans shown as ranges · Data licensed CC-BY-4.0 — cite as <em>“Stack Architect, Shopify App Pricing Index 2026”</em></p>

  <div class="tblwrap">
    <table>
      <thead><tr><th>App</th><th>Category</th><th>Typical monthly cost</th><th>Free tier</th><th>Free replacement</th><th>Verify</th></tr></thead>
      <tbody>
        {apps.map(a => (
          <tr>
            <td><strong>{a.app}</strong></td>
            <td>{a.cat}</td>
            <td class="cost">{a.cost}</td>
            <td>{a.free}</td>
            <td><a href={a.replUrl}>{a.repl}</a></td>
            <td class="src"><a href={a.src} target="_blank" rel="noopener">official pricing ↗</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="note">
    <strong>What a typical stack costs:</strong> a store running paid email (Klaviyo), paid tracking (Elevar or Triple Whale), a helpdesk (Gorgias), and inventory (Inventory Planner) commonly pays <strong>$300–$700+/month</strong> combined. The free-replacement column shows where that spend can go to $0 — every replacement is documented step-by-step on this site and runs on free tiers.
    <br /><a class="cta" href="/shopify-app-cost-calculator/">Calculate your own app bill →</a>
  </div>

  <h2>How this index is maintained</h2>
  <p class="lede">Each row links the vendor's official pricing page — that page is always authoritative. Figures are re-verified when vendors change plans (Klaviyo's February 2025 move to active-profile billing is the canonical example of why the date above matters). No affiliate relationship changes a listed price: several apps in this table pay us nothing, and the free replacements we recommend are free regardless.</p>

  <h2>FAQ</h2>
  <div class="faq">
    {faqs.map(f => (<div><h3 style="margin:.8rem 0 .2rem;font-size:1.02rem">{f.q}</h3><p>{f.a}</p></div>))}
  </div>

  <h2>Related on Stack Architect</h2>
  <p class="lede">
    <a href="/shopify-tracking-tools-pricing/" style="color:#59c9ff">Tracking-tools pricing deep dive</a> ·
    <a href="/blog/how-much-shopify-apps-really-cost-and-how-to-cut-your-app-bill-in-half/" style="color:#59c9ff">How to cut your app bill in half</a> ·
    <a href="/best-free-shopify-apps-2026/" style="color:#59c9ff">Best free Shopify apps 2026</a> ·
    <a href="/shopify-ios-attribution-gap-benchmark/" style="color:#59c9ff">Live iOS attribution-gap benchmark</a>
  </p>
</main>
<Footer />
</body>
</html>
