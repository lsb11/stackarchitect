<script>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      bar.style.width = Math.min(pct, 100) + '%';
    }, { passive: true });
  }


  function calcAttrib() {
    const shopify = parseFloat(document.getElementById('ag-shopify').value) || 0;
    const meta = parseFloat(document.getElementById('ag-meta').value) || 0;
    const spend = parseFloat(document.getElementById('ag-spend').value) || 0;
    const tracking = document.getElementById('ag-tracking').value;

    if (!shopify || !meta || !spend) return;

    const ratio = meta / shopify;
    const gapPct = Math.round((ratio - 1) * 100);
    const reportedROAS = spend > 0 ? (meta / spend).toFixed(2) : '--';

    // True ROAS adjusts for attribution overlap and tracking loss
    let trueAdj = 1;
    if (tracking === 'pixel') trueAdj = 0.85; // pixel loses ~15% of iOS conversions
    else if (tracking === 'capi') trueAdj = 0.98;
    const trueROAS = spend > 0 ? ((shopify * trueAdj) / spend).toFixed(2) : '--';

    let gapLabel, gapColor;
    if (ratio > 1.8) { gapLabel = 'Over-attribution — normal but watch for overlap'; gapColor = '#fbbf24'; }
    else if (ratio > 1.0) { gapLabel = 'Normal attribution overlap'; gapColor = '#4ade80'; }
    else if (ratio > 0.8) { gapLabel = 'Slight under-reporting — check pixel'; gapColor = '#fbbf24'; }
    else { gapLabel = 'Significant tracking loss detected'; gapColor = '#f87171'; }

    document.getElementById('ag-gap').textContent = (gapPct >= 0 ? '+' : '') + gapPct + '%';
    document.getElementById('ag-gap').style.color = gapColor;
    document.getElementById('ag-gap-label').textContent = gapLabel;
    document.getElementById('ag-roas').textContent = trueROAS + 'x';
    document.getElementById('ag-reported-roas').textContent = reportedROAS + 'x';

    let insight = '';
    if (ratio < 0.9 && tracking === 'pixel') {
      insight = '<strong>Tracking loss confirmed.</strong> Meta is missing conversions that Shopify is recording. Implementing server-side CAPI tracking is likely to recover £' + Math.round(spend * 0.25).toLocaleString() + '/month in attributed revenue at your current spend level. <a href="/capi-shield">Free CAPI setup guide →</a>';
    } else if (ratio > 2.0) {
      insight = '<strong>High over-attribution.</strong> Meta\'s reported ROAS is significantly above your true business ROAS. This often indicates heavy view-through attribution counting low-intent impressions. Consider switching to 7-day click only attribution to get a cleaner signal.';
    } else {
      insight = '<strong>Attribution is in a normal range.</strong> Your Shopify vs Meta ratio is typical for a DTC brand. Focus on improving tracking completeness with CAPI to ensure the ratio stays consistent as iOS restrictions tighten further.';
    }
    document.getElementById('ag-insight').innerHTML = insight;
    document.getElementById('ag-result').classList.add('show');
  }
  
</script>
