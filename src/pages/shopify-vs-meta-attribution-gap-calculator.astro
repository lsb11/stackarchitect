<div class="container">
  <nav class="breadcrumb" aria-label="breadcrumb">
    <a href="https://www.stackarchitect.xyz">Stack Architect</a>
    <span aria-hidden="true">›</span>
    <a href="https://www.stackarchitect.xyz/tools">Tools</a>
    <span aria-hidden="true">›</span>
    <span>Shopify vs. Meta Attribution Gap Calculator</span>
  </nav>

  <main>
    <article>
      
      <h1>Shopify vs. Meta vs. GA4 Attribution Gap Calculator</h1>
      <p class="intro">Your ad platforms will never agree on revenue — but the gaps should be explainable. Enter your numbers from each platform and this tool tells you which to trust, why they diverge, and the single fix that recovers the most data.</p>

      <section class="card">
        <p class="card-title">Enter your details</p>
        <form id="calcForm" novalidate>
          <div class="field"><label for="shopifyRevenue">Shopify revenue (last 30 days, £/$/€)</label><input type="number" id="shopifyRevenue" name="shopifyRevenue" placeholder="e.g. 25000" min="0" required></div>
<div class="field"><label for="metaRevenue">Meta Ads Manager revenue (same period)</label><input type="number" id="metaRevenue" name="metaRevenue" placeholder="e.g. 31000" min="0" required></div>
<div class="field"><label for="ga4Revenue">GA4 revenue (same period)</label><input type="number" id="ga4Revenue" name="ga4Revenue" placeholder="e.g. 18000" min="0"></div>
<div class="field"><label for="attributionWindow">Your Meta attribution window setting</label><select id="attributionWindow" name="attributionWindow"><option value="">Select…</option><option value="1-day click">1-day click</option><option value="7-day click">7-day click</option><option value="7-day click + 1-day view">7-day click + 1-day view</option><option value="28-day click (legacy)">28-day click (legacy)</option></select></div>
<div class="field"><label for="capiEnabled">Do you have CAPI enabled?</label><select id="capiEnabled" name="capiEnabled"><option value="">Select…</option><option value="No">No</option><option value="Shopify native CAPI">Shopify native CAPI</option><option value="True server-side CAPI">True server-side CAPI</option></select></div>
          <button type="submit" class="btn-calc">Calculate →</button>
        </form>
      </section>

      
<section id="teaser" hidden>
  <div class="teaser-card">
    <div class="teaser-number" id="teaserValue"></div>
    <div class="teaser-label" id="teaserLabel"></div>
    <div class="gate-box" id="emailGate">
      <p>Enter your email to unlock the full breakdown</p>
      <div class="gate-row">
        <input type="email" id="emailInput" placeholder="you@example.com" autocomplete="email">
        <button class="btn-gate" id="gateBtn">See your full attribution breakdown</button>
      </div>
    </div>
  </div>
</section>

      <section id="results" hidden>
        <div class="card">
          <p class="card-title">Your results</p>
          <div id="resultsContent"></div>
        </div>
      </section>

      <aside class="upsell" id="upsellBlock" hidden>
        <span class="upsell-text">Fix your tracking gap with CAPI Shield — free →</span>
        <a class="upsell-btn" href="https://www.stackarchitect.xyz/capi-shield" target="_blank" rel="noopener">Get started →</a>
      </aside>
    </article>

    <section class="faq-section">
      <h2>Frequently asked questions</h2>
      
<details>
  <summary>Why does Meta report more revenue than Shopify?</summary>
  <div class="faq-answer">Meta uses view-through and click attribution windows that can credit the same sale multiple times across campaigns. A 7-day click + 1-day view window will almost always show higher revenue than Shopify's order count.</div>
</details>
<details>
  <summary>Which platform should I trust for true revenue?</summary>
  <div class="faq-answer">Shopify is always the ground truth for actual orders placed and revenue received. Meta and GA4 show attributed revenue — their job is campaign measurement, not accounting.</div>
</details>
<details>
  <summary>Why does GA4 show less revenue than Shopify?</summary>
  <div class="faq-answer">GA4 relies on browser-side tracking which is blocked by iOS privacy, ad blockers, and users who close the page before the tracking fires. Server-side CAPI typically recovers 20–40% of this lost signal.</div>
</details>
    </section>

    <nav class="related-tools" aria-label="Related tools">
      <h2>Other free Shopify tools</h2>
      <div class="related-grid">
        <a class="related-link" href="/tools/meta-emq-score-estimator">Meta EMQ Score Estimator</a><a class="related-link" href="/tools/tiktok-vs-meta-roas-bridge-calculator">TikTok vs. Meta ROAS Bridge Calculator</a><a class="related-link" href="/tools/shopify-profit-loss-leak-finder">Shopify P&amp;L Leak Finder</a>
      </div>
    </nav>
  </main>
</div>

<footer>
  <p>Free tool by <a href="https://www.stackarchitect.xyz">Stack Architect</a> &mdash; Free Shopify tools. No apps. No fluff.</p>
</footer>

<script is:inline>
function fmt(n){ return Math.round(n).toLocaleString('en-GB'); }

function calculate(inp) {
  var shopify = parseFloat(inp.shopifyRevenue) || 0;
  var meta = parseFloat(inp.metaRevenue) || 0;
  var ga4 = parseFloat(inp.ga4Revenue) || 0;
  var metaOver = shopify > 0 ? ((meta - shopify) / shopify * 100) : 0;
  var ga4Under = (shopify > 0 && ga4 > 0) ? ((shopify - ga4) / shopify * 100) : null;
  var cause = metaOver > 30 ? 'Severe attribution window inflation' : 'Attribution window inflation';
  if (ga4Under !== null && ga4Under > 25) cause = 'Client-side tracking loss — CAPI fix needed';
  var topRec = (ga4Under !== null && ga4Under > 20) ? 'Fix GA4 tracking loss with server-side CAPI first' : 'Align Meta attribution window to 7-day click only';
  var metaFlag = metaOver > 30 ? 'bad' : metaOver > 15 ? 'warn' : 'good';
  var ga4Flag = ga4Under === null ? 'neutral' : ga4Under > 20 ? 'bad' : ga4Under > 10 ? 'warn' : 'good';
  var rows = [
    { label: 'Meta over-reports vs Shopify', value: metaOver.toFixed(1) + '%', flag: metaFlag },
    { label: 'Primary cause', value: cause, flag: metaFlag },
    { label: 'Trusted revenue source', value: 'Shopify (always ground truth)', flag: 'good' },
    { label: 'Top fix recommendation', value: topRec, flag: 'neutral' }
  ];
  if (ga4Under !== null) {
    rows.splice(1, 0, { label: 'GA4 under-reports vs Shopify', value: ga4Under.toFixed(1) + '%', flag: ga4Flag });
  }
  return {
    teaser: { label: 'Meta over-report vs Shopify', value: metaOver.toFixed(1) + '%', flag: metaFlag },
    rows: rows
  };
}

var IS_GATED = true;
var form = document.getElementById('calcForm');
var resultsSection = document.getElementById('results');
var resultsContent = document.getElementById('resultsContent');
var teaserSection = document.getElementById('teaser');
var teaserValue = document.getElementById('teaserValue');
var teaserLabel = document.getElementById('teaserLabel');
var emailGate = document.getElementById('emailGate');
var gateBtn = document.getElementById('gateBtn');
var upsellBlock = document.getElementById('upsellBlock');
var lastResult = null;

function getInputs() {
  var inp = {};
  var fd = new FormData(form);
  fd.forEach(function(v, k) {
    if (inp[k]) {
      inp[k] = Array.isArray(inp[k]) ? inp[k].concat(v) : [inp[k], v];
    } else {
      inp[k] = v;
    }
  });
  // Also grab textareas by id since FormData may not pick up all
  form.querySelectorAll('textarea').forEach(function(el){
    if (!inp[el.id]) inp[el.id] = el.value;
  });
  return inp;
}

function renderRows(rows) {
  return rows.map(function(r) {
    var sub = r.sub ? '<span class="sub">' + r.sub + '</span>' : '';
    return '<div class="result-row flag-' + (r.flag||'neutral') + '">' +
      '<span class="result-label">' + r.label + sub + '</span>' +
      '<span class="result-value">' + r.value + '</span>' +
    '</div>';
  }).join('');
}

function showFullResults(rows) {
  resultsContent.innerHTML = renderRows(rows);
  resultsSection.hidden = false;
  upsellBlock.hidden = false;
  resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

form.addEventListener('submit', function(e) {
  e.preventDefault();
  var inp = getInputs();
  var result;
  try { result = calculate(inp); } catch(err) { alert('Calculation error: ' + err.message); return; }
  lastResult = result;

  if (!IS_GATED) {
    showFullResults(result.rows);
    return;
  }

  // Show teaser
  teaserValue.textContent = result.teaser.value;
  teaserLabel.textContent = result.teaser.label;
  teaserSection.hidden = false;

  // Check if already gated
  var storedEmail = localStorage.getItem('sa_email');
  if (storedEmail) {
    emailGate.hidden = true;
    showFullResults(result.rows);
  } else {
    emailGate.hidden = false;
  }
  teaserSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});

if (gateBtn) {
  gateBtn.addEventListener('click', function() {
    var emailInput = document.getElementById('emailInput');
    var email = emailInput ? emailInput.value.trim() : '';
    if (!email || !email.includes('@')) { emailInput.focus(); return; }
    localStorage.setItem('sa_email', email);
    emailGate.hidden = true;
    if (lastResult) showFullResults(lastResult.rows);
  });
}
</script>
</body>
</html>