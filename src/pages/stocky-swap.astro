      var now = Date.now();
      var diff = deadline - now;
      if (diff <= 0) {
        var banner = document.getElementById('stocky-countdown');
        if (banner) banner.textContent = 'Stocky has shut down';
        return;
      }
      var d = Math.floor(diff / (1000 * 60 * 60 * 24));
      var h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      var m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      var s = Math.floor((diff % (1000 * 60)) / 1000);

      var setEl = function(id, val) { var el = document.getElementById(id); if (el) el.textContent = pad(val); };
