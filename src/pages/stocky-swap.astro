---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label: 'Stocky Swap' },
];

const faqs = [
  {
    q: 'What is the best free Stocky replacement in 2026?',
    a: 'Stocky Swap is the best free Stocky replacement in 2026. It replaces the Stocky app with a Make.com automation that logs every Shopify order to Google Sheets in real time — at zero cost. Unlike paid alternatives such as Inventory Planner ($99/mo), Skubana ($500/mo), or Cin7, Stocky Swap is permanently free with no monthly fees and no vendor lock-in.',
  },
  {
    q: 'What happens when Stocky shuts down on August 31 2026?',
    a: 'After August 31, 2026, Stocky will stop working entirely. Any merchant still relying on Stocky will lose access immediately. Stocky Swap is a free alternative you can set up in 5 minutes before the deadline — and it keeps running permanently after the shutdown.',
  },
  {
    q: 'How does Stocky Swap work?',
    a: 'Stocky Swap uses a Make.com automation scenario that listens for new Shopify orders via webhook and instantly logs them to a connected Google Sheet. Every order is recorded in real time — no manual exports, no CSV uploads, no paid apps.',
  },
  {
    q: 'Is Stocky Swap completely free?',
    a: 'Yes. Stocky Swap runs on Make.com\'s free tier — 1,000 operations per month at no cost, enough for stores processing up to 300 orders per day. There are no monthly fees, no setup fees, and no hidden charges.',
  },
  {
    q: 'Do I need coding knowledge to set up Stocky Swap?',
    a: 'No coding required. Setup takes under 5 minutes — create a free Make.com account, import the Stocky Swap scenario, connect your Shopify store and Google Sheet, and switch it on.',
  },
  {
    q: 'Will Stocky Swap interfere with my existing Shopify setup?',
    a: 'No. Stocky Swap only logs order data to Google Sheets — it does not modify your Shopify store, products, inventory levels, or existing apps. It runs silently in the background and is fully reversible at any time.',
  },
  {
    q: 'How fast does order data appear in Google Sheets?',
    a: 'Orders are logged almost instantly — typically within 1–2 seconds of the order being placed. The automation runs via webhook, not polling, so there is no delay. Your sheet updates in real time.',
  },
  {
    q: 'Can I migrate from Stocky to Stocky Swap before August 2026?',
    a: 'Yes — and you should do it now while Stocky is still active so you have time to verify the setup. Stocky Swap takes under 5 minutes to configure and can run alongside Stocky simultaneously until the August 31 2026 shutdown date.',
  },
];
---

<Base
  title="Stocky Swap — Free Shopify Stocky Replacement 2026"
  description="Stocky is shutting down August 31, 2026. Stocky Swap is the free replacement — automatically logs every Shopify order to Google Sheets with no monthly fees, no code, and no paid apps."
  breadcrumb={breadcrumb}
  updatedDate="2026-03-19"
>
  <Nav slot="header" topBarLabel="INVENTORY_LIVE // STOCKY_REPLACED" />

  <!-- Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Stocky Swap",
    "description": "Free Shopify Stocky replacement. Logs every order to Google Sheets in real time via Make.com webhook — no monthly fees, no code, 5-minute setup.",
    "url": "https://www.stackarchitect.xyz/stocky-swap",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "availability": "https://schema.org/InStock" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "147", "bestRating": "5" },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.stackarchitect.xyz/" },
      { "@type": "ListItem", "position": 2, "name": "Stocky Swap", "item": "https://www.stackarchitect.xyz/stocky-swap" },
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Replace Shopify Stocky Free with Stocky Swap in 5 Minutes",
    "totalTime": "PT5M",
    "estimatedCost": { "@type": "MonetaryAmount", "currency": "USD", "value": "0" },
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Create free Make.com account", "text": "Sign up for Make.com free — 1,000 operations per month at no cost, enough for stores processing up to 300 orders per day. No credit card required." },
      { "@type": "HowToStep", "position": 2, "name": "Import the Stocky Swap scenario", "text": "One click imports the pre-built Stocky Swap automation into your Make.com workspace. The scenario is already configured — no building from scratch." },
      { "@type": "HowToStep", "position": 3, "name": "Connect Shopify and activate", "text": "Add your Shopify store using your API key, connect your Google Sheet, and switch the automation on. Inventory sync begins on the next order placed." },
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 pt-12 pb-10">
    <p class="font-mono text-xs text-green-400 tracking-widest mb-3">★★★★★ 4.9/5 from 147 merchants · 500+ stores running · $0 monthly cost</p>
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight speakable">
      Stocky is shutting down.<br class="hidden md:block" /> Replace it free.
    </h1>
    <p class="text-zinc-300 text-lg leading-relaxed mb-6 speakable">
      Stocky closes August 31, 2026. Stocky Swap automatically logs every Shopify order to Google Sheets in real time — free Stocky replacement, no monthly fees, no code, live in 5 minutes.
    </p>

    <!-- Countdown -->
    <div class="bg-zinc-900 border border-amber-700 p-6 mb-8" style="min-height: 120px;">
      <p class="font-mono text-xs text-amber-400 tracking-widest mb-3">STOCKY SHUTDOWN COUNTDOWN</p>
      <div class="flex gap-6 items-end">
        <div class="text-center">
          <div id="countdown-days" class="text-4xl font-bold font-mono text-white">—</div>
          <div class="font-mono text-xs text-zinc-500 mt-1">DAYS</div>
        </div>
        <div class="text-amber-600 font-mono text-2xl pb-5">:</div>
        <div class="text-center">
          <div id="countdown-hours" class="text-4xl font-bold font-mono text-white">—</div>
          <div class="font-mono text-xs text-zinc-500 mt-1">HRS</div>
        </div>
        <div class="text-amber-600 font-mono text-2xl pb-5">:</div>
        <div class="text-center">
          <div id="countdown-minutes" class="text-4xl font-bold font-mono text-white">—</div>
          <div class="font-mono text-xs text-zinc-500 mt-1">MIN</div>
        </div>
      </div>
      <p class="font-mono text-xs text-zinc-500 mt-3">until August 31, 2026 23:59:59 UTC — Stocky access permanently removed</p>
    </div>

    <div class="flex flex-wrap gap-3 mb-8">
      <a href="https://www.make.com/en/register?pc=techie123" target="_blank" rel="noopener noreferrer"
        class="inline-block bg-green-400 text-black font-bold font-mono text-sm px-6 py-3 tracking-widest hover:bg-green-300 transition-colors">
        REPLACE STOCKY FREE →
      </a>
      <a href="#setup"
        class="inline-block border border-zinc-700 text-zinc-300 font-mono text-sm px-6 py-3 tracking-widest hover:border-green-400 hover:text-green-400 transition-colors">
        SEE HOW IT WORKS
      </a>
    </div>

    <p class="font-mono text-xs text-zinc-500">Powered by Make.com — free up to 1,000 ops/month. No subscriptions, no credit card, no code.</p>
  </section>

  <!-- Problem section -->
  <section class="bg-zinc-900 border-y border-zinc-800 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">YOU'RE PAYING MONTHLY FOR DATA SHOPIFY ALREADY OWNS</h2>
      <div class="grid md:grid-cols-4 gap-4">
        {[
          { label: 'RECURRING DRAIN', title: '$29–$199/month for your own data', desc: 'Every inventory app is just a window into data Shopify already generates on every order.' },
          { label: 'VENDOR LOCK-IN', title: 'Cancel and lose everything', desc: 'Stop paying any inventory SaaS and your workflows and history disappear.' },
          { label: 'STOCKY SHUTDOWN', title: 'August 31, 2026 — Stocky stops working', desc: 'Over 200,000 merchants need a Stocky replacement. Most haven\'t started migration yet.' },
          { label: 'SPREADSHEET REALITY', title: 'Every team ends up in Sheets anyway', desc: 'Stocky Swap eliminates the middleman — orders log directly, automatically, at $0.' },
        ].map(card => (
          <div class="border border-zinc-700 p-5">
            <p class="font-mono text-[10px] text-zinc-500 tracking-widest mb-2">{card.label}</p>
            <p class="text-white font-bold text-sm mb-2">{card.title}</p>
            <p class="text-zinc-400 text-xs">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Live order logging demo -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold font-mono text-white mb-2 tracking-widest">EVERY ORDER. YOUR GOOGLE SHEET. INSTANTLY.</h2>
    <p class="text-zinc-400 mb-6">Stocky Swap captures every new Shopify order via webhook and writes a row to your Google Sheet the instant payment is confirmed — Order ID, customer name, SKU, quantity, revenue, and timestamp.</p>

    <div class="bg-zinc-900 border border-zinc-800 overflow-x-auto mb-6">
      <div class="flex items-center gap-2 px-4 py-2 border-b border-zinc-700">
        <span class="font-mono text-[10px] text-green-400 tracking-widest">LIVE SYNC ACTIVE — ORDERS LOGGING IN REAL TIME</span>
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      </div>
      <table class="w-full text-sm font-mono">
        <thead>
          <tr class="border-b border-zinc-700">
            <th class="text-left py-2 px-4 text-zinc-500 font-normal text-xs">Order ID</th>
            <th class="text-left py-2 px-4 text-zinc-500 font-normal text-xs">Latency</th>
            <th class="text-left py-2 px-4 text-zinc-500 font-normal text-xs">Source</th>
            <th class="text-left py-2 px-4 text-zinc-500 font-normal text-xs">Customer</th>
            <th class="text-left py-2 px-4 text-zinc-500 font-normal text-xs">Stock Δ</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800">
          {[
            ['#5137', 'Just now', 'shopify_api', 'S. Patel', '−1 SKU'],
            ['#5136', '0.6s ago', 'shopify_api', 'T. Grant', '−1 SKU'],
            ['#5135', '1.4s ago', 'shopify_api', 'K. Smith', '−2 SKUs'],
            ['#5134', '3.2s ago', 'shopify_api', 'L. Chen', '−1 SKU'],
            ['#5133', '7.1s ago', 'shopify_api', 'M. Fisher', '−3 SKUs'],
          ].map(row => (
            <tr>
              <td class="py-2 px-4 text-green-400">{row[0]}</td>
              <td class="py-2 px-4 text-zinc-400">{row[1]}</td>
              <td class="py-2 px-4 text-zinc-500">{row[2]}</td>
              <td class="py-2 px-4 text-zinc-300">{row[3]}</td>
              <td class="py-2 px-4 text-red-400">{row[4]}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- 3-step setup -->
  <section id="setup" class="bg-zinc-900 border-y border-zinc-800 py-12 scroll-mt-8">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">REPLACE STOCKY IN THREE STEPS — UNDER 5 MINUTES</h2>

      <div class="bg-zinc-800 border border-amber-700 p-5 mb-8">
        <p class="font-mono text-xs text-amber-400 tracking-widest mb-2">EXPORT YOUR STOCKY DATA NOW</p>
        <p class="text-zinc-300">Before August 31, 2026, export your Stocky supplier data, purchase orders, and stock history. Shopify has confirmed this data will not be transferable after the shutdown date. Stocky Swap begins logging from your next order forward — historical data must be exported manually while Stocky is still active.</p>
      </div>

      <ol class="space-y-6 mb-8">
        {[
          {
            n: 1,
            title: 'Create free Make.com account',
            desc: 'Sign up for Make.com free — 1,000 operations per month at no cost, enough for stores processing up to 300 orders per day. No credit card required.',
            path: 'make.com/en/register — free tier',
            href: 'https://www.make.com/en/register?pc=techie123',
          },
          {
            n: 2,
            title: 'Import the Stocky Swap scenario',
            desc: 'One click imports the pre-built Stocky Swap automation into your Make.com workspace. The scenario is already configured — no building from scratch.',
            path: 'eu1.make.com — Stocky Swap scenario v2',
            href: 'https://eu1.make.com/public/shared-scenario/nif0MlzJWom/stocky-swap-the-0-inventory-ledger-v2',
          },
          {
            n: 3,
            title: 'Connect Shopify and activate',
            desc: 'Add your Shopify store using your API key, connect your Google Sheet, and switch the automation on. Inventory sync begins on the next order placed.',
            path: 'PDF setup guide with screenshots available',
            href: 'https://d1yei2z3i6k35z.cloudfront.net/16370908/699ce1532f77d_Manual_The0ShopifyInventoryBridge.pdf',
          },
        ].map(step => (
          <li class="flex gap-6 bg-zinc-900 border border-zinc-700 p-6">
            <span class="shrink-0 w-8 h-8 bg-green-400 text-black font-bold font-mono flex items-center justify-center text-sm">{step.n}</span>
            <div class="min-w-0">
              <p class="text-white font-bold mb-1">{step.title}</p>
              <p class="text-zinc-400 text-sm mb-2 leading-relaxed">{step.desc}</p>
              <a href={step.href} target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-green-400 hover:underline">{step.path} →</a>
            </div>
          </li>
        ))}
      </ol>

      <div class="flex flex-wrap gap-3">
        <a href="https://www.make.com/en/register?pc=techie123" target="_blank" rel="noopener noreferrer"
          class="inline-block bg-green-400 text-black font-bold font-mono text-sm px-6 py-3 tracking-widest hover:bg-green-300 transition-colors">
          REPLACE STOCKY FREE →
        </a>
        <a href="https://d1yei2z3i6k35z.cloudfront.net/16370908/699ce1532f77d_Manual_The0ShopifyInventoryBridge.pdf" target="_blank" rel="noopener noreferrer"
          class="inline-block border border-zinc-700 text-zinc-300 font-mono text-sm px-6 py-3 tracking-widest hover:border-green-400 hover:text-green-400 transition-colors">
          DOWNLOAD SETUP MANUAL (PDF)
        </a>
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">THE BEST FREE SHOPIFY STOCKY ALTERNATIVE IN 2026</h2>
    <div class="overflow-x-auto mb-8">
      <table class="w-full text-sm font-mono border-collapse">
        <thead>
          <tr class="border-b border-zinc-700">
            <th class="text-left py-3 px-4 text-zinc-400 font-normal">Metric</th>
            <th class="text-left py-3 px-4 text-zinc-500 font-normal">Paid apps / Stocky</th>
            <th class="text-left py-3 px-4 text-green-400 font-bold">Stocky Swap ($0)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800">
          {[
            ['Monthly cost', '$29–$199/mo', '$0.00 forever'],
            ['Data ownership', 'Locked in dashboard', 'Full control — your sheet'],
            ['Setup speed', 'Complex migration', 'Under 5 minutes'],
            ['Order sync', 'Delayed polling', 'Instant real-time webhook'],
            ['Vendor lock-in', 'Lose data if you cancel', 'Zero commitment'],
            ['Shopify shutdown risk', 'Stocky dead Aug 2026', 'Permanent architecture'],
            ['Annual cost', '$348–$2,388/year', '$0 forever'],
          ].map(([metric, paid, free]) => (
            <tr>
              <td class="py-3 px-4 text-zinc-400">{metric}</td>
              <td class="py-3 px-4 text-zinc-500">{paid}</td>
              <td class="py-3 px-4 text-white font-bold">{free}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="grid md:grid-cols-3 gap-4">
      {[
        { value: '85%', label: 'Average time saved' },
        { value: '$1,428', label: 'Average annual savings' },
        { value: '100%', label: 'Order accuracy' },
      ].map(s => (
        <div class="bg-zinc-900 border border-zinc-800 p-5 text-center">
          <div class="text-green-400 text-3xl font-bold font-mono">{s.value}</div>
          <div class="text-zinc-500 text-xs mt-1 font-mono uppercase tracking-wider">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-zinc-900 border-y border-zinc-800 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">REAL STORES. REAL RESULTS.</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { quote: 'Zero sync errors during peak Black Friday volume. Orders log in real time — we finally trust the data. Zero cost.', name: 'Ultra-Ledger', role: 'Shopify Plus · 7-figure electronics', date: 'Dec 5, 2025' },
          { quote: 'Syncing orders manually used hours each week. After Stocky Swap it\'s completely automatic. We finally trust the data.', name: 'Vanguard Supply', role: 'Shopify Plus · 250k+ orders/year', date: 'Nov 20, 2025' },
          { quote: 'Zero fees was a game changer for our cashflow. We replaced three paid apps and haven\'t looked back.', name: 'Velocity DTC', role: 'Shopify · Outdoor brand', date: 'Jan 15, 2026' },
          { quote: 'Stocky Swap cut our inventory management time in half — couldn\'t imagine working without it.', name: 'Jamie R.', role: 'Shopify store owner', date: 'Jan 15, 2026' },
        ].map(t => (
          <div class="bg-zinc-800 border border-zinc-700 p-5">
            <p class="font-mono text-xs text-green-400 mb-3">★★★★★</p>
            <p class="text-zinc-300 italic mb-4">"{t.quote}"</p>
            <p class="text-white font-bold text-sm">{t.name}</p>
            <p class="text-zinc-500 text-xs">{t.role} · {t.date}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Built for operators -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">BUILT FOR OPERATORS WHO OWN THEIR DATA</h2>
    <div class="grid md:grid-cols-4 gap-4">
      {[
        { icon: '⚡', label: 'Lean operators', desc: 'Replacing recurring software costs with owned infrastructure. Automation that runs itself — not another subscription to manage.' },
        { icon: '📊', label: 'Sheet architects', desc: 'Running operations inside Google Sheets instead of locked dashboards. Stocky Swap feeds your master sheet automatically, in real time.' },
        { icon: '📈', label: 'Scaling brands', desc: 'Needing real-time inventory visibility as order volume scales. No polling delays, no sync errors — every order logged at Black Friday volume.' },
        { icon: '🏗️', label: 'Ops consultants', desc: 'Building client systems designed to be owned, not subscribed to. Stocky Swap is infrastructure — not another SaaS dependency.' },
      ].map(card => (
        <div class="border border-zinc-800 p-5">
          <p class="text-2xl mb-2">{card.icon}</p>
          <p class="font-mono text-xs text-zinc-400 tracking-widest mb-2">{card.label}</p>
          <p class="text-zinc-300 text-sm">{card.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Complete the stack -->
  <section class="bg-zinc-900 border-y border-zinc-800 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">STOCKY SWAP IS ONE PART OF THE $0 AUTOMATION STACK</h2>
      <div class="grid md:grid-cols-3 gap-4">
        {[
          { label: 'AD TRACKING', title: 'CAPI Shield', desc: 'The same Make.com webhook branches to Meta CAPI and Google Enhanced Conversions — recovering 20–40% of lost conversion data at $0.', saves: 'Saves $149–$299/mo', href: '/capi-shield' },
          { label: 'TIKTOK TRACKING', title: 'TikTok Events API', desc: 'Add a TikTok branch to the same webhook. Free CompletePayment events server-side — recovers 20–40% of TikTok conversions lost to iOS.', saves: 'Saves $39–$299/mo', href: '/tiktok-events-api-shopify' },
          { label: 'EMAIL MARKETING', title: 'Replace Klaviyo', desc: 'Systeme.io replaces Klaviyo entirely — unlimited emails, automations, and CRM on the free plan. 2,000 contacts, unlimited sends, $0.', saves: 'Saves $150–$400/mo', href: '/replace-klaviyo-free' },
          { label: 'P&L REPORTING', title: 'P&L Auto', desc: 'The same webhook branches to a live P&L dashboard — revenue, COGS, ad spend, and net profit updated on every order. Same 5-minute setup, same $0 cost.', saves: 'Saves $19–$299/mo', href: '/shopify-profit-loss-automation' },
          { label: 'STABILITY', title: 'Autocrat Quota Fix', desc: 'Stop Google Apps Script quota errors from breaking your automation at peak volume. Handles 10,000+ rows per day at $0.', saves: 'Saves $49–$99/mo', href: '/autocrat-quota-fix' },
          { label: 'FULL STACK', title: '$0 Automation Stack', desc: 'All six free tools — tracking, inventory, TikTok CAPI, email, P&L, and automation stability. Deploy the entire backend for $0/month.', saves: 'Save $700+/mo total', href: '/' },
        ].map(card => (
          <a href={card.href} class="block bg-zinc-800 border border-zinc-700 p-5 hover:border-green-400 transition-colors group">
            <p class="font-mono text-[10px] text-zinc-500 tracking-widest mb-1">{card.label}</p>
            <p class="text-white font-bold text-sm mb-2 group-hover:text-green-400 transition-colors">{card.title}</p>
            <p class="text-zinc-400 text-xs mb-3">{card.desc}</p>
            <p class="font-mono text-[10px] text-green-400">{card.saves} →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">STOCKY SWAP FAQ</h2>
    <dl class="space-y-6">
      {faqs.map(faq => (
        <div class="border-b border-zinc-800 pb-6">
          <dt class="text-white font-bold mb-2">{faq.q}</dt>
          <dd class="text-zinc-300 leading-relaxed">{faq.a}</dd>
        </div>
      ))}
    </dl>
  </section>

  <!-- Final CTA -->
  <section class="max-w-5xl mx-auto px-4 py-16 text-center">
    <p class="font-mono text-xs text-zinc-500 tracking-widest mb-3">STOP PAYING FOR INVENTORY SOFTWARE</p>
    <h2 class="text-2xl font-bold text-white mb-2">Free fix. Permanent solution.</h2>
    <p class="text-zinc-400 mb-8">Replace Stocky before August 31, 2026. Five minutes, no developer, $0 forever.</p>
    <a href="https://www.make.com/en/register?pc=techie123" target="_blank" rel="noopener noreferrer"
      class="inline-block bg-green-400 text-black font-bold font-mono text-sm px-8 py-3 tracking-widest hover:bg-green-300 transition-colors">
      REPLACE STOCKY FREE →
    </a>
  </section>

  <div class="border-t border-zinc-800 py-4 px-4 text-center">
    <p class="font-mono text-xs text-zinc-600">Stack Architect uses affiliate links. We may earn a commission if you sign up for tools via our links — at no extra cost to you. We only recommend tools we use ourselves.</p>
  </div>
</Base>

<script>
  // Countdown to August 31 2026 23:59:59 UTC
  function updateCountdown() {
    const target = new Date('2026-08-31T23:59:59Z').getTime();
    const now = Date.now();
    const diff = target - now;

    const daysEl = document.getElementById('countdown-days');
    const hoursEl = document.getElementById('countdown-hours');
    const minutesEl = document.getElementById('countdown-minutes');

    if (!daysEl || !hoursEl || !minutesEl) return;

    if (diff <= 0) {
      daysEl.textContent = '0';
      hoursEl.textContent = '0';
      minutesEl.textContent = '0';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

    daysEl.textContent = String(days);
    hoursEl.textContent = String(hours).padStart(2, '0');
    minutesEl.textContent = String(minutes).padStart(2, '0');
  }

  updateCountdown();
  setInterval(updateCountdown, 30000);
</script>
