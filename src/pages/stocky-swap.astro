<!doctype html>
<html lang="en-GB" itemscope itemtype="https://schema.org/WebPage">
<head>
  <!-- ── Charset & Viewport ────────────────────────────────────────── -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ── Primary SEO ──────────────────────────────────────────────── -->
  <title>{SEO.title}</title>
  <meta name="description" content={SEO.description} />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="author" content="Stack Architect" />
  <meta name="keywords" content="stocky replacement, stocky alternative, shopify stocky replacement, free stocky replacement, stocky app shutdown, shopify inventory google sheets, stocky swap, shopify inventory management free, replace stocky 2026" />
  <link rel="canonical" href={SEO.canonical} />

  <!-- ── GEO / AI Search Signals ──────────────────────────────────── -->
  <meta name="article:published_time" content="2026-01-01T00:00:00Z" />
  <meta name="article:modified_time" content={`${DATE_MODIFIED}T00:00:00Z`} />
  <meta name="article:author" content="Stack Architect" />
  <meta name="article:section" content="Shopify Automation" />
  <meta name="article:tag" content="Stocky Replacement, Shopify Inventory, Google Sheets Automation, Make.com, Free Shopify Tools" />

  <!-- ── Geographic Targeting ─────────────────────────────────────── -->
  <meta name="geo.region" content="GB" />
  <meta name="geo.placename" content="United Kingdom" />
  <meta name="language" content="English" />
  <meta http-equiv="content-language" content="en-gb" />

  <!-- ── hreflang ─────────────────────────────────────────────────── -->
  <link rel="alternate" hreflang="en" href={SEO.canonical} />
  <link rel="alternate" hreflang="en-gb" href={SEO.canonical} />
  <link rel="alternate" hreflang="en-us" href={SEO.canonical} />
  <link rel="alternate" hreflang="x-default" href={SEO.canonical} />

  <!-- ── Open Graph ───────────────────────────────────────────────── -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={SEO.canonical} />
  <meta property="og:title" content="Stocky Swap — Free Shopify Stocky Replacement 2026" />
  <meta property="og:description" content="Stocky shuts down August 31, 2026. Replace it free — automated Shopify order logging to Google Sheets via Make.com. No monthly fees, no code, 5 minutes." />
  <meta property="og:image" content={SEO.ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Stocky Swap — free Shopify Stocky replacement that logs orders to Google Sheets" />
  <meta property="og:site_name" content="Stack Architect" />
  <meta property="og:locale" content="en_GB" />

  <!-- ── Twitter Card ─────────────────────────────────────────────── -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Stocky Swap — Free Shopify Stocky Replacement 2026" />
  <meta name="twitter:description" content="Stocky shuts down August 31 2026. Replace it free — Shopify orders auto-logged to Google Sheets. No monthly fees, 5 minutes." />
  <meta name="twitter:image" content={SEO.ogImage} />
  <meta name="twitter:image:alt" content="Stocky Swap — free Shopify Stocky replacement" />

  <!-- ── Performance: Preconnect + Preload ────────────────────────── -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://d1yei2z3i6k35z.cloudfront.net" />
  <link rel="dns-prefetch" href="https://www.make.com" />
  <link rel="preload" as="image" href={SEO.ogImage} />

  <!-- ── Fonts (font-display:swap baked in via &display=swap) ──────── -->
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700;800&display=swap"
  />

  <!-- ── JSON-LD Structured Data ──────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd, null, 2)} />

  <style>
    /* ── Design system reset + tokens ── */
    html, body,
    .page-container, .page-content, .page-body,
    div[data-lp], div[data-section],
    [class*="eluid"], [class*="sib-"], [class*="ss-"], [class*="section-"] {
      background-color: #020617 !important;
      font-family: 'Inter', -apple-system, sans-serif !important;
    }
    html, body, p, h1, h2, h3, h4, h5, h6,
    span, div, a, li, ul, ol, input, button, textarea,
    [class*="eluid"], [class*="sib-"], [class*="ss-"] {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif !important;
    }
    [class*="eluid"] p,
    [class*="eluid"] h1, [class*="eluid"] h2,
    [class*="eluid"] h3, [class*="eluid"] h4 { color: inherit !important; }
    [class*="eluid"] a { color: inherit !important; text-decoration: none !important; }
    [class*="eluid"] button { font-family: inherit !important; }
    html { scroll-behavior: smooth; }
    ::selection { background: rgba(0, 200, 100, .2); color: #f1f5f9; }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: #020617; }
    ::-webkit-scrollbar-thumb { background: rgba(0, 200, 100, .3); border-radius: 2px; }
    body { overflow-x: hidden; }

    /* ── CSS Custom Properties ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --g: #00c864; --g-dim: #00a854; --g-bg: rgba(0,200,100,.08); --g-border: rgba(0,200,100,.2);
      --bg: #020617; --bg-2: #06101e; --bg-3: #0a1628; --bg-4: #0f1f35;
      --border: #1e293b; --border-2: #263548;
      --text: #f1f5f9; --text-2: #cbd5e1; --text-3: #94a3b8; --text-4: #64748b; --text-inv: #020617;
      --red: #fc8181; --red-bg: rgba(252,129,129,.07); --red-border: rgba(252,129,129,.18);
      --sky: #7dd3fc; --sky-bg: rgba(125,211,252,.07); --sky-border: rgba(125,211,252,.18);
      --vio: #c4b5fd; --vio-bg: rgba(196,181,253,.07); --vio-border: rgba(196,181,253,.18);
      --amber: #fcd34d;
      --tiktok: #ff0050; --tiktok-bg: rgba(255,0,80,.07); --tiktok-border: rgba(255,0,80,.2);
      --mono: 'JetBrains Mono', monospace;
      --sans: 'Inter', -apple-system, sans-serif;
      --radius: 6px;
      --shadow-g: 0 8px 28px rgba(0,200,100,.3);
    }
    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text-3);
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── Skip link (accessibility) ── */
    .skip-link {
      position: absolute; left: -9999px; top: auto;
      width: 1px; height: 1px; overflow: hidden;
      background: var(--g); color: var(--text-inv);
      font-weight: 700; padding: 12px 20px; border-radius: 4px;
      z-index: 99999;
    }
    .skip-link:focus { position: fixed; top: 16px; left: 16px; width: auto; height: auto; }

    /* ── Utilities ── */
    .tag {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: var(--mono); font-size: 11px; font-weight: 700;
      letter-spacing: .12em; text-transform: uppercase; padding: 5px 12px;
      border-radius: 3px; background: var(--g-bg); border: 1px solid var(--g-border); color: var(--g);
    }
    .tag-dim   { background: rgba(255,255,255,.03); border-color: var(--border-2); color: var(--text-4); }
    .tag-sky   { background: var(--sky-bg); border-color: var(--sky-border); color: var(--sky); }
    .tag-red   { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }
    .tag-amber { background: rgba(252,211,77,.07); border-color: rgba(252,211,77,.2); color: var(--amber); }
    .tag-vio   { background: var(--vio-bg); border-color: var(--vio-border); color: var(--vio); }
    .tag-tiktok{ background: var(--tiktok-bg); border-color: var(--tiktok-border); color: var(--tiktok); }

    .dot {
      display: inline-block; width: 7px; height: 7px; min-width: 7px;
      border-radius: 50%; background: var(--g);
      animation: dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite;
    }
    @keyframes dotPing {
      0%   { box-shadow: 0 0 0 0 rgba(0,200,100,.5); }
      70%  { box-shadow: 0 0 0 8px rgba(0,200,100,0); }
      100% { box-shadow: 0 0 0 0 rgba(0,200,100,0); }
    }
    .dot-red { background: var(--red); animation: dotRed 1.5s ease-in-out infinite; }
    @keyframes dotRed { 0%,100% { opacity: 1; } 50% { opacity: .3; } }

    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      font-family: var(--sans); font-size: 16px; font-weight: 700; text-decoration: none;
      letter-spacing: -.01em; padding: 16px 32px; border-radius: var(--radius);
      border: none; cursor: pointer; white-space: nowrap;
      background: var(--g); color: var(--text-inv);
      transition: background .2s, transform .15s, box-shadow .2s; min-height: 52px;
    }
    .btn:hover { background: #00e070; transform: translateY(-2px); box-shadow: var(--shadow-g); }
    .btn.pulse { animation: btnGlow 2.8s ease-in-out infinite; }
    @keyframes btnGlow {
      0%,100% { box-shadow: 0 0 16px rgba(0,200,100,.1); }
      50%      { box-shadow: 0 0 28px rgba(0,200,100,.28); }
    }
    .btn.pulse:hover { animation: none; }
    .btn-sm { font-size: 14px; padding: 12px 22px; min-height: 44px; }
    .btn-outline {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: var(--sans); font-size: 15px; font-weight: 600; text-decoration: none;
      letter-spacing: -.01em; padding: 15px 28px; border-radius: var(--radius);
      border: 1.5px solid var(--border-2); cursor: pointer; white-space: nowrap;
      background: transparent; color: var(--text-2);
      transition: border-color .2s, color .2s, background .2s; min-height: 52px;
    }
    .btn-outline:hover { border-color: var(--g); color: var(--g); background: var(--g-bg); }

    .section     { padding: 100px 24px; }
    .section-alt { padding: 100px 24px; background: var(--bg-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .inner    { max-width: 1000px; margin: 0 auto; }
    .inner-sm { max-width: 720px; margin: 0 auto; }
    .inner-md { max-width: 860px; margin: 0 auto; }

    .sec-head { text-align: center; margin-bottom: 56px; }
    .sec-head h2 {
      font-family: var(--sans); font-weight: 900;
      font-size: clamp(26px, 4vw, 40px); letter-spacing: -.03em;
      color: var(--text); line-height: 1.05; margin-bottom: 10px;
    }
    .sec-head p { font-size: 15px; color: var(--text-3); max-width: 480px; margin: 14px auto 0; line-height: 1.75; }

    .bg-grid {
      background-color: var(--bg);
      background-image:
        radial-gradient(ellipse 80% 40% at 50% 0%, rgba(0,200,100,.06) 0%, transparent 60%),
        radial-gradient(circle, var(--border) 1px, transparent 1px);
      background-size: 100% 100%, 44px 44px;
    }

    .stat-strip { display: grid; grid-template-columns: repeat(4,1fr); background: var(--border); gap: 1px; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
    .stat-cell  { background: var(--bg); padding: 20px 12px; text-align: center; }
    .stat-v     { font-family: var(--mono); font-size: 22px; font-weight: 700; color: var(--g); line-height: 1; }
    .stat-l     { font-size: 11px; color: var(--text-4); text-transform: uppercase; letter-spacing: .12em; margin-top: 6px; font-family: var(--mono); }
    .divider    { height: 1px; background: var(--border); margin: 0; }

    /* ── Urgency Banner ── */
    .urgency-banner {
      width: 100%; background: linear-gradient(90deg, #7f1d1d, #991b1b, #7f1d1d);
      padding: 12px 24px; text-align: center;
      font-family: var(--mono); font-size: 11px; font-weight: 800;
      letter-spacing: 1.5px; text-transform: uppercase; color: #fca5a5;
      border-bottom: 1px solid rgba(255,100,100,.3);
      display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap;
    }
    .urgency-banner strong { color: #fff; }

    /* ── Navigation ── */
    .product-terminal-bar {
      width: 100%; background: #020617; padding: 12px 0;
      border-bottom: 1px solid #1e293b;
      position: sticky; top: 0; z-index: 10002;
      transition: all .3s ease;
    }
    .product-terminal-bar.scrolled {
      background: rgba(2,6,23,.95); backdrop-filter: blur(12px);
      padding: 8px 0; border-bottom: 1px solid rgba(0,168,84,.3);
      box-shadow: 0 4px 20px rgba(0,0,0,.4);
    }
    .terminal-container {
      max-width: 1100px; margin: 0 auto;
      display: flex; justify-content: space-between; align-items: center; padding: 0 24px;
    }
    .terminal-status {
      display: flex; align-items: center; gap: 10px;
      font-family: var(--mono); font-size: 9px; color: #475569;
      letter-spacing: 1.5px; font-weight: 800;
    }
    .status-indicator {
      width: 5px; height: 5px; background: #00a854; border-radius: 50%;
      box-shadow: 0 0 8px #00a854; animation: sPulse 2s infinite;
    }
    @keyframes sPulse {
      0%,100% { box-shadow: 0 0 8px #00a854; }
      50%      { box-shadow: 0 0 16px #00a854; }
    }
    .product-access-grid { display: flex; gap: clamp(12px,2.5vw,24px); list-style: none; align-items: center; }
    .product-link {
      font-family: var(--mono); font-size: 10px; font-weight: 800; color: #94a3b8;
      text-decoration: none; text-transform: uppercase; letter-spacing: 1px;
      transition: all .3s cubic-bezier(.16,1,.3,1);
      display: flex; align-items: center; gap: 4px;
    }
    .product-link::before { content: '['; color: #334155; transition: color .3s; }
    .product-link::after  { content: ']'; color: #334155; transition: color .3s; }
    .product-link:hover,
    .product-link.is-active { color: #fff; transform: translateY(-1px); }
    .product-link:hover::before, .product-link:hover::after,
    .product-link.is-active::before, .product-link.is-active::after { color: #00a854; }
    .product-link.is-active { color: #00a854; }

    .terminal-cta { display: flex; align-items: center; margin-left: 16px; }
    .savings-ticker { font-family: var(--mono); font-size: 8px; font-weight: 800; color: #00a854; letter-spacing: 1px; margin-right: 12px; white-space: nowrap; opacity: .8; }
    .cta-node {
      font-family: var(--mono); font-size: 10px; font-weight: 900; color: #00a854;
      text-decoration: none; text-transform: uppercase; padding: 6px 14px;
      border: 1px solid #00a854; border-radius: 4px;
      transition: all .3s cubic-bezier(.175,.885,.32,1.275);
      display: inline-block; white-space: nowrap;
    }
    .cta-node:hover { background: #00a854; color: #fff; box-shadow: 0 6px 20px rgba(0,168,84,.5); transform: scale(1.05); }

    .dropdown { position: relative; cursor: pointer; }
    .dropdown-menu {
      display: none; position: absolute; top: calc(100% + 8px); left: 0;
      background: #020617; border: 1px solid #1e293b; border-radius: 6px;
      padding: 8px 0; min-width: 280px; z-index: 10003; flex-direction: column;
      list-style: none; box-shadow: 0 20px 40px rgba(0,0,0,.5);
    }
    .dropdown-menu .product-link::before,
    .dropdown-menu .product-link::after { content: ''; }
    .dropdown-menu .product-link { display: block; padding: 10px 16px; font-size: 10px; color: #94a3b8; transition: all .15s; }
    .dropdown-menu .product-link:hover { color: #fff; background: rgba(0,168,84,.1); transform: none; }
    .dropdown-desc {
      display: block; font-family: var(--sans); font-size: 10px; font-weight: 400;
      color: #475569; letter-spacing: 0; text-transform: none; margin-top: 2px; line-height: 1.4;
    }
    @media (min-width: 851px) { .dropdown:hover .dropdown-menu { display: flex; } }
    @media (max-width: 850px) {
      .terminal-status, .savings-ticker { display: none; }
      .terminal-container { flex-direction: column; gap: 14px; }
      .product-access-grid { display: grid; grid-template-columns: repeat(2,auto); gap: 10px 18px; }
      .terminal-cta { margin-left: 0; order: -1; width: 100%; justify-content: center; }
      .cta-node { background: #00a854; color: #fff; width: 80%; text-align: center; }
    }

    /* ── Hero ── */
    .hero { padding: 80px 24px 72px; text-align: center; position: relative; overflow: hidden; }
    .hero-inner { max-width: 900px; margin: 0 auto; position: relative; }
    .hero-proof {
      display: inline-flex; align-items: center; gap: 12px;
      background: rgba(255,255,255,.04); border: 1px solid var(--border-2);
      border-radius: 100px; padding: 9px 22px; margin-bottom: 36px;
      flex-wrap: wrap; justify-content: center;
    }
    .hero-proof-stars { color: var(--amber); font-size: 14px; letter-spacing: 2px; }
    .hero-proof-txt { font-family: var(--mono); font-size: 11px; color: var(--text-4); letter-spacing: .08em; }
    .hero h1 { font-size: clamp(42px,7.5vw,88px); font-weight: 900; color: var(--text); line-height: .94; letter-spacing: -.05em; margin: 0 auto 24px; max-width: 820px; }
    .hero h1 .green { color: var(--g); }
    .hero h1 .dim   { color: var(--text-4); }
    .hero-sub { font-size: clamp(16px,2.2vw,20px); color: var(--text-3); max-width: 600px; margin: 0 auto 32px; line-height: 1.7; }
    .hero-sub strong { color: var(--text-2); font-weight: 600; }
    .hero-ctas { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 14px; margin-bottom: 14px; }
    .hero-cta-note { font-size: 13px; color: var(--text-4); line-height: 1.6; margin-bottom: 36px; }
    .hero-cta-note a { color: rgba(0,200,100,.6); text-decoration: underline; }
    .hero-social-proof {
      display: flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap;
      padding: 16px 24px; background: rgba(255,255,255,.02); border: 1px solid var(--border);
      border-radius: 12px; max-width: 700px; margin: 0 auto 36px;
    }
    .hsp-item { display: flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 10px; color: var(--text-4); letter-spacing: .08em; }
    .hsp-sep  { width: 1px; height: 16px; background: var(--border); }
    .hero-quote {
      display: inline-block; max-width: 500px; text-align: left;
      background: rgba(255,255,255,.03); border: 1px solid var(--border-2);
      border-left: 3px solid var(--sky); border-radius: 0 8px 8px 0; padding: 22px 26px;
      margin: 0 auto;
    }
    .hero-quote blockquote { font-size: 15px; color: var(--text-2); font-style: italic; line-height: 1.65; margin-bottom: 10px; }
    .hero-quote cite { font-family: var(--mono); font-size: 11px; color: var(--text-4); letter-spacing: .1em; text-transform: uppercase; font-style: normal; }

    /* ── Countdown ── */
    .countdown-strip {
      background: rgba(252,211,77,.06); border: 1px solid rgba(252,211,77,.2);
      border-radius: 10px; padding: 20px 28px; margin: 0 auto 20px; max-width: 600px; text-align: center;
    }
    .countdown-label { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: var(--amber); margin-bottom: 12px; }
    .countdown-nums  { display: flex; gap: 12px; justify-content: center; align-items: center; }
    .cd-unit  { text-align: center; }
    .cd-val   { font-family: var(--mono); font-size: 28px; font-weight: 700; color: var(--text); line-height: 1; }
    .cd-l     { font-size: 10px; color: var(--text-4); margin-top: 3px; font-family: var(--mono); }
    .cd-sep   { font-family: var(--mono); font-size: 24px; font-weight: 700; color: var(--text-4); padding-top: 2px; }

    /* ── Problem cards ── */
    .problem-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; margin-bottom: 40px; }
    .problem-card { background: var(--red-bg); border: 1px solid var(--red-border); border-radius: 12px; padding: 28px; }
    .problem-card-label { font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--red); letter-spacing: .12em; text-transform: uppercase; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
    .problem-card h3 { font-size: 18px; font-weight: 700; color: var(--text); letter-spacing: -.02em; margin-bottom: 8px; line-height: 1.3; }
    .problem-card p  { font-size: 13px; color: var(--text-3); line-height: 1.65; margin: 0; }
    .problem-card p strong { color: var(--text-2); }
    @media (max-width: 640px) { .problem-grid { grid-template-columns: 1fr; } }

    /* ── Comparison table ── */
    .comp-wrap { overflow-x: auto; margin: 20px 0; }
    .comp-table { width: 100%; border-collapse: collapse; min-width: 480px; }
    .comp-table th { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-4); padding: 12px 16px; text-align: left; background: rgba(255,255,255,.025); border-bottom: 1px solid var(--border); }
    .comp-table th.bad  { color: var(--red); }
    .comp-table th.good { color: var(--g); }
    .comp-table td { font-size: 13px; color: var(--text-3); padding: 12px 16px; border-bottom: 1px solid var(--border); }
    .comp-table tr:last-child td { border-bottom: none; }
    .comp-table .win  { color: var(--g); font-weight: 600; }
    .comp-table .lose { color: var(--text-4); }
    .comp-table tr:hover td { background: rgba(255,255,255,.02); }
    .comp-table .highlight-row td { background: rgba(0,200,100,.04); border-top: 1px solid var(--g-border); }
    .comp-table .highlight-row td:first-child { font-weight: 700; color: var(--text); }

    /* ── Live Ledger ── */
    .ledger-wrap { background: rgba(0,0,0,.4); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; font-family: var(--mono); }
    .ledger-header { display: grid; grid-template-columns: 1fr 80px 120px 120px 100px; padding: 12px 24px; background: rgba(255,255,255,.025); border-bottom: 1px solid var(--border); font-size: 9px; font-weight: 700; color: var(--text-4); letter-spacing: .12em; text-transform: uppercase; }
    .ledger-row { display: grid; grid-template-columns: 1fr 80px 120px 120px 100px; padding: 13px 24px; border-bottom: 1px solid rgba(255,255,255,.03); font-size: 11px; color: var(--text-4); align-items: center; transition: background .2s; }
    .ledger-row:last-child { border-bottom: none; }
    .ledger-row:hover { background: rgba(255,255,255,.02); }
    .ledger-row .order-id    { color: var(--text-2); font-weight: 700; }
    .ledger-row .latency     { color: var(--g); font-size: 10px; }
    .ledger-row .stock-change{ color: var(--red); font-weight: 700; }
    @media (max-width: 640px) {
      .ledger-header, .ledger-row { grid-template-columns: 1fr 70px 100px; }
      .ledger-header span:nth-child(4), .ledger-row span:nth-child(4),
      .ledger-header span:nth-child(5), .ledger-row span:nth-child(5) { display: none; }
    }

    /* ── Step cards ── */
    .step-cards { display: flex; flex-direction: column; gap: 12px; margin: 20px 0; }
    .step-card  { background: var(--bg-3); border: 1px solid var(--border); border-radius: 10px; padding: 20px 20px 20px 24px; display: flex; gap: 16px; align-items: flex-start; }
    .step-num   { width: 28px; height: 28px; min-width: 28px; border-radius: 50%; background: rgba(0,200,100,.1); border: 1px solid rgba(0,200,100,.25); display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--g); flex-shrink: 0; }
    .step-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 4px; line-height: 1.3; }
    .step-desc  { font-size: 13px; color: var(--text-3); line-height: 1.65; }
    .step-tool  { font-family: var(--mono); font-size: 10px; color: var(--text-4); background: rgba(255,255,255,.03); border: 1px solid var(--border); padding: 3px 8px; border-radius: 3px; display: inline-block; margin-top: 7px; }

    /* ── Callout ── */
    .callout { background: var(--bg-3); border: 1px solid var(--border-2); border-radius: 10px; padding: 22px 22px 22px 26px; margin: 24px 0; border-left: 3px solid var(--g); text-align: left; }
    .callout.warn { border-left-color: var(--amber); background: rgba(252,211,77,.04); }
    .callout.info { border-left-color: var(--sky);   background: rgba(125,211,252,.04); }
    .callout-label { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: var(--g); margin-bottom: 6px; }
    .callout.warn .callout-label { color: var(--amber); }
    .callout.info .callout-label { color: var(--sky); }
    .callout p { font-size: 14px; color: var(--text-2); line-height: 1.7; margin: 0; }
    .callout p strong { color: var(--text); }
    .callout p a { color: var(--g); text-decoration: underline; }

    /* ── Section CTA ── */
    .section-cta { background: rgba(0,200,100,.06); border: 1.5px solid rgba(0,200,100,.2); border-radius: 10px; padding: 24px 28px; margin: 32px 0; display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
    .section-cta-left h4 { font-weight: 700; font-size: 16px; color: var(--text); margin-bottom: 4px; line-height: 1.3; }
    .section-cta-left p  { font-size: 13px; color: var(--text-3); margin: 0; }
    @media (max-width: 600px) { .section-cta { flex-direction: column; } .section-cta .btn, .section-cta .btn-sm { width: 100%; justify-content: center; } }

    /* ── Body text ── */
    .body-text { max-width: 760px; margin: 0 auto; }
    .body-text p { font-size: 15px; color: var(--text-3); line-height: 1.8; margin-bottom: 18px; text-align: left; }
    .body-text p strong { color: var(--text-2); font-weight: 600; }
    .body-text p a { color: var(--g); text-decoration: underline; }
    .body-text h3 { font-weight: 700; font-size: clamp(18px,2.5vw,22px); color: var(--text-2); letter-spacing: -.02em; line-height: 1.15; margin: 32px 0 12px; text-align: left; }

    /* ── Key facts (GEO-optimised) ── */
    .key-facts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 12px; margin: 24px 0; }
    .key-fact { background: var(--bg-3); border: 1px solid var(--border); border-radius: 8px; padding: 16px 18px; }
    .key-fact-q { font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--text-4); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 6px; }
    .key-fact-a { font-size: 13px; color: var(--text-2); line-height: 1.55; }
    .key-fact-a strong { color: var(--g); font-weight: 700; }

    /* ── Profile cards ── */
    .profiles-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; }
    .profile-card  { background: rgba(255,255,255,.02); border: 1.5px solid var(--border); border-radius: 12px; padding: 28px; transition: border-color .2s, transform .2s; }
    .profile-card:hover { border-color: var(--g-border); transform: translateY(-3px); }
    .profile-icon  { font-size: 28px; margin-bottom: 12px; display: block; }
    .profile-title { font-size: 17px; font-weight: 700; color: var(--text); letter-spacing: -.02em; margin-bottom: 8px; }
    .profile-desc  { font-size: 13px; color: var(--text-4); line-height: 1.6; }
    @media (max-width: 600px) { .profiles-grid { grid-template-columns: 1fr; } }

    /* ── Cross-links ── */
    .crosslink-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 40px; }
    .crosslink-card { background: var(--bg-3); border: 1.5px solid var(--border); border-radius: 12px; padding: 28px; text-decoration: none; display: flex; flex-direction: column; transition: border-color .2s, transform .2s; }
    .crosslink-card:hover { border-color: var(--g-border); transform: translateY(-4px); }
    .crosslink-card.sky:hover    { border-color: var(--sky-border); }
    .crosslink-card.vio:hover    { border-color: var(--vio-border); }
    .crosslink-card.tiktok:hover { border-color: rgba(255,0,80,.25); }
    .crosslink-name  { font-weight: 900; font-size: 20px; color: var(--text); letter-spacing: -.02em; margin: 10px 0 6px; }
    .crosslink-desc  { font-size: 13px; color: var(--text-3); line-height: 1.6; margin-bottom: 14px; flex: 1; }
    .crosslink-save  { font-family: var(--mono); font-size: 12px; font-weight: 700; }
    @media (max-width: 600px) { .crosslink-grid { grid-template-columns: 1fr; } }

    /* ── FAQ ── */
