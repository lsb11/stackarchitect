  <script>
    (function () {
      // ── Nav scroll behaviour ──────────────────────────────────────
      const header = document.querySelector('.product-terminal-bar');
      window.addEventListener('scroll', () => {
        if (header) header.classList.toggle('scrolled', window.scrollY > 50);
      }, { passive: true });

      // ── Mobile dropdown toggle ───────────────────────────────────
      document.querySelectorAll('.dropdown > .product-link').forEach((link) => {
        link.addEventListener('click', (e) => {
          if (window.innerWidth <= 850) {
            e.preventDefault();
            const expanded = link.getAttribute('aria-expanded') === 'true';
            link.setAttribute('aria-expanded', String(!expanded));
            link.parentElement.classList.toggle('active');
          }
        });
      });

      // Inject active dropdown CSS
      const s = document.createElement('style');
      s.textContent = '.dropdown.active .dropdown-menu { display: flex; }';
      document.head.appendChild(s);

      // Close dropdowns on outside click
      document.addEventListener('click', (e) => {
        if (!e.target.closest('.dropdown')) {
          document.querySelectorAll('.dropdown').forEach((d) => {
            d.classList.remove('active');
            const link = d.querySelector('.product-link');
            if (link) link.setAttribute('aria-expanded', 'false');
          });
        }
      });

      // ── Dynamic copyright ────────────────────────────────────────
      const cr = document.getElementById('ss-copyright');
      if (cr) cr.textContent = `© ${new Date().getFullYear()} STACK_ARCHITECT // STOCKY_SWAP // INVENTORY_LIVE`;

      // ── Countdown to August 31 2026 ──────────────────────────────
      function updateCountdown() {
        const target = new Date('2026-08-31T23:59:59Z');
        const now    = new Date();
        const diff   = target - now;

        if (diff <= 0) {
          const el = document.getElementById('stocky-countdown');
          if (el) el.textContent = 'DEADLINE PASSED';
          ['cd-d', 'cd-h', 'cd-m'].forEach((id) => {
            const e = document.getElementById(id);
            if (e) e.textContent = '0';
          });
          return;
        }

        const days  = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const mins  = Math.floor((diff % 3600000) / 60000);

        const cd = document.getElementById('stocky-countdown');
        if (cd) cd.textContent = `${days} days ${hours}hrs remaining`;

        const d = document.getElementById('cd-d'); if (d) d.textContent = days;
        const h = document.getElementById('cd-h'); if (h) h.textContent = String(hours).padStart(2, '0');
        const m = document.getElementById('cd-m'); if (m) m.textContent = String(mins).padStart(2, '0');
      }

      updateCountdown();
      setInterval(updateCountdown, 30000);

      // ── Intersection Observer: fade-in sections ──────────────────
      if ('IntersectionObserver' in window) {
        const fadeEls = document.querySelectorAll('.section, .section-alt');
        const style = document.createElement('style');
        style.textContent = `
          .section, .section-alt {
            opacity: 0;
            transform: translateY(18px);
            transition: opacity .55s ease, transform .55s ease;
          }
          .section.visible, .section-alt.visible {
            opacity: 1;
            transform: none;
          }
        `;
        document.head.appendChild(style);

        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08 });

        fadeEls.forEach((el) => io.observe(el));
      }

      // ── Prefetch internal links on hover ─────────────────────────
      // (Astro handles this natively with prefetch:hover — added as JS fallback)
      document.querySelectorAll('a[href^="https://stackarchitect.xyz"]').forEach((link) => {
        link.addEventListener('mouseenter', () => {
          const lp = document.createElement('link');
          lp.rel  = 'prefetch';
          lp.href = link.href;
          document.head.appendChild(lp);
        }, { once: true, passive: true });
      });

    })();
  </script>


