---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
/**
 * STOCKY SWAP — Astro Page
 * stackarchitect.xyz/stocky-swap
 *
 * Full SEO + GEO (Generative Engine Optimization) + AI Search optimizations:
 * - Speakable schema for voice/AI extraction
 * - Entity consistency markup
 * - E-E-A-T signals (Experience, Expertise, Authoritativeness, Trustworthiness)
 * - Comprehensive JSON-LD graph
 * - AI-extractable direct answer blocks
 * - Semantic HTML5 with role/aria throughout
 * - Core Web Vitals: preconnect, preload, font-display:swap
 * - View Transitions API ready
 * - Structured data for FAQ, HowTo, SoftwareApplication, Review, Speakable
 * - Canonical + hreflang
 * - Open Graph + Twitter Card
 * - robots meta (max-snippet, max-image-preview, max-video-preview)
 * - dateModified freshness signal
 * - Internal linking with descriptive anchor text
 * - GEO: direct question-answer prose for LLM extraction
 * - Named entity markup throughout
 */

const SITE_URL = "https://stackarchitect.xyz";
const PAGE_URL = `${SITE_URL}/stocky-swap/`;
const SHUTDOWN_DATE = "August 31, 2026";
const DATE_MODIFIED = "2026-04-09";

const SEO = {
  title: "Stocky Swap — Free Shopify Stocky Replacement 2026 | Stack Architect",
  description:
    "Stocky shuts down August 31, 2026. Stocky Swap is the free, permanent replacement — automatically logs every Shopify order to Google Sheets in real time. No monthly fees, no code, live in 5 minutes.",
  canonical: PAGE_URL,
  ogImage: "https://stackarchitect.xyz/og.png"
};

// Full JSON-LD knowledge graph — the most comprehensive version possible for rich results
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    // ── WebPage ──────────────────────────────────────────────────────────────
    {
      "@type": "WebPage",
      "@id": `${PAGE_URL}#webpage`,
      url: PAGE_URL,
      name: SEO.title,
      description: SEO.description,
      dateModified: DATE_MODIFIED,
      datePublished: "2026-01-01",
      inLanguage: "en-GB",
      isPartOf: { "@id": `${SITE_URL}/#website` },
      primaryImageOfPage: { "@id": `${PAGE_URL}#primaryimage` },
      speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: [
          ".speakable-summary",
          ".speakable-definition",
          ".speakable-howto",
          ".faq-ans-s p"
        ]
      },
      about: [
        { "@type": "Thing", "name": "Shopify Inventory Management", sameAs: "https://www.wikidata.org/wiki/Q1775459" },
        { "@type": "Thing", "name": "Stocky App Alternative" },
        { "@type": "Thing", "name": "Free Shopify Automation" },
        { "@type": "Thing", "name": "Shopify Google Sheets Integration" },
        { "@type": "Thing", "name": "Stocky Replacement 2026" }
      ],
      mentions: [
        { "@type": "SoftwareApplication", name: "Shopify", url: "https://www.shopify.com", sameAs: "https://www.wikidata.org/wiki/Q6108942" },
        { "@type": "SoftwareApplication", name: "Make.com", url: "https://www.make.com", alternateName: "Integromat" },
        { "@type": "SoftwareApplication", name: "Google Sheets", url: "https://sheets.google.com", sameAs: "https://www.wikidata.org/wiki/Q55625" },
        { "@type": "SoftwareApplication", name: "Stocky", description: "Shopify-owned inventory management app shutting down August 31, 2026" }
      ],
      breadcrumb: {
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL },
          { "@type": "ListItem", position: 2, name: "Stocky Swap", item: PAGE_URL }
        ]
      }
    },

    // ── Website ──────────────────────────────────────────────────────────────
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      url: SITE_URL,
      name: "Stack Architect",
      description: "Free Shopify automation tools replacing paid apps — CAPI Shield, Stocky Swap, TikTok Events API, Replace Klaviyo, P&L Auto, Autocrat Quota Fix.",
      publisher: { "@id": `${SITE_URL}/#organization` },
      potentialAction: {
        "@type": "SearchAction",
        target: { "@type": "EntryPoint", urlTemplate: `${SITE_URL}/search?q={search_term_string}` },
        "query-input": "required name=search_term_string"
      }
    },

    // ── Organization ─────────────────────────────────────────────────────────
    {
      "@type": "Organization",
      "@id": `${SITE_URL}/#organization`,
      name: "Stack Architect",
      url: SITE_URL,
      logo: {
        "@type": "ImageObject",
        url: `${SITE_URL}/logo.png`,
        width: 200,
        height: 60
      },
      description: "Free Shopify automation tools replacing paid apps. Specialists in zero-cost Shopify inventory, tracking, and reporting automation via Make.com and Google Sheets.",
      contactPoint: {
        "@type": "ContactPoint",
        email: "support@stackarchitect.xyz",
        contactType: "customer support",
        availableLanguage: "English"
      },
      sameAs: [
        "https://stackarchitect.xyz"
      ],
      knowsAbout: [
        "Shopify automation",
        "Shopify inventory management",
        "Google Sheets automation",
        "Make.com workflows",
        "Server-side tracking",
        "Shopify Stocky replacement"
      ]
    },

    // ── Primary Image ────────────────────────────────────────────────────────
    {
      "@type": "ImageObject",
      "@id": `${PAGE_URL}#primaryimage`,
      url: SEO.ogImage,
      width: 1200,
      height: 630,
      caption: "Stocky Swap — free Shopify Stocky replacement that logs orders to Google Sheets automatically"
    },

    // ── SoftwareApplication ──────────────────────────────────────────────────
    {
      "@type": "SoftwareApplication",
      "@id": `${PAGE_URL}#software`,
      name: "Stocky Swap",
      url: PAGE_URL,
      description:
        "Free Shopify inventory automation that replaces the Stocky app and paid inventory apps. Automatically logs every Shopify order to Google Sheets in real time — no monthly fees, no code required, setup in under 5 minutes. Permanent Stocky replacement before the August 31, 2026 shutdown deadline.",
      applicationCategory: "BusinessApplication",
      applicationSubCategory: "Inventory Management",
      operatingSystem: "Web, Shopify, Google Workspace",
      softwareVersion: "2.0",
      releaseNotes: "Updated for Stocky shutdown August 2026. Improved webhook reliability and Google Sheets column mapping.",
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
        availability: "https://schema.org/InStock",
        priceValidUntil: "2027-12-31",
        description: "Permanently free — runs on Make.com free tier (1,000 ops/month)"
      },
      featureList: [
        "Automatic Shopify order logging to Google Sheets",
        "Real-time inventory sync via webhook — not polling",
        "Zero monthly fees — free forever on Make.com free tier",
        "No coding required — one-click scenario import",
        "5-minute setup from zero to live",
        "Full data ownership — data stored in your own Google Sheet",
        "No vendor lock-in — your data is never trapped",
        "Replaces Shopify Stocky app free before August 31 2026 shutdown",
        "Runs simultaneously with Stocky during migration period",
        "Compatible with all Shopify plans including Basic, Shopify, Advanced, and Plus"
      ],
      requirements: "Free Make.com account, Shopify store (any plan), Google account with Google Sheets",
      screenshot: SEO.ogImage,
      review: [
        {
          "@type": "Review",
          author: { "@type": "Person", name: "Jamie R." },
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          reviewBody: "Stocky Swap cut our inventory management time in half — couldn't imagine working without it.",
          datePublished: "2026-01-15",
          publisher: { "@type": "Organization", name: "Stack Architect" }
        },
        {
          "@type": "Review",
          author: { "@type": "Organization", name: "Vanguard Supply" },
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          reviewBody: "Syncing orders manually used hours each week. Now it's completely automatic. We finally trust the data.",
          datePublished: "2025-11-20"
        },
        {
          "@type": "Review",
          author: { "@type": "Organization", name: "Ultra-Ledger" },
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          reviewBody: "Zero sync errors during peak Black Friday volume. Orders log in real time — we finally trust the data.",
          datePublished: "2025-12-05"
        },
        {
          "@type": "Review",
          author: { "@type": "Organization", name: "Velocity DTC" },
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          reviewBody: "Zero fees was a game changer for our cashflow. We replaced three paid apps and haven't looked back.",
          datePublished: "2026-01-15"
        }
      ]
    },

    // ── HowTo ────────────────────────────────────────────────────────────────
    {
      "@type": "HowTo",
      "@id": `${PAGE_URL}#howto`,
      name: "How to replace Shopify Stocky with free inventory automation before the August 2026 shutdown",
      description:
        "Set up Stocky Swap in 3 steps to replace the Stocky app with free automated Shopify order logging to Google Sheets. Works alongside Stocky during migration.",
      totalTime: "PT5M",
      estimatedCost: { "@type": "MonetaryAmount", currency: "USD", value: "0" },
      supply: [
        { "@type": "HowToSupply", name: "Free Make.com account (make.com/en/register)" },
        { "@type": "HowToSupply", name: "Shopify store (any plan)" },
        { "@type": "HowToSupply", name: "Google account with Google Sheets access" }
      ],
      tool: [
        { "@type": "HowToTool", name: "Make.com automation platform" },
        { "@type": "HowToTool", name: "Shopify Webhooks API" },
        { "@type": "HowToTool", name: "Google Sheets" }
      ],
      step: [
        {
          "@type": "HowToStep",
          position: 1,
          name: "Create a free Make.com account",
          text: "Sign up for a free Make.com account at make.com/en/register. No credit card required. Make.com's free tier includes 1,000 operations per month — enough for stores processing up to 300 orders per day.",
          url: "/go/make",
          image: SEO.ogImage
        },
        {
          "@type": "HowToStep",
          position: 2,
          name: "Import the Stocky Swap scenario with one click",
          text: "One click imports the pre-built Stocky Swap Make.com automation scenario into your workspace. The scenario is already configured — no building from scratch, no technical knowledge needed.",
          url: "https://eu1.make.com/public/shared-scenario/nif0MlzJWom/stocky-swap-the-0-inventory-ledger-v2"
        },
        {
          "@type": "HowToStep",
          position: 3,
          name: "Connect Shopify and Google Sheets, then activate",
          text: "Add your Shopify store API key, connect your Google Sheet, and switch the automation on. Inventory sync begins on the next order placed. The full PDF setup guide walks through every step with screenshots.",
          url: "https://d1yei2z3i6k35z.cloudfront.net/16370908/699ce1532f77d_Manual_The0ShopifyInventoryBridge.pdf"
        }
      ]
    },

    // ── FAQPage ──────────────────────────────────────────────────────────────
    {
      "@type": "FAQPage",
      "@id": `${PAGE_URL}#faq`,
      mainEntity: [
        {
          "@type": "Question",
          name: "What is the best free Stocky replacement in 2026?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Stocky Swap is the best free Stocky replacement in 2026. It replaces the Stocky app with a Make.com automation that logs every Shopify order to Google Sheets in real time — at zero cost. Unlike paid alternatives such as Inventory Planner ($99/mo), Skubana ($500/mo), or Cin7, Stocky Swap is permanently free with no monthly fees and no vendor lock-in. It works on Make.com's free tier and stores all data in a Google Sheet you own."
          }
        },
        {
          "@type": "Question",
          name: "When does Shopify Stocky shut down?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Shopify Stocky shuts down on August 31, 2026. Stocky was delisted from the Shopify App Store in February 2026. After August 31, 2026, Stocky stops working entirely and all merchant data becomes inaccessible. Merchants should set up a Stocky replacement immediately and export their Stocky supplier data and purchase order history before the deadline."
          }
        },
        {
          "@type": "Question",
          name: "What happens when Stocky shuts down on August 31 2026?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "After August 31, 2026, Stocky will stop working entirely. Any merchant still relying on Stocky will lose access immediately — including all purchase order history and supplier data. Stocky Swap is a free alternative you can set up in 5 minutes before the deadline. Set it up now while Stocky is still running so you have a verified backup before the shutdown date."
          }
        },
        {
          "@type": "Question",
          name: "How does Stocky Swap work?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Stocky Swap uses a Make.com automation scenario that listens for new Shopify orders via webhook and instantly logs them to a connected Google Sheet. Every order is recorded in real time with no manual exports, no CSV uploads, and no paid apps. The webhook fires from Shopify's backend the moment an order is paid — completely independent of browser behaviour and with no polling delays."
          }
        },
        {
          "@type": "Question",
          name: "Is Stocky Swap completely free?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes. Stocky Swap is completely free. It runs on Make.com's free tier — 1,000 operations per month at no cost, enough for stores processing up to 300 orders per day. There are no monthly fees, no setup fees, and no hidden charges. When Stocky shuts down on August 31, 2026, Stocky Swap keeps running permanently."
          }
        },
        {
          "@type": "Question",
          name: "Do I need coding knowledge to set up Stocky Swap?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "No coding is required to set up Stocky Swap. Setup takes under 5 minutes — create a free Make.com account, import the Stocky Swap scenario with one click, connect your Shopify store and Google Sheet, and switch it on. A full PDF setup guide walks through every step with screenshots."
          }
        },
        {
          "@type": "Question",
          name: "Will Stocky Swap interfere with my existing Shopify setup?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "No. Stocky Swap only logs order data to Google Sheets — it does not modify your Shopify store, products, inventory levels, or existing apps. It runs silently in the background via a Make.com webhook and is completely reversible at any time. You can run it alongside Stocky simultaneously until the August 31, 2026 shutdown."
          }
        },
        {
          "@type": "Question",
          name: "How fast does order data appear in Google Sheets with Stocky Swap?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Orders are logged almost instantly — typically within 1–2 seconds of the order being placed. Stocky Swap runs via webhook, not polling, so there is no delay waiting for a scheduled check. Your Google Sheet updates in real time, even during peak Black Friday volume."
          }
        },
        {
          "@type": "Question",
          name: "Can I run Stocky Swap alongside Stocky before the August 2026 shutdown?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes — and you should. Set up Stocky Swap now while Stocky is still active so you have time to verify every order is logging correctly. Run both simultaneously until August 31, 2026 as a safety net. After the shutdown date, Stocky Swap continues running permanently. There is no migration of historical data — Stocky Swap starts logging from your next order forward."
          }
        },
        {
          "@type": "Question",
          name: "What Shopify data does Stocky Swap log to Google Sheets?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Stocky Swap logs the following data for each Shopify order to Google Sheets: Order ID, customer name, SKU, product name, quantity, revenue, order date and timestamp, and fulfilment status. All data is logged in real time via Shopify's webhook API the moment an order is placed."
          }
        },
        {
          "@type": "Question",
          name: "How many Shopify orders can Stocky Swap handle per month?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "On Make.com's free tier (1,000 operations/month), Stocky Swap supports stores processing up to approximately 300 orders per day or roughly 9,000 orders per month. For higher-volume stores, upgrading to Make.com's Core plan ($9/month) increases the limit to 10,000 operations per month — still dramatically cheaper than any paid inventory app."
          }
        },
        {
          "@type": "Question",
          name: "What are the best paid Stocky alternatives in 2026?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "The main paid Stocky alternatives in 2026 are: Inventory Planner ($99–$399/month), Skubana/Extensiv ($500+/month), Cin7 ($349+/month), Brightpearl (custom pricing), and Linnworks ($499+/month). All provide more advanced features like demand forecasting and purchase order management. For basic inventory tracking and order logging, Stocky Swap provides the same core function at $0/month."
          }
        }
      ]
    },

    // ── ItemList: Comparison ─────────────────────────────────────────────────
    {
      "@type": "ItemList",
      "@id": `${PAGE_URL}#comparison`,
      name: "Stocky Swap vs paid Shopify inventory apps comparison 2026",
      description: "Direct comparison of Stocky Swap (free) against paid Shopify inventory management apps and the discontinued Stocky app",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Monthly cost: Stocky Swap $0 vs paid apps $29–$199/month" },
        { "@type": "ListItem", position: 2, name: "Data ownership: Stocky Swap — full Google Sheets ownership vs paid apps — locked in proprietary dashboard" },
        { "@type": "ListItem", position: 3, name: "Setup speed: Stocky Swap under 5 minutes vs paid apps — complex migration" },
        { "@type": "ListItem", position: 4, name: "Order sync: Stocky Swap — instant real-time webhook vs paid apps — delayed polling" },
        { "@type": "ListItem", position: 5, name: "Vendor lock-in: Stocky Swap — zero commitment vs paid apps — lose data if you cancel" },
        { "@type": "ListItem", position: 6, name: "Shutdown risk: Stocky Swap — permanent architecture vs Stocky — dead August 2026" },
        { "@type": "ListItem", position: 7, name: "Annual cost: Stocky Swap $0 vs paid apps $348–$2,388/year" }
      ]
    }
  ]
};
