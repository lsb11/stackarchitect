---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const schemas = [{"@context":"https://schema.org","@type":"WebApplication","name":"GA4 vs Shopify Revenue Reconciler — Free Attribution Discrepancy Calculator","url":"https://stackarchitect.xyz/ga4-vs-shopify-revenue-reconciler/","description":"Calculate the gap between your GA4 reported revenue and actual Shopify revenue. Understand why the numbers differ and what decisions are safe to make based on each data source.","applicationCategory":"BusinessApplication","operatingSystem":"Any","offers":{"@type":"Offer","price":"0","priceCurrency":"GBP"},"provider":{"@type":"Organization","name":"Stack Architect","url":"https://stackarchitect.xyz"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is an acceptable GA4 vs Shopify revenue discrepancy?","acceptedAnswer":{"@type":"Answer","text":"A gap of 5–15% with GA4 showing less than Shopify is considered normal and acceptable for operational decisions. Use Shopify as your source of truth for actual revenue and GA4 for relative channel performance comparisons. If your GA4 consistently shows 85–95% of Shopify revenue, that's a healthy tracking setup."}},{"@type":"Question","name":"How do I fix GA4 under-reporting on Shopify?","acceptedAnswer":{"@type":"Answer","text":"The most effective fixes are: (1) verify the GA4 purchase event is firing correctly in DebugView; (2) check for blocked scripts using browser developer tools on your order confirmation page; (3) consider server-side GA4 measurement protocol events to capture conversions that browser tracking misses; (4) ensure your GA4 configuration tag fires on all pages including the order status page."}}]},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://stackarchitect.xyz"},{"@type":"ListItem","position":2,"name":"Tools","item":"https://stackarchitect.xyz/tools/"},{"@type":"ListItem","position":3,"name":"GA4 vs Shopify Revenue Reconciler — Free Attribution Discrepancy Calculator","item":"https://stackarchitect.xyz/ga4-vs-shopify-revenue-reconciler/"}]}];

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools' },
  { label: 'GA4 vs Shopify Revenue Reconciler — Free Attribution Discrepancy Calculator' },
];
---

<Base
  title="GA4 vs Shopify Revenue Reconciler — Free Attribution Discrepancy Calculator | Stack Architect"
  description="Calculate the gap between your GA4 reported revenue and actual Shopify revenue. Understand why the numbers differ and what decisions are safe to make based on each data source."
  canonical="https://stackarchitect.xyz/ga4-vs-shopify-revenue-reconciler/"
  schema={schemas}
  breadcrumb={breadcrumb}
>
  <Nav slot="header" />

  <main class="flex-1">
    <div id="reading-progress"></div>
    
<style>
  .tool-hero{padding:48px 24px 32px;background:#000;border-bottom:1px solid #1f1f1f;}
  .tool-hero-inner{max-width:860px;margin:0 auto;}
  .tool-badge{display:inline-flex;align-items:center;gap:6px;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:4px 12px;border:1px solid rgba(74,222,128,.3);color:#4ade80;background:rgba(74,222,128,.06);margin-bottom:18px;}
  .tool-badge .dot{width:6px;height:6px;border-radius:50%;background:#4ade80;animation:dp 2s infinite;}
  @keyframes dp{0%,100%{opacity:1;}50%{opacity:.3;}}
  .tool-hero h1{font-size:clamp(22px,4vw,38px);font-weight:900;color:#fff;letter-spacing:-.03em;line-height:1.05;margin-bottom:12px;}
  .tool-hero h1 .green{color:#4ade80;}
  .tool-hero-desc{font-size:14px;color:#a1a1aa;line-height:1.75;max-width:600px;margin-bottom:20px;}
  .tool-trust{display:flex;flex-wrap:wrap;gap:16px;}
  .tool-trust span{font-size:11px;color:#52525b;display:flex;align-items:center;gap:5px;}
  .tool-trust span::before{content:'✓';color:#4ade80;font-weight:700;}

  .calc-section{padding:40px 24px;background:#0a0a0a;border-bottom:1px solid #1f1f1f;}
  .calc-inner{max-width:860px;margin:0 auto;}
  .calc-card{border:1px solid #1f1f1f;background:#000;padding:32px;}
  .calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;}
  @media(max-width:600px){.calc-grid{grid-template-columns:1fr;}}
  .calc-field{display:flex;flex-direction:column;gap:6px;}
  .calc-field label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#52525b;}
  .calc-field input,.calc-field select{background:#0a0a0a;border:1px solid #1f1f1f;color:#fff;font-family:inherit;font-size:13px;padding:10px 14px;outline:none;transition:border-color .2s;width:100%;}
  .calc-field input:focus,.calc-field select:focus{border-color:#4ade80;}
  .calc-field input::placeholder{color:#3f3f46;}
  .calc-btn{width:100%;background:#4ade80;color:#000;font-family:inherit;font-size:12px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;padding:14px;border:none;cursor:pointer;transition:background .2s;margin-top:8px;}
  .calc-btn:hover{background:#22c55e;}
  .calc-result{display:none;margin-top:24px;border:1px solid #1f1f1f;background:#0a0a0a;padding:24px;}
  .calc-result.show{display:block;}
  .result-label{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#52525b;margin-bottom:6px;}
  .result-value{font-size:36px;font-weight:900;color:#4ade80;line-height:1;letter-spacing:-.03em;}
  .result-sub{font-size:12px;color:#52525b;margin-top:6px;line-height:1.6;}
  .result-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;margin-bottom:20px;}
  .result-cell{background:#000;border:1px solid #1f1f1f;padding:16px;}
  .result-insight{font-size:12px;color:#a1a1aa;line-height:1.7;border-top:1px solid #1f1f1f;padding-top:16px;margin-top:16px;}
  .result-insight strong{color:#fff;}
  .result-cta{display:inline-block;margin-top:16px;font-size:11px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;color:#000;background:#4ade80;padding:10px 20px;text-decoration:none;transition:background .2s;}
  .result-cta:hover{background:#22c55e;}
  .result-warn{border-left:3px solid #4ade80;padding-left:16px;margin-top:16px;}

  .aff-block{margin:24px 0;border:1px solid rgba(74,222,128,.2);background:rgba(74,222,128,.04);padding:20px 24px;display:flex;align-items:flex-start;justify-content:space-between;gap:20px;flex-wrap:wrap;}
  .aff-block-text{flex:1;}
  .aff-block-label{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:#52525b;margin-bottom:6px;}
  .aff-block-title{font-size:13px;font-weight:700;color:#fff;margin-bottom:4px;}
  .aff-block-desc{font-size:11px;color:#71717a;line-height:1.6;}
  .aff-block-link{flex-shrink:0;display:inline-flex;align-items:center;font-size:10px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;color:#4ade80;border:1px solid rgba(74,222,128,.4);padding:8px 16px;text-decoration:none;transition:all .2s;white-space:nowrap;}
  .aff-block-link:hover{background:#4ade80;color:#000;}
  .aff-disclosure{font-size:9px;color:#3f3f46;margin-top:8px;}

  .editorial{padding:48px 24px;background:#000;border-bottom:1px solid #1f1f1f;}
  .editorial-inner{max-width:720px;margin:0 auto;}
  .editorial h2{font-size:clamp(18px,3vw,26px);font-weight:900;color:#fff;letter-spacing:-.03em;margin:36px 0 12px;line-height:1.2;}
  .editorial h2:first-child{margin-top:0;}
  .editorial p{font-size:13px;color:#a1a1aa;line-height:1.85;margin-bottom:16px;}
  .editorial strong{color:#e4e4e7;}
  .editorial a{color:#4ade80;text-decoration:underline;}
  .editorial ul{list-style:none;padding:0;margin:0 0 16px;}
  .editorial ul li{font-size:13px;color:#a1a1aa;line-height:1.75;padding:6px 0 6px 20px;position:relative;border-bottom:1px solid #0a0a0a;}
  .editorial ul li::before{content:'→';position:absolute;left:0;color:#4ade80;font-size:11px;}

  .faq-section{padding:48px 24px;background:#0a0a0a;border-bottom:1px solid #1f1f1f;}
  .faq-inner{max-width:720px;margin:0 auto;}
  .faq-heading{font-size:clamp(18px,3vw,24px);font-weight:900;color:#fff;letter-spacing:-.03em;margin-bottom:28px;}
  .faq-item{border:1px solid #1f1f1f;margin-bottom:8px;background:#000;}
  .faq-item summary{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;list-style:none;font-size:12px;font-weight:700;color:#a1a1aa;letter-spacing:.02em;gap:16px;}
  .faq-item summary::-webkit-details-marker{display:none;}
  .faq-item[open] summary{color:#fff;border-bottom:1px solid #1f1f1f;}
  .faq-item[open]{border-color:rgba(74,222,128,.3);}
  .faq-arrow{flex-shrink:0;font-size:10px;color:#52525b;transition:transform .2s;}
  .faq-item[open] .faq-arrow{transform:rotate(180deg);color:#4ade80;}
  .faq-answer{padding:16px 20px;font-size:12px;color:#71717a;line-height:1.8;}
  .faq-answer a{color:#4ade80;}

  .cta-strip-tool{padding:40px 24px;background:#0a0a0a;border-top:1px solid #1f1f1f;text-align:center;}
  .cta-strip-tool h2{font-size:clamp(16px,3vw,22px);font-weight:900;color:#fff;letter-spacing:-.03em;margin-bottom:8px;}
  .cta-strip-tool p{font-size:12px;color:#52525b;margin-bottom:20px;}
  .cta-strip-tool a{display:inline-block;background:#4ade80;color:#000;font-size:11px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;padding:14px 28px;text-decoration:none;transition:background .2s;}
  .cta-strip-tool a:hover{background:#22c55e;}
  #reading-progress{position:fixed;top:0;left:0;width:0;height:2px;background:#4ade80;z-index:9999;transition:width .1s;}
</style>


  <section class="tool-hero">
    <div class="tool-hero-inner">
      <div class="tool-badge"><span class="dot"></span>FREE TOOL // GA4 Attribution</div>
      <h1>GA4 vs Shopify <span class="green">Revenue Reconciler</span></h1>
      <p class="tool-hero-desc">Calculate the gap between your GA4 reported revenue and actual Shopify revenue. Understand why the numbers differ and what decisions are safe to make based on each data source.</p>
      <div class="tool-trust"><span>Free forever</span><span>No account required</span><span>Instant results</span></div>
    </div>
  </section>
  <section class="calc-section"><div class="calc-inner"><div class="calc-card">
    <div style="font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#52525b;margin-bottom:20px;">// GA4_RECONCILIATION_CALCULATOR</div>
    <div class="calc-grid">
      <div class="calc-field"><label>Shopify revenue (30 days) £/$</label><input type="number" id="ga-shopify" placeholder="e.g. 45000" /></div>
      <div class="calc-field"><label>GA4 reported revenue (same period) £/$</label><input type="number" id="ga-ga4" placeholder="e.g. 38000" /></div>
      <div class="calc-field"><label>Total sessions (GA4, same period)</label><input type="number" id="ga-sessions" placeholder="e.g. 12000" /></div>
      <div class="calc-field"><label>Is GA4 purchase event firing correctly?</label><select id="ga-pixel"><option value="yes">Yes — verified in DebugView</option><option value="unsure">Unsure</option><option value="issues">Known issues</option></select></div>
    </div>
    <button class="calc-btn" onclick="calcGA4()">RECONCILE MY REVENUE DATA →</button>
    <div class="calc-result" id="ga-result">
      <div class="result-grid">
        <div class="result-cell"><div class="result-label">GA4 vs Shopify Gap</div><div class="result-value" id="ga-gap">--</div><div class="result-sub" id="ga-gap-dir">--</div></div>
        <div class="result-cell"><div class="result-label">Revenue Per Session (GA4)</div><div class="result-value" id="ga-rps" style="font-size:22px;">--</div><div class="result-sub">GA4 reported figure</div></div>
        <div class="result-cell"><div class="result-label">True Revenue Per Session</div><div class="result-value" id="ga-rps-true" style="font-size:22px;color:#4ade80;">--</div><div class="result-sub">Based on Shopify data</div></div>
      </div>
      <div class="result-insight" id="ga-insight"></div>
    </div>
  </div>
  
  <div class="aff-block">
    <div class="aff-block-text">
      <div class="aff-block-label">Recommended tool</div>
      <div class="aff-block-title">CAPI Shield — Free Server-Side Tracking</div>
      <div class="aff-block-desc">Improve GA4 data accuracy by ensuring conversion events fire server-side, reducing the gap caused by ad blockers and iOS restrictions.</div>
    </div>
    <div>
      <a href="/go/make" target="_blank" rel="noopener sponsored" class="aff-block-link">Deploy CAPI Shield Free →</a>
      <div class="aff-disclosure">Affiliate link — costs you nothing extra</div>
    </div>
  </div></div></section>
  <section class="editorial"><div class="editorial-inner"><h2>Why GA4 and Shopify Never Show the Same Revenue</h2>
  <p>A common point of confusion for Shopify store owners is that GA4 and Shopify never show identical revenue figures — and this is expected, not a sign of a problem. The two systems measure fundamentally different things. Shopify records actual orders as they are paid and fulfilled. GA4 records purchase events as they fire in a browser — which is dependent on the customer's browser accepting JavaScript, not blocking analytics tags, and having a complete session attributed to a source.</p>
  <p><strong>Normal GA4 under-reporting range: 5–15%.</strong> This is expected and acceptable for decision-making purposes. The discrepancy is caused by: iOS users with ad blockers, Safari's ITP preventing complete session tracking, orders placed on browsers where GA4 couldn't fire (some corporate networks block analytics), and orders that happen after a session timeout creates attribution gaps.</p>
  <h2>When the Gap Signals a Real Problem</h2>
  <p>A gap exceeding 20% in either direction warrants investigation. Over-reporting by 20%+ usually indicates duplicate purchase events firing — common when a checkout confirmation page is refreshed or when both the Shopify GA4 channel and a manual gtag.js implementation are both firing the purchase event. Under-reporting by 20%+ usually indicates a broken implementation or significant tracking loss that is affecting your ability to accurately attribute revenue to acquisition channels.</p></div></section>
  
  <section class="faq-section" itemscope itemtype="https://schema.org/FAQPage">
    <div class="faq-inner">
      <h2 class="faq-heading">// COMMON_QUESTIONS</h2>
      
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">What is an acceptable GA4 vs Shopify revenue discrepancy?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">A gap of 5–15% with GA4 showing less than Shopify is considered normal and acceptable for operational decisions. Use Shopify as your source of truth for actual revenue and GA4 for relative channel performance comparisons. If your GA4 consistently shows 85–95% of Shopify revenue, that's a healthy tracking setup.</p>
      </div>
    </details>
    <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
      <summary><span itemprop="name">How do I fix GA4 under-reporting on Shopify?</span><span class="faq-arrow">▼</span></summary>
      <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
        <p itemprop="text">The most effective fixes are: (1) verify the GA4 purchase event is firing correctly in DebugView; (2) check for blocked scripts using browser developer tools on your order confirmation page; (3) consider server-side GA4 measurement protocol events to capture conversions that browser tracking misses; (4) ensure your GA4 configuration tag fires on all pages including the order status page.</p>
      </div>
    </details>
    </div>
  </section>
  <section class="cta-strip-tool"><h2>Fix Your GA4 Tracking</h2><p>Free tool. No account. Instant results.</p><a href="/capi-shield">Fix Your GA4 Tracking →</a></section>
  </main>

  <Footer />
</Base>

<script>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      bar.style.width = Math.min(pct, 100) + '%';
    }, { passive: true });
  }

function calcGA4() {
    const shopify = parseFloat(document.getElementById('ga-shopify').value) || 0;
    const ga4 = parseFloat(document.getElementById('ga-ga4').value) || 0;
    const sessions = parseInt(document.getElementById('ga-sessions').value) || 0;
    const pixel = document.getElementById('ga-pixel').value;
    if (!shopify || !ga4) return;
    const gap = ((ga4 - shopify) / shopify * 100).toFixed(1);
    const gapAbs = Math.abs(gap);
    const rpsGA4 = sessions > 0 ? (ga4 / sessions).toFixed(2) : '--';
    const rpsTrue = sessions > 0 ? (shopify / sessions).toFixed(2) : '--';
    document.getElementById('ga-gap').textContent = (gap >= 0 ? '+' : '') + gap + '%';
    document.getElementById('ga-gap').style.color = Math.abs(parseFloat(gap)) < 10 ? '#4ade80' : parseFloat(gap) > 0 ? '#fbbf24' : '#f87171';
    document.getElementById('ga-gap-dir').textContent = parseFloat(gap) > 0 ? 'GA4 over-reporting' : 'GA4 under-reporting';
    document.getElementById('ga-rps').textContent = '£' + rpsGA4;
    document.getElementById('ga-rps-true').textContent = '£' + rpsTrue;
    let insight = '';
    if (parseFloat(gap) < -15) {
      insight = '<strong>Significant GA4 under-reporting.</strong> GA4 is missing ' + Math.abs(gap) + '% of revenue. Likely causes: GA4 purchase event not firing on all orders, ad blocker blocking gtag, or Safari ITP preventing session attribution. Verify in GA4 DebugView. ';
    } else if (parseFloat(gap) > 10) {
      insight = '<strong>GA4 is over-reporting.</strong> Possible cause: GA4 purchase event firing multiple times per order (deduplication issue), or test/admin purchases not excluded. Check for duplicate purchase events in DebugView. ';
    } else {
      insight = 'Gap of ' + gapAbs + '% is within normal tolerance (under 10%). Small discrepancies are expected due to currency conversion, order cancellations processed after the measurement period, and session attribution differences. ';
    }
    if (pixel === 'unsure' || pixel === 'issues') insight += '<strong>Check your GA4 purchase tag</strong> in Google Tag Manager or Shopify\'s Google & YouTube channel — incorrect implementation is the most common cause of large discrepancies. ';
    document.getElementById('ga-insight').innerHTML = insight;
    document.getElementById('ga-result').classList.add('show');
  }
</script>
