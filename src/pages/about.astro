  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --sans:'Inter',-apple-system,sans-serif;
      --mono:'JetBrains Mono',monospace;
      --bg:#080c0a;--bg-2:#0c110f;--bg-3:#111916;
      --g:#00c864;--g-dim:rgba(0,200,100,.06);--g-b:rgba(0,200,100,.18);
      --border:rgba(255,255,255,.07);
      --text:#f1f5f9;--text-2:#cbd5e1;--text-3:#94a3b8;--text-4:#64748b;
      --red:#ef4444;--amber:#f59e0b;--r:8px
    }
    body{font-family:var(--sans);background:var(--bg);color:var(--text);line-height:1.7;-webkit-font-smoothing:antialiased}
    a{color:var(--g);text-decoration:none}a:hover{text-decoration:underline}
    /* Breadcrumb */
    .bc{max-width:900px;margin:0 auto;padding:14px 24px 0;font-family:var(--mono);font-size:11px;color:var(--text-4);display:flex;gap:6px;align-items:center}
    .bc a{color:var(--text-4);text-decoration:none}.bc a:hover{color:var(--g)}
    /* Hero */
    .hero{padding:64px 24px 52px;background:var(--bg)}
    .hero-inner{max-width:760px;margin:0 auto}
    .tag{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--g);background:var(--g-dim);border:1px solid var(--g-b);padding:4px 12px;border-radius:4px;display:inline-block;margin-bottom:22px}
    .hero h1{font-size:clamp(34px,5.5vw,54px);font-weight:900;letter-spacing:-.04em;line-height:1.04;color:var(--text);margin-bottom:8px}
    .hero-role{font-family:var(--mono);font-size:12px;color:var(--g);letter-spacing:.08em;margin-bottom:22px;display:flex;align-items:center;gap:10px}
    .hero-role::before{content:'';display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--g);animation:ping 2.2s ease-in-out infinite}
    @keyframes ping{0%,100%{opacity:1}50%{opacity:.3}}
    .hero-lead{font-size:17px;color:var(--text-3);line-height:1.85;margin-bottom:32px;max-width:640px}
    /* Credential strip */
    .cred-strip{display:flex;flex-wrap:wrap;gap:8px}
    .cred{font-family:var(--mono);font-size:10px;color:var(--text-4);border:1px solid var(--border);background:var(--bg-2);padding:6px 12px;border-radius:4px;display:flex;align-items:center;gap:6px;white-space:nowrap}
    .cred-dot{width:5px;height:5px;border-radius:50%;background:var(--g);flex-shrink:0}
    .cred-link{color:var(--text-4);text-decoration:none}.cred-link:hover{color:var(--g);text-decoration:none}
    /* Sections */
    .section{padding:60px 24px;background:var(--bg)}
    .section-alt{padding:60px 24px;background:var(--bg-2)}
    .inner{max-width:760px;margin:0 auto}
    .sec-tag{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--text-4);margin-bottom:12px}
    h2{font-size:clamp(20px,3vw,26px);font-weight:800;letter-spacing:-.025em;color:var(--text);margin-bottom:16px;line-height:1.2}
    p{font-size:15px;color:var(--text-3);line-height:1.85;margin-bottom:16px}
    p:last-child{margin-bottom:0}
    strong{color:var(--text)}
    /* Expertise grid */
    .exp-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:28px}
    .exp-card{border:1px solid var(--border);border-radius:var(--r);padding:20px 22px;background:var(--bg-3)}
    .exp-label{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--g);margin-bottom:8px}
    .exp-title{font-size:14px;font-weight:700;color:var(--text);margin-bottom:6px;line-height:1.3}
    .exp-body{font-size:13px;color:var(--text-3);line-height:1.65}
    .exp-body a{color:var(--g);text-decoration:underline;text-underline-offset:2px}
    /* Methodology */
    .methodology{border:1px solid var(--g-b);background:var(--g-dim);border-radius:var(--r);padding:26px 30px;margin-top:28px}
    .methodology-label{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.14em;color:var(--g);margin-bottom:16px;text-transform:uppercase}
    .methodology p{font-size:14px;color:var(--text-3);line-height:1.75;margin-bottom:20px}
    .method-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .m-item{background:rgba(0,0,0,.35);border-radius:6px;padding:14px 16px;border:1px solid rgba(0,200,100,.08)}
    .m-source{font-family:var(--mono);font-size:11px;font-weight:700;color:var(--g);margin-bottom:4px}
    .m-desc{font-size:12px;color:var(--text-4);line-height:1.55}
    /* Transparency */
    .transparency{border:1px solid var(--border);border-radius:var(--r);background:var(--bg-3);overflow:hidden;margin-top:28px}
    .t-row{display:flex;gap:16px;align-items:flex-start;padding:18px 22px;border-bottom:1px solid var(--border)}
    .t-row:last-child{border-bottom:none}
    .t-icon{font-family:var(--mono);font-size:14px;color:var(--g);flex-shrink:0;width:22px;padding-top:1px}
    .t-text{font-size:14px;color:var(--text-3);line-height:1.7}
    .t-text strong{color:var(--text)}
    .t-text a{color:var(--g)}
    /* Tools */
    .tools-list{display:flex;flex-direction:column;gap:8px;margin-top:24px}
    .tool-row{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 18px;border:1px solid var(--border);border-radius:var(--r);background:var(--bg-3);text-decoration:none;transition:border-color .18s}
    .tool-row:hover{border-color:var(--g-b);text-decoration:none}
    .tool-name{font-size:14px;font-weight:600;color:var(--text)}
    .tool-saving{font-family:var(--mono);font-size:11px;color:var(--g);white-space:nowrap}
    /* Contact */
    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px}
    .contact-card{border:1px solid var(--border);border-radius:var(--r);padding:18px 20px;background:var(--bg-3)}
    .contact-label{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--text-4);margin-bottom:10px}
    .contact-link{font-size:14px;font-weight:600;color:var(--g);text-decoration:none}
    .contact-link:hover{text-decoration:underline}
    .contact-desc{font-size:12px;color:var(--text-4);margin-top:5px;line-height:1.5}
    /* CTA strip */
    .cta-strip{background:var(--bg-3);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:40px 24px}
    .cta-inner{max-width:760px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}
    .cta-text h3{font-size:18px;font-weight:800;color:var(--text);margin-bottom:6px;letter-spacing:-.02em}
    .cta-text p{font-size:14px;color:var(--text-3);margin:0}
    .btn{display:inline-flex;align-items:center;gap:8px;font-family:var(--sans);font-size:14px;font-weight:700;padding:13px 26px;border-radius:var(--r);background:var(--g);color:#020617;text-decoration:none;transition:opacity .2s,transform .2s;white-space:nowrap}
    .btn:hover{opacity:.88;transform:translateY(-1px);text-decoration:none}
    @media(max-width:640px){
      .exp-grid,.method-grid,.contact-grid{grid-template-columns:1fr}
      .hero{padding:44px 16px 36px}
      .section,.section-alt{padding:44px 16px}
      .cta-inner{flex-direction:column;align-items:flex-start}
    }
  </style>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-TE6Z6CW514"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-TE6Z6CW514');</script>
