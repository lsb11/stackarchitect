---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Stack Architect',
  url: 'https://www.stackarchitect.xyz/about',
  sameAs: ['https://www.stackarchitect.xyz'],
  knowsAbout: [
    'Shopify automation',
    'Server-side tracking',
    'eCommerce operations',
    'Marketing attribution',
    'Google Sheets automation',
    'Make.com workflows',
  ],
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Stack Architect',
  url: 'https://www.stackarchitect.xyz',
  description:
    'Free Shopify automation guides and tools for store operators. No paid app recommendations without a free alternative.',
  founder: {
    '@type': 'Person',
    name: 'Stack Architect',
  },
};
---

<Base
  title="About Stack Architect — Free Shopify Automation Guides"
  description="Stack Architect publishes free Shopify automation guides and tools for store operators. No paid app recommendations without a free alternative. No code required."
  canonical="https://www.stackarchitect.xyz/about"
  schema={[personSchema, orgSchema]}
>
  <Nav />
  <main class="flex-1 max-w-2xl mx-auto px-4 py-16 w-full">
    <div class="mb-8">
      <div class="text-xs text-[#52525b] uppercase tracking-widest mb-3">ABOUT</div>
      <h1 class="text-xl font-bold text-white mb-2">Stack Architect</h1>
      <p class="text-xs text-[#52525b]">Free Shopify Automation Guides &amp; Tools</p>
    </div>

    <div class="space-y-6 text-sm text-gray-400 leading-relaxed">
      <p>
        Stack Architect publishes free guides and tools for Shopify store operators who want to
        automate without paying for another SaaS subscription. Every guide is built around a
        working zero-cost alternative tested in real stores.
      </p>

      <div class="border-l-2 border-[#4ade80] pl-4">
        <p class="text-white font-bold text-xs uppercase tracking-wide mb-2">THE MISSION</p>
        <p>
          Most "Shopify tool" content is written by SaaS companies trying to sell you their
          product. This site is written by an operator. Every recommendation starts with the
          question: <em class="text-white">what's the free version?</em>
        </p>
      </div>

      <div class="border border-[#1f1f1f] bg-[#0a0a0a] p-4 space-y-3">
        <div class="text-xs text-[#52525b] uppercase tracking-widest">PRINCIPLES</div>
        <ul class="space-y-2 text-xs">
          <li class="flex items-start gap-2">
            <span class="text-[#4ade80] flex-shrink-0">→</span>
            <span>No paid app recommendation without a free alternative covered first</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#4ade80] flex-shrink-0">→</span>
            <span>All tools tested before publication — no theoretical guides</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#4ade80] flex-shrink-0">→</span>
            <span>No code required unless there's truly no other way</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#4ade80] flex-shrink-0">→</span>
            <span>Written for operators, not developers</span>
          </li>
        </ul>
      </div>

      <p>
        <strong class="text-white">Affiliate disclosure:</strong> Some links on this site use
        affiliate codes (Make.com, Systeme.io). These are the same free-tier tools recommended
        regardless of commission. Affiliate links never influence which tools are recommended —
        only tools with genuinely useful free plans are included.
      </p>

      <div class="border border-[#1f1f1f] p-4 space-y-3">
        <div class="text-xs text-[#52525b] uppercase tracking-widest mb-3">EXPLORE</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <a
            href="/shopify-automation-guides"
            class="flex items-center justify-between border border-[#1f1f1f] px-3 py-2 hover:border-[#4ade80]/40 transition-colors group"
          >
            <span class="text-xs text-gray-400 group-hover:text-white">All Guides</span>
            <span class="text-[#4ade80] text-xs">→</span>
          </a>
          <a
            href="/tools"
            class="flex items-center justify-between border border-[#1f1f1f] px-3 py-2 hover:border-[#4ade80]/40 transition-colors group"
          >
            <span class="text-xs text-gray-400 group-hover:text-white">Free Tools</span>
            <span class="text-[#4ade80] text-xs">→</span>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>
