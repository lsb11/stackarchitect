// ─── JSON-LD SCHEMA ───────────────────────────────────────────────────────────

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Stack Architect", "item": SITE },
    { "@type": "ListItem", "position": 2, "name": "Recommended Stack", "item": CANONICAL }
  ]
};

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Recommended Shopify Automation Stack 2026",
  "description": "Seven free tools that replace $700+/month of paid Shopify apps — vetted and ranked by Stack Architect.",
  "numberOfItems": tools.length,
  "itemListElement": tools.map((t, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": t.name,
    "url": t.affiliateURL
  }))
};

// SoftwareApplication schema for each tool — boosts entity recognition in AI/LLM search
const schemaSoftware = tools.map(t => ({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": t.name,
  "applicationCategory": "BusinessApplication",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": t.tagline,
}));

// Article schema — E-E-A-T signal for Google + AI crawlers
const schemaArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Recommended Shopify Stack 2026 — 7 Free Tools, Vetted & Ranked",
  "description": "The exact free Shopify automation stack recommended by Stack Architect — 7 vetted tools replacing $700+/month of paid apps.",
  "dateModified": "2026-04-01",
  "author": { "@type": "Organization", "name": "Stack Architect", "url": SITE },
  "publisher": { "@type": "Organization", "name": "Stack Architect", "url": SITE },
  "mainEntityOfPage": CANONICAL,
};
