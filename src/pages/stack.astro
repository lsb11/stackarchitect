  .nav-links a:hover,
  .nav-active { color: var(--text-primary) !important; }
  .nav-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    background: var(--accent);
    color: #000 !important;
    padding: 8px 14px;
