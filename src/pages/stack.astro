<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ─── PRIMARY META ─── -->
  <title>Recommended Shopify Stack 2026 — 7 Free Tools, Vetted &amp; Ranked | Stack Architect</title>
  <meta name="description" content="The exact free Shopify automation stack recommended by Stack Architect — 7 vetted tools replacing $700+/month of paid apps. Make.com, Systeme.io, Tidio, Meta CAPI, TikTok Events API and more. No code. Used by 500+ stores across the UK, US, AU and CA." />
  <link rel="canonical" href={CANONICAL} />

  <!-- ─── GEO / HREFLANG (multi-region audience: UK, US, AU, CA) ─── -->
  <link rel="alternate" hreflang="en-gb" href={CANONICAL} />
  <link rel="alternate" hreflang="en-us" href={CANONICAL} />
  <link rel="alternate" hreflang="en-au" href={CANONICAL} />
  <link rel="alternate" hreflang="en-ca" href={CANONICAL} />
  <link rel="alternate" hreflang="x-default" href={CANONICAL} />

  <!-- ─── REDIRECT SIGNAL: tools subdomain now lives at /tools ─── -->
  <!-- Old: tools.stackarchitect.xyz → New: stackarchitect.xyz/tools (301 handled at DNS/server layer) -->

  <!-- ─── OPEN GRAPH ─── -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={CANONICAL} />
  <meta property="og:title"       content="Recommended Shopify Stack 2026 — 7 Free Tools, Vetted & Ranked" />
  <meta property="og:description" content="7 free tools replacing $700+/month of paid Shopify apps — vetted, ranked, and honest about when to upgrade. Used by 500+ stores." />
  <meta property="og:image"       content={`${SITE}/og-stack.png`} />
  <meta property="og:site_name"   content="Stack Architect" />
  <meta property="og:locale"      content="en_GB" />

  <!-- ─── TWITTER ─── -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="Recommended Shopify Stack 2026 — 7 Free Tools" />
  <meta name="twitter:description" content="7 free tools replacing $700+/month of paid Shopify apps. No code. Deploy fast." />
  <meta name="twitter:image"       content={`${SITE}/og-stack.png`} />

  <!-- ─── ROBOTS ─── -->
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

  <!-- ─── SCHEMA ─── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaArticle)} />
  {schemaSoftware.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- ─── FONTS ─── -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- ─── BEEHIIV EMBED SCRIPT (deferred so it doesn't block render) ─── -->
  <script defer src="https://cdn.beehiiv.com/js/embed.js"></script>
</head>

