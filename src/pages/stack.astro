              <span class={`badge badge--${tool.badgeType}`}>{tool.badge}</span>
            </div>
            <div class="version-tag">{tool.version}</div>
          </div>

          <h2 class="tool-name" id={`tool-name-${tool.id}`}>{tool.name}</h2>
          <p class="tool-tagline">{tool.tagline}</p>

          <div class="tool-quick-stats">
            <div class="qs-item">
              <span class="qs-label">saves</span>
              <span class="qs-value accent">{tool.saving}</span>
            </div>
            <div class="qs-divider" aria-hidden="true" />
            <div class="qs-item">
              <span class="qs-label">setup</span>
              <span class="qs-value">{tool.setup}</span>
            </div>
          </div>

          <div class="tool-replaces">
            <span class="replaces-label">replaces</span>
            <div class="replaces-tags" aria-label={`${tool.name} replaces: ${tool.replaces.join(', ')}`}>
              {tool.replaces.map(r => <span class="replace-tag">{r}</span>)}
            </div>
          </div>

          <div class="free-tier-block" aria-label="Free tier details">
            <span class="free-tier-prefix" aria-hidden="true">// free tier</span>
            <span class="free-tier-text">{tool.freeTier}</span>
          </div>

          <div class="tool-details">
            <div class="detail-row">
              <span class="detail-label">best for</span>
              <span class="detail-val">{tool.bestFor}</span>
            </div>
            <div class="detail-row detail-row--dim">
              <span class="detail-label">not for</span>
              <span class="detail-val">{tool.notFor}</span>
            </div>
          </div>

          <p class="tool-why">{tool.why}</p>

          <a href={tool.affiliateURL} class="btn-tool-cta" target="_blank" rel="nofollow noopener" aria-label={`${tool.cta} — opens in new tab`}>
            {tool.cta}
          </a>
