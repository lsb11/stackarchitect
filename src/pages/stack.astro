  .section-sub { font-size: 13px; color: var(--text-dim); margin-top: 6px; font-family: var(--font-mono); }

  /* ─── SKIP LINK (a11y) ─── */
  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
