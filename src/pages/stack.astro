  "numberOfItems": tools.length,
  "itemListElement": tools.map((t, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": t.name,
    "description": t.tagline,
    "url": t.affiliateURL
  }))
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Recommended Shopify Automation Stack 2026",
