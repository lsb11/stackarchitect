    position: fixed;
    top: 0;
    left: 0;
    width: auto;
    height: auto;
    padding: 8px 16px;
    background: var(--accent);
    color: #000;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    z-index: 9999;
