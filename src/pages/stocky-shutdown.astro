  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "When does Shopify Stocky shut down?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Shopify Stocky shuts down permanently on August 31, 2026. After that date, the app stops working entirely and all data — including purchase orders, supplier records, stock forecasts, and inventory history — is permanently deleted with no recovery option. Shopify delisted Stocky from the App Store in February 2026."
        }
      },
      {
        "@type": "Question",
        "name": "What data will be deleted when Stocky shuts down?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "When Stocky shuts down on August 31, 2026, the following data will be permanently deleted: all purchase orders created in Stocky, supplier contact records and lead times, stock forecasting history and demand projections, stocktake and inventory adjustment records, and all product cost and margin data entered in Stocky. Order history in Shopify Admin is not affected — only data that lives inside Stocky itself will be deleted."
        }
      },
      {
        "@type": "Question",
        "name": "How many merchants are affected by the Stocky shutdown?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Over 200,000 Shopify merchants used Stocky and are affected by its August 31, 2026 shutdown. Stocky was available to all Shopify merchants at no cost and was widely used for purchase order management and basic inventory tracking, particularly by small and mid-size stores that could not justify the cost of paid inventory apps."
        }
      },
      {
        "@type": "Question",
        "name": "What replaces Shopify Stocky after the shutdown?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The best free Stocky replacement is Stocky Swap by Stack Architect — a free inventory system that logs every Shopify order to Google Sheets in real time using a Make.com webhook. It deploys in 4 minutes, costs $0 per month, requires no code, and runs permanently on Make.com's free tier. Paid alternatives include Inventory Planner ($99/month), Linnworks ($449/month), and Skubana ($500/month)."
        }
      },
      {
        "@type": "Question",
        "name": "Is Shopify building a replacement for Stocky?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Shopify has not announced a built-in replacement for Stocky. Shopify's official guidance directs merchants to the Shopify App Store to find third-party inventory management apps. Shopify does offer basic inventory tracking in the admin panel, but this does not include the purchase order management, demand forecasting, or supplier management that Stocky provided."
        }
      },
      {
        "@type": "Question",
        "name": "Should I export my Stocky data before August 31, 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You should export your Stocky data immediately. Before August 31, 2026, export your supplier contact records, purchase order history, stocktake records, and any product cost data you have entered in Stocky. After the shutdown date this data cannot be recovered. Shopify has confirmed that Stocky data will not be migrated or transferred automatically."
        }
      },
      {
        "@type": "Question",
        "name": "Can I run a Stocky replacement alongside Stocky before August 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — and this is the recommended approach. Set up Stocky Swap or your chosen replacement now while Stocky is still active, so you can verify every order is logging correctly before the shutdown date. Running both simultaneously until August 31, 2026 gives you a safety net. After the shutdown date, your replacement continues running permanently."
        }
      }
    ]
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700;800&display=swap" as="style" onload="this.onload=null;this.rel=\'stylesheet\'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700;800&display=swap" /></noscript>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    :root {
      --bg: #0a0a0a;
      --bg-2: #111111;
      --bg-3: #181818;
      --bg-4: #222222;
      --text: #e8e6e0;
      --text-2: #c8c4bc;
      --text-3: #9a9690;
      --text-4: #6a6660;
      --g: #00c864;
      --g-border: rgba(0,200,100,.25);
      --g-bg: rgba(0,200,100,.06);
      --red: #ef4444;
      --red-bg: rgba(239,68,68,.07);
      --red-border: rgba(239,68,68,.2);
      --amber: #f59e0b;
      --amber-bg: rgba(245,158,11,.07);
      --amber-border: rgba(245,158,11,.2);
      --sky: #38bdf8;
      --mono: 'JetBrains Mono', monospace;
      --sans: 'Inter', sans-serif;
      --border: rgba(255,255,255,.07);
      --border-2: rgba(255,255,255,.12);
      --radius: 8px;
      --radius-lg: 12px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 16px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--g); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { font-weight: 600; color: var(--text); }
    code {
      font-family: var(--mono);
      font-size: 12px;
      background: var(--bg-3);
      padding: 2px 6px;
      border-radius: 4px;
      color: var(--sky);
    }

    /* NAV */
    .nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,10,.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
    }
    .nav-inner {
      max-width: 900px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      height: 52px; gap: 20px;
    }
    .nav-status {
      font-family: var(--mono); font-size: 9px; font-weight: 700;
      color: var(--red); letter-spacing: .12em; text-transform: uppercase;
      display: flex; align-items: center; gap: 6px; flex-shrink: 0;
    }
    .nav-status .dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--red);
      animation: pulse-red 1.5s ease-in-out infinite;
    }
    @keyframes pulse-red {
      0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(239,68,68,.4)}
      50%{opacity:.8;box-shadow:0 0 0 4px rgba(239,68,68,0)}
    }
    .nav-links { display: flex; align-items: center; gap: 20px; }
    .nav-links a {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      color: var(--text-3); letter-spacing: .08em; text-transform: uppercase;
      text-decoration: none; transition: color .15s;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-cta {
      font-family: var(--mono); font-size: 10px; font-weight: 800;
      color: var(--g); letter-spacing: .1em; text-transform: uppercase;
      border: 1px solid var(--g-border); padding: 6px 14px; border-radius: var(--radius);
      background: var(--g-bg); text-decoration: none; transition: all .15s; flex-shrink: 0;
    }
    .nav-cta:hover { background: rgba(0,200,100,.12); text-decoration: none; }

    /* BREADCRUMB */
    .breadcrumb {
      background: var(--bg-2); border-bottom: 1px solid var(--border);
      padding: 10px 24px;
    }
    .breadcrumb-inner {
      max-width: 900px; margin: 0 auto;
      font-family: var(--mono); font-size: 11px; color: var(--text-4);
      display: flex; align-items: center; gap: 8px;
    }
    .breadcrumb-inner a { color: var(--text-4); text-decoration: none; }
    .breadcrumb-inner a:hover { color: var(--text-3); }
    .breadcrumb-inner span { color: var(--text-4); }

    /* LAYOUT */
    .inner { max-width: 900px; margin: 0 auto; padding: 0 24px; }
    .inner-sm { max-width: 720px; margin: 0 auto; padding: 0 24px; }
    section { padding: 64px 0; }
    section.alt { background: var(--bg-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

    /* ALERT BAND */
    .alert-band {
      background: var(--red-bg);
      border-top: 1px solid var(--red-border);
      border-bottom: 1px solid var(--red-border);
      padding: 16px 24px;
    }
    .alert-band-inner {
      max-width: 900px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap;
    }
    .alert-band-text {
      font-family: var(--mono); font-size: 11px; font-weight: 700;
      color: var(--red); letter-spacing: .08em; text-transform: uppercase;
      display: flex; align-items: center; gap: 8px;
    }
    .alert-band-sub {
      font-family: var(--sans); font-size: 13px; color: var(--text-3);
      font-weight: 400; letter-spacing: 0; text-transform: none;
      margin-top: 2px;
    }
    .alert-band-cta {
      font-family: var(--mono); font-size: 10px; font-weight: 800;
      color: var(--red); letter-spacing: .1em; text-transform: uppercase;
      border: 1px solid var(--red-border); padding: 6px 14px; border-radius: var(--radius);
      background: rgba(239,68,68,.1); text-decoration: none; white-space: nowrap;
      transition: background .15s; flex-shrink: 0;
    }
    .alert-band-cta:hover { background: rgba(239,68,68,.16); text-decoration: none; }

    /* COUNTDOWN */
    .countdown-wrap {
      display: flex; align-items: center; gap: 6px;
      font-family: var(--mono); font-weight: 800;
    }
    .cd-unit { text-align: center; }
    .cd-val {
      font-size: 28px; font-weight: 800; color: var(--red);
      display: block; line-height: 1;
      text-shadow: 0 0 20px rgba(239,68,68,.3);
    }
    .cd-val.large { font-size: 48px; }
    .cd-l { font-size: 9px; color: var(--text-4); letter-spacing: .1em; text-transform: uppercase; margin-top: 3px; }
    .cd-sep { font-size: 24px; font-weight: 800; color: var(--red-border); padding-bottom: 18px; }
    .cd-sep.large { font-size: 40px; padding-bottom: 24px; }

    /* HERO */
    .hero { padding: 72px 0 56px; }
    .hero-dateline {
      font-family: var(--mono); font-size: 10px; color: var(--text-4);
      letter-spacing: .1em; text-transform: uppercase; margin-bottom: 16px;
    }
    .hero h1 {
      font-size: clamp(28px, 5vw, 44px); font-weight: 700; line-height: 1.15;
      color: var(--text); margin-bottom: 20px; letter-spacing: -.02em;
    }
    .hero h1 .red { color: var(--red); }
    .hero-sub {
      font-size: 18px; color: var(--text-2); line-height: 1.65;
      max-width: 640px; margin-bottom: 32px;
    }
    .hero-countdown-block {
      background: var(--red-bg); border: 1px solid var(--red-border);
      border-radius: var(--radius-lg); padding: 24px 28px; display: inline-flex;
      flex-direction: column; gap: 12px; margin-bottom: 32px;
    }
    .hero-countdown-label {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      color: var(--red); letter-spacing: .12em; text-transform: uppercase;
      display: flex; align-items: center; gap: 6px;
    }

    /* STAT STRIP */
    .stat-strip {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 12px; margin: 32px 0;
    }
    .stat-cell {
      background: var(--bg-3); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 16px;
    }
    .stat-v { font-family: var(--mono); font-size: 22px; font-weight: 800; color: var(--text); }
    .stat-v.red { color: var(--red); }
    .stat-v.amber { color: var(--amber); }
    .stat-l { font-size: 11px; color: var(--text-4); margin-top: 3px; }

    /* TAG */
    .tag {
      display: inline-flex; align-items: center;
      font-family: var(--mono); font-size: 9px; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase;
      padding: 4px 10px; border-radius: 4px;
      background: var(--bg-3); border: 1px solid var(--border); color: var(--text-4);
    }
    .tag-red { background: var(--red-bg); border-color: var(--red-border); color: var(--red); }
    .tag-g { background: var(--g-bg); border-color: var(--g-border); color: var(--g); }
    .tag-amber { background: var(--amber-bg); border-color: var(--amber-border); color: var(--amber); }

    /* SECTION HEAD */
    .sec-head { text-align: center; margin-bottom: 40px; }
    .sec-head h2 {
      font-size: clamp(22px, 4vw, 32px); font-weight: 700; color: var(--text);
      margin: 12px 0; letter-spacing: -.02em; line-height: 1.2;
    }
    .sec-head h2 .g { color: var(--g); }
    .sec-head h2 .red { color: var(--red); }
    .sec-head p { font-size: 16px; color: var(--text-3); max-width: 560px; margin: 0 auto; }

    /* TIMELINE */
    .timeline { display: flex; flex-direction: column; gap: 0; }
    .tl-item {
      display: flex; gap: 20px; padding: 0 0 36px;
      position: relative;
    }
    .tl-item:last-child { padding-bottom: 0; }
    .tl-left { display: flex; flex-direction: column; align-items: center; width: 40px; flex-shrink: 0; }
    .tl-dot {
      width: 14px; height: 14px; border-radius: 50%;
      border: 2px solid var(--border-2); background: var(--bg-3);
      flex-shrink: 0; z-index: 1; margin-top: 4px;
    }
    .tl-dot.done { background: var(--text-4); border-color: var(--text-4); }
    .tl-dot.warn { background: var(--amber); border-color: var(--amber); box-shadow: 0 0 8px rgba(245,158,11,.3); }
    .tl-dot.urgent { background: var(--red); border-color: var(--red); box-shadow: 0 0 12px rgba(239,68,68,.4); animation: pulse-red 1.5s ease-in-out infinite; }
    .tl-line {
      flex: 1; width: 1px; background: var(--border); margin-top: 4px;
    }
    .tl-item:last-child .tl-line { display: none; }
    .tl-right { flex: 1; padding-bottom: 4px; }
    .tl-date {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      color: var(--text-4); letter-spacing: .1em; text-transform: uppercase;
      margin-bottom: 6px;
    }
    .tl-date.red { color: var(--red); }
    .tl-title { font-size: 16px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
    .tl-body { font-size: 14px; color: var(--text-3); line-height: 1.65; }

    /* DATA RISK TABLE */
    .risk-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 12px;
    }
    .risk-card {
      background: var(--bg-3); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 20px;
    }
    .risk-card.danger { border-color: var(--red-border); background: var(--red-bg); }
    .risk-card.safe { border-color: var(--g-border); background: var(--g-bg); }
    .risk-card-label {
      font-family: var(--mono); font-size: 9px; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px;
    }
    .risk-card.danger .risk-card-label { color: var(--red); }
    .risk-card.safe .risk-card-label { color: var(--g); }
    .risk-card h3 { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 10px; }
    .risk-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .risk-list li { font-size: 13px; color: var(--text-3); display: flex; gap: 8px; align-items: flex-start; line-height: 1.5; }
    .risk-list li::before { content: '✗'; color: var(--red); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .risk-card.safe .risk-list li::before { content: '✓'; color: var(--g); }

    /* WHAT TO DO STEPS */
    .steps { display: flex; flex-direction: column; gap: 16px; }
    .step {
      display: flex; gap: 16px; align-items: flex-start;
      background: var(--bg-3); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 20px;
    }
    .step.urgent { border-color: var(--red-border); }
    .step-n {
      font-family: var(--mono); font-size: 11px; font-weight: 800;
      color: var(--text-4); background: var(--bg-4);
      width: 28px; height: 28px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; margin-top: 1px;
    }
    .step.urgent .step-n { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }
    .step-body { flex: 1; }
    .step-title { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
    .step-desc { font-size: 13px; color: var(--text-3); line-height: 1.6; }
    .step-time {
      font-family: var(--mono); font-size: 9px; color: var(--text-4);
      letter-spacing: .08em; text-transform: uppercase; margin-top: 6px;
    }

    /* PROSE */
    .prose h3 { font-size: 18px; font-weight: 600; color: var(--text); margin: 32px 0 10px; letter-spacing: -.01em; }
    .prose h3:first-child { margin-top: 0; }
    .prose p { font-size: 15px; color: var(--text-3); line-height: 1.75; margin-bottom: 16px; }
    .prose p:last-child { margin-bottom: 0; }
    .prose a { color: var(--g); }

    /* FAQ */
    .faq-list { display: flex; flex-direction: column; gap: 0; }
    .faq-item {
      border-bottom: 1px solid var(--border);
    }
    .faq-item:first-child { border-top: 1px solid var(--border); }
    .faq-q {
      width: 100%; background: none; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 0; gap: 16px; text-align: left;
      font-family: var(--sans); font-size: 15px; font-weight: 500; color: var(--text);
    }
    .faq-q:hover { color: var(--g); }
    .faq-icon { font-family: var(--mono); font-size: 18px; color: var(--text-4); flex-shrink: 0; transition: transform .2s; }
    .faq-item.open .faq-icon { transform: rotate(45deg); color: var(--g); }
    .faq-a { display: none; padding: 0 0 18px; font-size: 14px; color: var(--text-3); line-height: 1.7; }
    .faq-item.open .faq-a { display: block; }

    /* BOTTOM CTA */
    .bottom-cta {
      background: var(--bg-2); border-top: 1px solid var(--g-border);
