  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--sans:'Inter',-apple-system,sans-serif;--mono:'JetBrains Mono',monospace;--bg:#0c0f0d;--bg-2:#111;--text:#f0efe8;--text-2:#c8c7c0;--text-3:#888780;--text-4:#555450;--g:#34d377;--border:rgba(255,255,255,0.08)}
    body{font-family:var(--sans);background:var(--bg);color:var(--text);line-height:1.7}
    a{color:var(--g);text-decoration:none}a:hover{text-decoration:underline}
    .nav{background:var(--bg-2);border-bottom:1px solid var(--border);padding:0 24px;position:sticky;top:0;z-index:100}
    .nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:16px;height:52px;flex-wrap:wrap}
    .dot{width:6px;height:6px;border-radius:50%;background:var(--g);display:inline-block}
    .nav-status{font-family:var(--mono);font-size:10px;color:var(--text-4);display:flex;align-items:center;gap:6px}
    .nav-links{list-style:none;display:flex;gap:4px;flex-wrap:wrap;flex:1}
    .nl{font-family:var(--mono);font-size:11px;color:var(--text-3);text-decoration:none;padding:4px 8px;border-radius:4px}.nl:hover{color:var(--text);text-decoration:none}.nl-home{color:var(--g)}
    .nav-cta{margin-left:auto;display:flex;align-items:center;gap:12px}
    .ticker{font-family:var(--mono);font-size:10px;color:var(--g);letter-spacing:.1em}
    .btn-nav{font-family:var(--mono);font-size:11px;font-weight:700;color:#000;background:var(--g);padding:8px 14px;border-radius:6px;text-decoration:none;white-space:nowrap}
    .bc{max-width:1200px;margin:0 auto;padding:14px 24px 0;font-family:var(--mono);font-size:11px;color:var(--text-4);display:flex;gap:6px;align-items:center}
    .bc a{color:var(--text-4);text-decoration:none}.bc-sep{opacity:.4}
    .hero{padding:60px 24px 48px;text-align:center}.hero-inner{max-width:680px;margin:0 auto}
    .tag{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--g);background:rgba(52,211,119,.08);border:1px solid rgba(52,211,119,.2);padding:4px 12px;border-radius:4px;display:inline-block;margin-bottom:20px}
    h1{font-size:clamp(28px,5vw,40px);font-weight:700;letter-spacing:-.03em;line-height:1.1;color:var(--text);margin-bottom:14px}
    .dateline{font-family:var(--mono);font-size:11px;color:var(--text-4)}
    .prose-wrap{padding:0 24px 80px}.prose-inner{max-width:680px;margin:0 auto}
    .prose h2{font-size:20px;font-weight:700;color:var(--text);margin:40px 0 12px}.prose h2:first-child{margin-top:0}
    .prose p{font-size:15px;color:var(--text-2);line-height:1.8;margin-bottom:16px}
    .prose ul{padding-left:20px;margin-bottom:16px}.prose li{font-size:15px;color:var(--text-2);line-height:1.8;margin-bottom:6px}
    footer{background:var(--bg-2);border-top:1px solid var(--border);padding:48px 24px 32px;margin-top:40px}.ft{max-width:1200px;margin:0 auto}
    .ft-strip{background:rgba(52,211,119,.06);border:1px solid rgba(52,211,119,.15);border-radius:10px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:40px}
    .ft-strip-txt{font-size:14px;color:var(--text-2)}.ft-strip-txt span{font-weight:700;color:var(--text)}
    .ft-strip-cta{font-family:var(--mono);font-size:12px;font-weight:700;color:#000;background:var(--g);padding:10px 18px;border-radius:6px;text-decoration:none;white-space:nowrap}
    .ft-title{font-family:var(--mono);font-size:10px;font-weight:700;color:var(--text-4);letter-spacing:.2em;text-transform:uppercase;display:block;margin-bottom:16px}
    .ft-links,.ft-sec{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}
    .ft-links a,.ft-sec a{font-family:var(--mono);font-size:11px;color:var(--text-4);text-decoration:none;padding:3px 8px;border:1px solid var(--border);border-radius:4px}
    .ft-trust{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:24px}
    .tb{font-family:var(--mono);font-size:10px;color:var(--text-4);display:flex;align-items:center;gap:5px}
    .tb-dot{width:5px;height:5px;border-radius:50%;background:var(--g);display:inline-block}
    .ft-div{border:none;border-top:1px solid var(--border);margin:24px 0}
    .ft-ret{font-family:var(--mono);font-size:10px;color:var(--text-4);text-decoration:none;display:block;margin-bottom:16px}
    .ft-copy{font-family:var(--mono);font-size:10px;color:var(--text-4);margin-bottom:12px}
    .ft-disc{font-size:12px;color:var(--text-4);line-height:1.6}.ft-disc a{color:var(--text-4)}
