.code-block{background:#0a0f1a;border:1px solid var(--border-2);border-radius:8px;padding:20px 24px;margin:16px 0;overflow-x:auto;}
.code-block pre{font-family:var(--mono);font-size:12px;color:#93a09a;line-height:1.7;white-space:pre;margin:0;}
.code-label{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--tt);margin-bottom:10px;display:block;}

/* ── Comparison table ── */
.comp-wrap{overflow-x:auto;margin:20px 0;}
.comp-table{width:100%;border-collapse:collapse;min-width:500px;}
.comp-table th{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-4);padding:12px 16px;text-align:left;background:rgba(255,255,255,.025);border-bottom:1px solid var(--border);}
.comp-table td{font-size:13px;color:var(--text-3);padding:12px 16px;border-bottom:1px solid var(--border);}
.comp-table tr:last-child td{border-bottom:none;}
.comp-table .win{color:var(--g);font-weight:600;}
.comp-table .lose{color:var(--text-4);}
.comp-table tr:hover td{background:rgba(255,255,255,.02);}
.comp-table .highlight-row td{background:rgba(52,211,119,.04);border-top:1px solid var(--g-border);}
.comp-table .highlight-row td:first-child{font-weight:700;color:var(--text);}

/* ── Body text ── */
.body-text{max-width:760px;margin:0 auto;}
.body-text p{font-size:15px;color:var(--text-3);line-height:1.8;margin-bottom:18px;text-align:left;}
.body-text p strong{color:var(--text-2);font-weight:600;}
.body-text p a{color:var(--tt);text-decoration:underline;}
.body-text h3{font-weight:700;font-size:clamp(18px,2.5vw,22px);color:var(--text-2);letter-spacing:-.02em;line-height:1.15;margin:32px 0 12px;text-align:left;}
.body-text ul{padding-left:0;list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:20px;}
.body-text li{display:flex;align-items:flex-start;gap:10px;font-size:15px;color:var(--text-3);line-height:1.65;text-align:left;}
.body-text li::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--tt);flex-shrink:0;margin-top:9px;}
.body-text li strong{color:var(--text-2);font-weight:600;}

/* ── Cross-links ── */
.crosslink-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:40px;}
.crosslink-card{background:var(--bg-3);border:1.5px solid var(--border);border-radius:12px;padding:28px;text-decoration:none;display:flex;flex-direction:column;transition:border-color .2s,transform .2s;}
.crosslink-card:hover{border-color:var(--tt-border);transform:translateY(-4px);}
.crosslink-card.green:hover{border-color:var(--g-border);}
.crosslink-card.sky:hover{border-color:var(--sky-border);}
.crosslink-card.vio:hover{border-color:var(--vio-border);}
.crosslink-name{font-weight:700;font-size:20px;color:var(--text);letter-spacing:-.02em;margin:10px 0 6px;}
.crosslink-desc{font-size:13px;color:var(--text-3);line-height:1.6;margin-bottom:14px;flex:1;}
.crosslink-save{font-family:var(--mono);font-size:12px;font-weight:700;}

/* ── FAQ ── */
.faq-list-c{display:flex;flex-direction:column;gap:8px;margin-top:40px;}
details.faq-item-c{border-radius:10px;border:1.5px solid var(--border);background:rgba(255,255,255,.02);transition:border-color .2s;}
details.faq-item-c[open]{border-color:rgba(255,46,99,.25);background:rgba(255,46,99,.025);}
details.faq-item-c summary{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:18px 22px;cursor:pointer;list-style:none;min-height:58px;font-size:15px;font-weight:600;color:var(--text-3);}
details.faq-item-c summary::-webkit-details-marker{display:none;}
details.faq-item-c[open] summary{color:var(--text);}
.faq-ico{width:16px;height:16px;min-width:16px;display:inline-block;flex-shrink:0;position:relative;opacity:.4;}
.faq-ico::before{content:'';position:absolute;top:3px;left:2px;width:10px;height:10px;border-right:2px solid currentColor;border-bottom:2px solid currentColor;transform:rotate(45deg);transition:transform .25s;}
details.faq-item-c[open] summary .faq-ico{opacity:1;color:var(--tt);}
details.faq-item-c[open] summary .faq-ico::before{transform:rotate(225deg);top:6px;}
.faq-ans-c{padding:0 22px 20px;font-size:14px;color:var(--text-3);line-height:1.75;border-top:1px solid var(--border);padding-top:14px;text-align:left;}
.faq-ans-c a{color:var(--tt);text-decoration:underline;}

/* ── Footer ── */
.architect-footer{background:#0c0f0d;position:relative;padding:60px 24px 30px;font-family:var(--sans);color:#5d6862;text-align:center;border-top:1px solid #222825;}
.architect-footer::before{content:"";position:absolute;top:0;left:0;right:0;bottom:0;background-image:radial-gradient(#ff2e63 0.5px,transparent 0.5px);background-size:30px 30px;opacity:.04;pointer-events:none;}
.footer-container{max-width:900px;margin:0 auto;position:relative;z-index:2;}
.footer-conversion-strip{background:rgba(255,46,99,.05);border:1px solid rgba(255,46,99,.15);border-radius:8px;padding:20px 30px;margin-bottom:40px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;}
.footer-conversion-text{font-size:14px;font-weight:700;color:#93a09a;text-align:left;}
.footer-conversion-text span{color:#fff;}
.footer-conversion-cta{font-family:var(--mono);font-size:10px;font-weight:700;color:var(--tt);text-decoration:none;text-transform:uppercase;letter-spacing:2px;border:1px solid rgba(255,46,99,.4);padding:8px 16px;border-radius:4px;white-space:nowrap;transition:all .3s;flex-shrink:0;}
.footer-conversion-cta:hover{background:var(--tt);color:#fff;}
.footer-system-title{font-size:22px;font-weight:700;color:#f2f5f3;letter-spacing:-1.5px;margin-bottom:20px;display:block;}
.status-bar{display:inline-flex;align-items:center;gap:15px;background:rgba(15,23,42,.5);border:1px solid #222825;padding:6px 15px;border-radius:4px;margin-bottom:40px;}
.status-item{font-family:var(--mono);font-size:8px;letter-spacing:1.2px;text-transform:uppercase;color:#6b7671;display:flex;align-items:center;gap:8px;text-decoration:none;transition:color .3s;}
.engine-link:hover{color:#15803d;}
.bar-sep{width:1px;height:10px;background:#2f3733;}
.pulse-dot{height:4px;width:4px;background:var(--tt);border-radius:50%;animation:ps 2s infinite;}
@keyframes ps{0%{opacity:1;}50%{opacity:.3;}100%{opacity:1;}}
.footer-links{display:flex;justify-content:center;gap:20px;margin-bottom:30px;flex-wrap:wrap;}
.footer-links a{font-size:12px;font-weight:700;color:#f2f5f3;text-decoration:none;letter-spacing:-.3px;transition:all .3s;}
.footer-links a:hover{color:var(--tt);transform:translateY(-1px);}
.nav-secondary{display:flex;justify-content:center;gap:20px;margin-bottom:30px;flex-wrap:wrap;}
.nav-secondary a{font-family:var(--mono);font-size:9px;color:#5d6862;text-decoration:none;transition:color .3s;}
.nav-secondary a:hover{color:#f2f5f3;}
.footer-trust-row{display:flex;justify-content:center;align-items:center;gap:24px;margin-bottom:30px;flex-wrap:wrap;}
.trust-badge{font-family:var(--mono);font-size:8px;font-weight:700;color:#2f3733;letter-spacing:1px;text-transform:uppercase;display:flex;align-items:center;gap:6px;}
.trust-badge-dot{width:4px;height:4px;background:#15803d;border-radius:50%;flex-shrink:0;}
.footer-divider{width:40px;height:1px;background:#222825;margin:30px auto;}
.return-origin{font-family:var(--mono);font-size:10px;color:var(--tt);text-decoration:none;font-weight:800;letter-spacing:2px;transition:all .3s;display:inline-block;}
.return-origin:hover{letter-spacing:4px;}
.copyright{font-family:var(--mono);font-size:8px;color:#222825;margin-top:20px;text-transform:uppercase;}
.affiliate-disclosure{font-size:10px;color:#2f3733;margin-top:12px;line-height:1.5;max-width:600px;margin-left:auto;margin-right:auto;}
.affiliate-disclosure a{color:#5d6862;}

/* ── Responsive ── */
@media(max-width:850px){
  .terminal-status,.savings-ticker{display:none;}
  .terminal-container{flex-direction:column;gap:14px;}
  .product-access-grid{display:grid;grid-template-columns:repeat(2,auto);gap:10px 18px;}
  .terminal-cta{margin-left:0;order:-1;width:100%;justify-content:center;}
  .cta-node{background:var(--tt);color:#fff;width:80%;text-align:center;}
}
@media(max-width:720px){
  .flow-grid{grid-template-columns:1fr 1fr;}
  .flow-step+.flow-step{border-left:none;}
  .flow-step:nth-child(odd)+.flow-step{border-left:1px solid var(--border);}
  .flow-step:nth-child(n+3){border-top:1px solid var(--border);}
}
@media(max-width:640px){
  .hero{padding:72px 20px 64px;}
  .hero-ctas{flex-direction:column;align-items:stretch;max-width:340px;margin-left:auto;margin-right:auto;}
  .btn,.btn-outline{width:100%;justify-content:center;}
  .stat-strip{grid-template-columns:repeat(2,1fr);}
  .crosslink-grid{grid-template-columns:1fr;}
  .section-cta{flex-direction:column;}
  .section-cta .btn,.section-cta .btn-sm{width:100%;justify-content:center;}
  .stat-callout{flex-direction:column;gap:10px;}
  .status-bar{flex-direction:column;gap:10px;padding:15px;}
  .bar-sep{display:none;}
  .footer-conversion-strip{flex-direction:column;align-items:flex-start;}
  .footer-conversion-cta{align-self:stretch;text-align:center;}
  .scenario-import-link{width:100%;justify-content:center;}
}
@media(max-width:460px){
  .flow-grid{grid-template-columns:1fr;}
  .flow-step+.flow-step{border-left:none;border-top:1px solid var(--border);}
}
@media print{
  .product-terminal-bar,.terminal-cta{display:none;}
  body{background:#fff;color:#000;}
}
</style>



</body>
</html>
