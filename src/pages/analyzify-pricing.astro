        <div class="cost-pill"><div class="cost-v">$99/mo</div><div class="cost-l">Growth (GA4+CAPI)</div></div>
        <div class="cost-pill"><div class="cost-v" style="color:var(--amber);">$299/mo</div><div class="cost-l">Pro (all platforms)</div></div>
        <div class="cost-pill"><div class="cost-v" style="color:var(--g);">$1,188</div><div class="cost-l">Annual Growth cost</div></div>
        <div class="cost-pill"><div class="cost-v" style="color:var(--red);">$3,588</div><div class="cost-l">Annual Pro cost</div></div>
      </div>
      <div class="hero-ctas">
        <a href="#tiers" class="btn-outline" onclick="event.preventDefault();document.getElementById('tiers').scrollIntoView({behavior:'smooth'})">See Both Plans <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 9l6 6 6-6"></path></svg></a>
