        <div style="background:var(--bg-3);padding:12px 18px;font-family:var(--mono);font-size:10px;font-weight:700;color:var(--text-4);letter-spacing:.12em;">// ANNUAL COST vs FREE ALTERNATIVE</div>
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);"><th style="padding:11px 18px;text-align:left;color:var(--text-4);font-weight:500;">Option</th><th style="padding:11px 18px;text-align:right;color:var(--text-4);font-weight:500;">Monthly</th><th style="padding:11px 18px;text-align:right;color:var(--text-4);font-weight:500;">Annual</th><th style="padding:11px 18px;text-align:left;color:var(--text-4);font-weight:500;">Platforms covered</th></tr></thead>
          <tbody>
            <tr style="border-bottom:1px solid var(--border);background:rgba(0,200,100,.03);"><td style="padding:11px 18px;color:var(--text);font-weight:600;">Free stack (CAPI Shield + TikTok + GA4 native)</td><td style="padding:11px 18px;text-align:right;color:var(--g);font-weight:700;">$0</td><td style="padding:11px 18px;text-align:right;color:var(--g);">$0</td><td style="padding:11px 18px;color:var(--text-3);">Meta, Google, TikTok, GA4</td></tr>
            <tr style="border-bottom:1px solid var(--border);"><td style="padding:11px 18px;color:var(--text-3);">Analyzify Growth</td><td style="padding:11px 18px;text-align:right;color:var(--text-3);">$99</td><td style="padding:11px 18px;text-align:right;color:var(--amber);">$1,188</td><td style="padding:11px 18px;color:var(--text-3);">Meta, Google, GA4</td></tr>
            <tr><td style="padding:11px 18px;color:var(--text-3);">Analyzify Pro</td><td style="padding:11px 18px;text-align:right;color:var(--amber);">$299</td><td style="padding:11px 18px;text-align:right;color:var(--red);">$3,588</td><td style="padding:11px 18px;color:var(--text-3);">Meta, Google, TikTok, Pinterest, Snapchat, GA4</td></tr>
