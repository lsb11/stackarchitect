    // ── APP LIBRARY ────────────────────────────────────────────────
    const appLibrary = [
      { name:"Klaviyo",            match:["klaviyo","_learnq","kly"],                               cost:150, category:"Email Marketing",  replacementLabel:"Replace with Systeme.io Free",      replacementUrl:"/go/systeme" },
      { name:"Attentive",          match:["attn.tv","attentive","attn"],                             cost:200, category:"SMS Marketing",    replacementLabel:"Replace with Systeme.io Free",      replacementUrl:"/go/systeme" },
      { name:"Postscript",         match:["postscript","ps-sdk"],                                    cost:100, category:"SMS Marketing",    replacementLabel:"Replace with Systeme.io Free",      replacementUrl:"/go/systeme" },
      { name:"Drip",               match:["drip.com","dc.js"],                                      cost:100, category:"Email Marketing",  replacementLabel:"Replace with Systeme.io Free",      replacementUrl:"/go/systeme" },
      { name:"Omnisend",           match:["omnisend","omisend"],                                     cost:80,  category:"Email Marketing",  replacementLabel:"Replace with Systeme.io Free",      replacementUrl:"/go/systeme" },
      { name:"Mailchimp",          match:["mailchimp","chimpstatic","list-manage"],                  cost:60,  category:"Email Marketing",  replacementLabel:"Replace with Systeme.io Free",      replacementUrl:"/go/systeme" },
      { name:"Triple Whale",       match:["triplewhale","triple-whale","triplewhale.com"],           cost:150, category:"Analytics",        replacementLabel:"Replace with CAPI Shield Free",     replacementUrl:"/go/make" },
      { name:"Northbeam",          match:["northbeam","nb.js"],                                     cost:300, category:"Attribution",      replacementLabel:"Replace with CAPI Shield Free",     replacementUrl:"/go/make" },
      { name:"Elevar",             match:["elevar","getelevar"],                                     cost:200, category:"Tracking",         replacementLabel:"Replace with CAPI Shield Free",     replacementUrl:"/go/make" },
      { name:"Rockerbox",          match:["rockerbox","rdr.io"],                                    cost:250, category:"Attribution",      replacementLabel:"Replace with CAPI Shield Free",     replacementUrl:"/go/make" },
      { name:"Heap Analytics",     match:["heap","heapanalytics"],                                   cost:80,  category:"Analytics",        replacementLabel:"Replace with CAPI Shield Free",     replacementUrl:"/go/make" },
      { name:"Recharge",           match:["recharge","rc-widget","rechargepayments"],                cost:100, category:"Subscriptions",    replacementLabel:"Replace with Make.com Free",        replacementUrl:"/go/make" },
      { name:"Bold Subscriptions", match:["boldcommerce","bold-subscriptions","bold_subscriptions"], cost:80,  category:"Subscriptions",    replacementLabel:"Replace with Make.com Free",        replacementUrl:"/go/make" },
      { name:"Stocky",             match:["stocky","shopify-stocky"],                               cost:50,  category:"Inventory",        replacementLabel:"Replace with Stocky Swap Free",     replacementUrl:"/go/make" },
      { name:"Inventory Planner",  match:["inventory-planner","inventoryplanner"],                   cost:100, category:"Inventory",        replacementLabel:"Replace with Stocky Swap Free",     replacementUrl:"/go/make" },
      { name:"Skubana",            match:["skubana","ordoro"],                                      cost:200, category:"Inventory",        replacementLabel:"Replace with Stocky Swap Free",     replacementUrl:"/go/make" },
      { name:"Gorgias",            match:["gorgias","gorgias.js","gorgias-chat"],                   cost:100, category:"Customer Support", replacementLabel:"Reduce Costs with Make.com",        replacementUrl:"/go/make" },
      { name:"Zendesk",            match:["zendesk","zdassets","zopim"],                             cost:100, category:"Customer Support", replacementLabel:"Reduce Costs with Make.com",        replacementUrl:"/go/make" },
      { name:"Intercom",           match:["intercom","intercomcdn"],                                cost:150, category:"Customer Support", replacementLabel:"Reduce Costs with Make.com",        replacementUrl:"/go/make" },
      { name:"Yotpo",              match:["yotpo","yotpo.com"],                                     cost:80,  category:"Reviews",          replacementLabel:"Automate Reviews with Make.com",    replacementUrl:"/go/make" },
      { name:"Okendo",             match:["okendo","cdn.okendo"],                                    cost:100, category:"Reviews",          replacementLabel:"Automate Reviews with Make.com",    replacementUrl:"/go/make" },
      { name:"Stamped",            match:["stamped.io","stampedbadge"],                             cost:50,  category:"Reviews",          replacementLabel:"Automate Reviews with Make.com",    replacementUrl:"/go/make" },
      { name:"ShipBob",            match:["shipbob","sbtracking"],                                  cost:150, category:"Shipping",         replacementLabel:"Automate Shipping with Make.com",   replacementUrl:"/go/make" },
      { name:"Shipstation",        match:["shipstation","ss.affiliate"],                             cost:60,  category:"Shipping",         replacementLabel:"Automate Shipping with Make.com",   replacementUrl:"/go/make" },
      { name:"Zapier",             match:["zapier","hooks.zapier"],                                 cost:100, category:"Automation",       replacementLabel:"Replace Zapier with Make.com Free", replacementUrl:"/go/make" },
      { name:"Alloy Automation",   match:["alloy.co","runalloy"],                                   cost:150, category:"Automation",       replacementLabel:"Replace with Make.com Free",        replacementUrl:"/go/make" },
      { name:"Privy",              match:["privy","widget.privy"],                                  cost:50,  category:"Conversion",       replacementLabel:"Replace with Systeme.io Free",      replacementUrl:"/go/systeme" },
      { name:"CartHook",           match:["carthook","carthook.com"],                               cost:100, category:"Upsell",           replacementLabel:"Replace with Systeme.io Free",      replacementUrl:"/go/systeme" },
      { name:"ReConvert",          match:["reconvert","reconv"],                                    cost:50,  category:"Upsell",           replacementLabel:"Automate with Make.com Free",       replacementUrl:"/go/make" },
      { name:"Smile.io",           match:["smile.io","cdn.smile.io","smile_ui"],                    cost:100, category:"Loyalty",          replacementLabel:"Automate Loyalty with Make.com",    replacementUrl:"/go/make" },
      { name:"LoyaltyLion",        match:["loyaltylion","lng.js"],                                 cost:100, category:"Loyalty",          replacementLabel:"Automate Loyalty with Make.com",    replacementUrl:"/go/make" }
    ];

    const solutionCards = [
      { label:"Ad Tracking",     title:"CAPI Shield — Free Server-Side Tracking",  desc:"Recover lost conversion data by sending purchase events directly to Google Ads and Meta — bypassing iOS tracking limits and ad blockers.",             url:"/go/make",                      cta:"Deploy Free →" },
      { label:"Inventory",       title:"Stocky Swap — Free Inventory Automation",  desc:"Replace paid inventory apps by syncing Shopify orders to Google Sheets automatically. Zero monthly fees, complete data ownership.",                      url:"/go/make",                      cta:"Activate Free →" },
      { label:"Email & Funnels", title:"Systeme.io — Free Email & CRM",            desc:"Replace Klaviyo and Mailchimp with Systeme.io's free plan — funnels, email sequences, automation, and CRM all included at $0/month.",                   url:"/go/systeme", cta:"Replace Free →" }
    ];

    let scanHistory = [];
    try { scanHistory = JSON.parse(sessionStorage.getItem('sa_scan_history') || '[]'); } catch(e) {}
    let currentMode = 'own';

    // ── BOOT ──────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('trigger-audit').addEventListener('click', runScan);
      document.getElementById('target-url').addEventListener('keydown', e => { if (e.key === 'Enter') runScan(); });
      document.getElementById('reset-btn').addEventListener('click', resetScanner);
      document.getElementById('email-submit-btn').addEventListener('click', submitEmail);
      document.getElementById('mode-own').addEventListener('click',        () => setMode('own'));
      document.getElementById('mode-competitor').addEventListener('click', () => setMode('competitor'));
      document.getElementById('mode-example').addEventListener('click',    toggleExample);
      ['1','2','3','4','5','6'].forEach(n => {
        const b = document.getElementById(`acc-btn-${n}`);
        if (b) b.addEventListener('click', () => toggleAccordion(`acc-${n}`));
      });
      document.querySelectorAll('.faq-trigger').forEach(b => b.addEventListener('click', () => toggleFaq(b)));
    });

    // ── MODE ──────────────────────────────────────────────────────
    function setMode(mode) {
      currentMode = mode;
      document.querySelectorAll('.competitor-toggle button').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed','false'); });
      const b = document.getElementById('mode-'+mode);
      b.classList.add('active'); b.setAttribute('aria-pressed','true');
      const lbl = document.getElementById('mode-label');
      const inp = document.getElementById('target-url');
      if (mode === 'own') { lbl.textContent = 'Enter your Shopify store domain below'; inp.placeholder = 'yourstore.com'; }
      else                { lbl.textContent = "Enter a competitor's Shopify store domain below"; inp.placeholder = 'competitor.com'; }
      document.getElementById('example-preview').classList.remove('visible');
      document.getElementById('mode-example').classList.remove('active');
      document.getElementById('mode-example').setAttribute('aria-pressed','false');
    }

    function toggleExample() {
      const p = document.getElementById('example-preview'), b = document.getElementById('mode-example');
      const v = p.classList.contains('visible');
      p.classList.toggle('visible',!v); b.classList.toggle('active',!v); b.setAttribute('aria-pressed',String(!v));
    }

    // ── SCAN ──────────────────────────────────────────────────────
    async function runScan() {
      const raw = document.getElementById('target-url').value.trim();
      if (!raw) { document.getElementById('target-url').focus(); return; }
      const domain = raw.replace(/^https?:\/\//,'').replace(/\/$/,'').toLowerCase().split('/')[0];

      const $r = document.getElementById('results-box'),
            $l = document.getElementById('loading-box'),
            $i = document.getElementById('input-area'),
            $t = document.querySelector('.competitor-toggle'),
            $m = document.getElementById('mode-label'),
            $e = document.getElementById('example-preview'),
            $p = document.getElementById('p-bar'),
            $s = document.getElementById('loader-status');

      $i.style.display='none'; $t.style.display='none'; $m.style.display='none';
      $e.classList.remove('visible'); $l.style.display='block'; $l.setAttribute('aria-busy','true'); $r.style.display='none';

      try {
        $p.style.width='20%'; $s.textContent='BYPASSING_STORE_FIREWALL...'; await sleep(700);
        $p.style.width='50%'; $s.textContent='DECRYPTING_INFRASTRUCTURE_SCRIPTS...';
        const res  = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent('https://'+domain)}&t=${Date.now()}`);
        const data = await res.json();
        const html = (data.contents||'').toLowerCase();
        if (!html||html.length<200) throw new Error('empty');
        $p.style.width='80%'; $s.textContent='ANALYZING_DOM_FOOTPRINTS...'; await sleep(600);
        const detected = appLibrary.filter(a => a.match.some(sig => html.includes(sig)));
        document.getElementById('scan-status').textContent  = currentMode==='competitor' ? 'COMPETITOR SCAN COMPLETE' : 'LIVE SCAN COMPLETE';
        document.getElementById('scan-status').style.color = 'var(--green)';
        renderResults(detected.length ? detected : defaultApps(), domain);
      } catch(err) {
        $p.style.width='90%'; $s.textContent='EXECUTING_FORENSIC_ESTIMATION...'; await sleep(900);
        document.getElementById('scan-status').textContent  = 'ESTIMATED SCAN COMPLETE';
        document.getElementById('scan-status').style.color = 'var(--warn)';
        renderResults(defaultApps(), domain);
      }
    }

    const sleep = ms => new Promise(r => setTimeout(r,ms));
    const defaultApps = () => ['Klaviyo','Triple Whale','Gorgias'].map(n => appLibrary.find(a => a.name===n)).filter(Boolean);

    // ── RENDER ────────────────────────────────────────────────────
    function renderResults(detected, domain) {
      document.getElementById('p-bar').style.width='100%';
      setTimeout(() => {
        const $l = document.getElementById('loading-box'), $r = document.getElementById('results-box');
        $l.style.display='none'; $l.setAttribute('aria-busy','false'); $r.style.display='block';

        const monthly     = detected.reduce((s,a) => s+a.cost, 0);
        const score       = Math.max(10, 100 - detected.length*14);
        const annualWaste = Math.round(monthly*12*0.45);

        document.getElementById('score-circle-element').style.setProperty('--score-deg',(score*3.6)+'deg');
        document.getElementById('score-val').textContent       = score;
        document.getElementById('score-label-val').textContent = score;
        document.getElementById('res-apps').textContent        = detected.length;
        document.getElementById('res-monthly').textContent     = '$'+monthly.toLocaleString();
        document.getElementById('res-waste').textContent       = '$'+annualWaste.toLocaleString();

        const hdr = document.querySelector('.result-header'), sub = document.querySelector('.result-sub');
        if      (score>=80) { hdr.textContent='✅ Well-Optimised Stack';       sub.textContent="Your stack is lean — but there are still savings available below."; }
        else if (score>=60) { hdr.textContent='⚠️ Savings Opportunity Found'; sub.textContent="Your stack has replaceable apps — here's how to cut costs."; }
        else                { hdr.textContent='⚠️ Efficiency Leak Detected';  sub.textContent="Your Shopify stack is creating unnecessary monthly overhead."; }

        const appList = document.getElementById('app-list');
        appList.innerHTML='';
        detected.forEach(app => {
          const row = document.createElement('div'); row.className='app-row';
          row.innerHTML=`<div class="app-info"><div class="app-dot" aria-hidden="true"></div><div><div class="app-name">${esc(app.name)}</div><div style="font-family:var(--mono);font-size:10px;color:#475569;letter-spacing:1px;text-transform:uppercase;margin-top:4px;">${esc(app.category)}</div></div></div><div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;"><span class="app-cost">~$${app.cost.toLocaleString()}/mo</span><a href="${app.replacementUrl}" class="app-replace-btn" target="_blank" rel="noopener noreferrer">${esc(app.replacementLabel)} →</a></div>`;
          appList.appendChild(row);
        });

        const cardsList = document.getElementById('solution-cards-list'); cardsList.innerHTML='';
        solutionCards.forEach(card => {
          const el = document.createElement('a'); el.href=card.url; el.target='_blank'; el.rel='noopener noreferrer'; el.className='solution-card';
          el.innerHTML=`<span class="solution-card-label">${esc(card.label)}</span><div class="solution-card-title">${esc(card.title)}</div><div class="solution-card-desc">${esc(card.desc)}</div><span class="solution-card-cta">${esc(card.cta)}</span>`;
          cardsList.appendChild(el);
        });

        const names = detected.map(a=>`<strong style="color:#fff;">${esc(a.name)}</strong>`).join(', ');
        document.getElementById('diag-text').innerHTML=
          `We detected <strong style="color:#fff;">${detected.length} paid app${detected.length!==1?'s':''}</strong> on `+
          `<strong style="color:#fff;">${esc(domain)}</strong> — including ${names} — `+
          `costing an estimated <strong style="color:var(--red);">$${monthly.toLocaleString()}/month</strong>. `+
          `Replacing with free automation via Make.com, Google Sheets, and Systeme.io could recover approximately `+
          `<strong style="color:var(--green);">$${annualWaste.toLocaleString()}/year</strong>.`;

        const tweet=`⚠️ Shopify Efficiency Leak on ${domain}\n\n${detected.length} paid apps — ~$${monthly.toLocaleString()}/mo overhead\nEfficiency score: ${score}/100\n\nAudit your store free:`;
        document.getElementById('share-link').href=`https://twitter.com/intent/tweet?text=${encodeURIComponent(tweet)}&url=${encodeURIComponent('https://stackarchitect.xyz/shopify-automation-scanner')}`;

        const entry={domain,apps:detected.length,monthly,score,time:new Date().toLocaleTimeString()};
        scanHistory.unshift(entry); if(scanHistory.length>5) scanHistory=scanHistory.slice(0,5);
        try{ sessionStorage.setItem('sa_scan_history',JSON.stringify(scanHistory)); }catch(e){}
        renderHistory();

        if(score>75 && typeof confetti==='function') confetti({particleCount:100,spread:70,origin:{y:0.6}});
        document.getElementById('results-box').scrollIntoView({behavior:'smooth',block:'start'});
      },400);
    }

    // ── HISTORY ───────────────────────────────────────────────────
    function renderHistory() {
      if(scanHistory.length<2) return;
      document.getElementById('history-container').style.display='block';
      const list=document.getElementById('history-list'); list.innerHTML='';
      scanHistory.slice(1).forEach(entry => {
        const item=document.createElement('div'); item.className='history-item';
        item.setAttribute('role','button'); item.setAttribute('tabindex','0'); item.setAttribute('aria-label',`Re-scan ${entry.domain}`);
        item.innerHTML=`<span class="history-domain">${esc(entry.domain)}</span><div style="display:flex;gap:16px;flex-wrap:wrap;"><span class="history-badge">${entry.apps} apps</span><span class="history-badge" style="color:var(--red);">$${entry.monthly}/mo</span><span class="history-badge">Score: ${entry.score}</span><span class="history-badge" style="color:var(--green);">↺ rescan</span></div>`;
        const go=()=>{ document.getElementById('target-url').value=entry.domain; resetScanner(); setTimeout(runScan,100); };
        item.addEventListener('click',go); item.addEventListener('keydown',e=>{ if(e.key==='Enter'||e.key===' ') go(); });
        list.appendChild(item);
      });
    }

    // ── RESET ─────────────────────────────────────────────────────
    function resetScanner() {
      document.getElementById('results-box').style.display='none';
      document.getElementById('input-area').style.display='block';
      document.querySelector('.competitor-toggle').style.display='block';
      document.getElementById('mode-label').style.display='block';
      document.getElementById('p-bar').style.width='0%';
      const inp=document.getElementById('target-url'); inp.value=''; inp.focus();
      document.getElementById('scanner-v1-root').scrollIntoView({behavior:'smooth',block:'start'});
    }

    // ── EMAIL ─────────────────────────────────────────────────────
    function submitEmail() {
      const inp=document.getElementById('capture-email');
      if(!inp.value.trim()||!inp.value.includes('@')){ inp.style.borderColor='var(--red)'; inp.focus(); return; }
      window.open('/go/systeme','_blank','noopener noreferrer');
      document.getElementById('email-success').style.display='block';
      inp.style.display='none'; document.getElementById('email-submit-btn').style.display='none';
    }

    // ── ACCORDIONS ────────────────────────────────────────────────
    function toggleAccordion(id) {
      const item=document.getElementById(id), isOpen=item.classList.contains('open');
      document.querySelectorAll('.accordion-item').forEach(i=>{ i.classList.remove('open'); const b=i.querySelector('.accordion-trigger'); if(b) b.setAttribute('aria-expanded','false'); });
      if(!isOpen){ item.classList.add('open'); item.querySelector('.accordion-trigger').setAttribute('aria-expanded','true'); }
    }

    function toggleFaq(btn) {
      const item=btn.closest('.faq-item-outer'), isOpen=item.classList.contains('open');
      document.querySelectorAll('.faq-item-outer').forEach(i=>{ i.classList.remove('open'); i.querySelector('.faq-trigger').setAttribute('aria-expanded','false'); });
      if(!isOpen){ item.classList.add('open'); btn.setAttribute('aria-expanded','true'); }
    }

    // ── XSS ESCAPE ────────────────────────────────────────────────
    function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
  </script>
</body>
</html>
