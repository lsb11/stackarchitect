      { name:"LoyaltyLion",        match:["loyaltylion","lng.js"],                                cost:100, category:"Loyalty",          replacement:"make",    replacementLabel:"Automate Loyalty with Make.com",     replacementUrl:"https://www.make.com/en/register?pc=techie123" },
    ];

    const solutionCards = [
      {
        label: "Ad Tracking",
        title: "CAPI Shield — Free Server-Side Tracking",
        desc: "Recover lost conversion data by sending purchase events directly to Google Ads and Meta — bypassing iOS tracking limits and browser restrictions.",
        url: "https://www.make.com/en/register?pc=techie123",
        cta: "Deploy Free →"
      },
      {
        label: "Inventory",
        title: "Stocky Swap — Free Inventory Automation",
        desc: "Replace paid inventory apps by syncing Shopify orders to Google Sheets automatically. Zero monthly fees, complete data ownership.",
        url: "https://www.make.com/en/register?pc=techie123",
        cta: "Activate Free →"
      },
      {
        label: "Email & Funnels",
        title: "Systeme.io — Free Email & CRM",
        desc: "Replace Klaviyo and Mailchimp with Systeme.io's free plan — funnels, email sequences, automation, and CRM all included at $0/month.",
        url: "https://systeme.io/?sa=sa0262937272be99703a8ea16153f5dd5ae2a3eea7",
        cta: "Replace Free →"
      }
    ];

    // ============================================================
    // STATE
    // ============================================================
    let scanHistory = [];
    try { scanHistory = JSON.parse(sessionStorage.getItem('sa_scan_history') || '[]'); } catch(e) {}
    let currentMode = 'own';

    // ============================================================
    // BOOT: wire up event listeners once DOM is ready
    // ============================================================
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('trigger-audit').addEventListener('click', runScan);
      document.getElementById('target-url').addEventListener('keydown', e => { if (e.key === 'Enter') runScan(); });
      document.getElementById('reset-btn').addEventListener('click', resetScanner);
      document.getElementById('email-submit-btn').addEventListener('click', submitEmail);

      // Mode toggle buttons
      document.getElementById('mode-own').addEventListener('click', () => setMode('own'));
      document.getElementById('mode-competitor').addEventListener('click', () => setMode('competitor'));
      document.getElementById('mode-example').addEventListener('click', toggleExample);

      // Accordion buttons (SEO section)
      ['1','2','3','4','5','6'].forEach(n => {
        const btn = document.getElementById(`acc-btn-${n}`);
        if (btn) btn.addEventListener('click', () => toggleAccordion(`acc-${n}`));
      });

      // FAQ triggers (delegated)
      document.querySelectorAll('.faq-trigger').forEach(btn => {
        btn.addEventListener('click', () => toggleFaq(btn));
      });
    });

    // ============================================================
    // MODE & EXAMPLE TOGGLES
    // ============================================================
    function setMode(mode) {
      currentMode = mode;
      document.querySelectorAll('.competitor-toggle button').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      const activeBtn = document.getElementById('mode-' + mode);
      activeBtn.classList.add('active');
      activeBtn.setAttribute('aria-pressed', 'true');

      const label = document.getElementById('mode-label');
      const input = document.getElementById('target-url');
      if (mode === 'own') {
        label.textContent = 'Enter your Shopify store domain below';
        input.placeholder = 'yourstore.com';
      } else {
        label.textContent = 'Enter a competitor\'s Shopify store domain below';
        input.placeholder = 'competitor.com';
      }
      document.getElementById('example-preview').classList.remove('visible');
      document.getElementById('mode-example').classList.remove('active');
      document.getElementById('mode-example').setAttribute('aria-pressed', 'false');
    }

    function toggleExample() {
      const preview = document.getElementById('example-preview');
      const btn = document.getElementById('mode-example');
      const isVisible = preview.classList.contains('visible');
      preview.classList.toggle('visible', !isVisible);
      btn.classList.toggle('active', !isVisible);
      btn.setAttribute('aria-pressed', String(!isVisible));
    }

    // ============================================================
    // SCAN LOGIC
    // ============================================================
    async function runScan() {
      let raw = document.getElementById('target-url').value.trim();
      if (!raw) { document.getElementById('target-url').focus(); return; }

      // Sanitise input
      const domain = raw
        .replace(/^https?:\/\//, '')
        .replace(/\/$/, '')
        .toLowerCase()
        .split('/')[0];

      const resultsBox = document.getElementById('results-box');
      const loaderBox  = document.getElementById('loading-box');
      const inputArea  = document.getElementById('input-area');
      const pBar       = document.getElementById('p-bar');
      const loaderTxt  = document.getElementById('loader-status');
      const modeTabs   = document.querySelector('.competitor-toggle');
      const modeLabel  = document.getElementById('mode-label');
      const exPrev     = document.getElementById('example-preview');

      // Transition to loading state
      inputArea.style.display  = 'none';
      modeTabs.style.display   = 'none';
      modeLabel.style.display  = 'none';
      exPrev.classList.remove('visible');
      loaderBox.style.display  = 'block';
      loaderBox.setAttribute('aria-busy', 'true');
      resultsBox.style.display = 'none';

      const steps = [
        [20,  700, "BYPASSING_STORE_FIREWALL..."],
        [50,  0,   "DECRYPTING_INFRASTRUCTURE_SCRIPTS..."],
        [80,  600, "ANALYZING_DOM_FOOTPRINTS..."],
      ];

      try {
        for (const [pct, delay, msg] of steps) {
          pBar.style.width = pct + '%';
          loaderTxt.textContent = msg;
          if (delay) await sleep(delay);
        }

        const res  = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent('https://' + domain)}&t=${Date.now()}`);
        const data = await res.json();
        const html = (data.contents || '').toLowerCase();

        if (!html || html.length < 200) throw new Error('Empty response');

        const detected = appLibrary.filter(app => app.match.some(sig => html.includes(sig)));
        const final = detected.length > 0 ? detected : getDefaultApps();

        document.getElementById('scan-status').textContent = currentMode === 'competitor'
          ? 'COMPETITOR SCAN COMPLETE'
          : 'LIVE SCAN COMPLETE';
        document.getElementById('scan-status').style.color = 'var(--brand-green)';

        renderResults(final, domain);

      } catch (err) {
        // Graceful fallback — forensic estimation mode
        console.info('[Scanner] Falling back to estimation:', err.message);
        pBar.style.width = '90%';
        loaderTxt.textContent = 'EXECUTING_FORENSIC_ESTIMATION...';
        await sleep(900);

        document.getElementById('scan-status').textContent = 'ESTIMATED SCAN COMPLETE';
        document.getElementById('scan-status').style.color = 'var(--brand-warn)';
        renderResults(getDefaultApps(), domain);
      }
    }

    const sleep = ms => new Promise(r => setTimeout(r, ms));

    function getDefaultApps() {
      return ['Klaviyo', 'Triple Whale', 'Gorgias']
        .map(name => appLibrary.find(a => a.name === name))
        .filter(Boolean);
    }

    // ============================================================
    // RENDER RESULTS
    // ============================================================
    function renderResults(detected, domain) {
      document.getElementById('p-bar').style.width = '100%';

      setTimeout(() => {
        const loaderBox  = document.getElementById('loading-box');
        const resultsBox = document.getElementById('results-box');

        loaderBox.style.display  = 'none';
        loaderBox.setAttribute('aria-busy', 'false');
        resultsBox.style.display = 'block';

        const monthly     = detected.reduce((s, a) => s + a.cost, 0);
        const score       = Math.max(10, 100 - (detected.length * 14));
        const annualWaste = Math.round(monthly * 12 * 0.45);

        // Animate score circle
        document.getElementById('score-circle-element').style.setProperty('--score-deg', (score * 3.6) + 'deg');
        document.getElementById('score-val').textContent        = score;
        document.getElementById('score-label-val').textContent  = score;
        document.getElementById('res-apps').textContent         = detected.length;
        document.getElementById('res-monthly').textContent      = '$' + monthly.toLocaleString();
        document.getElementById('res-waste').textContent        = '$' + annualWaste.toLocaleString();

        // Update heading based on score
        const header = document.querySelector('.result-header');
        const sub    = document.querySelector('.result-sub');
        if (score >= 80) {
          header.textContent = '✅ Well-Optimised Stack';
          sub.textContent    = 'Your Shopify stack is lean — but there are still savings available below.';
        } else if (score >= 60) {
          header.textContent = '⚠️ Savings Opportunity Found';
          sub.textContent    = 'Your stack has replaceable apps — here\'s how to cut costs.';
        } else {
          header.textContent = '⚠️ Efficiency Leak Detected';
          sub.textContent    = 'Your Shopify stack is creating unnecessary monthly overhead.';
        }

        // Render app rows
        const appList = document.getElementById('app-list');
        appList.innerHTML = '';
        detected.forEach(app => {
          const row = document.createElement('div');
          row.className = 'app-row';
          row.innerHTML = `
            <div class="app-info">
              <div class="app-dot" aria-hidden="true"></div>
              <div>
                <div class="app-name">${escHtml(app.name)}</div>
                <div style="font-family:var(--mono);font-size:10px;color:#475569;letter-spacing:1px;text-transform:uppercase;margin-top:4px;">${escHtml(app.category)}</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
              <span class="app-cost">~$${app.cost.toLocaleString()}/mo</span>
              <a href="${app.replacementUrl}" class="app-replace-btn" target="_blank" rel="noopener noreferrer" aria-label="Replace ${escHtml(app.name)} for free">${escHtml(app.replacementLabel)} →</a>
            </div>
          `;
          appList.appendChild(row);
        });

        // Render solution cards
        const cardsList = document.getElementById('solution-cards-list');
        cardsList.innerHTML = '';
        solutionCards.forEach(card => {
          const el = document.createElement('a');
          el.href      = card.url;
          el.target    = '_blank';
          el.rel       = 'noopener noreferrer';
          el.className = 'solution-card';
          el.setAttribute('aria-label', `${card.title} — ${card.desc}`);
          el.innerHTML = `
            <span class="solution-card-label">${escHtml(card.label)}</span>
            <div class="solution-card-title">${escHtml(card.title)}</div>
            <div class="solution-card-desc">${escHtml(card.desc)}</div>
            <span class="solution-card-cta">${escHtml(card.cta)}</span>
          `;
          cardsList.appendChild(el);
        });

        // Dynamic diagnostic copy
        const appNames = detected.map(a => `<strong style="color:#fff;">${escHtml(a.name)}</strong>`).join(', ');
        document.getElementById('diag-text').innerHTML =
          `We detected <strong style="color:#fff;">${detected.length} paid app${detected.length !== 1 ? 's' : ''}</strong> on ` +
          `<strong style="color:#fff;">${escHtml(domain)}</strong> — including ${appNames} — ` +
          `costing an estimated <strong style="color:var(--brand-red);">$${monthly.toLocaleString()}/month</strong>. ` +
          `Based on typical stack optimisation, you could recover approximately ` +
          `<strong style="color:var(--brand-green);">$${annualWaste.toLocaleString()}/year</strong> by replacing these with ` +
          `free automation workflows using Make.com, Google Sheets, and Systeme.io.`;

        // Twitter share
        const tweetText = `⚠️ Shopify Efficiency Leak Detected on ${domain}\n\n${detected.length} paid apps — ~$${monthly.toLocaleString()}/mo overhead\nEfficiency score: ${score}/100\n\nAudit your store free:`;
        document.getElementById('share-link').href =
          `https://twitter.com/intent/tweet?text=${encodeURIComponent(tweetText)}&url=${encodeURIComponent('https://www.stackarchitect.xyz/shopify-automation-scanner')}`;

        // Save to session history
        const entry = { domain, apps: detected.length, monthly, score, time: new Date().toLocaleTimeString() };
        scanHistory.unshift(entry);
        if (scanHistory.length > 5) scanHistory = scanHistory.slice(0, 5);
        try { sessionStorage.setItem('sa_scan_history', JSON.stringify(scanHistory)); } catch(e) {}
        renderHistory();

        // Confetti if great score
        if (score > 75 && typeof confetti === 'function') {
          confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 } });
        }

        // Smooth scroll to results
        resultsBox.scrollIntoView({ behavior: 'smooth', block: 'start' });

      }, 400);
    }

    // ============================================================
    // SCAN HISTORY
    // ============================================================
    function renderHistory() {
      if (scanHistory.length < 2) return;
      const container = document.getElementById('history-container');
      const list      = document.getElementById('history-list');
      container.style.display = 'block';
      list.innerHTML = '';

      scanHistory.slice(1).forEach(entry => {
        const item = document.createElement('div');
        item.className = 'history-item';
        item.setAttribute('role', 'button');
        item.setAttribute('tabindex', '0');
        item.setAttribute('aria-label', `Re-scan ${entry.domain}`);
        item.innerHTML = `
          <span class="history-domain">${escHtml(entry.domain)}</span>
          <div style="display:flex;gap:16px;flex-wrap:wrap;">
            <span class="history-badge">${entry.apps} apps</span>
            <span class="history-badge" style="color:var(--brand-red);">$${entry.monthly}/mo</span>
            <span class="history-badge">Score: ${entry.score}</span>
            <span class="history-badge" style="color:var(--brand-green);">↺ rescan</span>
          </div>
        `;
        const rescan = () => {
          document.getElementById('target-url').value = entry.domain;
          resetScanner();
          setTimeout(runScan, 100);
        };
        item.addEventListener('click', rescan);
        item.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') rescan(); });
        list.appendChild(item);
      });
    }

    // ============================================================
    // RESET
    // ============================================================
    function resetScanner() {
      document.getElementById('results-box').style.display = 'none';
      document.getElementById('input-area').style.display  = 'block';
      document.querySelector('.competitor-toggle').style.display = 'block';
      document.getElementById('mode-label').style.display  = 'block';
      document.getElementById('p-bar').style.width = '0%';
      const input = document.getElementById('target-url');
      input.value = '';
      input.focus();
      document.getElementById('scanner-v1-root').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ============================================================
    // EMAIL CAPTURE
    // ============================================================
    function submitEmail() {
      const emailEl = document.getElementById('capture-email');
      const email   = emailEl.value.trim();
      if (!email || !email.includes('@')) {
        emailEl.style.borderColor = 'var(--brand-red)';
        emailEl.focus();
        return;
      }
      window.open('https://systeme.io/?sa=sa0262937272be99703a8ea16153f5dd5ae2a3eea7', '_blank', 'noopener noreferrer');
      document.getElementById('email-success').style.display = 'block';
      emailEl.style.display = 'none';
      document.getElementById('email-submit-btn').style.display = 'none';
    }

    // ============================================================
    // ACCORDION — SEO content section
    // ============================================================
    function toggleAccordion(id) {
      const item   = document.getElementById(id);
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.accordion-item').forEach(i => {
        i.classList.remove('open');
        const btn = i.querySelector('.accordion-trigger');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        item.querySelector('.accordion-trigger').setAttribute('aria-expanded', 'true');
      }
    }

    // ============================================================
    // FAQ ACCORDION
    // ============================================================
    function toggleFaq(btn) {
      const item   = btn.closest('.faq-item-outer');
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item-outer').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    }

    // ============================================================
    // XSS UTILITY
    // ============================================================
    function escHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }
  </script>
