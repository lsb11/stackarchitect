---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const SITE_URL = "https://stackarchitect.xyz";
const PAGE_URL = `${SITE_URL}/shopify-automation-scanner/`;
const DATE_MOD = "2026-04-14";

const title       = "Shopify Automation Scanner — Free App Audit Tool (Detect Apps, Cut Costs)";
const description = "Free Shopify app scanner. Enter any store domain to detect active apps, calculate monthly costs, identify automation savings, and find free replacements. Trusted by 2,400+ Shopify store owners.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${PAGE_URL}#webpage`,
      "url": PAGE_URL,
      "name": "Free Shopify Automation Scanner — Detect Apps, Calculate Costs, Find Free Replacements",
      "headline": "Shopify Automation Scanner — Scan Any Store in 30 Seconds",
      "description": description,
      "inLanguage": "en-GB",
      "dateModified": DATE_MOD,
      "isPartOf": { "@id": `${SITE_URL}/#website` },
      "about": [
        { "@type": "Thing", "name": "Shopify App Detection" },
        { "@type": "Thing", "name": "Shopify Automation Audit" },
        { "@type": "Thing", "name": "Shopify App Cost Calculator" },
        { "@type": "Thing", "name": "Free Shopify App Alternatives" }
      ],
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",  "item": SITE_URL },
          { "@type": "ListItem", "position": 2, "name": "Tools", "item": `${SITE_URL}/tools` },
          { "@type": "ListItem", "position": 3, "name": "Shopify Automation Scanner", "item": PAGE_URL }
        ]
      }
    },
    {
      "@type": "WebApplication",
      "name": "Shopify Automation Scanner",
      "url": PAGE_URL,
      "description": "Free tool to scan any Shopify store, detect installed apps, calculate monthly subscription costs, and identify free automation replacements.",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "featureList": [
        "Detect active Shopify apps from any public store",
        "Calculate estimated monthly app costs",
        "Identify free automation replacements",
        "Generate automation efficiency score",
        "Scan competitor stores",
        "No login required"
      ]},
    {
      "@type": "HowTo",
      "name": "How to Scan Your Shopify Store for App Cost Savings",
      "description": "Use the free Shopify Automation Scanner to detect active apps, calculate monthly costs, and find free replacements in under 30 seconds.",
      "totalTime": "PT30S",
      "estimatedCost": { "@type": "MonetaryAmount", "currency": "USD", "value": "0" },
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Enter your store domain",  "text": "Type your Shopify store domain into the scanner input field. No login or Shopify access required." },
        { "@type": "HowToStep", "position": 2, "name": "Initiate the audit",       "text": "Click Initiate Audit. The scanner analyses your store's public frontend code for app signatures in under 30 seconds." },
        { "@type": "HowToStep", "position": 3, "name": "Review your results",      "text": "See your efficiency score, detected apps, estimated monthly costs, and potential annual savings." },
        { "@type": "HowToStep", "position": 4, "name": "Replace apps for free",    "text": "Use the free replacement links to swap each detected paid app with a free automation workflow via Make.com, Systeme.io, or Google Sheets." }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is the Shopify Automation Scanner?",      "acceptedAnswer": { "@type": "Answer", "text": "A free tool that scans any public Shopify store to detect installed apps, estimate monthly subscription costs, and identify which apps can be replaced with free automation workflows." } },
        { "@type": "Question", "name": "How does the Shopify app scanner work?",       "acceptedAnswer": { "@type": "Answer", "text": "The scanner fetches your store's public frontend HTML and analyses script signatures, tracking pixels, and widget code to identify which third-party apps are installed. It cross-references these against a database of 30+ common Shopify apps with their typical subscription costs." } },
        { "@type": "Question", "name": "Can I scan a competitor's Shopify store?",     "acceptedAnswer": { "@type": "Answer", "text": "Yes. The scanner only reads publicly visible frontend code, so you can scan any public Shopify store including competitor stores without any authentication." } },
        { "@type": "Question", "name": "Is the Shopify Automation Scanner free?",      "acceptedAnswer": { "@type": "Answer", "text": "Yes, completely free. No account, login, or credit card required." } },
        { "@type": "Question", "name": "What apps can the scanner detect?",            "acceptedAnswer": { "@type": "Answer", "text": "Over 30 common Shopify apps including Klaviyo, Triple Whale, Gorgias, Recharge, Attentive, Zapier, Yotpo, Postscript, Zendesk, Shipstation, Smile.io, Northbeam, Elevar, and many more." } },
        { "@type": "Question", "name": "How accurate are the cost estimates?",         "acceptedAnswer": { "@type": "Answer", "text": "Cost estimates are based on typical mid-tier pricing and are directional rather than exact. Actual costs vary by plan, usage, and negotiated rates." } }
      ]
    }
  ]
};
---

<!DOCTYPE html>
<html lang="en-GB" style="background:#020617;">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{title}</title>
  <meta name="description"  content={description} />
  <meta name="author"       content="Stack Architect" />
  <meta name="keywords"     content="shopify automation scanner, shopify app scanner, free shopify audit, replace klaviyo, triple whale alternative, shopify app cost calculator, shopify cost savings" />
  <link rel="canonical"     href={PAGE_URL} />

  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={PAGE_URL} />
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="Stack Architect" />
  <meta property="og:image"       content={`${SITE_URL}/og-scanner.png`} />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={`${SITE_URL}/og-scanner.png`} />

  <!-- Dark chrome on mobile — matches site background exactly -->
  <meta name="theme-color" content="#020617" />

  <!-- Performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.allorigins.win" />
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=JetBrains+Mono:wght@500;800&display=swap"
    rel="stylesheet"
  />

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <style>
    /* ── DESIGN TOKENS ─────────────────────────────────────────── */
    :root {
      --green:   #00a854;
      --red:     #ff4d4d;
      --warn:    #ffbb33;
      --dark:    #020617;
      --inter:   'Inter', sans-serif;
      --mono:    'JetBrains Mono', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; }

    /* ── GLOBAL DARK BACKGROUND ─────────────────────────────────
       Covers html + body so zero white shows between nav, scanner
       hero, SEO sections, footer at any viewport or scroll depth. */
    html, body {
      background: var(--dark);
      margin: 0;
      padding: 0;
      min-height: 100%;
    }
    body {
      font-family: var(--inter);
      color: #f8fafc;
      -webkit-font-smoothing: antialiased;
    }

    /* ── SCANNER HERO ────────────────────────────────────────── */
    #scanner-v1-root {
      font-family: var(--inter);
      color: #f8fafc;
      /* Radial lift fades cleanly into the global dark body */
      background: radial-gradient(circle at 50% 0%, #1e293b 0%, var(--dark) 68%);
      padding: 80px 40px 100px;
      line-height: 1.6;
      position: relative;
    }

    /* ── TRUST BAR ───────────────────────────────────────────── */
    .trust-bar  { display:flex; align-items:center; justify-content:center; gap:24px; flex-wrap:wrap; margin-bottom:50px; padding:16px 20px; background:rgba(0,168,84,.05); border:1px solid rgba(0,168,84,.15); border-radius:12px; }
    .trust-item { font-family:var(--mono); font-size:9px; color:#64748b; letter-spacing:1.5px; text-transform:uppercase; display:flex; align-items:center; gap:8px; }
    .trust-dot  { width:5px; height:5px; background:var(--green); border-radius:50%; flex-shrink:0; }
    .trust-sep  { width:1px; height:12px; background:rgba(255,255,255,.08); }

    /* ── MODE TOGGLE ─────────────────────────────────────────── */
    .competitor-toggle { text-align:center; margin-bottom:20px; }
    .competitor-toggle button { font-family:var(--mono); font-size:10px; font-weight:800; letter-spacing:1.5px; text-transform:uppercase; color:#475569; background:none; border:1px solid rgba(255,255,255,.06); padding:8px 20px; border-radius:20px; cursor:pointer; transition:all .3s; margin:0 6px 8px; }
    .competitor-toggle button:hover,
    .competitor-toggle button.active { color:var(--green); border-color:rgba(0,168,84,.4); background:rgba(0,168,84,.05); }

    /* ── EXAMPLE PREVIEW ─────────────────────────────────────── */
    .example-preview { margin:30px 0 0; padding:20px 24px; background:rgba(255,255,255,.02); border:1px solid rgba(255,255,255,.05); border-radius:16px; display:none; }
    .example-preview.visible { display:block; }
    .preview-label { font-family:var(--mono); font-size:9px; color:var(--warn); letter-spacing:2px; margin-bottom:14px; display:block; }
    .preview-row   { display:flex; align-items:center; justify-content:space-between; padding:10px 0; border-bottom:1px solid rgba(255,255,255,.03); font-size:13px; gap:12px; flex-wrap:wrap; }
    .preview-row:last-child { border-bottom:none; }
    .preview-app   { font-weight:700; color:#f8fafc; }
    .preview-cost  { font-family:var(--mono); font-size:11px; color:var(--red); }
    .preview-badge { font-family:var(--mono); font-size:8px; color:var(--green); border:1px solid rgba(0,168,84,.3); padding:3px 8px; border-radius:3px; }

    /* ── SCAN STATUS ─────────────────────────────────────────── */
    #scan-status { display:inline-block; font-family:var(--mono); font-size:10px; letter-spacing:2px; padding:6px 12px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:6px; margin-bottom:20px; color:var(--green); }

    /* ── SCORE CIRCLE ────────────────────────────────────────── */
    @property --score-deg { syntax: '<angle>'; inherits: false; initial-value: 0deg; }
    .score-circle { width:240px; height:240px; border-radius:50%; margin:0 auto 30px; display:flex; flex-direction:column; justify-content:center; position:relative; background:rgba(0,0,0,.3); border:14px solid rgba(255,255,255,.03); }
    .score-circle::before { content:''; position:absolute; inset:-14px; border-radius:50%; padding:14px; background:conic-gradient(var(--green) var(--score-deg,0deg),transparent 0deg); -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0); -webkit-mask-composite:xor; mask-composite:exclude; transition:--score-deg 2s cubic-bezier(.16,1,.3,1); }

    /* ── INPUT ───────────────────────────────────────────────── */
    .input-group { display:flex; gap:16px; background:rgba(255,255,255,.04); padding:16px 20px; border-radius:20px; border:1px solid rgba(255,255,255,.1); transition:border-color .3s; }
    .input-group:focus-within { border-color:rgba(0,168,84,.4); }
    .store-input { flex:1; background:transparent; border:none; color:#fff; font-family:var(--mono); outline:none; font-size:15px; min-width:0; }
    .store-input::placeholder { color:#334155; }
    .scan-btn { background:var(--green); color:#fff; border:none; padding:16px 36px; border-radius:12px; font-weight:900; cursor:pointer; text-transform:uppercase; font-size:13px; transition:all .3s; white-space:nowrap; letter-spacing:.5px; }
    .scan-btn:hover { background:#00c464; transform:translateY(-2px); box-shadow:0 8px 20px rgba(0,168,84,.3); }

    /* ── RESULTS HEADINGS ────────────────────────────────────── */
    .result-header { font-size:clamp(28px,4vw,44px); color:var(--red); margin-bottom:10px; font-weight:900; letter-spacing:-2px; line-height:1.1; }
    .result-sub    { color:#64748b; font-size:20px; margin-bottom:40px; }

    /* ── STATS GRID ──────────────────────────────────────────── */
    .stats-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin:50px 0; }
    .stat-card  { background:rgba(255,255,255,.02); padding:32px 20px; border-radius:24px; text-align:center; border:1px solid rgba(255,255,255,.05); }
    .stat-val   { font-size:52px; font-weight:900; letter-spacing:-2.5px; line-height:1.1; display:block; margin-bottom:8px; }
    .stat-label { font-family:var(--inter); font-size:13px; color:#64748b; font-weight:600; }

    /* ── APP ROWS ────────────────────────────────────────────── */
    .detected-apps-block { text-align:left; max-width:800px; margin:40px auto; padding:36px; background:rgba(255,255,255,.02); border-radius:20px; border:1px solid rgba(255,255,255,.05); }
    .diag-title  { font-family:var(--mono); color:var(--green); font-size:10px; letter-spacing:3px; margin-bottom:20px; display:block; font-weight:800; text-transform:uppercase; }
    .app-row     { display:flex; align-items:center; justify-content:space-between; padding:20px 0; border-bottom:1px solid rgba(255,255,255,.06); flex-wrap:wrap; gap:12px; }
    .app-row:last-child { border-bottom:none; }
    .app-info    { display:flex; align-items:center; gap:12px; }
    .app-dot     { width:7px; height:7px; background:var(--red); border-radius:50%; flex-shrink:0; }
    .app-name    { font-weight:900; font-size:18px; letter-spacing:-.5px; }
    .app-cost    { font-family:var(--mono); font-size:14px; color:var(--red); font-weight:800; }
    .app-replace-btn { font-family:var(--mono); font-size:10px; font-weight:800; letter-spacing:1px; text-transform:uppercase; color:var(--green); border:1px solid rgba(0,168,84,.3); padding:9px 16px; border-radius:4px; text-decoration:none; transition:all .3s; white-space:nowrap; }
    .app-replace-btn:hover { background:var(--green); color:#fff; border-color:var(--green); }

    /* ── DIAGNOSTIC ──────────────────────────────────────────── */
    .diagnostic-block { text-align:left; max-width:800px; margin:30px auto; padding:36px; background:rgba(255,255,255,.02); border-radius:20px; border:1px solid rgba(255,255,255,.05); }

    /* ── PRIMARY CTA ─────────────────────────────────────────── */
    .primary-affiliate-cta { background:var(--green); border-radius:24px; padding:56px 40px; margin:50px 0; text-align:center; }
    .primary-affiliate-cta h3 { font-size:clamp(26px,4vw,40px); font-weight:900; letter-spacing:-2px; color:#fff; margin-bottom:12px; text-transform:uppercase; }
    .primary-affiliate-cta p  { color:rgba(255,255,255,.85); font-size:15px; max-width:580px; margin:0 auto 28px; }
    .primary-cta-btn { display:inline-block; background:#fff; color:#000!important; text-decoration:none; padding:18px 46px; border-radius:10px; font-weight:900; font-size:15px; text-transform:uppercase; letter-spacing:-.2px; transition:all .3s; }
    .primary-cta-btn:hover { transform:translateY(-3px); box-shadow:0 15px 30px rgba(0,0,0,.2); }
    .primary-cta-trust { font-family:var(--mono); font-size:9px; color:rgba(255,255,255,.6); margin-top:14px; display:block; letter-spacing:1px; }

    /* ── SOLUTION CARDS ──────────────────────────────────────── */
    .solution-cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:16px; margin:30px 0; text-align:left; }
    .solution-card  { background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.07); border-radius:14px; padding:26px; text-decoration:none; color:inherit; transition:all .3s; display:block; }
    .solution-card:hover { background:rgba(0,168,84,.08); border-color:rgba(0,168,84,.3); transform:translateY(-4px); }
    .solution-card-label { font-family:var(--mono); font-size:9px; color:var(--green); letter-spacing:2px; font-weight:800; text-transform:uppercase; margin-bottom:8px; display:block; }
    .solution-card-title { font-size:16px; font-weight:900; color:#fff; letter-spacing:-.4px; margin-bottom:7px; }
    .solution-card-desc  { font-size:12px; color:#64748b; line-height:1.5; margin-bottom:14px; }
    .solution-card-cta   { font-family:var(--mono); font-size:9px; color:var(--green); font-weight:800; letter-spacing:1px; text-transform:uppercase; }

    /* ── HISTORY ─────────────────────────────────────────────── */
    .scan-history-block { max-width:800px; margin:40px auto 0; text-align:left; }
    .scan-another-btn   { display:inline-flex; align-items:center; gap:10px; font-family:var(--mono); font-size:10px; font-weight:800; letter-spacing:2px; text-transform:uppercase; color:#475569; background:none; border:1px solid rgba(255,255,255,.08); padding:12px 24px; border-radius:8px; cursor:pointer; transition:all .3s; margin-top:20px; }
    .scan-another-btn:hover { color:var(--green); border-color:rgba(0,168,84,.4); }
    .history-list  { margin-top:16px; }
    .history-item  { display:flex; align-items:center; justify-content:space-between; padding:10px 0; border-bottom:1px solid rgba(255,255,255,.04); font-size:12px; gap:12px; flex-wrap:wrap; cursor:pointer; transition:color .2s; }
    .history-item:hover { color:var(--green); }
    .history-domain { font-family:var(--mono); font-weight:800; font-size:11px; color:#94a3b8; }
    .history-badge  { font-family:var(--mono); font-size:8px; color:#475569; }

    /* ── EMAIL CAPTURE ───────────────────────────────────────── */
    .email-capture-block { background:rgba(255,255,255,.04); padding:56px 48px; border-radius:28px; margin-top:50px; text-align:center; border:1px solid rgba(255,255,255,.08); }
    .email-capture-block h3 { font-size:clamp(22px,3.5vw,34px); font-weight:900; letter-spacing:-1.5px; color:#f8fafc; margin-bottom:10px; text-transform:uppercase; }
    .email-capture-block p  { font-size:15px; color:#64748b; max-width:480px; margin:0 auto 26px; }
    .email-form   { display:flex; gap:10px; max-width:460px; margin:0 auto; }
    .email-input  { flex:1; padding:14px 18px; border:2px solid rgba(255,255,255,.1); border-radius:8px; font-size:14px; outline:none; font-family:var(--inter); transition:border-color .3s; background:rgba(255,255,255,.05); color:#f8fafc; }
    .email-input:focus  { border-color:var(--green); }
    .email-submit { background:var(--green); color:#fff; border:none; padding:14px 24px; border-radius:8px; font-weight:900; font-size:12px; cursor:pointer; text-transform:uppercase; letter-spacing:.5px; white-space:nowrap; transition:all .3s; }
    .email-submit:hover { background:#00c464; transform:translateY(-2px); }
    .email-trust   { font-family:var(--mono); font-size:9px; color:#94a3b8; margin-top:12px; display:block; }
    .email-success { display:none; color:var(--green); font-weight:900; font-size:15px; margin-top:12px; }

    .share-link { color:var(--green); font-family:var(--mono); text-decoration:none; font-size:10px; letter-spacing:2px; margin-top:36px; display:inline-block; transition:letter-spacing .3s; }
    .share-link:hover { letter-spacing:3px; }

    /* ── SEO ACCORDION ───────────────────────────────────────── */
    /* Inherits global dark bg — no extra background needed */
    .seo-content-section { max-width:1100px; margin:0 auto; padding:60px 40px 40px; font-family:var(--inter); }
    .accordion-item     { border-bottom:1px solid rgba(255,255,255,.06); }
    .accordion-trigger  { width:100%; display:flex; align-items:center; justify-content:space-between; padding:24px 0; background:none; border:none; cursor:pointer; text-align:left; gap:16px; }
    .accordion-trigger h2 { font-size:clamp(16px,2vw,20px); font-weight:900; color:#f8fafc; letter-spacing:-.8px; margin:0; }
    .accordion-icon     { font-family:var(--mono); font-size:20px; color:var(--green); flex-shrink:0; transition:transform .3s; }
    .accordion-item.open .accordion-icon  { transform:rotate(45deg); }
    .accordion-body     { max-height:0; overflow:hidden; transition:max-height .4s cubic-bezier(.4,0,.2,1); }
    .accordion-item.open .accordion-body  { max-height:900px; }
    .accordion-content  { padding:0 0 28px; font-size:15px; color:#64748b; line-height:1.7; }
    .accordion-content strong { color:#f8fafc; }
    .accordion-content a      { color:var(--green); text-decoration:none; border-bottom:1px solid rgba(0,168,84,.3); transition:border-color .2s; }
    .accordion-content a:hover { border-color:var(--green); }
    .accordion-content ul { padding-left:20px; margin:12px 0; }
    .accordion-content li { margin-bottom:6px; }

    /* ── FAQ ─────────────────────────────────────────────────── */
    .faq-section       { max-width:1100px; margin:0 auto; padding:40px 40px 80px; font-family:var(--inter); }
    .faq-section-title { font-size:clamp(24px,3.5vw,36px); font-weight:900; color:#f8fafc; letter-spacing:-2px; margin-bottom:40px; text-align:center; }
    .faq-item-outer    { border-bottom:1px solid rgba(255,255,255,.06); }
    .faq-trigger       { width:100%; display:flex; align-items:flex-start; justify-content:space-between; padding:22px 0; background:none; border:none; cursor:pointer; text-align:left; gap:16px; }
    .faq-question      { font-size:16px; font-weight:700; color:#f8fafc; letter-spacing:-.4px; flex:1; line-height:1.3; }
    .faq-plus          { font-family:var(--mono); font-size:20px; color:var(--green); flex-shrink:0; transition:transform .3s; margin-top:2px; }
    .faq-item-outer.open .faq-plus { transform:rotate(45deg); }
    .faq-answer        { max-height:0; overflow:hidden; transition:max-height .4s cubic-bezier(.4,0,.2,1); }
    .faq-item-outer.open .faq-answer { max-height:500px; }
    .faq-answer-inner  { padding:0 0 22px; font-size:14px; color:#64748b; line-height:1.7; }

    /* ── RESPONSIVE ──────────────────────────────────────────── */
    @media (max-width:768px) {
      #scanner-v1-root       { padding:50px 24px 70px; }
      .stats-grid            { grid-template-columns:1fr; gap:12px; }
      .input-group           { flex-direction:column; padding:14px; }
      .scan-btn              { width:100%; padding:16px; }
      .trust-bar             { flex-direction:column; gap:12px; }
      .trust-sep             { display:none; }
      .app-row               { flex-direction:column; align-items:flex-start; }
      .email-form            { flex-direction:column; }
      .email-capture-block   { padding:40px 20px; }
      .primary-affiliate-cta { padding:40px 20px; }
      .competitor-toggle button { font-size:9px; padding:7px 14px; }
      .seo-content-section   { padding-left:24px; padding-right:24px; }
      .faq-section           { padding-left:24px; padding-right:24px; }
    }
  </style>
