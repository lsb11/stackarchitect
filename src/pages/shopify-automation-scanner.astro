      { name:"ReConvert",          match:["reconvert","reconv"],                                   cost:50,  category:"Upsell",           replacement:"make",    replacementLabel:"Automate with Make.com Free",        replacementUrl:"https://www.make.com/en/register?pc=techie123" },
