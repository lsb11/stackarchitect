import Nav from '../components/Nav.astro';
// src/pages/shopify-profit-loss-automation.astro
// Stack Architect — Shopify P&L Automation
// Optimised for organic, GEO, and AI search (rank-1 target)
// Deployed via Cloudflare Pages

const SITE = "https://stackarchitect.xyz";
const PAGE = `${SITE}/shopify-profit-loss-automation/`;
const OG_IMAGE = "https://d1yei2z3i6k35z.cloudfront.net/16370908/69a093a668d36_Gemini_Generated_Image_3i6wmo3i6wmo3i6w.png";
const DATE_PUBLISHED = "2026-01-01";
const DATE_MODIFIED = "2026-04-10";

// ── Affiliate links ──────────────────────────────────────────
const AFF = {
  make:      "/go/make",
  workspace: "/go/workspace",
  systeme:   "/go/systeme",
  getresp:   "/go/getresponse",
  beehiiv:   "/go/beehiiv",
  tidio:     "/go/tidio",
  gorgias:   "/go/gorgias",
};

// ── Structured data ──────────────────────────────────────────
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    // WebPage
    {
      "@type": "WebPage",
      "@id": `${PAGE}#webpage`,
      "url": PAGE,
      "name": "Shopify P&L Automation Free (2026) — Live Profit and Loss in Google Sheets",
      "description": "Free Shopify profit and loss automation via Make.com and Google Sheets. Every Shopify order automatically writes revenue, COGS, fees, and net margin to a live P&L statement — no manual exports, no paid apps, deploys in 10 minutes.",
      "datePublished": DATE_PUBLISHED,
      "dateModified": DATE_MODIFIED,
      "inLanguage": "en-GB",
      "isPartOf": { "@id": `${SITE}/#website` },
      "primaryImageOfPage": { "@type": "ImageObject", "url": OG_IMAGE },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                    "item": `${SITE}/` },
          { "@type": "ListItem", "position": 2, "name": "Shopify P&L Automation",  "item": PAGE }
        ]
      },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["#hero-headline","#why-h","#how-h","#structure-h","#setup-h","#faq-h"]
      }
    },
    // Website
    {
      "@type": "WebSite",
      "@id": `${SITE}/#website`,
      "url": SITE,
      "name": "Stack Architect",
      "description": "Free automation tools for Shopify operators — $0 stack replacing paid apps.",
      "publisher": { "@id": `${SITE}/#org` },
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": `${SITE}/?s={search_term_string}` },
        "query-input": "required name=search_term_string"
      }
    },
    // Organisation
    {
      "@type": "Organization",
      "@id": `${SITE}/#org`,
      "name": "Stack Architect",
      "url": SITE,
      "logo": { "@type": "ImageObject", "url": `${SITE}/favicon.svg` },
      "sameAs": [SITE],
      "knowsAbout": [
        "Shopify profit and loss automation","Google Sheets financial reporting",
        "Make.com Shopify webhooks","Ecommerce P&L","Gross margin tracking",
        "Shopify order data","COGS tracking","Real-time financial reporting"
      ],
      "contactPoint": { "@type": "ContactPoint", "email": "support@stackarchitect.xyz", "contactType": "customer support" }
    },
    // SoftwareApplication
    {
      "@type": "SoftwareApplication",
      "@id": `${PAGE}#software`,
      "name": "Shopify P&L Automation",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "url": PAGE,
      "description": "Free live Shopify profit and loss automation. Every order automatically writes to Google Sheets via Make.com webhooks — revenue, COGS, Shopify fees, and net margin tracked in real time at zero cost.",
      "featureList": [
        "Real-time P&L updates on every Shopify order",
        "Automatic COGS matching via VLOOKUP",
        "Refund handling via separate webhook scenario",
        "Monthly aggregation via SUMIF formulas",
        "Multi-channel breakdown (online, POS, TikTok Shop)",
        "Free via Make.com (1,000 ops/month)",
        "No code required",
        "Deploys in 10 minutes",
        "Your data in your Google account forever"
      ],
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "availability": "https://schema.org/InStock" },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "3",
        "bestRating": "5"
      },
      "author": { "@id": `${SITE}/#org` },
      "isRelatedTo": [
        { "@type": "SoftwareApplication", "name": "Make.com", "url": "https://www.make.com" },
        { "@type": "SoftwareApplication", "name": "Google Sheets", "url": "https://sheets.google.com" },
        { "@type": "SoftwareApplication", "name": "Shopify", "url": "https://www.shopify.com" }
      ]
    },
    // Article
    {
      "@type": ["Article","TechArticle"],
      "@id": `${PAGE}#article`,
      "headline": "Shopify P&L Automation Free (2026) — Live Profit and Loss in Google Sheets via Make.com",
      "description": "How to build a live auto-updating Shopify profit and loss statement in Google Sheets for free using Make.com webhooks. Every order writes automatically — no manual entry, no paid apps, no code required.",
      "author": { "@id": `${SITE}/#org` },
      "publisher": { "@id": `${SITE}/#org` },
      "datePublished": DATE_PUBLISHED,
      "dateModified": DATE_MODIFIED,
      "inLanguage": "en-GB",
      "url": PAGE,
      "image": { "@type": "ImageObject", "url": OG_IMAGE, "width": 1200, "height": 630 },
      "wordCount": 4200,
      "timeRequired": "PT12M",
      "mainEntityOfPage": { "@id": `${PAGE}#webpage` },
      "about": [
        { "@type": "Thing", "name": "Shopify financial reporting", "sameAs": "https://www.shopify.com/blog/profit-and-loss" },
        { "@type": "Thing", "name": "Google Sheets automation", "sameAs": "https://workspace.google.com/products/sheets/" },
        { "@type": "Thing", "name": "Make.com automation platform", "sameAs": "https://www.make.com" },
        { "@type": "Thing", "name": "Profit and loss statement", "sameAs": "https://en.wikipedia.org/wiki/Income_statement" }
      ],
      "mentions": [
        { "@type": "SoftwareApplication", "name": "Make.com" },
        { "@type": "SoftwareApplication", "name": "Google Sheets" },
        { "@type": "SoftwareApplication", "name": "Shopify" },
        { "@type": "SoftwareApplication", "name": "TrueProfit" },
        { "@type": "SoftwareApplication", "name": "Lifetimely" },
        { "@type": "SoftwareApplication", "name": "Finaloop" }
      ],
      "educationalLevel": "beginner",
      "proficiencyLevel": "Beginner"
    },
    // HowTo
    {
      "@type": "HowTo",
      "@id": `${PAGE}#howto`,
      "name": "How to automate Shopify profit and loss reporting in Google Sheets for free",
      "description": "Build a live auto-updating Shopify P&L statement in Google Sheets using Make.com webhooks. Free, no code, deploys in 10 minutes.",
      "totalTime": "PT10M",
      "estimatedCost": { "@type": "MonetaryAmount", "currency": "USD", "value": "0" },
      "tool": [
        { "@type": "HowToTool", "name": "Make.com (free tier)" },
        { "@type": "HowToTool", "name": "Google Sheets" },
        { "@type": "HowToTool", "name": "Shopify Webhooks" }
      ],
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Create your P&L Google Sheet",
          "text": "Create a Google Sheet with three tabs: Order Data, P&L Summary, and COGS Table. Add column headers in Order Data: Order_ID, Date, Channel, Revenue, Discount, Shipping_Rev, Shopify_Fee, Payment_Fee, COGS, Gross_Profit." },
        { "@type": "HowToStep", "position": 2, "name": "Activate Make.com free",
          "text": "Sign up for Make.com free tier — 1,000 operations per month at no cost. Create a new scenario with a Webhooks trigger.", "url": AFF.make },
        { "@type": "HowToStep", "position": 3, "name": "Add Shopify order payment webhook",
          "text": "In Shopify Admin go to Settings → Notifications → Webhooks. Create a webhook for Order payment pointing to your Make.com webhook URL." },
        { "@type": "HowToStep", "position": 4, "name": "Map order data to Google Sheets",
          "text": "Add a Google Sheets module to append a new row. Map order fields: order.id, order.created_at, order.source_name, order.total_price, order.total_discounts, and order.total_shipping_price_set." },
        { "@type": "HowToStep", "position": 5, "name": "Add refund webhook",
          "text": "Create a second Shopify webhook for Refund created. Build a second Make.com scenario that writes negative revenue rows when refunds occur." },
        { "@type": "HowToStep", "position": 6, "name": "Build P&L formula layer",
          "text": "In the P&L Summary tab use SUMIF formulas to aggregate revenue, COGS, fees, and profit by month. Add manual rows for ad spend and fixed costs." }
      ]
    },
    // FAQPage
    {
      "@type": "FAQPage",
      "@id": `${PAGE}#faq`,
      "mainEntity": [
        { "@type": "Question", "name": "Can I automate Shopify profit and loss reporting in Google Sheets for free?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Using Make.com's free tier, every Shopify order automatically writes revenue, fees, and order data to a Google Sheet. SUMIF formulas in a summary tab calculate live gross margin and net profit without any manual entry. Make.com's free plan covers 1,000 operations per month — enough for stores processing up to 500 orders per month." } },
        { "@type": "Question", "name": "What data does Make.com pull from Shopify for P&L reporting?",
          "acceptedAnswer": { "@type": "Answer", "text": "The Shopify order webhook payload includes order ID, date, channel, total revenue, subtotal, discounts, shipping revenue, tax collected, payment gateway, line item quantities, variant IDs, and customer details. For P&L purposes you use total revenue, discounts, shipping, Shopify transaction fees, and variant IDs that map to your COGS table via VLOOKUP." } },
        { "@type": "Question", "name": "How is this different from Shopify's built-in financial reports?",
          "acceptedAnswer": { "@type": "Answer", "text": "Shopify's built-in reports show revenue, units sold, and average order value. They do not calculate net profit — they have no concept of COGS, Shopify subscription fee, ad spend, or operating expenses. The automated P&L in Google Sheets adds all of these in a single live view you own and customise, with zero monthly fees." } },
        { "@type": "Question", "name": "How do I track COGS automatically in the Shopify P&L?",
          "acceptedAnswer": { "@type": "Answer", "text": "Store your cost price per variant in a COGS Table tab. Make.com pulls the variant ID from each Shopify order. A VLOOKUP formula in your Order Data tab matches each variant ID to its cost automatically. Update COGS in the table when supplier prices change and every historical order row recalculates." } },
        { "@type": "Question", "name": "How do refunds appear in the automated Shopify P&L?",
          "acceptedAnswer": { "@type": "Answer", "text": "A second Make.com scenario monitors the Shopify Refund created webhook. When a refund occurs, it writes a negative revenue row to the same Order Data tab. SUMIF formulas in your P&L Summary automatically net refunds against gross revenue with no manual adjustment needed." } },
        { "@type": "Question", "name": "Do I need Google Workspace or does free Gmail work for Shopify P&L automation?",
          "acceptedAnswer": { "@type": "Answer", "text": "Free Gmail works for stores processing up to 500 orders per month. At higher volumes, Gmail API limits may throttle Make.com's Google Sheets write operations during peak periods. Google Workspace removes all limits and adds shared workspaces — recommended for high-volume stores or teams." } }
      ]
    }
  ]
});
