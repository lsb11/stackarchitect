  window.addEventListener('scroll', function(){
    if(header) header.classList.toggle('scrolled', window.scrollY > 50);
  }, { passive: true });
  document.querySelectorAll('.dropdown > .product-link').forEach(function(l){
    l.addEventListener('click', function(e){
      if(window.innerWidth <= 850){
        e.preventDefault();
        var exp = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', String(!exp));
        this.parentElement.classList.toggle('active');
      }
    });
  });
  var s = document.createElement('style');
  s.textContent = '.dropdown.active .dropdown-menu{display:flex;}';
  document.head.appendChild(s);
  document.addEventListener('click', function(e){
    if(!e.target.closest('.dropdown'))
      document.querySelectorAll('.dropdown').forEach(function(d){
        d.classList.remove('active');
        var l = d.querySelector('.product-link[aria-expanded]');
        if(l) l.setAttribute('aria-expanded','false');
      });
  });
  var cr = document.getElementById('pl-copyright');
  if(cr) cr.textContent = '© ' + new Date().getFullYear() + ' STACK_ARCHITECT // SHOPIFY_PL_AUTOMATION // LIVE_REPORTING';
})();
</script>


