<script>
(function () {
  // ── Sticky nav scroll class ──────────────────────────────────────────────────
  const header = document.querySelector('.product-terminal-bar');
  window.addEventListener('scroll', () => {
    if (header) header.classList.toggle('scrolled', window.scrollY > 50);
  });

  // ── Dropdown: hover on desktop, click on mobile ──────────────────────────────
  const style = document.createElement('style');
  style.textContent = '.dropdown.active .dropdown-menu{display:flex;}';
  document.head.appendChild(style);

  document.querySelectorAll('.dropdown > .product-link').forEach(link => {
    link.addEventListener('click', e => {
      if (window.innerWidth <= 850) {
        e.preventDefault();
        const expanded = link.getAttribute('aria-expanded') === 'true';
        link.setAttribute('aria-expanded', String(!expanded));
        link.parentElement.classList.toggle('active');
      }
    });
  });

  document.addEventListener('click', e => {
    if (!e.target.closest('.dropdown')) {
      document.querySelectorAll('.dropdown').forEach(d => d.classList.remove('active'));
    }
  });

  // ── Dynamic copyright ────────────────────────────────────────────────────────
  const cr = document.getElementById('cs-copyright');
  if (cr) cr.textContent = `© ${new Date().getFullYear()} STACK_ARCHITECT // CAPI_SHIELD // TRACKING_RESTORED`;
})();
</script>

