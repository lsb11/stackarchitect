---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label: 'CAPI Shield' },
];

const faqs = [
  {
    q: 'What is Shopify server-side tracking?',
    a: 'Server-side tracking sends Shopify conversion events directly from your server to ad platforms, bypassing the browser entirely. iOS restrictions, ad blockers, and cookie expiry cannot interfere. CAPI Shield implements this free via Make.com webhooks.',
  },
  {
    q: 'What is Meta CAPI and how does it work with Shopify?',
    a: 'Meta Conversions API (CAPI) is a server-to-server connection that sends Shopify purchase events directly to Meta without going through the browser. CAPI Shield sets this up free using Make.com, typically achieving Event Match Quality scores of 7–8.5.',
  },
  {
    q: 'What is Google Enhanced Conversions for Shopify?',
    a: 'Google Enhanced Conversions is Google\'s server-side conversion tracking system. It sends hashed customer data (email, phone, name) alongside conversion events to improve Smart Bidding accuracy. CAPI Shield sends Enhanced Conversions to Google Ads simultaneously with Meta CAPI from the same Make.com scenario, recovering Google conversion data lost to iOS restrictions and ad blockers.',
  },
  {
    q: 'How to set up Shopify server-side tracking free?',
    a: 'Use CAPI Shield — a free Make.com scenario that routes Shopify order webhooks to Meta Conversions API and Google Enhanced Conversions simultaneously. Takes 6 minutes, no code required, free on Make.com\'s free tier. The webhook fires from Shopify\'s backend the instant an order is paid, bypassing all browser restrictions.',
  },
  {
    q: 'How much conversion data am I losing without server-side tracking?',
    a: 'Typically 20–40% of purchase events are lost with browser-only pixel tracking in 2026. Stores with high mobile and iOS traffic often lose 35–50%.',
  },
  {
    q: 'Does CAPI Shield replace my Meta Pixel?',
    a: 'No. CAPI Shield works alongside your existing Meta Pixel. The pixel still captures upper-funnel events. CAPI Shield adds server-side Purchase events on top. Both fire simultaneously and Meta deduplicates them automatically using the event_id.',
  },
  {
    q: 'What is the difference between CAPI Shield and Elevar or Northbeam?',
    a: 'Elevar costs $150+/month and Northbeam costs $300+/month. CAPI Shield uses Make.com to achieve the same server-side event forwarding for free. The core technical outcome is identical. Elevar and Northbeam add analytics dashboards on top — if you only need conversion recovery, CAPI Shield is the free equivalent.',
  },
  {
    q: 'Will CAPI Shield improve my ROAS?',
    a: 'Indirectly, yes. CAPI Shield gives Meta and Google complete conversion data. Smart Bidding and Advantage+ use conversion signals to optimise delivery. Most stores see measurable ROAS improvement within 14–21 days as the algorithm relearns with full data.',
  },
  {
    q: 'What is Event Match Quality and why does it matter?',
    a: 'Event Match Quality (EMQ) is Meta\'s 0–10 score for how well server-side events are matched to Meta user accounts. Scores above 7.0 indicate strong matching. CAPI Shield sends hashed email, phone, name, and IP address with every event, typically achieving EMQ scores of 7–8.5.',
  },
  {
    q: 'Is CAPI Shield GDPR compliant?',
    a: 'The data flows through your own Make.com workspace. CAPI Shield hashes all personally identifiable information using SHA-256 before transmission, as required by Meta\'s API specification. Ensure your privacy policy covers server-side tracking data sharing.',
  },
  {
    q: 'How long does CAPI Shield setup take?',
    a: 'Most stores are live within 6 minutes. The Make.com scenario takes 3–4 minutes. The Shopify webhook takes under 2 minutes. Testing takes 1–2 minutes. No developer required.',
  },
  {
    q: 'Why is Shopify\'s built-in CAPI not enough?',
    a: 'Shopify\'s native CAPI is still browser-triggered — the thank-you page Web Pixel must execute before the server event fires. If a browser blocks the Web Pixel, the server event may not fire. CAPI Shield uses a server-to-server webhook that fires from Shopify\'s backend the moment payment is confirmed, regardless of browser behaviour.',
  },
  {
    q: 'Does this work with TikTok Ads as well?',
    a: 'Yes. The same Make.com scenario can route events to Meta CAPI, Google Enhanced Conversions, and TikTok Events API simultaneously. Most stores start with Meta and Google, then add TikTok as a third branch.',
  },
  {
    q: 'What happens if I want to remove CAPI Shield?',
    a: 'Delete the Make.com scenario and the Shopify webhook. Nothing is installed on your store. Data stops flowing immediately. No residue, no lock-in, no cancellation fees.',
  },
];

const steps = [
  {
    n: 1,
    title: 'Activate Make.com free',
    desc: 'Sign up for Make.com free — 1,000 operations per month at no cost, enough for stores processing up to 300 orders per month. No credit card required. Make.com is your automation hub connecting Shopify to Meta and Google.',
    path: 'make.com/en/register — free tier, no credit card',
  },
  {
    n: 2,
    title: 'Create a new scenario with Webhooks trigger',
    desc: 'In Make.com, create a new scenario. Add a Webhooks module as the trigger. Copy the generated webhook URL — you will paste this into Shopify in the next step.',
    path: 'Make.com → Create scenario → Webhooks',
  },
  {
    n: 3,
    title: 'Add Shopify webhook for order payment',
    desc: 'In Shopify Admin → Settings → Notifications → Webhooks, create a new webhook. Select "Order payment" as the event. Paste the Make.com webhook URL. Set format to JSON. Save. This is the server-to-server trigger — entirely independent of the browser.',
    path: 'Shopify Admin → Settings → Notifications → Webhooks',
  },
  {
    n: 4,
    title: 'Add Meta Conversions API module',
    desc: 'In Make.com, add the Meta Conversions API module after the webhook trigger. Connect your Meta Business account. Set event_name to "Purchase". Map event_id to order.id, value to order.total_price, currency to order.currency, and all customer information parameters (email, phone, first_name, last_name). Enable SHA-256 hashing for all PII fields.',
    path: 'Make.com → Meta Conversions API module',
  },
  {
    n: 5,
    title: 'Add Google Enhanced Conversions branch',
    desc: 'Add a second branch to the same scenario using a Router module. Add the Google Ads module and select "Create a conversion". Map order value, currency, and hashed email. This recovers Google Ads conversion data with no additional Shopify setup — same webhook, second destination.',
    path: 'Make.com → Router → Google Ads Enhanced Conversions',
  },
  {
    n: 6,
    title: 'Test and verify both platforms',
    desc: 'Place a test order. In Meta Events Manager → Test Events, verify a server Purchase event appears alongside the browser event — confirming deduplication is working. In Google Ads, check Conversion Actions for an Enhanced Conversion entry. Both should show within minutes.',
    path: 'Meta Events Manager → Test Events',
  },
];
---

<Base
  title="CAPI Shield — Free Shopify Server-Side Tracking 2026"
  description="Recover 20–40% of lost Shopify conversion data free. CAPI Shield sends purchase events server-side to Meta CAPI and Google Enhanced Conversions — bypasses iOS, no code, 6 minutes."
  breadcrumb={breadcrumb}
  updatedDate="2026-03-19"
>
  <Nav slot="header" topBarLabel="TRACKING_RESTORED // ACCESS_OPEN" />

  <!-- Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "CAPI Shield",
    "description": "Free Shopify server-side tracking. Sends purchase events to Meta CAPI and Google Enhanced Conversions via Make.com webhook — no code, 6 minutes.",
    "url": "https://www.stackarchitect.xyz/capi-shield",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "availability": "https://schema.org/InStock" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "500", "bestRating": "5" },
    "featureList": [
      "Meta Conversions API (CAPI)",
      "Google Enhanced Conversions",
      "SHA-256 hashed PII",
      "Event deduplication",
      "No code required",
      "6-minute setup",
      "Free forever on Make.com free tier",
      "EMQ scores 7–8.5 achieved",
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.stackarchitect.xyz/" },
      { "@type": "ListItem", "position": 2, "name": "CAPI Shield", "item": "https://www.stackarchitect.xyz/capi-shield" },
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Deploy CAPI Shield — Free Shopify Server-Side Tracking in 6 Minutes",
    "totalTime": "PT6M",
    "estimatedCost": { "@type": "MonetaryAmount", "currency": "USD", "value": "0" },
    "step": steps.map((s) => ({
      "@type": "HowToStep",
      "position": s.n,
      "name": s.title,
      "text": s.desc,
    })),
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a },
    })),
  })} />

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 pt-12 pb-10">
    <p class="font-mono text-xs text-green-400 tracking-widest mb-3">★★★★★ 500+ stores · recovers 20–40% of lost conversions · free forever</p>
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4 leading-tight speakable">
      Your Shopify store is losing 35% of its conversion data.<br class="hidden md:block" /> Fix it free.
    </h1>
    <p class="text-zinc-300 text-lg leading-relaxed mb-6 speakable">
      CAPI Shield sends Shopify purchase events server-side to Meta Conversions API and Google Enhanced Conversions via Make.com — bypassing iOS restrictions, ad blockers, and Shopify's pixel throttle. Six minutes. No code. $0 forever.
    </p>

    <!-- Loss pills -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
      {[
        { value: '20–40%', label: 'Conversions lost', warn: true },
        { value: '$149–$299/mo', label: 'Paid tools charge', warn: true },
        { value: 'Degraded', label: 'ROAS — smart bidding blind', warn: true },
        { value: '$0', label: 'CAPI Shield costs', warn: false },
      ].map(s => (
        <div class={`border p-4 text-center ${s.warn ? 'bg-zinc-900 border-red-900' : 'bg-zinc-900 border-green-700'}`}>
          <div class={`text-xl font-bold font-mono ${s.warn ? 'text-red-400' : 'text-green-400'}`}>{s.value}</div>
          <div class="text-zinc-500 text-xs mt-1 font-mono uppercase tracking-wider leading-snug">{s.label}</div>
        </div>
      ))}
    </div>

    <div class="flex flex-wrap gap-3 mb-8">
      <a href="https://www.make.com/en/register?pc=techie123" target="_blank" rel="noopener noreferrer"
        class="inline-block bg-green-400 text-black font-bold font-mono text-sm px-6 py-3 tracking-widest hover:bg-green-300 transition-colors">
        DEPLOY CAPI SHIELD FREE →
      </a>
      <a href="#setup"
        class="inline-block border border-zinc-700 text-zinc-300 font-mono text-sm px-6 py-3 tracking-widest hover:border-green-400 hover:text-green-400 transition-colors">
        SEE HOW IT WORKS
      </a>
    </div>

    <!-- Testimonial -->
    <blockquote class="border-l-2 border-green-400 pl-4">
      <p class="text-zinc-300 italic">"Recovered $600/mo in under 10 minutes. We were bleeding attribution data after iOS 17 and had no idea. CAPI Shield fixed it the same day."</p>
      <footer class="text-zinc-500 text-sm mt-1 font-mono">— Jamie L. · 6-figure Shopify Apparel Brand</footer>
    </blockquote>
  </section>

  <!-- How it works: 4-step flow -->
  <section class="bg-zinc-900 border-y border-zinc-800 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">HOW IT WORKS: WEBHOOK-TRIGGERED. SERVER-TO-SERVER. BROWSER CANNOT INTERFERE.</h2>
      <div class="grid md:grid-cols-4 gap-4">
        {[
          { n: '01', title: 'Order paid in Shopify', desc: 'Customer completes checkout. Shopify marks the order as paid in its backend — completely independent of what happens in the browser.' },
          { n: '02', title: 'Webhook fires instantly', desc: 'Shopify sends a webhook to Make.com the moment payment is confirmed. No browser involved. Ad blockers and iOS restrictions cannot intercept this signal.' },
          { n: '03', title: 'Data enriched and hashed', desc: 'Make.com extracts order value, currency, and customer identifiers. All PII is hashed with SHA-256 before transmission, as required by Meta\'s API specification.' },
          { n: '04', title: 'Sent to Meta + Google', desc: 'Purchase events delivered simultaneously to Meta Conversions API and Google Enhanced Conversions. Both platforms receive complete data regardless of browser behaviour.' },
        ].map(step => (
          <div class="border border-zinc-700 p-5">
            <p class="font-mono text-green-400 text-xs tracking-widest mb-2">STEP {step.n}</p>
            <p class="text-white font-bold text-sm mb-2">{step.title}</p>
            <p class="text-zinc-400 text-sm">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platform split -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">BOTH PLATFORMS: META CAPI AND GOOGLE ENHANCED CONVERSIONS — ONE SETUP, BOTH FIXED</h2>
    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <div class="bg-zinc-900 border border-zinc-800 p-6">
        <p class="font-mono text-xs text-blue-400 tracking-widest mb-2">META CAPI</p>
        <h3 class="text-white font-bold text-lg mb-3">Recover lost Meta purchase events</h3>
        <p class="text-zinc-300 mb-4">Meta CAPI sends Shopify purchase events server-to-server, bypassing iOS ITP, ad blockers, and Safari cookie restrictions. CAPI Shield sends hashed email, phone, name, and IP address with every event — the full customer signal set Meta needs for accurate attribution and Advantage+ optimisation.</p>
        <p class="font-mono text-xs text-green-400">EMQ scores 7.0–8.5 achieved</p>
      </div>
      <div class="bg-zinc-900 border border-zinc-800 p-6">
        <p class="font-mono text-xs text-amber-400 tracking-widest mb-2">GOOGLE ADS</p>
        <h3 class="text-white font-bold text-lg mb-3">Free Shopify Google Enhanced Conversions</h3>
        <p class="text-zinc-300 mb-4">Google Enhanced Conversions is Google's server-side equivalent — it sends hashed customer data alongside conversion events to improve Smart Bidding accuracy. The same Make.com scenario branches to Google Ads simultaneously, recovering Google conversion data lost to iOS and ad blockers at no extra cost or setup time.</p>
        <p class="font-mono text-xs text-green-400">Smart Bidding signal fully restored</p>
      </div>
    </div>

    <div class="bg-zinc-900 border border-zinc-800 p-5 mb-4">
      <p class="font-mono text-xs text-zinc-500 tracking-widest mb-2">WHY SHOPIFY'S BUILT-IN CAPI HAS A HIDDEN LIMITATION</p>
      <p class="text-zinc-300">Shopify's native CAPI is still browser-triggered — the thank-you page Web Pixel must execute before the server event fires. If a browser blocks the Web Pixel, the server event may not fire. CAPI Shield uses a server-to-server webhook that fires from Shopify's backend the moment payment is confirmed, regardless of browser behaviour.</p>
    </div>

    <p class="text-zinc-400 text-sm">Related: <a href="/blog/shopify-meta-roas-dropped-2026-fix" class="text-green-400 hover:underline">Shopify Meta ROAS dropped in 2026 — the free fix</a> · <a href="/blog/shopify-server-side-tracking-complete-setup-guide" class="text-green-400 hover:underline">Complete server-side tracking setup guide</a></p>
  </section>

  <!-- EMQ Section -->
  <section class="bg-zinc-900 border-y border-zinc-800 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold font-mono text-white mb-4 tracking-widest">EVENT MATCH QUALITY FOR META — HOW TO MAXIMISE YOUR SCORE</h2>
      <p class="text-zinc-300 mb-6">Event Match Quality (EMQ) is Meta's 0–10 score measuring how accurately server events are matched to Meta user accounts. Events that can't be matched provide no algorithm signal. Scores above 7.0 indicate strong matching.</p>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          { signal: 'Hashed email address', impact: 'HIGH', note: 'Present on almost every Shopify order' },
          { signal: 'Hashed phone number', impact: 'HIGH', note: 'Where customer enters phone at checkout' },
          { signal: 'IP address', impact: 'MEDIUM', note: 'Available from Shopify order.browser_ip' },
          { signal: 'User agent', impact: 'MEDIUM', note: 'Available from order.client_details' },
          { signal: 'Hashed first + last name', impact: 'MEDIUM', note: 'Shipped with every order' },
          { signal: 'External ID (order ID)', impact: 'HIGH', note: 'Required for deduplication' },
        ].map(row => (
          <div class="flex gap-4 items-start border border-zinc-700 p-4">
            <span class={`shrink-0 font-mono text-xs px-2 py-1 ${row.impact === 'HIGH' ? 'bg-green-400 text-black' : 'bg-zinc-700 text-zinc-300'}`}>{row.impact}</span>
            <div>
              <p class="text-white text-sm font-bold">{row.signal}</p>
              <p class="text-zinc-500 text-xs">{row.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6-Step Setup Guide -->
  <section id="setup" class="max-w-5xl mx-auto px-4 py-12 scroll-mt-8">
    <h2 class="text-xl font-bold font-mono text-white mb-2 tracking-widest">SETUP GUIDE: DEPLOY CAPI SHIELD IN 6 MINUTES — STEP BY STEP</h2>
    <p class="text-zinc-400 text-sm mb-8 font-mono">set up Meta CAPI and Google Enhanced Conversions free</p>

    <ol class="space-y-6 mb-8">
      {steps.map(step => (
        <li class="flex gap-6 bg-zinc-900 border border-zinc-800 p-6">
          <span class="shrink-0 w-8 h-8 bg-green-400 text-black font-bold font-mono flex items-center justify-center text-sm">{step.n}</span>
          <div class="min-w-0">
            <p class="text-white font-bold mb-1">{step.title}</p>
            <p class="text-zinc-400 text-sm mb-2 leading-relaxed">{step.desc}</p>
            <p class="font-mono text-xs text-zinc-500">{step.path}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="bg-zinc-900 border border-amber-700 p-5 mb-6">
      <p class="font-mono text-xs text-amber-400 tracking-widest mb-2">COMMON MISTAKE</p>
      <p class="text-zinc-300">Do not run two server-side tools with different event IDs simultaneously. If you have CAPI Shield running and also use another tracking app, ensure they use the same <code class="text-green-400">event_id</code> for deduplication. Running two tools with different event IDs causes double-counting that inflates reported conversions and degrades campaign performance.</p>
    </div>

    <div class="flex flex-wrap gap-3">
      <a href="https://www.make.com/en/register?pc=techie123" target="_blank" rel="noopener noreferrer"
        class="inline-block bg-green-400 text-black font-bold font-mono text-sm px-6 py-3 tracking-widest hover:bg-green-300 transition-colors">
        START DEPLOYMENT →
      </a>
      <a href="https://d1yei2z3i6k35z.cloudfront.net/16370908/699ca2c9a5dea_CAPI_Shield_The_0_Automation_Stack.pdf" target="_blank" rel="noopener noreferrer"
        class="inline-block border border-zinc-700 text-zinc-300 font-mono text-sm px-6 py-3 tracking-widest hover:border-green-400 hover:text-green-400 transition-colors">
        DOWNLOAD SETUP MANUAL (PDF)
      </a>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="bg-zinc-900 border-y border-zinc-800 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold font-mono text-white mb-8 tracking-widest">COMPARISON: CAPI SHIELD VS PAID ALTERNATIVES</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm font-mono border-collapse">
          <thead>
            <tr class="border-b border-zinc-700">
              <th class="text-left py-3 px-4 text-zinc-400 font-normal">Feature</th>
              <th class="text-left py-3 px-4 text-green-400 font-bold">CAPI Shield</th>
              <th class="text-left py-3 px-4 text-zinc-500 font-normal">Elevar</th>
              <th class="text-left py-3 px-4 text-zinc-500 font-normal">Northbeam</th>
              <th class="text-left py-3 px-4 text-zinc-500 font-normal">Triple Whale</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800">
            {[
              ['Monthly cost', '$0 forever', '$150+/mo', '$299+/mo', '$299+/mo'],
              ['Meta CAPI', 'Yes', 'Yes', 'Yes', 'Yes'],
              ['Google Enhanced Conversions', 'Yes', 'Yes', 'Partial', 'Limited'],
              ['Webhook-triggered (not browser)', 'Yes', 'Partial', 'Partial', 'Partial'],
              ['Data in your own account', 'Yes — Make.com', 'Their servers', 'Their servers', 'Their servers'],
              ['Vendor lock-in', 'None', 'High', 'High', 'High'],
              ['Annual cost', '$0', '$1,800+', '$3,588+', '$3,588+'],
            ].map(([feature, ...vals]) => (
              <tr>
                <td class="py-3 px-4 text-zinc-400">{feature}</td>
                <td class="py-3 px-4 text-white font-bold">{vals[0]}</td>
                {vals.slice(1).map(v => <td class="py-3 px-4 text-zinc-500">{v}</td>)}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold font-mono text-white mb-2 tracking-widest">VERIFIED RESULTS: WHAT STORE OWNERS SAY AFTER DEPLOYING</h2>
    <p class="font-mono text-xs text-green-400 mb-8">★★★★★ 4.9 / 5 across 500+ stores</p>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        { quote: 'Recovered $600/mo in under 10 minutes. We were bleeding attribution data after iOS 17 and had no idea. CAPI Shield fixed it the same day.', name: 'Jamie L.', role: '6-figure Shopify Apparel Brand' },
        { quote: 'Our Meta campaigns were optimising on broken data for months. After CAPI Shield our event match quality went from 5.2 to 8.1 and our CPA dropped 22% within three weeks.', name: 'Marcus T.', role: 'DTC Fashion Store (~£60k/mo GMV)' },
        { quote: 'I was paying Elevar $150/month. Same result with CAPI Shield for zero dollars. Set up in 8 minutes. I feel like an idiot for not doing this sooner.', name: 'Sarah K.', role: 'Performance Marketing Agency, 15 Shopify clients' },
      ].map(t => (
        <div class="bg-zinc-900 border border-zinc-800 p-5">
          <p class="font-mono text-xs text-green-400 mb-3">★★★★★</p>
          <p class="text-zinc-300 italic mb-4">"{t.quote}"</p>
          <p class="text-white font-bold text-sm">{t.name}</p>
          <p class="text-zinc-500 text-xs">{t.role}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Complete the stack -->
  <section class="bg-zinc-900 border-y border-zinc-800 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold font-mono text-white mb-2 tracking-widest">COMPLETE THE STACK: CAPI SHIELD IS ONE PART OF THE $0 AUTOMATION STACK</h2>
      <p class="text-zinc-400 mb-8">Average store saves $700+/month deploying the full stack.</p>
      <div class="grid md:grid-cols-3 gap-4">
        {[
          { label: 'INVENTORY', title: 'Stocky Swap', desc: 'Replace Stocky before the August 2026 shutdown. Every Shopify order logged to Google Sheets in real time — live stock tracking at $0/month forever.', saves: 'Saves $29–$199/mo', href: '/stocky-swap' },
          { label: 'TIKTOK TRACKING', title: 'TikTok Events API', desc: 'The same Make.com webhook branches to TikTok\'s Events API simultaneously. Free CompletePayment events server-side — recovers 20–40% of TikTok conversions lost to iOS.', saves: 'Saves $39–$299/mo', href: '/tiktok-events-api-shopify' },
