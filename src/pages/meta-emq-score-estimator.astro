<div class="container">
  <nav class="breadcrumb" aria-label="breadcrumb">
    <a href="https://www.stackarchitect.xyz">Stack Architect</a>
    <span aria-hidden="true">›</span>
    <a href="https://www.stackarchitect.xyz/tools">Tools</a>
    <span aria-hidden="true">›</span>
    <span>Meta EMQ Score Estimator</span>
  </nav>

  <main>
    <article>
      
      <h1>Meta EMQ Score Estimator</h1>
      <p class="intro">A low EMQ score means Meta is optimising your campaigns on bad data. Enter your current setup and see your estimated score — and exactly how much recoverable revenue you're leaving on the table.</p>

      <section class="card">
        <p class="card-title">Enter your details</p>
        <form id="calcForm" novalidate>
          <div class="field"><label for="adSpend">Monthly Meta ad spend (£/$/€)</label><input type="number" id="adSpend" name="adSpend" placeholder="e.g. 3000" min="0" required></div>
<div class="field"><label for="capiStatus">Current CAPI setup</label><select id="capiStatus" name="capiStatus" required><option value="">Select…</option><option value="No CAPI — pixel only">No CAPI — pixel only</option><option value="Shopify native CAPI (browser-triggered)">Shopify native CAPI (browser-triggered)</option><option value="True server-side CAPI (e.g. CAPI Shield)">True server-side CAPI (e.g. CAPI Shield)</option><option value="Not sure">Not sure</option></select></div>
<div class="field"><label for="pixelEvents">How many purchase events fire per 100 actual orders?</label><select id="pixelEvents" name="pixelEvents" required><option value="">Select…</option><option value="Fewer than 50">Fewer than 50</option><option value="50–70">50–70</option><option value="70–85">70–85</option><option value="85–95">85–95</option><option value="95–100">95–100</option></select></div>
<div class="field"><label for="iosTraffic">Estimated iOS traffic share</label><select id="iosTraffic" name="iosTraffic"><option value="">Select…</option><option value="Under 30%">Under 30%</option><option value="30–50%">30–50%</option><option value="Over 50%">Over 50%</option></select></div>
          <button type="submit" class="btn-calc">Calculate →</button>
        </form>
      </section>

      
<section id="teaser" hidden>
  <div class="teaser-card">
    <div class="teaser-number" id="teaserValue"></div>
    <div class="teaser-label" id="teaserLabel"></div>
    <div class="gate-box" id="emailGate">
      <p>Enter your email to unlock the full breakdown</p>
      <div class="gate-row">
        <input type="email" id="emailInput" placeholder="you@example.com" autocomplete="email">
        <button class="btn-gate" id="gateBtn">Get your full EMQ breakdown</button>
      </div>
    </div>
  </div>
</section>

      <section id="results" hidden>
        <div class="card">
          <p class="card-title">Your results</p>
          <div id="resultsContent"></div>
        </div>
      </section>

      <aside class="upsell" id="upsellBlock" hidden>
        <span class="upsell-text">Fix your EMQ to 8.0+ for free with CAPI Shield →</span>
        <a class="upsell-btn" href="https://www.stackarchitect.xyz/capi-shield" target="_blank" rel="noopener">Get started →</a>
      </aside>
    </article>

    <section class="faq-section">
      <h2>Frequently asked questions</h2>
      
<details>
  <summary>What is a good EMQ score for Meta?</summary>
  <div class="faq-answer">A score of 6.0 is the bare minimum for Advantage+ Shopping Campaigns to function effectively. 7.0–8.0 is considered good. 8.0+ is excellent and required for maximum algorithmic performance.</div>
</details>
<details>
  <summary>Why does Shopify's native CAPI give a low EMQ?</summary>
  <div class="faq-answer">Shopify's built-in CAPI is still browser-triggered — the thank-you page pixel must fire before the server event sends. If iOS or an ad blocker blocks that page, the server event never fires at all.</div>
</details>
<details>
  <summary>How much ad spend is wasted with a low EMQ?</summary>
  <div class="faq-answer">Studies suggest 25–40% of Meta ad spend is wasted through poor signal quality, as Meta's algorithm optimises against incomplete conversion data.</div>
</details>
    </section>

    <nav class="related-tools" aria-label="Related tools">
      <h2>Other free Shopify tools</h2>
      <div class="related-grid">
        <a class="related-link" href="/tools/shopify-vs-meta-attribution-gap-calculator">Shopify vs. Meta Attribution Gap Calculator</a><a class="related-link" href="/tools/tiktok-vs-meta-roas-bridge-calculator">TikTok vs. Meta ROAS Bridge Calculator</a><a class="related-link" href="/tools/shopify-profit-loss-leak-finder">Shopify P&amp;L Leak Finder</a>
      </div>
    </nav>
  </main>
</div>

<footer>
  <p>Free tool by <a href="https://www.stackarchitect.xyz">Stack Architect</a> &mdash; Free Shopify tools. No apps. No fluff.</p>
</footer>

<script is:inline>
function fmt(n){ return Math.round(n).toLocaleString('en-GB'); }

function calculate(inp) {
  var spend = parseFloat(inp.adSpend) || 0;
  var emq = 4.0;
  if (inp.capiStatus === 'No CAPI — pixel only') emq = 3.5;
  else if (inp.capiStatus === 'Shopify native CAPI (browser-triggered)') emq = 5.5;
  else if (inp.capiStatus === 'True server-side CAPI (e.g. CAPI Shield)') emq = 8.0;
  if (inp.pixelEvents === 'Fewer than 50') emq -= 1.5;
  else if (inp.pixelEvents === '50–70') emq -= 0.5;
  else if (inp.pixelEvents === '85–95') emq += 0.5;
  else if (inp.pixelEvents === '95–100') emq += 1.0;
  if (inp.iosTraffic === 'Over 50%') emq -= 0.5;
  emq = Math.max(0, Math.min(10, emq));
  var wasted = spend * (1 - emq / 10) * 0.25;
  var recovered = spend * (Math.max(0, 8.0 - emq)) / 10 * 0.3;
  var emqFlag = emq >= 8 ? 'good' : emq >= 6 ? 'warn' : 'bad';
  var emqLabel = emq >= 8 ? 'Excellent' : emq >= 7 ? 'Good' : emq >= 6 ? 'Acceptable' : emq >= 4 ? 'Poor' : 'Critical';
  return {
    teaser: { label: 'Your estimated EMQ score', value: emq.toFixed(1) + ' / 10', flag: emqFlag },
    rows: [
      { label: 'Estimated EMQ score', value: emq.toFixed(1) + ' / 10', flag: emqFlag, sub: emqLabel },
      { label: 'Wasted ad spend (monthly)', value: '£' + fmt(wasted), flag: wasted > spend * 0.2 ? 'bad' : 'warn' },
      { label: 'Wasted ad spend (annual)', value: '£' + fmt(wasted * 12), flag: 'bad' },
      { label: 'Recoverable revenue (monthly)', value: '£' + fmt(recovered), flag: 'good' },
      { label: 'Recoverable revenue (annual)', value: '£' + fmt(recovered * 12), flag: 'good' },
      { label: 'Target EMQ', value: '8.0 / 10', flag: 'good' }
    ]
  };
}

var IS_GATED = true;
var form = document.getElementById('calcForm');
var resultsSection = document.getElementById('results');
var resultsContent = document.getElementById('resultsContent');
var teaserSection = document.getElementById('teaser');
var teaserValue = document.getElementById('teaserValue');
var teaserLabel = document.getElementById('teaserLabel');
var emailGate = document.getElementById('emailGate');
var gateBtn = document.getElementById('gateBtn');
var upsellBlock = document.getElementById('upsellBlock');
var lastResult = null;

function getInputs() {
  var inp = {};
  var fd = new FormData(form);
  fd.forEach(function(v, k) {
    if (inp[k]) {
      inp[k] = Array.isArray(inp[k]) ? inp[k].concat(v) : [inp[k], v];
    } else {
      inp[k] = v;
    }
  });
  // Also grab textareas by id since FormData may not pick up all
  form.querySelectorAll('textarea').forEach(function(el){
    if (!inp[el.id]) inp[el.id] = el.value;
  });
  return inp;
}

function renderRows(rows) {
  return rows.map(function(r) {
    var sub = r.sub ? '<span class="sub">' + r.sub + '</span>' : '';
    return '<div class="result-row flag-' + (r.flag||'neutral') + '">' +
      '<span class="result-label">' + r.label + sub + '</span>' +
      '<span class="result-value">' + r.value + '</span>' +
    '</div>';
  }).join('');
}

function showFullResults(rows) {
  resultsContent.innerHTML = renderRows(rows);
  resultsSection.hidden = false;
  upsellBlock.hidden = false;
  resultsSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

form.addEventListener('submit', function(e) {
  e.preventDefault();
  var inp = getInputs();
  var result;
  try { result = calculate(inp); } catch(err) { alert('Calculation error: ' + err.message); return; }
  lastResult = result;

  if (!IS_GATED) {
    showFullResults(result.rows);
    return;
  }

  // Show teaser
  teaserValue.textContent = result.teaser.value;
  teaserLabel.textContent = result.teaser.label;
  teaserSection.hidden = false;

  // Check if already gated
  var storedEmail = localStorage.getItem('sa_email');
  if (storedEmail) {
    emailGate.hidden = true;
    showFullResults(result.rows);
  } else {
    emailGate.hidden = false;
  }
  teaserSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});

if (gateBtn) {
  gateBtn.addEventListener('click', function() {
    var emailInput = document.getElementById('emailInput');
    var email = emailInput ? emailInput.value.trim() : '';
    if (!email || !email.includes('@')) { emailInput.focus(); return; }
    localStorage.setItem('sa_email', email);
    emailGate.hidden = true;
    if (lastResult) showFullResults(lastResult.rows);
  });
}
</script>
</body>
</html>