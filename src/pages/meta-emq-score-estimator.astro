<script>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      bar.style.width = Math.min(pct, 100) + '%';
    }, { passive: true });
  }


  function calcEMQ() {
    const signals = [...document.querySelectorAll('[data-signal]:checked')].map(el => el.dataset.signal);
    const method = document.getElementById('emq-method').value;
    const spend = parseFloat(document.getElementById('emq-spend').value) || 0;

    // EMQ score calculation based on signal weights
    const weights = { email: 2.8, phone: 2.2, external_id: 1.2, click_id: 1.0, ip: 0.5, ua: 0.3, ttp: 0.5 };
    const multipliers = { pixel: 0.65, hybrid: 1.0, serveronly: 1.05 };

    let raw = signals.reduce((sum, s) => sum + (weights[s] || 0), 0);
    let score = Math.min(10, raw * (multipliers[method] || 1));
    score = Math.round(score * 10) / 10;

    const matchRate = Math.min(98, Math.round(score * 10 + (method === 'serveronly' ? 5 : method === 'hybrid' ? 3 : 0)));
    const missing = spend > 0 ? Math.round(spend * (1 - matchRate / 100) * 0.15) : null;

    let grade, gradeColor;
    if (score >= 8) { grade = 'Excellent — top attribution quality'; gradeColor = '#4ade80'; }
    else if (score >= 6) { grade = 'Good — minor improvements possible'; gradeColor = '#a3e635'; }
    else if (score >= 4) { grade = 'Moderate — significant lift available'; gradeColor = '#fbbf24'; }
    else { grade = 'Low — attribution data unreliable'; gradeColor = '#f87171'; }

    document.getElementById('emq-score').textContent = score.toFixed(1);
    document.getElementById('emq-score').style.color = gradeColor;
    document.getElementById('emq-grade').textContent = grade;
    document.getElementById('emq-match').textContent = matchRate + '%';
    document.getElementById('emq-missing').textContent = missing ? '~£' + missing.toLocaleString() + '/mo' : 'Enter spend';

    let insight = '';
    if (!signals.includes('email')) insight += '<strong>Add email address</strong> — the highest-impact single signal. Hashed SHA256, sent server-side. ';
    if (!signals.includes('phone')) insight += '<strong>Add phone number</strong> — second highest EMQ impact. Hashed E.164 format. ';
    if (method === 'pixel') insight += '<strong>Switch to server-side Events API</strong> — browser pixel loses 20–40% of iOS conversions. ';
    if (!signals.includes('click_id')) insight += '<strong>Capture ttclid from URL</strong> — enables precise click-level deduplication. ';
    if (!insight) insight = 'Strong signal setup. Maintain server-side tracking and ensure all customer data fields are consistently populated at checkout.';

    document.getElementById('emq-insight').innerHTML = insight;
    document.getElementById('emq-result').classList.add('show');
  }
  
</script>
