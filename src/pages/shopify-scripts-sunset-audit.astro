  <style>
    /* ═══════════════════════════════════════════════
       DESIGN TOKENS — identical to homepage
    ════════════════════════════════════════════════ */
    :root {
      --bg:      #020617;
      --bg-2:    #080f1f;
      --bg-3:    #0f172a;
      --bg-4:    #1e293b;
      --text:    #f1f5f9;
      --text-2:  #cbd5e1;
      --text-3:  #94a3b8;
      --text-4:  #64748b;
      --border:  rgba(255,255,255,.07);
      --g:       #00c864;
      --g-dark:  #00a854;
      --sky:     #38bdf8;
      --vio:     #c4b5fd;
      --amber:   #f59e0b;
      --red:     #ef4444;
      --tiktok:  #ff2d55;
      --sans:    'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      --mono:    'JetBrains Mono', 'Fira Mono', monospace;
    }

    /* ═══ RESET ═══ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }
    img { max-width: 100%; display: block; }

    /* ═══ KEYFRAMES ═══ */
    @keyframes dotPing {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: .35; transform: scale(.7); }
    }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(0,200,100,.4); }
      50%       { box-shadow: 0 0 0 8px rgba(0,200,100,0); }
    }
    @keyframes countIn {
      from { opacity:0; transform: translateY(6px); }
      to   { opacity:1; transform: translateY(0); }
    }

    /* ═══ LAYOUT CONTAINERS ═══ */
    .inner    { max-width: 1060px; margin: 0 auto; padding: 0 24px; }
    .inner-md { max-width: 780px;  margin: 0 auto; padding: 0 24px; }
    .inner-sm { max-width: 620px;  margin: 0 auto; padding: 0 24px; }

    /* ═══ NAVIGATION ═══ */
    .product-terminal-bar {
      position: sticky; top: 0; z-index: 900;
      background: rgba(2,6,23,.92);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      transition: background .3s;
    }
    .product-terminal-bar.scrolled { background: rgba(2,6,23,.98); }
    .terminal-container {
      max-width: 1200px; margin: 0 auto; padding: 0 20px;
      display: flex; align-items: center; gap: 20px;
      height: 52px;
    }
    .terminal-status {
      font-family: var(--mono); font-size: 9px; font-weight: 700;
      letter-spacing: .16em; color: var(--text-4); white-space: nowrap;
      display: flex; align-items: center; gap: 6px;
    }
    .status-indicator {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--g); display: inline-block;
      animation: dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite;
    }
    .product-access-grid {
      display: flex; align-items: center; gap: 4px; flex: 1;
      overflow-x: auto; scrollbar-width: none;
    }
    .product-access-grid::-webkit-scrollbar { display: none; }
    .product-link {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase;
      color: var(--text-4); padding: 6px 10px; border-radius: 4px;
      white-space: nowrap; transition: color .2s, background .2s;
      display: flex; align-items: center; gap: 2px;
    }
    .product-link:hover, .product-link.is-active { color: var(--text); background: rgba(255,255,255,.05); }
    .home-node { color: var(--g); }
    .dropdown { position: relative; }
    .dropdown-menu {
      display: none; position: absolute; top: calc(100% + 4px); left: 0;
      background: var(--bg-3); border: 1px solid var(--border);
      border-radius: 8px; padding: 6px; min-width: 260px;
      flex-direction: column; gap: 2px; z-index: 999;
      box-shadow: 0 12px 40px rgba(0,0,0,.5);
    }
    .dropdown:hover .dropdown-menu { display: flex; }
    .dropdown-menu .product-link {
      flex-direction: column; align-items: flex-start; padding: 8px 12px;
      border-radius: 6px; gap: 2px;
    }
    .dropdown-desc {
      font-family: var(--sans); font-size: 11px; font-weight: 400;
      text-transform: none; letter-spacing: 0; color: var(--text-4);
      display: block;
    }
    .terminal-cta { display: flex; align-items: center; gap: 10px; margin-left: auto; }
    .savings-ticker {
      font-family: var(--mono); font-size: 9px; font-weight: 700;
      letter-spacing: .12em; color: var(--g); white-space: nowrap;
    }
    .cta-node {
      font-family: var(--mono); font-size: 10px; font-weight: 900;
      letter-spacing: .1em; text-transform: uppercase;
      background: var(--g-dark); color: #fff; border: 1px solid var(--g);
      padding: 7px 14px; border-radius: 4px; white-space: nowrap;
      transition: background .2s; display: inline-block;
    }
    .cta-node:hover { background: var(--g); color: #020617; }

    /* ═══ BUTTONS ═══ */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--g); color: #020617;
      font-family: var(--mono); font-size: 12px; font-weight: 900;
      letter-spacing: .08em; text-transform: uppercase;
      padding: 14px 24px; border-radius: 6px; border: none; cursor: pointer;
      transition: background .2s, transform .15s; text-decoration: none;
    }
    .btn:hover { background: #00e674; transform: translateY(-1px); }
    .btn.pulse { animation: pulse 2.4s ease-in-out infinite; }
    .btn-sm { font-size: 11px; padding: 10px 18px; }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; color: var(--text-3);
      font-family: var(--mono); font-size: 12px; font-weight: 700;
      letter-spacing: .08em; text-transform: uppercase;
      padding: 13px 22px; border-radius: 6px; border: 1px solid var(--border);
      cursor: pointer; transition: border-color .2s, color .2s; text-decoration: none;
    }
    .btn-outline:hover { border-color: var(--text-4); color: var(--text); }
    .btn-outline-sm { font-size: 11px; padding: 9px 16px; }

    /* ═══ TAGS ═══ */
    .tag {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .12em; text-transform: uppercase;
      background: rgba(0,200,100,.1); color: var(--g);
      border: 1px solid rgba(0,200,100,.2); padding: 4px 10px; border-radius: 4px;
      display: inline-flex; align-items: center; gap: 6px;
    }
    .tag-dim  { background: rgba(255,255,255,.04); color: var(--text-4); border-color: var(--border); }
    .tag-sky  { background: rgba(56,189,248,.1); color: var(--sky); border-color: rgba(56,189,248,.2); }
    .tag-vio  { background: rgba(196,181,253,.1); color: var(--vio); border-color: rgba(196,181,253,.2); }
    .tag-amber{ background: rgba(245,158,11,.1); color: var(--amber); border-color: rgba(245,158,11,.2); }
    .tag-red  { background: rgba(239,68,68,.1); color: var(--red); border-color: rgba(239,68,68,.25); }

    /* ═══ DOT INDICATOR ═══ */
    .dot {
      width: 7px; height: 7px; border-radius: 50%; background: var(--g);
      display: inline-block; animation: dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite;
    }

    /* ═══ DIVIDER ═══ */
    .divider { height: 1px; background: var(--border); margin: 0; }

    /* ═══ SECTION HEADS ═══ */
    .sec-head { text-align: center; margin-bottom: 48px; }
    .sec-head h2 {
      font-family: var(--sans); font-weight: 900;
      font-size: clamp(26px,4.5vw,44px); letter-spacing: -.03em;
      color: var(--text); line-height: 1.05; margin-bottom: 14px;
    }
    .sec-head p { font-size: 16px; color: var(--text-3); max-width: 520px; margin: 0 auto; line-height: 1.75; }

    /* ═══ HERO ═══ */
    .hero { padding: 80px 24px 64px; position: relative; overflow: hidden; }
    .bg-grid {
      background-image:
        linear-gradient(rgba(0,200,100,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,200,100,.03) 1px, transparent 1px);
      background-size: 44px 44px;
    }
    .hero-inner { max-width: 780px; margin: 0 auto; text-align: center; }
    .hero-dateline {
      font-family: var(--mono); font-size: 10px; font-weight: 700;
      letter-spacing: .15em; text-transform: uppercase; color: var(--text-4);
      margin-bottom: 20px;
    }
    .hero-proof {
      display: inline-flex; align-items: center; gap: 10px;
      background: rgba(0,200,100,.06); border: 1px solid rgba(0,200,100,.12);
      padding: 6px 14px; border-radius: 20px; margin-bottom: 28px;
    }
    .hero-proof-stars { color: var(--amber); font-size: 12px; letter-spacing: .1em; }
    .hero-proof-txt { font-family: var(--mono); font-size: 10px; font-weight: 700; color: var(--text-4); }
    .hero h1 {
      font-family: var(--sans); font-weight: 900;
      font-size: clamp(36px,6vw,68px); letter-spacing: -.035em; line-height: 1.0;
      color: var(--text); margin-bottom: 22px;
    }
    .hero h1 .green { color: var(--g); }
    .hero h1 .dim   { color: var(--text-4); }
    .hero-sub {
      font-size: clamp(15px,2vw,18px); color: var(--text-3); max-width: 600px;
      margin: 0 auto 32px; line-height: 1.75;
    }
    .cost-row { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 28px; }
    .cost-pill {
      background: var(--bg-3); border: 1px solid var(--border);
      border-radius: 8px; padding: 10px 18px; text-align: center;
    }
    .cost-v { font-family: var(--mono); font-size: 15px; font-weight: 800; color: var(--red); letter-spacing: -.02em; }
    .cost-l { font-size: 11px; color: var(--text-4); margin-top: 2px; }
    .trust-row { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; margin-bottom: 22px; }
    .trust-item { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-3); }
    .urgency {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--mono); font-size: 11px; font-weight: 700;
      color: var(--amber); background: rgba(245,158,11,.08);
      border: 1px solid rgba(245,158,11,.18); padding: 8px 16px; border-radius: 6px;
      margin-bottom: 32px; letter-spacing: .04em;
    }
    .urgency .dot { background: var(--amber); animation: none; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-bottom: 14px; }
    .hero-cta-note { font-size: 12px; color: var(--text-4); margin-bottom: 36px; line-height: 1.6; }
    .hero-cta-note a { color: var(--text-3); text-decoration: underline; text-underline-offset: 3px; }
    .hero-quote {
      background: rgba(255,255,255,.025); border: 1px solid var(--border);
      border-left: 3px solid var(--g); border-radius: 8px;
      padding: 20px 24px; margin: 32px 0; text-align: left; max-width: 600px; margin-inline: auto;
    }
    .hero-quote blockquote { font-size: 14px; color: var(--text-3); line-height: 1.7; font-style: italic; }
    .hero-quote cite { display: block; font-size: 12px; color: var(--text-4); margin-top: 10px; font-style: normal; font-family: var(--mono); }

    /* ═══ PILLARS ═══ */
    .pillars {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 12px;
      margin: 32px 0 12px; text-align: left;
    }
    .pillar {
      background: var(--bg-3); border: 1px solid var(--border);
      border-radius: 10px; padding: 18px 16px;
      transition: border-color .2s, transform .2s; display: block;
    }
    .pillar:hover { border-color: rgba(0,200,100,.25); transform: translateY(-2px); }
    .ptag  { display: inline-flex; margin-bottom: 10px; }
    .pname { font-weight: 700; font-size: 15px; color: var(--text); margin-bottom: 5px; }
    .pdesc { font-size: 12px; color: var(--text-3); line-height: 1.55; margin-bottom: 8px; }
    .psave { font-family: var(--mono); font-size: 11px; font-weight: 700; }
    .pillars-more { font-size: 13px; color: var(--text-4); margin-bottom: 36px; }
    .pillars-more a { color: var(--text-4); text-decoration: underline; text-underline-offset: 3px; }

    /* ═══ STAT STRIP ═══ */
    .stat-strip {
      display: flex; flex-wrap: wrap; gap: 0;
      background: var(--bg-3); border: 1px solid var(--border); border-radius: 10px;
      overflow: hidden; margin-top: 40px;
    }
    .stat-cell {
      flex: 1; min-width: 100px; padding: 18px 12px; text-align: center;
      border-right: 1px solid var(--border);
    }
    .stat-cell:last-child { border-right: none; }
    .stat-v { font-family: var(--mono); font-size: 22px; font-weight: 800; color: var(--g); letter-spacing: -.03em; }
    .stat-l { font-size: 11px; color: var(--text-4); margin-top: 3px; }

    /* ═══ SECTION WRAPPERS ═══ */
    .section     { padding: 80px 0; background: var(--bg); }
    .section-alt { padding: 80px 0; background: var(--bg-2); }

    /* ═══ SCANNER ═══ */
    .scan-card {
      background: var(--bg-3); border: 1px solid var(--border); border-radius: 14px;
      overflow: hidden;
    }
    .pain-list { display: flex; flex-direction: column; gap: 0; }
    .pain-btn {
      background: none; border: none; border-bottom: 1px solid var(--border);
      padding: 14px 20px; cursor: pointer; width: 100%;
      display: flex; align-items: center; justify-content: space-between;
      transition: background .15s; text-align: left; gap: 12px;
    }
    .pain-btn:last-child { border-bottom: none; }
    .pain-btn:hover { background: rgba(255,255,255,.03); }
    .pain-btn.on { background: rgba(0,200,100,.06); }
    .pain-chk {
      width: 18px; height: 18px; border-radius: 4px; border: 1.5px solid var(--text-4);
      flex-shrink: 0; display: flex; align-items: center; justify-content: center;
      transition: background .15s, border-color .15s;
    }
    .pain-btn.on .pain-chk { background: var(--g); border-color: var(--g); }
    .pain-label-wrap { flex: 1; }
    .pain-label { font-size: 13px; color: var(--text-2); line-height: 1.45; }
    .pain-badge {
      font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .1em;
      text-transform: uppercase; background: rgba(245,158,11,.1); color: var(--amber);
      border: 1px solid rgba(245,158,11,.2); padding: 2px 7px; border-radius: 3px;
      display: inline-block; margin-top: 4px;
    }
    .pain-cost { font-family: var(--mono); font-size: 12px; font-weight: 700; color: var(--red); white-space: nowrap; }
    .scan-result {
      padding: 20px 20px 0; background: var(--bg-4); border-top: 1px solid var(--border);
      transition: background .3s;
    }
    .scan-result.leak { background: rgba(239,68,68,.05); border-top-color: rgba(239,68,68,.2); }
    .sr-inner { display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; flex-wrap: wrap; padding-bottom: 20px; }
    .sr-label { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--text-4); margin-bottom: 6px; }
    .sr-total { font-family: var(--mono); font-size: 36px; font-weight: 800; color: var(--red); letter-spacing: -.04em; line-height: 1; }
    .sr-mo { font-size: 16px; font-weight: 400; }
    .sr-year { font-family: var(--mono); font-size: 11px; color: var(--text-4); margin-top: 4px; display: none; }
    .sr-recs-label { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-4); margin-bottom: 6px; }
    .sr-recs-item { font-family: var(--mono); font-size: 12px; color: var(--g); padding: 2px 0; }
    .scan-cta-wrap { padding: 16px 20px 20px; background: var(--bg-4); }
    .scan-cta {
      width: 100%; padding: 14px; border-radius: 8px; border: none; cursor: pointer;
      font-family: var(--mono); font-size: 12px; font-weight: 900; letter-spacing: .08em;
      text-transform: uppercase; transition: background .2s, color .2s;
      background: var(--bg-3); color: var(--text-4);
    }
    .scan-cta.ready { background: var(--g); color: #020617; animation: pulse 2.4s ease-in-out infinite; }
    .scan-cta:disabled { cursor: not-allowed; }
    .scan-meta { font-size: 11px; color: var(--text-4); text-align: center; margin-top: 10px; }

    /* Plan step */
    .plan-step { display: none; padding: 24px 20px; }
    .plan-hd h3 { font-weight: 800; font-size: 20px; color: var(--text); margin-bottom: 6px; }
    .plan-hd p  { font-size: 13px; color: var(--text-3); margin-bottom: 20px; }
    .plan-items { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
    .plan-item  { display: flex; gap: 14px; align-items: flex-start; background: var(--bg-4); border: 1px solid var(--border); border-radius: 8px; padding: 14px 16px; }
    .plan-num   { font-family: var(--mono); font-size: 11px; font-weight: 800; color: var(--g); background: rgba(0,200,100,.1); border: 1px solid rgba(0,200,100,.2); border-radius: 4px; padding: 2px 8px; flex-shrink: 0; }
    .plan-sol   { font-weight: 700; font-size: 14px; color: var(--text); margin-bottom: 3px; }
    .plan-fix   { font-size: 12px; color: var(--text-3); margin-bottom: 4px; }
    .plan-rec   { font-family: var(--mono); font-size: 11px; color: var(--text-4); }

    /* Email block */
    .email-block { background: rgba(0,200,100,.04); border: 1px solid rgba(0,200,100,.12); border-radius: 10px; padding: 20px; }
    .email-block h4 { font-weight: 700; font-size: 15px; color: var(--text); margin-bottom: 6px; }
    .email-block p  { font-size: 13px; color: var(--text-3); margin-bottom: 14px; }
    .email-row  { display: flex; gap: 8px; }
    .email-inp  { flex: 1; background: var(--bg-3); border: 1px solid var(--border); border-radius: 6px; padding: 11px 14px; font-size: 14px; color: var(--text); font-family: var(--sans); outline: none; }
    .email-inp:focus { border-color: var(--g); }
    .email-go   { background: var(--g); color: #020617; border: none; border-radius: 6px; padding: 11px 18px; font-family: var(--mono); font-size: 11px; font-weight: 900; letter-spacing: .08em; cursor: pointer; white-space: nowrap; }
    .email-disc { font-size: 11px; color: var(--text-4); margin-top: 10px !important; }

    /* Done step */
    .done-step  { display: none; padding: 40px 24px; text-align: center; }
    .done-icon  { width: 48px; height: 48px; border-radius: 50%; background: rgba(0,200,100,.1); border: 1px solid rgba(0,200,100,.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
    .done-step h3 { font-weight: 800; font-size: 20px; color: var(--text); margin-bottom: 8px; }
    .done-step p  { font-size: 14px; color: var(--text-3); margin-bottom: 20px; }

    /* ═══ HOW IT WORKS ═══ */
    .how-grid  { display: grid; grid-template-columns: repeat(3,1fr); gap: 0; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; margin-bottom: 0; }
    .how-step  { padding: 32px 28px; background: var(--bg-3); }
    .how-n     { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: .12em; color: var(--g); margin-bottom: 14px; }
    .how-title { font-weight: 800; font-size: 18px; color: var(--text); margin-bottom: 10px; }
    .how-body  { font-size: 13px; color: var(--text-3); line-height: 1.7; margin-bottom: 14px; }
    .how-tool  { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-4); }

    /* ═══ CTA STRIP ═══ */
    .cta-strip { background: rgba(239,68,68,.05); border-top: 1px solid rgba(239,68,68,.15); border-bottom: 1px solid rgba(239,68,68,.15); padding: 24px; }
    .cta-strip-inner { max-width: 860px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
    .cta-strip-title { font-weight: 800; font-size: 18px; color: var(--text); margin-bottom: 4px; }
    .cta-strip-sub   { font-size: 13px; color: var(--text-3); }
    .cta-strip-sub span { color: var(--g); font-weight: 600; }
    .cta-strip-actions { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }

    /* ═══ SOLUTIONS GRID ═══ */
    /* Urgent card */
    .sol-urgent { border: 1.5px solid rgba(245,158,11,.3); border-radius: 12px; overflow: hidden; margin-bottom: 20px; }
    .sol-urgent-bar { height: 3px; background: linear-gradient(90deg, var(--amber), var(--red)); }
    .sol-urgent-inner { padding: 32px; display: flex; gap: 32px; flex-wrap: wrap; }
    .sol-urgent-badge {
      font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .14em;
      text-transform: uppercase; color: var(--amber); background: rgba(245,158,11,.1);
      border: 1px solid rgba(245,158,11,.2); padding: 4px 10px; border-radius: 4px;
      display: inline-block; margin-bottom: 14px;
    }
    .sol-urgent-name { font-weight: 900; font-size: 26px; color: var(--text); letter-spacing: -.02em; margin: 10px 0 6px; }
    .sol-urgent-hl   { font-weight: 700; font-size: 16px; color: var(--amber); margin-bottom: 12px; }
    .sol-urgent-desc { font-size: 14px; color: var(--text-3); line-height: 1.7; margin-bottom: 14px; }
    .sol-urgent-reps { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
    .sol-urgent-meta { display: flex; gap: 16px; align-items: center; }
    .sol-urgent-save { font-family: var(--mono); font-size: 13px; font-weight: 800; color: var(--amber); }
    .sol-urgent-time { font-family: var(--mono); font-size: 11px; color: var(--text-4); }
    .sol-urgent-right { display: flex; flex-direction: column; align-items: center; gap: 12px; min-width: 180px; }

    /* Countdown */
    .countdown-box { background: var(--bg-3); border: 1px solid rgba(245,158,11,.2); border-radius: 10px; padding: 18px 20px; text-align: center; }
    .countdown-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--text-4); margin-bottom: 12px; }
    .countdown-nums { display: flex; align-items: center; gap: 4px; }
    .cd-unit { text-align: center; }
    .cd-val  { font-family: var(--mono); font-size: 28px; font-weight: 800; color: var(--amber); letter-spacing: -.03em; line-height: 1; }
    .cd-l    { font-size: 9px; color: var(--text-4); margin-top: 3px; text-transform: uppercase; letter-spacing: .08em; }
    .cd-sep  { font-family: var(--mono); font-size: 22px; font-weight: 700; color: var(--text-4); padding-bottom: 10px; }

    /* Sol grid */
    .sol-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; }
    .sol-card { border-radius: 12px; overflow: hidden; border: 1px solid var(--border); background: var(--bg-3); display: flex; flex-direction: column; transition: transform .2s, border-color .2s; }
    .sol-card:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.12); }
    .sol-card.g { border-color: rgba(0,200,100,.12); }
    .sol-card.g:hover { border-color: rgba(0,200,100,.28); }
    .sol-card.s { border-color: rgba(56,189,248,.12); }
    .sol-card.s:hover { border-color: rgba(56,189,248,.28); }
    .sol-card.v { border-color: rgba(196,181,253,.12); }
    .sol-card.v:hover { border-color: rgba(196,181,253,.28); }
    .sol-card.t { border-color: rgba(255,45,85,.12); }
    .sol-card.t:hover { border-color: rgba(255,45,85,.28); }
    .sol-bar { height: 3px; }
    .sol-card.g .sol-bar { background: linear-gradient(90deg,var(--g),#00a8e8); }
    .sol-card.s .sol-bar { background: linear-gradient(90deg,var(--sky),var(--vio)); }
    .sol-card.v .sol-bar { background: linear-gradient(90deg,var(--vio),#a78bfa); }
    .sol-card.t .sol-bar { background: linear-gradient(90deg,var(--tiktok),#ff6b6b); }
    .sol-body { padding: 24px 24px 16px; flex: 1; }
    .sol-name { font-weight: 800; font-size: 20px; color: var(--text); letter-spacing: -.02em; margin: 10px 0 6px; }
    .sol-hl   { font-weight: 700; font-size: 14px; color: var(--text-2); margin-bottom: 10px; }
    .sol-desc { font-size: 13px; color: var(--text-3); line-height: 1.65; margin-bottom: 14px; }
    .sol-rep-label { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--text-4); margin-bottom: 6px; }
    .sol-reps { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 12px; }
    .sol-rep { font-family: var(--mono); font-size: 10px; color: var(--text-4); background: rgba(255,255,255,.04); border: 1px solid var(--border); padding: 3px 9px; border-radius: 3px; }
    .sol-meta { display: flex; gap: 12px; align-items: center; }
    .sol-save { font-family: var(--mono); font-size: 12px; font-weight: 800; color: var(--g); }
    .sol-time { font-family: var(--mono); font-size: 10px; color: var(--text-4); }
    .sol-foot { padding: 14px 24px; border-top: 1px solid var(--border); background: rgba(255,255,255,.015); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
    .sol-cta  { font-family: var(--mono); font-size: 11px; font-weight: 800; letter-spacing: .07em; text-transform: uppercase; color: var(--g); }
    .sol-cta:hover { text-decoration: underline; text-underline-offset: 3px; }
    .sol-guide { font-family: var(--mono); font-size: 10px; color: var(--text-4); }
    .sol-guide:hover { color: var(--text-3); }

    /* ═══ TESTIMONIALS ═══ */
    .testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
    .tc { background: var(--bg-3); border: 1px solid var(--border); border-radius: 12px; padding: 24px; }
    .tc.featured { border-color: rgba(0,200,100,.2); background: rgba(0,200,100,.04); grid-column: span 1; }
    .tc-stars { color: var(--amber); font-size: 12px; letter-spacing: .1em; margin-bottom: 12px; }
    .tc-quote { font-size: 13px; color: var(--text-3); line-height: 1.7; margin-bottom: 14px; font-style: italic; }
    .tc-name  { font-weight: 700; font-size: 13px; color: var(--text); }
    .tc-store { font-family: var(--mono); font-size: 10px; color: var(--text-4); margin-top: 2px; }

    /* ═══ SEO PROSE ═══ */
    .seo-prose h3 { font-weight: 800; font-size: 20px; color: var(--text); letter-spacing: -.02em; margin: 32px 0 10px; }
    .seo-prose p  { font-size: 14px; color: var(--text-3); line-height: 1.8; margin-bottom: 16px; }
    .seo-prose a  { color: var(--g); text-decoration: underline; text-underline-offset: 3px; }
    .seo-prose strong { color: var(--text-2); }

    /* ═══ GUIDE CARD ═══ */
    .guide-card { background: var(--bg-3); border: 1px solid rgba(0,200,100,.15); border-radius: 16px; padding: 48px 40px; position: relative; overflow: hidden; }
    .guide-title { font-weight: 900; font-size: clamp(26px,4vw,40px); letter-spacing: -.03em; color: var(--text); line-height: 1.05; margin: 14px 0 10px; }
    .guide-desc  { font-size: 15px; color: var(--text-3); line-height: 1.7; margin-bottom: 10px; }
    .guide-proof { font-family: var(--mono); font-size: 11px; color: var(--text-4); margin-bottom: 20px; }
    .guide-proof span { color: var(--g); font-weight: 700; }
    .guide-specs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
    .gs { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-3); }
    .gs-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--g); flex-shrink: 0; }
    .gf-label { font-weight: 700; font-size: 15px; color: var(--text); margin-bottom: 4px; }
    .gf-sub   { font-size: 12px; color: var(--text-4); margin-bottom: 14px; }
    .gf-row   { display: flex; gap: 8px; }
    .gf-inp   { flex: 1; background: var(--bg-4); border: 1px solid var(--border); border-radius: 6px; padding: 12px 16px; font-size: 14px; color: var(--text); font-family: var(--sans); outline: none; }
    .gf-inp:focus { border-color: var(--g); }
    .gf-go    { background: var(--g); color: #020617; border: none; border-radius: 6px; padding: 12px 20px; font-family: var(--mono); font-size: 11px; font-weight: 900; letter-spacing: .08em; cursor: pointer; white-space: nowrap; }
    .gf-priv  { font-size: 11px; color: var(--text-4); margin-top: 10px; }
    .gf-priv a { color: var(--text-4); text-decoration: underline; text-underline-offset: 3px; }
    .guide-done { display: none; padding: 24px; text-align: center; }
    .guide-done-icon { width: 44px; height: 44px; border-radius: 50%; background: rgba(0,200,100,.1); border: 1px solid rgba(0,200,100,.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; }
    .guide-done-msg { font-size: 15px; color: var(--text-3); }
    .guide-trust { font-family: var(--mono); font-size: 10px; color: var(--text-4); margin-top: 16px; }

    /* ═══ FAQ ═══ */
    .faq-list-c { display: flex; flex-direction: column; gap: 8px; }
    .faq-item-c { background: var(--bg-3); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    .faq-item-c summary {
      padding: 18px 20px; font-weight: 600; font-size: 14px; color: var(--text);
      cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: 16px;
    }
    .faq-item-c summary::-webkit-details-marker { display: none; }
    .faq-ico { width: 18px; height: 18px; border-radius: 50%; border: 1.5px solid var(--text-4); flex-shrink: 0; position: relative; }
    .faq-ico::before, .faq-ico::after { content: ''; position: absolute; background: var(--text-4); border-radius: 2px; top: 50%; left: 50%; transform: translate(-50%,-50%); }
    .faq-ico::before { width: 8px; height: 1.5px; }
    .faq-ico::after  { width: 1.5px; height: 8px; transition: opacity .2s; }
    .faq-item-c[open] .faq-ico::after { opacity: 0; }
    .faq-ans-c { padding: 0 20px 18px; }
    .faq-ans-c p { font-size: 13px; color: var(--text-3); line-height: 1.75; }
    .faq-ans-c a { color: var(--g); text-decoration: underline; text-underline-offset: 3px; }

    /* ═══ SCROLL BAR ═══ */
    .scroll-bar { display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 888; background: var(--bg-3); border-top: 1px solid var(--border); padding: 12px 20px; }
    .scroll-bar-inner { max-width: 900px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .scroll-bar-text { font-size: 13px; color: var(--text-3); }
    .scroll-bar-text span { color: var(--g); font-weight: 600; }
    .scroll-bar-actions { display: flex; gap: 10px; align-items: center; }
    .scroll-bar-dismiss { background: none; border: 1px solid var(--border); color: var(--text-4); border-radius: 4px; padding: 6px 12px; font-size: 11px; cursor: pointer; }

    /* ═══ FOOTER ═══ */
    .architect-footer { background: var(--bg-2); border-top: 1px solid var(--border); padding: 0; }
    .footer-container { max-width: 1060px; margin: 0 auto; padding: 48px 24px 32px; }
    .footer-conversion-strip { background: rgba(0,200,100,.06); border: 1px solid rgba(0,200,100,.12); border-radius: 10px; padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 40px; }
    .footer-conversion-text { font-size: 14px; color: var(--text-3); }
    .footer-conversion-text span { color: var(--text); font-weight: 700; }
    .footer-conversion-cta { font-family: var(--mono); font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: var(--g); }
    .footer-system-title { font-family: var(--mono); font-size: 9px; font-weight: 700; letter-spacing: .2em; color: var(--text-4); display: block; margin-bottom: 16px; }
    .status-bar { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
    .status-item { font-family: var(--mono); font-size: 10px; color: var(--text-4); letter-spacing: .08em; display: flex; align-items: center; gap: 6px; }
    .bar-sep { width: 1px; height: 12px; background: var(--border); }
    .pulse-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--g); display: inline-block; animation: dotPing 2.2s cubic-bezier(.4,0,.6,1) infinite; }
