════════════════════════════════════════════════════════════ */
(function() {
  var P = [
    { id:'d', label:'Discount or promotional scripts — BOGO, tiered pricing, volume rules', cost:149, badge:'Most common', sol:'Make.com Discount Automation', url:'https://www.make.com/en/register?pc=techie123' },
    { id:'o', label:'Order routing or fulfilment logic scripts', cost:199, badge:'Check now', sol:'Make.com Order Router', url:'https://www.make.com/en/register?pc=techie123' },
    { id:'e', label:'Email trigger scripts — cart abandonment, post-purchase, welcome', cost:300, badge:'Replace free', sol:'Systeme.io Free Plan', url:'/go/systeme' },
    { id:'g', label:'Advanced email flows for 2,000+ contacts', cost:199, badge:'GetResponse', sol:'GetResponse', url:'https://try.getresponsetoday.com/gejtf3pvvf1u' },
    { id:'c', label:'Customer service or support automation scripts', cost:150, badge:'Gorgias fix', sol:'Gorgias Helpdesk', url:'https://partner.gorgias.com/xclmfdgeizdk' },
    { id:'r', label:'Reporting or analytics scripts — P&L, revenue tracking', cost:99, badge:'Quick fix', sol:'P&L Auto — Google Sheets', url:'https://stackarchitect.xyz/shopify-profit-loss-automation' },
  ];
  var sel = [], cur = 0, tgt = 0, raf;
  var list = document.getElementById('sc-list');
  if (!list) return;
  P.forEach(function(p) {
    var b = document.createElement('button');
    b.type = 'button'; b.className = 'pain-btn';
    b.setAttribute('role', 'checkbox'); b.setAttribute('aria-checked', 'false');
    b.innerHTML = '<div style="display:flex;align-items:center;gap:12px;flex:1;"><div class="pain-chk" id="chk' + p.id + '"><svg id="chkv' + p.id + '" width="11" height="9" viewBox="0 0 11 9" fill="none" style="display:none"><path d="M1 4.5L3.8 7.5L10 1" stroke="#020617" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="pain-label-wrap"><div class="pain-label">' + p.label + '</div>' + (p.badge ? '<span class="pain-badge">' + p.badge + '</span>' : '') + '</div></div><div class="pain-cost">~$' + p.cost + '/mo</div>';
    b.onclick = function() { scToggle(p, b); };
    list.appendChild(b); p._b = b;
  });

  function scToggle(p, b) {
    var on = sel.indexOf(p.id) === -1;
    if (on) sel.push(p.id); else sel.splice(sel.indexOf(p.id), 1);
    b.classList.toggle('on', on); b.setAttribute('aria-checked', '' + on);
    var v = document.getElementById('chkv' + p.id); if (v) v.style.display = on ? 'block' : 'none';
    scUpdate();
  }

  function scUpdate() {
    var tot = 0, recs = [];
    P.forEach(function(p) { if (sel.indexOf(p.id) !== -1) { tot += p.cost; if (recs.indexOf(p.sol) === -1) recs.push(p.sol); } });
    tgt = tot; cancelAnimationFrame(raf);
    (function go() {
      if (cur < tgt) cur += Math.max(1, Math.ceil((tgt - cur) / 5));
      else if (cur > tgt) cur -= Math.max(1, Math.ceil((cur - tgt) / 5));
      var el = document.getElementById('sc-n');
      if(el) el.textContent = cur.toLocaleString('en-US');
      if (cur !== tgt) raf = requestAnimationFrame(go);
    })();
    var res = document.getElementById('sc-result');
    if(res) res.className = 'scan-result' + (tot > 0 ? ' leak' : '');
    var yr = document.getElementById('sc-yr'); if(yr) yr.style.display = tot > 0 ? 'block' : 'none';
    var yn = document.getElementById('sc-yn'); if(yn) yn.textContent = (tot * 12).toLocaleString('en-US');
    var rc = document.getElementById('sc-recs'); if(rc) { rc.style.display = recs.length ? 'flex' : 'none'; rc.style.flexDirection = 'column'; }
    var rl = document.getElementById('sc-recs-list'); if(rl) rl.innerHTML = recs.map(function(r) { return '<div class="sr-recs-item">→ ' + r + '</div>'; }).join('');
    var btn = document.getElementById('sc-btn');
    if (btn) {
      if (sel.length) {
        btn.disabled = false; btn.className = 'scan-cta ready';
        btn.textContent = 'Build My Free Migration Plan — Save $' + tot + '/mo →';
      } else {
        btn.disabled = true; btn.className = 'scan-cta';
        btn.textContent = 'Select at least one script type above';
      }
    }
  }

  window.scNext = function() {
    if (!sel.length) return;
    var tot = 0, items = [];
    P.forEach(function(p) { if (sel.indexOf(p.id) !== -1) { tot += p.cost; items.push(p); } });
    var ph = document.getElementById('sc-plan-h');
    if(ph) ph.textContent = 'You\'re exposed to ~$' + tot + '/mo in replacement costs';
    var pi = document.getElementById('sc-plan-items');
    if(pi) pi.innerHTML = items.map(function(p, i) {
      return '<div class="plan-item"><div class="plan-num">' + (i + 1) + '</div><div><div class="plan-sol">' + p.sol + '</div><div class="plan-fix">Fixes: ' + p.label + '</div><div class="plan-rec">Recovers ~$' + p.cost + '/mo → <a href="' + p.url + '" target="_blank" rel="noopener sponsored" style="color:var(--g)">Deploy free →</a></div></div></div>';
    }).join('');
    var scan = document.getElementById('sc-scan');
    var plan = document.getElementById('sc-plan');
    if(scan) scan.style.display = 'none';
    if(plan) plan.style.display = 'block';
  };

  window.scSubmit = function() {
    var emailEl = document.getElementById('sc-email');
    var e = (emailEl ? emailEl.value : '').trim();
    if (!e || !e.includes('@')) { if (emailEl) { emailEl.style.borderColor = '#ef4444'; emailEl.focus(); } return; }
    if (emailEl) emailEl.style.borderColor = '';
    window.open('https://stackarchitect.beehiiv.com/subscribe?email=' + encodeURIComponent(e), '_blank');
    var plan = document.getElementById('sc-plan');
    var done = document.getElementById('sc-done');
    if (plan) plan.style.display = 'none';
    if (done) done.style.display = 'block';
  };
})();

