<div class="author-card-container" style="background:#0f1311;border:1px solid #222825;border-radius:12px;padding:1.5rem;margin:3rem 0;display:flex;align-items:center;gap:1.25rem;box-shadow:0 4px 16px rgba(0,0,0,.3);">
  <img src="/luke.jpg" alt="Luke Sandelands" style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:2px solid #34d377;flex-shrink:0;" />
  <div>
    <div style="font-weight:700;color:#fff;font-size:1.05rem;display:flex;align-items:center;gap:8px;">
      Written by Luke Sandelands
      <span style="font-size:0.75rem;font-family:'JetBrains Mono',monospace;color:#34d377;border:1px solid rgba(52,211,119,.3);border-radius:99px;padding:2px 8px;font-weight:600;">Verified Author</span>
    </div>
    <div style="font-size:0.85rem;color:#6b7671;margin-bottom:6px;">Founder, Stack Architect · Shopify Automation Specialist</div>
    <div style="font-size:0.88rem;color:#b6c0ba;line-height:1.5;">
      Developer of <a href="https://stocklog.onrender.com/" target="_blank" rel="noopener" style="color:#34d377;text-decoration:underline;">StockLog</a> and author of the open-source <a href="https://www.npmjs.com/package/shopify-capi-validator" target="_blank" rel="noopener" style="color:#34d377;text-decoration:underline;"><code>shopify-capi-validator</code></a> npm package. Certified in Shopify server-side tracking, Meta CAPI, and Google Apps Script engineering.
    </div>
  </div>
</div>
