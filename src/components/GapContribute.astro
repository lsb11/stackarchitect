---
/**
 * GapContribute.astro — inline contribution card for the live iOS attribution
 * gap benchmark. Mount on any page where a visitor has real store data in
 * front of them (calculators, tracking guides).
 *
 * - Lazy: fetches /api/gap-stats only when revealed (call window.gapContributeShow()).
 * - Posts the two raw numbers to /api/submit-gap; the server validates hard and
 *   computes the gap itself — this card never sends a percentage.
 * - Anonymous by design: two integers, a window, and an optional platform note.
 */
interface Props {
  /** Optional context string appended to platform_note, e.g. "gap-calculator" */
  source?: string;
}
const { source = 'onsite' } = Astro.props;
---

<div id="gap-contribute" data-source={source} style="display:none;margin-top:24px;border:1px solid #14532d;background:linear-gradient(180deg,#04170c,#0a0a0a);padding:24px;">
  <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:6px;">
    <h3 style="font-size:15px;font-weight:800;color:#fff;margin:0;">Add your numbers to the live benchmark</h3>
    <span style="font-family:ui-monospace,monospace;font-size:11px;color:#4ade80;letter-spacing:.08em;text-transform:uppercase;"><span id="gc-count">–</span> of <span id="gc-goal">10</span> stores</span>
  </div>
  <div style="height:6px;background:#111;border-radius:99px;overflow:hidden;margin-bottom:14px;">
    <div id="gc-fill" style="height:100%;width:0%;background:#4ade80;border-radius:99px;transition:width .6s ease;"></div>
  </div>
  <p style="font-size:13px;color:#a1a1aa;line-height:1.6;margin:0 0 16px;">
    You already have the real figures open — contribute them anonymously and help publish the first
    genuine first-party iOS attribution gap figure for Shopify stores. Two numbers, no store name,
    no email. Submissions are reviewed before inclusion.
    <a href="/shopify-ios-attribution-gap-benchmark/" style="color:#4ade80;">See the benchmark &amp; methodology →</a>
  </p>

  <div id="gc-form">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;">
      <div class="calc-field">
        <label for="gc-reported">Conversions your ad platform reported</label>
        <input id="gc-reported" type="number" inputmode="numeric" min="0" step="1" placeholder="e.g. 320" />
      </div>
      <div class="calc-field">
        <label for="gc-actual">Actual Shopify orders, same period</label>
        <input id="gc-actual" type="number" inputmode="numeric" min="20" step="1" placeholder="e.g. 470" />
      </div>
      <div class="calc-field">
        <label for="gc-window">Measurement window</label>
        <select id="gc-window">
          <option value="30" selected>Last 30 days</option>
          <option value="7">Last 7 days</option>
          <option value="90">Last 90 days</option>
        </select>
      </div>
    </div>
    <button id="gc-submit" class="calc-btn" type="button">ADD MY (ANONYMOUS) RESULT →</button>
    <p id="gc-msg" role="status" aria-live="polite" style="font-size:12px;color:#a1a1aa;margin:10px 0 0;min-height:1.2em;"></p>
  </div>

  <div id="gc-done" style="display:none;">
    <p style="font-size:14px;color:#4ade80;font-weight:700;margin:0 0 6px;">✓ Submitted for review — thank you.</p>
    <p style="font-size:13px;color:#a1a1aa;line-height:1.6;margin:0;">
      Once 10 verified stores are in, the benchmark publishes a genuine first-party figure —
      and you'll have helped build it. Track progress on the
      <a href="/shopify-ios-attribution-gap-benchmark/" style="color:#4ade80;">live benchmark page</a>.
    </p>
  </div>
</div>

<script>
  (function () {
    const root = document.getElementById('gap-contribute');
    if (!root) return;
    let statsLoaded = false;

    async function loadStats() {
      if (statsLoaded) return;
      statsLoaded = true;
      try {
        const r = await fetch('/api/gap-stats');
        const d = await r.json();
        const n = d.n ?? 0;
        const goal = d.min_n ?? 10;
        const countEl = document.getElementById('gc-count');
        const goalEl = document.getElementById('gc-goal');
        const fillEl = document.getElementById('gc-fill');
        if (countEl) countEl.textContent = String(n);
        if (goalEl) goalEl.textContent = String(goal);
        if (fillEl) fillEl.style.width = Math.min(100, (n / goal) * 100) + '%';
      } catch { /* meter is decorative; the form still works */ }
    }

    // Public reveal hook — call after a calculator result renders.
    (window as any).gapContributeShow = function () {
      root.style.display = 'block';
      loadStats();
    };

    const btn = document.getElementById('gc-submit');
    if (btn) btn.addEventListener('click', async () => {
      const msg = document.getElementById('gc-msg')!;
      const reported = Math.round(Number((document.getElementById('gc-reported') as HTMLInputElement).value));
      const actual = Math.round(Number((document.getElementById('gc-actual') as HTMLInputElement).value));
      const windowDays = Number((document.getElementById('gc-window') as HTMLSelectElement).value);

      msg.style.color = '#a1a1aa';
      if (!reported && reported !== 0) { msg.textContent = 'Enter the conversions your ad platform reported.'; return; }
      if (!actual) { msg.textContent = 'Enter your actual Shopify order count for the same period.'; return; }
      if (actual < 20) { msg.textContent = 'The benchmark needs at least 20 orders in the window to be a meaningful measurement.'; return; }
      if (reported > actual) { msg.textContent = 'The benchmark measures under-reporting only (platform showing fewer conversions than Shopify). Over-attribution is normal — see the benchmark page for why.'; return; }

      (btn as HTMLButtonElement).disabled = true;
      msg.textContent = 'Submitting…';
      try {
        const r = await fetch('/api/submit-gap', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            meta_reported: reported,
            actual_orders: actual,
            window_days: windowDays,
            platform_note: 'source:' + (root.dataset.source || 'onsite'),
          }),
        });
        const d = await r.json();
        if (r.ok && d.ok) {
          document.getElementById('gc-form')!.style.display = 'none';
          document.getElementById('gc-done')!.style.display = 'block';
        } else {
          msg.style.color = '#f87171';
          msg.textContent = d.error || 'Could not submit — please try again.';
          (btn as HTMLButtonElement).disabled = false;
        }
      } catch {
        msg.style.color = '#f87171';
        msg.textContent = 'Network error — please try again.';
        (btn as HTMLButtonElement).disabled = false;
      }
    });
  })();
</script>
