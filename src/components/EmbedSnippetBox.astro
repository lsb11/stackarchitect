---
// EmbedSnippetBox.astro
// The "Embed this tool" box for the bottom of a public tool page.
// Generates the copy-paste snippet the visitor pastes on their own site.
// The snippet's <a> tag is the backlink; the <iframe> is just the live tool.
//
// Props:
//   embedPath  — the /embed/ route to frame (e.g. "/embed/make-vs-zapier/")
//   canonical  — the public tool page the attribution link points to
//   title      — accessible iframe title / anchor text
//   height     — initial iframe height in px (auto-resizes after load)
interface Props {
  embedPath: string;
  canonical: string;
  title: string;
  height?: number;
}
const { embedPath, canonical, title, height = 560 } = Astro.props;
const src = `https://stackarchitect.xyz${embedPath}`;

// Build the snippet as a plain string. Visitors copy this verbatim.
const snippet =
`<iframe src="${src}" title="${title}" width="100%" height="${height}" style="border:0;max-width:640px" loading="lazy"></iframe>
<p style="font:13px sans-serif"><a href="${canonical}" target="_blank" rel="noopener">${title}</a> by Stack Architect</p>
<script>window.addEventListener("message",function(e){if(e.data&&e.data.saEmbedHeight){var f=document.querySelector('iframe[src="${src}"]');if(f)f.style.height=e.data.saEmbedHeight+"px";}});<\/script>`;
---

<section class="embed-box-section">
  <div class="embed-box-inner">
    <div class="embed-box-kicker">// EMBED THIS TOOL — FREE</div>
    <h2 class="embed-box-h">Put this calculator on your site</h2>
    <p class="embed-box-lede">Free to embed. Copy the code below — it stays up to date automatically and includes a small credit link back.</p>
    <textarea class="embed-box-code" id="embed-snippet" readonly set:text={snippet}></textarea>
    <div class="embed-box-row">
      <button type="button" class="embed-box-btn" id="embed-copy-btn">Copy embed code</button>
      <span class="embed-box-ok" id="embed-copy-ok">Copied ✓</span>
    </div>
  </div>
</section>

<style>
  .embed-box-section{padding:40px 24px;background:#000;border-bottom:1px solid #1f1f1f;}
  .embed-box-inner{max-width:720px;margin:0 auto;}
  .embed-box-kicker{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#4ade80;margin-bottom:10px;}
  .embed-box-h{font-size:clamp(16px,3vw,22px);font-weight:900;color:#fff;letter-spacing:-.03em;margin:0 0 6px;}
  .embed-box-lede{font-size:13px;color:#a1a1aa;line-height:1.7;margin:0 0 16px;}
  .embed-box-code{width:100%;height:120px;background:#0a0a0a;border:1px solid #1f1f1f;color:#a1a1aa;font-family:ui-monospace,Menlo,Consolas,monospace;font-size:12px;padding:12px;resize:vertical;outline:none;}
  .embed-box-code:focus{border-color:#4ade80;}
  .embed-box-row{display:flex;align-items:center;gap:12px;margin-top:12px;}
  .embed-box-btn{background:#4ade80;color:#000;font-family:inherit;font-size:11px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;padding:11px 20px;border:none;cursor:pointer;transition:background .2s;}
  .embed-box-btn:hover{background:#22c55e;}
  .embed-box-ok{font-size:12px;color:#4ade80;opacity:0;transition:opacity .2s;}
  .embed-box-ok.show{opacity:1;}
</style>

<script>
  const btn = document.getElementById('embed-copy-btn');
  const ta = document.getElementById('embed-snippet') as HTMLTextAreaElement | null;
  const ok = document.getElementById('embed-copy-ok');
  if (btn && ta) {
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(ta.value).then(() => {
        if (ok) { ok.classList.add('show'); setTimeout(() => ok.classList.remove('show'), 1600); }
      }).catch(() => { ta.select(); document.execCommand('copy'); });
    });
  }
</script>
