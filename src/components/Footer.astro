---
// Footer.astro — Stack Architect
// Exact design tokens from design pack
// Max conversion + SEO/GEO link coverage
interface Props {
  variant?: 'default' | 'minimal';
  ctaText?: string;
  ctaHref?: string;
  ctaBtnText?: string;
}
const {
  variant = 'default',
  ctaText = "Still paying for Shopify apps? Replace all six in under 10 minutes — <strong>free forever</strong>. Or get the pre-built kit for <strong>$29</strong>.",
  ctaHref = '/pro/',
  ctaBtnText = 'Get the Kit — $29 →',
} = Astro.props;
const year = new Date().getFullYear();
---

<footer class="sa-footer" role="contentinfo">

  {variant === 'default' && (
    <div class="sa-footer-cta-strip">
      <div class="sa-footer-cta-inner">
        <div class="sa-footer-cta-left">
          <div class="sa-footer-cta-label">// the $0 automation stack</div>
          <div class="sa-footer-cta-text" set:html={ctaText} />
        </div>
        <div class="sa-footer-cta-actions">
          <a href={ctaHref} class="sa-footer-btn-kit">{ctaBtnText}</a>
          <a href="/go/make" target="_blank" rel="noopener sponsored" class="sa-footer-btn-free">Replace Free →</a>
        </div>
      </div>
    </div>
  )}

  <div class="sa-footer-body">
    <div class="sa-footer-inner">

      <!-- Brand row -->
      <div class="sa-footer-brand-row">
        <div class="sa-footer-brand">
          <div class="sa-footer-logo">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="20" height="20" fill="none" aria-hidden="true">
              <rect x="17" y="65" width="66" height="9" rx="2.6" fill="#00c864"/>
              <rect x="23.5" y="52" width="53" height="9" rx="2.6" fill="#00c864"/>
              <rect x="30" y="39" width="40" height="9" rx="2.6" fill="#00c864"/>
              <rect x="36.5" y="26" width="27" height="9" rx="2.6" fill="#86efac"/>
            </svg>
            <span class="sa-footer-wordmark">Stack<span class="sa-g">Architect</span></span>
          </div>
          <div class="sa-footer-tagline">Free Shopify automation — replace <a href="/best-free-shopify-apps-2026/" style="color:inherit;text-decoration:underline;text-underline-offset:2px;">$700+/mo of paid apps</a>.</div>
          <div class="sa-footer-status">
            <span class="sa-footer-dot"></span>
            <span>SYSTEM_STABLE // {year}</span>
            <span class="sa-footer-sep">·</span>
            <span>BUILT ON ASTRO</span>
            <span class="sa-footer-sep">·</span>
            <span>OPEN-SOURCE</span>
          </div>
        </div>

        <!-- Trust badges -->
        <div class="sa-footer-trust">
          <div class="sa-trust-badge"><span class="sa-trust-dot"></span>No monthly fees</div>
          <div class="sa-trust-badge"><span class="sa-trust-dot"></span>GDPR compliant</div>
          <div class="sa-trust-badge"><span class="sa-trust-dot"></span>No code required</div>
          <div class="sa-trust-badge"><span class="sa-trust-dot"></span>Any Shopify plan</div>
          <div class="sa-trust-badge"><span class="sa-trust-dot"></span>Open-source on GitHub</div>
          <div class="sa-trust-badge"><span class="sa-trust-dot"></span>Instant Stripe delivery</div>
        </div>
      </div>

      <!-- Link grid -->
      <div class="sa-footer-grid">

        <!-- Products -->
        <div class="sa-footer-col">
          <div class="sa-footer-col-label">Products</div>
          <a href="/">$0 Automation Stack</a>
          <a href="/capi-shield/">CAPI Shield</a>
          <a href="/shopify-google-ads-conversion-tracking/">Google Ads Tracking</a>
          <a href="/stocky-swap/">Stocky Swap</a>
          <a href="/tiktok-events-api-shopify/">TikTok Events API</a>
          <a href="/replace-klaviyo-free/">Replace Klaviyo</a>
          <a href="/shopify-profit-loss-automation/">P&amp;L Auto</a>
          <a href="/autocrat-quota-fix/">Autocrat Quota Fix</a>
          <a href="/stack/">★ Recommended Stack 2026</a>
          <a href="/pro/" class="sa-g">Complete Kit — $29</a>
          <a href="/best-ai-tools-shopify/">Best AI Tools 2026</a>
        </div>

        <!-- Compare -->
        <div class="sa-footer-col">
          <div class="sa-footer-col-label">Compare</div>
          <a href="/best-free-shopify-apps-2026/" style="color:var(--sa-g)">Best Free Shopify Apps 2026</a>
          <a href="/shopify-ios-attribution-gap-benchmark/">iOS Attribution Gap Benchmark</a>
          <a href="/shopify-tracking-tools-pricing/">Live Pricing Tracker 2026</a>
          <a href="/triple-whale-alternative/">Triple Whale Alternative</a>
          <a href="/elevar-alternative/">Elevar Alternative</a>
          <a href="/northbeam-alternative/">Northbeam Alternative</a>
          <a href="/analyzify-alternative/">Analyzify Alternative</a>
          <a href="/stocky-alternative/">Stocky Alternative</a>
          <a href="/klaviyo-vs-systeme-io/">Klaviyo vs Systeme.io</a>
          <div class="sa-footer-col-label" style="margin-top:16px;">Urgent</div>
          <a href="/stocky-shutdown/" class="sa-footer-urgent">⚠ Stocky Shutdown — Aug 2026</a>
          <a href="/shopify-scripts-sunset-audit/">Scripts Sunset Audit</a>
        </div>

        <!-- FAQ -->
        <div class="sa-footer-col">
          <div class="sa-footer-col-label">Quick Answers</div>
          <a href="/faq/">FAQ Hub — All Quick Answers</a>
          <a href="/faq/what-replaces-stocky-after-august-2026/">What replaces Stocky?</a>
          <a href="/faq/is-klaviyo-free/">Is Klaviyo free?</a>
          <a href="/faq/how-much-does-triple-whale-cost/">Triple Whale pricing</a>
          <a href="/faq/what-is-server-side-tracking-for-shopify/">What is server-side tracking?</a>
          <a href="/faq/what-is-the-shopify-capi/">What is the Shopify CAPI?</a>
          <a href="/faq/does-make-com-work-with-shopify/">Does Make.com work with Shopify?</a>
          <a href="/faq/how-do-i-set-up-tiktok-events-api-on-shopify-without-code/">TikTok Events API — no code?</a>
        </div>

        <!-- Tools + Site -->
        <div class="sa-footer-col">
          <div class="sa-footer-col-label">Tools</div>
          <a href="/tools/">All 21 Free Tools</a>
          <a href="/shopify-automation-scanner/">Automation Scanner</a>
          <a href="/app-audit/">App Audit</a>
          <a href="/shopify-app-stack-kill-or-keep-auditor/">App Stack Auditor</a>
          <a href="/make-vs-zapier-cost-calculator/">Make vs Zapier</a>
          <a href="/stocky-migration-risk-scorer/">Stocky Migration Scorer</a>
          <div class="sa-footer-col-label" style="margin-top:16px;">Guides</div>
          <a href="/shopify-automation-guides/">All Guides</a>
          <a href="/ultimate-shopify-automation-guide/">Ultimate Automation Guide</a>
          <a href="/blog/shopify-abandoned-cart-recovery-free-2026/">Abandoned Cart Recovery Free</a>
          <a href="/blog/shopify-email-marketing-free-2026/">Email Marketing Free 2026</a>
          <a href="/blog/shopify-conversion-rate-optimisation-free-2026/">CRO Free — 12 Free Tools</a>
          <div class="sa-footer-col-label" style="margin-top:16px;">Company</div>
          <a href="/about/">About</a>
          <a href="/privacy/">Privacy</a>
          <a href="/terms/">Terms</a>
        </div>

      </div>

      <!-- Divider -->
      <div class="sa-footer-divider"></div>

      <!-- Bottom bar -->
      <div class="sa-footer-bottom">
        <div class="sa-footer-bottom-left">
          <div class="sa-footer-links-row">
            <a href="/about/">About</a>
            <a href="https://www.linkedin.com/in/luke-stackarchitect" target="_blank" rel="noopener">LinkedIn</a>
            <a href="/privacy/">Privacy</a>
            <a href="/terms/">Terms</a>
            <a href="/sitemap-page/">Sitemap</a>
            <a href="mailto:support@stackarchitect.xyz">Support</a>
          </div>
          <div class="sa-footer-disclosure">
            Stack Architect uses affiliate links. We may earn a commission if you sign up for tools via our links — at no extra cost to you. We only recommend tools we use ourselves.
            <a href="/privacy/">Privacy policy</a>.
          </div>
          <div class="sa-footer-copy">&copy; {year} Stack Architect. All rights reserved.</div>
          <div class="sa-footer-badges">
            <a href="https://marketingdb.live" target="_blank" rel="noopener noreferrer nofollow sponsored" aria-label="Listed on MarketingDB">
              <img src="https://marketingdb.live/badge.svg" alt="Listed on MarketingDB" width="150" height="35" loading="lazy" />
            </a>
          </div>
        </div>
        <a href="#top" class="sa-footer-return">↑ RETURN_TO_ORIGIN</a>
      </div>

    </div>
  </div>
</footer>

<style>
  /* ── Design tokens ─────────────────────────────────────────── */
  .sa-footer {
    --g: #00c864;
    --g-hover: #00e070;
    --g-dim: #00a854;
    --g-bg: rgba(0,200,100,0.08);
    --g-border: rgba(0,200,100,0.18);
    --g-glow: rgba(0,200,100,0.40);
    --bg: #020617;
    --bg-2: #06101e;
    --border: #1e293b;
    --text: #f1f5f9;
    --text-2: #cbd5e1;
    --text-3: #94a3b8;
    --text-4: #64748b;
    --text-mute: #475569;
    --text-dim: #334155;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
    --sans: 'Inter', -apple-system, sans-serif;
    --glow-dot: 0 0 8px #00a854;
    --shadow-cta: 0 6px 20px rgba(0,168,84,0.50);
    --ease: cubic-bezier(0.16,1,0.3,1);
    --dur: 200ms;
    --radius: 6px;
    --radius-lg: 10px;
  }

  /* ── Conversion strip ──────────────────────────────────────── */
  .sa-footer-cta-strip {
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 20px 24px;
  }
  .sa-footer-cta-inner {
    max-width: 1060px; margin: 0 auto;
    display: flex; align-items: center;
    justify-content: space-between; gap: 20px; flex-wrap: wrap;
  }
  .sa-footer-cta-label {
    font-family: var(--mono); font-size: 9px; font-weight: 700;
    color: var(--g); letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 4px;
  }
  .sa-footer-cta-text {
    font-size: 14px; color: var(--text-3); line-height: 1.5;
  }
  .sa-footer-cta-text strong { color: var(--text); font-weight: 600; }
  .sa-footer-cta-actions { display: flex; align-items: center; gap: 10px; flex-shrink: 0; flex-wrap: wrap; }
  .sa-footer-btn-kit {
    font-family: var(--mono); font-size: 10px; font-weight: 900;
    color: #000; background: var(--g);
    text-decoration: none; padding: 9px 16px; border-radius: var(--radius);
    letter-spacing: .1em; text-transform: uppercase; white-space: nowrap;
    transition: background var(--dur) var(--ease), box-shadow var(--dur);
  }
  .sa-footer-btn-kit:hover { background: var(--g-hover); box-shadow: var(--shadow-cta); }
  .sa-footer-btn-free {
    font-family: var(--mono); font-size: 10px; font-weight: 800;
    color: var(--g); border: 1px solid var(--g-border);
    text-decoration: none; padding: 8px 16px; border-radius: var(--radius);
    letter-spacing: .1em; text-transform: uppercase; white-space: nowrap;
    transition: all var(--dur) var(--ease);
  }
  .sa-footer-btn-free:hover { background: var(--g); color: #000; }

  /* ── Footer body — dotted grid texture ────────────────────── */
  .sa-footer-body {
    background: var(--bg);
    position: relative;
    border-top: 1px solid var(--border);
  }
  .sa-footer-body::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(#00a854 0.5px, transparent 0.5px);
    background-size: 30px 30px;
    opacity: .07;
    pointer-events: none;
  }
  .sa-footer-inner {
    max-width: 1060px; margin: 0 auto;
    padding: 52px 24px 32px;
    position: relative; z-index: 1;
  }

  /* ── Brand row ─────────────────────────────────────────────── */
  .sa-footer-brand-row {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 32px;
    margin-bottom: 44px; flex-wrap: wrap;
  }
  .sa-footer-logo {
    display: flex; align-items: center; gap: 8px; margin-bottom: 10px;
  }
  .sa-footer-wordmark {
    font-family: var(--mono); font-size: 13px; font-weight: 800;
    color: var(--text-3); letter-spacing: .1em; text-transform: uppercase;
  }
  .sa-g { color: var(--g); }
  .sa-footer-tagline {
    font-size: 13px; color: var(--text-mute); margin-bottom: 12px;
    max-width: 320px; line-height: 1.5;
  }
  .sa-footer-status {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    font-family: var(--mono); font-size: 9px; font-weight: 700;
    color: var(--text-dim); letter-spacing: .1em; text-transform: uppercase;
  }
  .sa-footer-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--g-dim); box-shadow: var(--glow-dot);
    animation: sa-fp 2s linear infinite; flex-shrink: 0;
  }
  @keyframes sa-fp { 0%,100%{opacity:1} 50%{opacity:.3} }
  .sa-footer-sep { color: var(--text-dim); opacity: .4; }

  /* Trust badges */
  .sa-footer-trust {
    display: flex; flex-direction: column; gap: 8px; flex-shrink: 0;
  }
  .sa-trust-badge {
    display: flex; align-items: center; gap: 7px;
    font-size: 12px; color: var(--text-4);
  }
  .sa-trust-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--g); flex-shrink: 0; opacity: .7;
  }

  /* ── Link grid ─────────────────────────────────────────────── */
  .sa-footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px; margin-bottom: 40px;
  }
  .sa-footer-col { display: flex; flex-direction: column; gap: 8px; }
  .sa-footer-col-label {
    font-family: var(--mono); font-size: 9px; font-weight: 700;
    color: var(--text-dim); letter-spacing: .16em; text-transform: uppercase;
    margin-bottom: 4px; padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .sa-footer-col a {
    font-size: 12px; color: var(--text-mute);
    text-decoration: none; line-height: 1.4;
    transition: color var(--dur) var(--ease);
  }
  .sa-footer-col a:hover { color: var(--text-2); }
  .sa-footer-col a.sa-g { color: var(--g); }
  .sa-footer-col a.sa-g:hover { color: var(--g-hover); }
  .sa-footer-urgent {
    color: rgba(252,129,129,.7) !important;
    font-weight: 500;
  }
  .sa-footer-urgent:hover { color: #fc8181 !important; }

  /* ── Divider ───────────────────────────────────────────────── */
  .sa-footer-divider {
    height: 1px; background: var(--border); margin-bottom: 24px;
  }

  /* ── Bottom bar ────────────────────────────────────────────── */
  .sa-footer-bottom {
    display: flex; align-items: flex-end;
    justify-content: space-between; gap: 16px; flex-wrap: wrap;
  }
  .sa-footer-links-row {
    display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 12px;
  }
  .sa-footer-links-row a {
    font-family: var(--mono); font-size: 9px; font-weight: 700;
    color: var(--text-dim); letter-spacing: .1em; text-transform: uppercase;
    text-decoration: none; transition: color var(--dur);
  }
  .sa-footer-links-row a:hover { color: var(--text-3); }
  .sa-footer-disclosure {
    font-size: 11px; color: var(--text-dim); line-height: 1.65;
    max-width: 600px; margin-bottom: 8px;
  }
  .sa-footer-disclosure a { color: var(--text-mute); text-decoration: underline; }
  .sa-footer-disclosure a:hover { color: var(--text-3); }
  .sa-footer-copy {
    font-family: var(--mono); font-size: 9px; color: var(--text-dim);
    letter-spacing: .06em;
  }
  .sa-footer-return {
    font-family: var(--mono); font-size: 9px; font-weight: 700;
    color: var(--text-dim); letter-spacing: .1em; text-transform: uppercase;
    text-decoration: none; flex-shrink: 0; padding-bottom: 2px;
    transition: color var(--dur);
  }
  .sa-footer-return:hover { color: var(--text-3); }

  /* ── Directory badges */
  .sa-footer-badges {
    margin-top: 14px;
    opacity: 0.55;
    transition: opacity var(--dur) var(--ease);
  }
  .sa-footer-badges:hover { opacity: 0.85; }
  .sa-footer-badges img { display: block; }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .sa-footer-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .sa-footer-brand-row { flex-direction: column; gap: 20px; }
    .sa-footer-trust { flex-direction: row; flex-wrap: wrap; gap: 10px 20px; }
  }
  @media (max-width: 560px) {
    .sa-footer-grid { grid-template-columns: 1fr; }
    .sa-footer-inner { padding: 40px 16px 24px; }
    .sa-footer-cta-strip { padding: 16px; }
    .sa-footer-cta-inner { flex-direction: column; align-items: flex-start; }
    .sa-footer-bottom { flex-direction: column; align-items: flex-start; }
    .sa-footer-return { align-self: flex-end; }
    /* ── Directory badges ──────────────────────────────────────── */
  .sa-footer-badges {
    margin-top: 14px;
    opacity: 0.55;
    transition: opacity var(--dur) var(--ease);
  }
  .sa-footer-badges:hover { opacity: 0.85; }
  .sa-footer-badges img { display: block; }
  }

  /* Sticky-bar clearance — only applied while the conversion bar is visible */
  body.sa-sticky-visible .sa-footer-bottom { padding-bottom: 72px; }
  @media (max-width: 560px) {
    body.sa-sticky-visible .sa-footer-bottom { padding-bottom: 110px; }
  }
</style>
