---
// Footer — replicates stackarchitect.xyz footer exactly
---

<!-- Conversion strip -->
<div class="border-t border-[#1f1f1f] bg-[#0a0a0a] px-4 py-8 text-center">
  <p class="text-sm text-gray-400 mb-4 max-w-xl mx-auto">
    Still paying for Shopify apps? Replace all six in under 10 minutes — free forever.
  </p>
  <a
    href="https://www.make.com/en/register?pc=techie123"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block text-xs font-bold text-black bg-[#4ade80] px-6 py-3 hover:bg-[#22c55e] transition-colors font-mono uppercase tracking-wide"
  >
    REPLACE MY APPS FREE →
  </a>
</div>

<footer class="bg-black border-t border-[#1f1f1f] px-4 pt-10 pb-6 font-mono">
  <div class="max-w-6xl mx-auto">

    <!-- Header row -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 mb-8 pb-8 border-b border-[#1f1f1f]">
      <div>
        <div class="text-xs font-bold text-white uppercase tracking-widest mb-1">
          THE $0 AUTOMATION STACK
        </div>
        <div class="text-xs text-[#52525b]">SYSTEM_STABLE // 2026.03.28</div>
      </div>
      <div class="text-xs text-[#52525b]">
        ENGINE:{' '}
        <a
          href="/go/systeme"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#4ade80] hover:underline"
        >
          SYSTEME.IO
        </a>
      </div>
    </div>

    <!-- Link columns -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-8 mb-10">

      <!-- Products -->
      <div>
        <div class="text-xs text-[#52525b] uppercase tracking-widest mb-4">PRODUCTS</div>
        <ul class="space-y-2">
          <li><a href="/" class="text-xs text-gray-500 hover:text-white transition-colors">$0 STACK</a></li>
          <li><a href="/capi-shield" class="text-xs text-gray-500 hover:text-white transition-colors">CAPI SHIELD</a></li>
          <li><a href="/stocky-swap" class="text-xs text-gray-500 hover:text-white transition-colors">STOCKY SWAP</a></li>
          <li><a href="/tiktok-events-api-shopify" class="text-xs text-gray-500 hover:text-white transition-colors">TIKTOK CAPI</a></li>
          <li><a href="/replace-klaviyo-free" class="text-xs text-gray-500 hover:text-white transition-colors">REPLACE KLAVIYO</a></li>
          <li><a href="/shopify-profit-loss-automation" class="text-xs text-gray-500 hover:text-white transition-colors">P&amp;L AUTO</a></li>
          <li><a href="/autocrat-quota-fix" class="text-xs text-gray-500 hover:text-white transition-colors">AUTOCRAT FIX</a></li>
          <li><a href="/best-ai-tools-shopify" class="text-xs text-gray-500 hover:text-white transition-colors">AI TOOLS</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <div class="text-xs text-[#52525b] uppercase tracking-widest mb-4">RESOURCES</div>
        <ul class="space-y-2">
          <li><a href="/tools" class="text-xs text-gray-500 hover:text-white transition-colors">All Tools</a></li>
          <li><a href="/shopify-automation-scanner" class="text-xs text-gray-500 hover:text-white transition-colors">Scanner</a></li>
          <li><a href="/shopify-automation-guides" class="text-xs text-gray-500 hover:text-white transition-colors">Guides</a></li>
          <li><a href="/ultimate-shopify-automation-guide" class="text-xs text-gray-500 hover:text-white transition-colors">Ultimate Guide</a></li>
          <li><a href="/about" class="text-xs text-gray-500 hover:text-white transition-colors">About</a></li>
          <li><a href="/privacy" class="text-xs text-gray-500 hover:text-white transition-colors">Privacy</a></li>
          <li><a href="/terms" class="text-xs text-gray-500 hover:text-white transition-colors">Terms</a></li>
          <li><a href="/sitemap" class="text-xs text-gray-500 hover:text-white transition-colors">Sitemap</a></li>
        </ul>
      </div>

      <!-- Trust signals -->
      <div class="col-span-2 md:col-span-1">
        <div class="text-xs text-[#52525b] uppercase tracking-widest mb-4">VERIFIED</div>
        <div class="grid grid-cols-2 gap-2">
          {
            [
              'No monthly fees',
              'GDPR compliant',
              'No code required',
              'Works with any Shopify store',
            ].map((badge) => (
              <div class="flex items-center gap-1.5 text-xs text-gray-500">
                <span class="w-1.5 h-1.5 rounded-full bg-[#4ade80] flex-shrink-0" />
                {badge}
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[#1f1f1f] pt-6 space-y-3">
      <div class="flex items-center justify-between">
        <p class="text-xs text-[#52525b]">
          &copy; {new Date().getFullYear()} Stack Architect. All rights reserved.
        </p>
        <a href="#top" class="text-xs text-[#52525b] hover:text-white transition-colors">
          ↑ RETURN_TO_ORIGIN
        </a>
      </div>
      <p class="text-xs text-[#52525b] leading-relaxed max-w-2xl">
        Affiliate disclosure: some links on this site use affiliate codes (Make.com, Systeme.io).
        These tools are recommended because they have genuinely useful free plans — not because of
        commission. See our{' '}
        <a href="/privacy" class="text-gray-500 hover:text-white underline transition-colors">
          privacy policy
        </a>.
      </p>
    </div>
  </div>
</footer>
