---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 my-8">
  {
    stats.map(({ value, label }) => (
      <div class="border border-[#1f1f1f] bg-[#0a0a0a] p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold text-[#4ade80]">{value}</div>
        <div class="text-xs text-[#52525b] mt-1 uppercase tracking-wider">{label}</div>
      </div>
    ))
  }
</div>
