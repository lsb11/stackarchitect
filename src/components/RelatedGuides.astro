---
interface Guide {
  title: string;
  href: string;
  badge?: string;
}

interface Props {
  guides: Guide[];
}

const { guides } = Astro.props;

// Normalise internal hrefs to trailing-slash form (site is trailingSlash:'always');
// prevents a 301 hop on every related-guide link when frontmatter omits the slash.
const norm = (h: string) =>
  h.startsWith('/') && !h.endsWith('/') && !/\.[a-z0-9]{2,5}$/i.test(h.split('#')[0])
    ? h.replace(/^([^#?]+)/, '$1/')
    : h;
---

<section class="related-section" aria-labelledby="related-heading">
  <span class="related-label" id="related-heading">Related guides</span>
  <div class="related-list">
    {guides.map(({ title, href, badge }) => (
      <a href={norm(href)} class="related-item">
        <span class="related-title">{title}</span>
        {badge && <span class="related-badge">{badge}</span>}
        <span class="related-arrow">→</span>
      </a>
    ))}
  </div>
</section>

<style>
  .related-section {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 24px 28px;
    margin: 48px 0 0;
  }

  .related-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 800;
    color: #15803d;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: block;
  }

  .related-list {
    display: flex;
    flex-direction: column;
  }

  .related-item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #dfe6e2;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding: 12px 0;
    font-size: 14px;
    font-weight: 600;
    transition: color 0.2s;
  }

  .related-item:last-child {
    border-bottom: none;
  }

  .related-item:hover {
    color: #15803d;
  }

  .related-title {
    flex: 1;
  }

  .related-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    color: #15803d;
    background: rgba(0, 168, 84, 0.1);
    border: 1px solid rgba(0, 168, 84, 0.2);
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .related-arrow {
    color: #2f3733;
    font-size: 13px;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .related-item:hover .related-arrow {
    color: #15803d;
  }
</style>
