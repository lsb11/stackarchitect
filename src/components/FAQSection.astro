---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;
---

<section class="faq-section" aria-labelledby="faq-heading">
  <h2 id="faq-heading">Frequently Asked Questions</h2>
  <div class="faq-list">
    {faqs.map(({ question, answer }) => (
      <div class="faq-item" itemscope itemtype="https://schema.org/Question" itemprop="mainEntity">
        <p class="faq-q" itemprop="name">{question}</p>
        <div itemscope itemtype="https://schema.org/Answer" itemprop="acceptedAnswer">
          <p class="faq-a" itemprop="text">{answer}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .faq-section {
    margin: 52px 0 0;
  }

  .faq-section h2 {
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 900;
    letter-spacing: -1px;
    color: #fff;
    margin: 0 0 24px;
    padding-top: 36px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 20px 0;
  }

  .faq-item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .faq-q {
    font-size: 16px;
    font-weight: 700;
    color: #f1f5f9;
    margin: 0 0 10px;
    line-height: 1.4;
  }

  .faq-a {
    font-size: 14px;
    color: #64748b;
    line-height: 1.75;
    margin: 0;
  }
</style>
