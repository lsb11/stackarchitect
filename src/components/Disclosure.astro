---
// src/components/Disclosure.astro
// Drop <Disclosure /> directly above any affiliate link block or comparison table.
// On-page disclosure beats a one-click-away policy page for E-E-A-T.
import { } from "astro";
---
<p style="font-size:12.5px;opacity:.75;margin:6px 0 14px;border-left:2px solid #34d399;padding-left:10px;">
  Some links below are affiliate links (marked <code>sponsored</code>). They fund the free
  guides and never change a recommendation — our default pick on this page is a free tier.
  <a href="/how-we-test/" style="text-decoration:underline;">How we test &amp; disclose →</a>
</p>
