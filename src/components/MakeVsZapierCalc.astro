---
// MakeVsZapierCalc.astro
// Single source of truth for the Make vs Zapier calculator.
// Imported by BOTH the public tool page and the /embed/ route so the
// pricing logic can never drift between them.
//
// Props:
//   embed   — when true, renders the compact embed chrome (attribution
//             footer + height auto-report) and omits the page-level hero.
interface Props {
  embed?: boolean;
}
const { embed = false } = Astro.props;
---

<div class="mz-calc" data-embed={embed ? '1' : '0'}>
  <div class="calc-card">
    <div class="calc-kicker">// AUTOMATION_COST_CALCULATOR</div>
    <div class="calc-grid">
      <div class="calc-field">
        <label for="mz-runs">Monthly automation runs (workflow executions)</label>
        <input type="number" id="mz-runs" placeholder="e.g. 500" inputmode="numeric" min="0" />
      </div>
      <div class="calc-field">
        <label for="mz-steps">Average steps per workflow</label>
        <select id="mz-steps">
          <option value="2">1–3 steps (simple trigger → action)</option>
          <option value="5">4–6 steps (intermediate)</option>
          <option value="9">7–12 steps (complex)</option>
          <option value="15">12+ steps (advanced)</option>
        </select>
      </div>
      <div class="calc-field">
        <label for="mz-current">Current platform</label>
        <select id="mz-current">
          <option value="zapier">Zapier</option>
          <option value="make">Make.com</option>
          <option value="neither">Neither (evaluating)</option>
        </select>
      </div>
      <div class="calc-field">
        <label for="mz-cost">Current monthly cost £/$</label>
        <input type="number" id="mz-cost" placeholder="e.g. 49" inputmode="numeric" min="0" />
      </div>
    </div>
    <button class="calc-btn" type="button" id="mz-go">COMPARE PLATFORM COSTS →</button>
    <div class="calc-result" id="mz-result">
      <div class="result-grid">
        <div class="result-cell"><div class="result-label">Make.com Monthly Cost</div><div class="result-value" id="mz-make">--</div><div class="result-sub" id="mz-make-plan">--</div></div>
        <div class="result-cell"><div class="result-label">Zapier Monthly Cost</div><div class="result-value" id="mz-zapier" style="font-size:28px;color:#f87171;">--</div><div class="result-sub" id="mz-zapier-plan">--</div></div>
        <div class="result-cell"><div class="result-label">Monthly Saving (Make)</div><div class="result-value" id="mz-saving" style="font-size:28px;">--</div><div class="result-sub">Annual: <span id="mz-annual">--</span></div></div>
      </div>
      <div class="result-insight" id="mz-insight"></div>
    </div>
  </div>

  {embed && (
    <div class="mz-attrib">
      <a href="https://stackarchitect.xyz/make-vs-zapier-cost-calculator/?utm_source=embed&utm_medium=attribution" target="_blank" rel="noopener">
        Make vs Zapier Cost Calculator
      </a>
      — free tool from Stack Architect
    </div>
  )}
</div>

<style>
  .mz-calc{font-family:inherit;}
  /* Embed mode: standalone surface, no surrounding page chrome */
  .mz-calc[data-embed="1"]{max-width:640px;margin:0 auto;}

  .calc-card{border:1px solid #222825;background:#000;padding:32px;}
  .calc-kicker{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#6b7671;margin-bottom:20px;}
  .calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;}
  @media(max-width:600px){.calc-grid{grid-template-columns:1fr;}}
  .calc-field{display:flex;flex-direction:column;gap:6px;}
  .calc-field label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#6b7671;}
  .calc-field input,.calc-field select{background:#0c0f0d;border:1px solid #222825;color:#fff;font-family:inherit;font-size:13px;padding:10px 14px;outline:none;transition:border-color .2s;width:100%;}
  .calc-field input:focus,.calc-field select:focus{border-color:#34d377;}
  .calc-field input::placeholder{color:#2f3733;}
  .calc-btn{width:100%;background:#34d377;color:#000;font-family:inherit;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:14px;border:none;cursor:pointer;transition:background .2s;margin-top:8px;}
  .calc-btn:hover{background:#34d377;}
  .calc-result{display:none;margin-top:24px;border:1px solid #222825;background:#0c0f0d;padding:24px;}
  .calc-result.show{display:block;}
  .result-label{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:#6b7671;margin-bottom:6px;}
  .result-value{font-size:36px;font-weight:700;color:#34d377;line-height:1;letter-spacing:-.03em;}
  .result-sub{font-size:12px;color:#6b7671;margin-top:6px;line-height:1.6;}
  .result-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;margin-bottom:20px;}
  .result-cell{background:#000;border:1px solid #222825;padding:16px;}
  .result-insight{font-size:12px;color:#93a09a;line-height:1.7;border-top:1px solid #222825;padding-top:16px;margin-top:16px;}
  .result-insight strong{color:#fff;}

  .mz-attrib{margin-top:14px;text-align:center;font-size:11px;color:#6b7671;}
  .mz-attrib a{color:#34d377;text-decoration:none;}
  .mz-attrib a:hover{text-decoration:underline;}
</style>

<script>
  function calcMakeZapier() {
    const runsEl = document.getElementById('mz-runs') as HTMLInputElement | null;
    const stepsEl = document.getElementById('mz-steps') as HTMLSelectElement | null;
    if (!runsEl || !stepsEl) return;

    const runs = parseInt(runsEl.value) || 0;
    const steps = parseInt(stepsEl.value);
    const ops = runs * steps;

    let makeCost, makePlan;
    if (ops <= 1000) { makeCost = 0; makePlan = 'Free tier'; }
    else if (ops <= 10000) { makeCost = 9; makePlan = 'Core — 10k ops'; }
    else if (ops <= 40000) { makeCost = 16; makePlan = 'Pro — 40k ops'; }
    else if (ops <= 150000) { makeCost = 29; makePlan = 'Teams — 150k ops'; }
    else { makeCost = 99; makePlan = 'Enterprise'; }

    let zapierCost, zapierPlan;
    if (ops <= 100) { zapierCost = 0; zapierPlan = 'Free tier'; }
    else if (ops <= 750) { zapierCost = 17; zapierPlan = 'Starter — 750 tasks'; }
    else if (ops <= 2000) { zapierCost = 44; zapierPlan = 'Professional — 2k tasks'; }
    else if (ops <= 50000) { zapierCost = 89; zapierPlan = 'Team — 50k tasks'; }
    else { zapierCost = 299; zapierPlan = 'Company'; }

    const saving = zapierCost - makeCost;
    const set = (id: string, v: string) => { const el = document.getElementById(id); if (el) el.textContent = v; };

    const makeEl = document.getElementById('mz-make');
    if (makeEl) { makeEl.textContent = makeCost === 0 ? 'FREE' : '£' + makeCost + '/mo'; (makeEl as HTMLElement).style.color = '#34d377'; }
    set('mz-make-plan', makePlan + ' (' + ops.toLocaleString() + ' ops needed)');
    set('mz-zapier', zapierCost === 0 ? 'FREE' : '£' + zapierCost + '/mo');
    set('mz-zapier-plan', zapierPlan);

    const savingEl = document.getElementById('mz-saving');
    if (savingEl) { savingEl.textContent = saving > 0 ? '£' + saving + '/mo' : '£0'; (savingEl as HTMLElement).style.color = saving > 0 ? '#34d377' : '#6b7671'; }
    set('mz-annual', saving > 0 ? '£' + (saving * 12).toLocaleString() : '£0');

    const insight = saving > 0
      ? '<strong>Switching to Make.com saves £' + saving + '/month</strong> (£' + (saving * 12) + '/year) at your automation volume. Make.com also handles the multi-path routing required for Shopify CAPI, TikTok Events API, and Google Sheets simultaneously — which Zapier cannot do in a single workflow.'
      : 'At this volume both platforms are in a similar price bracket. Make.com\'s advantage is in capability — complex multi-path scenarios, data transformation, and running the full $0 Shopify automation stack in a single scenario.';
    const insightEl = document.getElementById('mz-insight');
    if (insightEl) insightEl.innerHTML = insight;
    const resultEl = document.getElementById('mz-result');
    if (resultEl) resultEl.classList.add('show');

    reportEmbedHeight();
  }

  // When embedded, tell the host page our height so the iframe fits with no scrollbar.
  function reportEmbedHeight() {
    const root = document.querySelector('.mz-calc') as HTMLElement | null;
    if (!root || root.dataset.embed !== '1') return;
    const h = document.body.scrollHeight;
    if (window.parent && window.parent !== window) {
      window.parent.postMessage({ saEmbedHeight: h, tool: 'make-vs-zapier' }, '*');
    }
  }

  const goBtn = document.getElementById('mz-go');
  if (goBtn) goBtn.addEventListener('click', calcMakeZapier);
  window.addEventListener('load', reportEmbedHeight);
  window.addEventListener('resize', reportEmbedHeight);
</script>
