<style>
/* ── Utilities ─────────────────────────────────────────────── */
.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}

/* ── Design tokens (from colors_and_type.css) ──────────────── */
:root{
  --g:#00c864;
  --g-hover:#00e070;
  --g-dim:#00a854;
  --g-bg:rgba(0,200,100,0.08);
  --g-border:rgba(0,200,100,0.18);
  --g-glow:rgba(0,200,100,0.40);
  --bg:#020617;
  --bg-2:#06101e;
  --bg-3:#0a1628;
  --border:#1e293b;
  --border-2:#263548;
  --text:#f1f5f9;
  --text-2:#cbd5e1;
  --text-3:#94a3b8;
  --text-4:#64748b;
  --text-mute:#475569;
  --text-dim:#334155;
  --sans:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  --mono:'JetBrains Mono',ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,'Courier New',monospace;
  --ease:cubic-bezier(0.16,1,0.3,1);
  --dur:200ms;
  --shadow-md:0 16px 40px rgba(0,0,0,0.60);
  --shadow-cta:0 6px 20px rgba(0,168,84,0.50);
  --glow-dot:0 0 8px #00a854;
  --radius:6px;
}

/* ── Top bar ───────────────────────────────────────────────── */
.sa-topbar{
  display:flex;align-items:center;justify-content:space-between;
  background:var(--bg);border-bottom:1px solid var(--border);
  padding:6px 24px;font-size:10px;color:var(--text-mute);
}
.sa-topbar-left{display:flex;align-items:center;gap:8px;}
.sa-topbar-right{
  font-family:var(--mono);font-size:9px;font-weight:700;
  color:var(--g);letter-spacing:1.5px;text-transform:uppercase;
}
.sa-pulse{
  display:inline-block;width:5px;height:5px;border-radius:50%;
  background:var(--g-dim);box-shadow:var(--glow-dot);
  animation:sa-pulse 2s linear infinite;flex-shrink:0;
}
@keyframes sa-pulse{0%,100%{opacity:1;}50%{opacity:.3;}}
.sa-mono{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;}

/* ── Nav shell ─────────────────────────────────────────────── */
.sa-nav{
  background:var(--bg);border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:10000;
  transition:box-shadow var(--dur) var(--ease);
}
.sa-nav.scrolled{
  box-shadow:0 4px 20px rgba(0,0,0,0.40);
  backdrop-filter:blur(12px);
  background:rgba(2,6,23,0.95);
}
.sa-nav-inner{
  max-width:1200px;margin:0 auto;padding:0 24px;
  display:flex;align-items:center;height:52px;gap:0;
}

/* ── Logo ──────────────────────────────────────────────────── */
.sa-logo{
  display:flex;align-items:center;gap:8px;
  text-decoration:none;margin-right:20px;flex-shrink:0;
  transition:opacity var(--dur) var(--ease);
}
.sa-logo:hover{opacity:.85;}
.sa-logo-mark{
  display:flex;align-items:center;flex-shrink:0;
  transition:filter var(--dur) var(--ease);
}
.sa-logo:hover .sa-logo-mark{filter:drop-shadow(0 0 6px var(--g-glow));}
.sa-logo-text{
  font-family:var(--mono);font-size:11px;font-weight:800;
  color:var(--text-3);letter-spacing:.1em;text-transform:uppercase;
  line-height:1;white-space:nowrap;
}
.sa-logo-accent{color:var(--g);}

/* ── Desktop nav links ─────────────────────────────────────── */
.sa-nav-links{display:flex;align-items:center;gap:0;flex:1;}

/* Dropdown trigger */
.sa-drop{position:relative;}
.sa-drop-btn{
  display:flex;align-items:center;gap:3px;
  background:none;border:none;cursor:pointer;
  font-family:var(--mono);font-size:10px;font-weight:700;
  color:var(--text-4);letter-spacing:.06em;text-transform:uppercase;
  padding:16px 11px;white-space:nowrap;
  transition:color var(--dur) var(--ease);line-height:1;
}
.sa-drop-btn:hover,
.sa-drop.open .sa-drop-btn{color:var(--text);}

/* Brackets — the signature motif */
.sa-bracket{
  color:var(--text-dim);font-weight:800;
  transition:color var(--dur) var(--ease);
}
.sa-drop-btn:hover .sa-bracket,
.sa-drop.open .sa-drop-btn .sa-bracket{color:var(--g);}

.sa-caret{font-size:7px;transition:transform var(--dur) var(--ease);margin-top:1px;opacity:.6;}
.sa-drop.open .sa-caret{transform:rotate(180deg);}

/* Dropdown panel */
.sa-drop-panel{
  display:none;position:absolute;top:calc(100% + 2px);left:0;
  background:#050a14;border:1px solid var(--border);
  border-radius:var(--radius);padding:6px 0;
  min-width:260px;max-width:320px;
  z-index:10001;box-shadow:var(--shadow-md);
  max-height:80vh;overflow-y:auto;
}
.sa-drop.open .sa-drop-panel{display:block;}

.sa-drop-panel::-webkit-scrollbar{width:3px;}
.sa-drop-panel::-webkit-scrollbar-track{background:transparent;}
.sa-drop-panel::-webkit-scrollbar-thumb{background:var(--border-2);border-radius:2px;}

.sa-drop-item{
  display:flex;flex-direction:column;padding:10px 16px;
  text-decoration:none;transition:background var(--dur);gap:2px;
}
.sa-drop-item:hover{background:rgba(0,200,100,.05);}
.sa-drop-item--pro{background:rgba(0,200,100,.04);}
.sa-drop-item--pro:hover{background:rgba(0,200,100,.09);}

.sa-drop-title{
  font-family:var(--mono);font-size:10px;font-weight:700;
  color:var(--text-2);letter-spacing:.05em;
  transition:color var(--dur);line-height:1.3;
}
.sa-drop-item:hover .sa-drop-title{color:var(--g);}
.sa-drop-item--pro .sa-drop-title{color:var(--g);}
.sa-drop-desc{font-size:10px;color:var(--text-mute);line-height:1.4;margin-top:2px;}
.sa-drop-divider{height:1px;background:var(--border);margin:4px 0;}
.sa-drop-group-label{
  font-family:var(--mono);font-size:9px;font-weight:700;
  color:var(--text-dim);letter-spacing:.18em;text-transform:uppercase;
  padding:8px 16px 4px;line-height:1;
}
.sa-pro-badge{
  display:inline-block;background:var(--g);color:#000;
  font-size:8px;font-weight:900;padding:2px 5px;
  border-radius:2px;margin-left:6px;letter-spacing:.08em;vertical-align:middle;
}

/* ── Right CTAs ────────────────────────────────────────────── */
.sa-nav-right{display:flex;align-items:center;gap:8px;margin-left:auto;flex-shrink:0;}
.sa-pro-cta{
  font-family:var(--mono);font-size:9px;font-weight:900;
  color:#000;background:var(--g);
  text-decoration:none;padding:7px 13px;border-radius:var(--radius);
  letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;
  transition:background var(--dur) var(--ease),transform var(--dur) var(--ease-pop);
  line-height:1;
}
.sa-pro-cta:hover{background:var(--g-hover);transform:translateY(-1px);}

.sa-free-cta{
  font-family:var(--mono);font-size:9px;font-weight:800;
  color:var(--g);border:1px solid var(--g-border);
  text-decoration:none;padding:6px 13px;border-radius:var(--radius);
  letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;
  transition:all var(--dur) var(--ease);line-height:1;
}
.sa-free-cta:hover{background:var(--g);color:#000;}

/* ── Hamburger ─────────────────────────────────────────────── */
.sa-hamburger{
  display:none;flex-direction:column;gap:5px;
  background:none;border:none;cursor:pointer;
  padding:8px;margin-left:12px;
}
.sa-hamburger span{
  display:block;width:20px;height:1.5px;
  background:var(--text-3);transition:all .25s;
}
.sa-hamburger.open span:nth-child(1){transform:rotate(45deg) translate(4px,4px);}
.sa-hamburger.open span:nth-child(2){opacity:0;}
.sa-hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(4px,-4px);}

/* ── Mobile menu ───────────────────────────────────────────── */
.sa-mobile-menu{
  display:none;background:#050a14;border-top:1px solid var(--border);
  padding:16px 24px 28px;max-height:80vh;overflow-y:auto;
}
.sa-mobile-menu.open{display:block;}
.sa-mobile-section-label{
  font-family:var(--mono);font-size:9px;font-weight:700;
  color:var(--text-dim);letter-spacing:.18em;text-transform:uppercase;
  padding:16px 0 8px;border-top:1px solid var(--border);margin-top:8px;
}
.sa-mobile-section-label:first-child{margin-top:0;border-top:none;padding-top:4px;}
.sa-mobile-link{
  display:block;font-family:var(--mono);font-size:10px;
  color:var(--text-4);text-decoration:none;
  padding:7px 0;transition:color var(--dur);letter-spacing:.06em;
}
.sa-mobile-link:hover{color:var(--text);}
.sa-mobile-link--pro{color:var(--g) !important;}
.sa-mobile-ctas{
  display:flex;flex-direction:column;gap:10px;
  margin-top:20px;padding-top:16px;border-top:1px solid var(--border);
}
.sa-mobile-cta-pro{
  display:block;text-align:center;
  font-family:var(--mono);font-size:11px;font-weight:900;
  color:#000;background:var(--g);
  text-decoration:none;padding:12px;border-radius:var(--radius);
  letter-spacing:.1em;text-transform:uppercase;
  transition:background var(--dur);
}
.sa-mobile-cta-pro:hover{background:var(--g-hover);}
.sa-mobile-cta-free{
  display:block;text-align:center;
  font-family:var(--mono);font-size:11px;font-weight:900;
  color:var(--g);border:1px solid var(--g-border);
  text-decoration:none;padding:12px;border-radius:var(--radius);
  letter-spacing:.1em;text-transform:uppercase;
  transition:all var(--dur);
}
.sa-mobile-cta-free:hover{background:var(--g);color:#000;}

/* ── Responsive ────────────────────────────────────────────── */
@media(max-width:900px){
  .sa-nav-links,.sa-nav-right{display:none;}
  .sa-hamburger{display:flex;}
  .sa-topbar-right{display:none;}
}
@media(max-width:480px){
  .sa-topbar{padding:6px 16px;}
  .sa-nav-inner{padding:0 16px;}
  .sa-mobile-menu{padding:16px 16px 24px;}
}
</style>

<script is:inline>
(function() {
  var nav = document.getElementById('sa-nav-main');
  window.addEventListener('scroll', function() {
    if (nav) nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  var drops = document.querySelectorAll('.sa-drop');
  drops.forEach(function(drop) {
    var btn = drop.querySelector('.sa-drop-btn');
    if (!btn) return;
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var isOpen = drop.classList.contains('open');
      drops.forEach(function(d) {
        d.classList.remove('open');
        var b = d.querySelector('.sa-drop-btn');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        drop.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  document.addEventListener('click', function() {
    drops.forEach(function(d) {
      d.classList.remove('open');
      var b = d.querySelector('.sa-drop-btn');
      if (b) b.setAttribute('aria-expanded', 'false');
    });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      drops.forEach(function(d) {
        d.classList.remove('open');
        var b = d.querySelector('.sa-drop-btn');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
    }
  });

  var hamburger = document.getElementById('sa-hamburger');
  var mobileMenu = document.getElementById('sa-mobile-menu');
  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', function() {
      var open = hamburger.classList.toggle('open');
      mobileMenu.classList.toggle('open', open);
      mobileMenu.setAttribute('aria-hidden', String(!open));
      hamburger.setAttribute('aria-expanded', String(open));
      drops.forEach(function(d) { d.classList.remove('open'); });
    });
  }
})();
</script>
