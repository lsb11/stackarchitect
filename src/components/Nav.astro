---
interface Props {
  topBarLabel?: string;
}

const { topBarLabel = 'PRODUCT_NODES // ACCESS_OPEN' } = Astro.props;
---

<a id="top" class="sr-only" aria-hidden="true"></a>

<!-- Top status bar -->
<div class="bg-[#0a0a0a] border-b border-[#1f1f1f] px-4 py-1.5 text-xs text-[#52525b] flex items-center justify-between overflow-hidden">
  <span class="flex items-center gap-2">
    <span class="w-1.5 h-1.5 rounded-full bg-[#4ade80] animate-pulse inline-block"></span>
    <span class="font-mono">{topBarLabel}</span>
  </span>
  <span class="hidden sm:block text-[#4ade80] font-mono text-xs">SAVE $700+/MO →</span>
</div>

<!-- Mobile nav toggle (CSS checkbox hack) -->
<input type="checkbox" id="mobile-nav-toggle" class="hidden peer/nav" aria-hidden="true" />

<!-- Main nav -->
<nav class="bg-black border-b border-[#1f1f1f] relative z-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-12">

      <!-- Logo / home -->
      <a
        href="/"
        class="text-xs font-bold font-mono text-white hover:text-[#4ade80] transition-colors tracking-wider"
      >
        ~/HOME
      </a>

      <!-- Desktop nav items -->
      <div class="hidden md:flex items-center gap-1">

        <!-- Products dropdown -->
        <div class="relative group/products">
          <button
            class="flex items-center gap-1 text-xs text-gray-400 hover:text-white px-3 py-3 transition-colors font-mono"
            aria-haspopup="true"
          >
            Products <span class="text-[#52525b]">▾</span>
          </button>
          <div
            class="absolute top-full left-0 min-w-[280px] bg-black border border-[#1f1f1f] invisible opacity-0 translate-y-1
                   group-hover/products:visible group-hover/products:opacity-100 group-hover/products:translate-y-0
                   focus-within:visible focus-within:opacity-100 focus-within:translate-y-0
                   transition-all duration-150 z-50"
          >
            <a href="/capi-shield" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">CAPI_Shield</span>
              <span class="text-xs text-[#52525b] mt-0.5">Free Meta + Google server-side tracking</span>
            </a>
            <a href="/stocky-swap" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">$0_Stocky_Swap</span>
              <span class="text-xs text-[#52525b] mt-0.5">Free inventory — replaces Stocky Aug 2026</span>
            </a>
            <a href="/tiktok-events-api-shopify" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">TikTok_Events_API</span>
              <span class="text-xs text-[#52525b] mt-0.5">Free TikTok server-side tracking</span>
            </a>
            <a href="/replace-klaviyo-free" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">Replace_Klaviyo_Free</span>
              <span class="text-xs text-[#52525b] mt-0.5">Free email automation via Systeme.io</span>
            </a>
            <a href="/shopify-profit-loss-automation" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">Shopify_P&amp;L_Auto</span>
              <span class="text-xs text-[#52525b] mt-0.5">Live profit and loss in Google Sheets free</span>
            </a>
            <a href="/autocrat-quota-fix" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">Autocrat_Quota_Fix</span>
              <span class="text-xs text-[#52525b] mt-0.5">Fix Google Apps Script quota errors free</span>
            </a>
          </div>
        </div>

        <!-- Tools dropdown -->
        <div class="relative group/tools">
          <button
            class="flex items-center gap-1 text-xs text-gray-400 hover:text-white px-3 py-3 transition-colors font-mono"
            aria-haspopup="true"
          >
            Tools <span class="text-[#52525b]">▾</span>
          </button>
          <div
            class="absolute top-full left-0 min-w-[300px] bg-black border border-[#1f1f1f] invisible opacity-0 translate-y-1
                   group-hover/tools:visible group-hover/tools:opacity-100 group-hover/tools:translate-y-0
                   focus-within:visible focus-within:opacity-100 focus-within:translate-y-0
                   transition-all duration-150 z-50"
          >
            <a href="/tools" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">All Tools</span>
              <span class="text-xs text-[#52525b] mt-0.5">Free tools to audit and automate your store</span>
            </a>
            <a href="/shopify-automation-scanner" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">Automation Scanner</span>
              <span class="text-xs text-[#52525b] mt-0.5">Find which apps you can replace for $0</span>
            </a>
            <a href="/shopify-app-cost-calculator" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">App Cost Calculator</span>
              <span class="text-xs text-[#52525b] mt-0.5">Calculate your exact monthly app bill</span>
            </a>
            <a href="https://audit.stackarchitect.xyz" target="_blank" rel="noopener noreferrer" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">
                App Audit <span class="text-[#52525b] font-normal">↗</span>
              </span>
              <span class="text-xs text-[#52525b] mt-0.5">AI audit — enter your apps, get a free savings report</span>
            </a>
            <a href="/best-ai-tools-shopify" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">Best AI Tools 2026</span>
              <span class="text-xs text-[#52525b] mt-0.5">9 AI tools for Shopify ranked by ROI — free options noted</span>
            </a>
          </div>
        </div>

        <!-- Guides dropdown -->
        <div class="relative group/guides">
          <button
            class="flex items-center gap-1 text-xs text-gray-400 hover:text-white px-3 py-3 transition-colors font-mono"
            aria-haspopup="true"
          >
            Guides <span class="text-[#52525b]">▾</span>
          </button>
          <div
            class="absolute top-full left-0 min-w-[280px] bg-black border border-[#1f1f1f] invisible opacity-0 translate-y-1
                   group-hover/guides:visible group-hover/guides:opacity-100 group-hover/guides:translate-y-0
                   focus-within:visible focus-within:opacity-100 focus-within:translate-y-0
                   transition-all duration-150 z-50"
          >
            <a href="/shopify-automation-guides" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] border-b border-[#1f1f1f] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">All Guides</span>
              <span class="text-xs text-[#52525b] mt-0.5">Tracking, inventory, P&amp;L and workflow guides</span>
            </a>
            <a href="/ultimate-shopify-automation-guide" class="flex flex-col px-4 py-3 hover:bg-[#0a0a0a] group/item">
              <span class="text-xs font-bold text-white group-hover/item:text-[#4ade80] transition-colors font-mono">Ultimate Automation Guide</span>
              <span class="text-xs text-[#52525b] mt-0.5">The complete $0 automation setup guide</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center gap-3">
        <span class="text-xs text-[#52525b] font-mono">SAVE $700+/MO →</span>
        <a
          href="https://www.make.com/en/register?pc=techie123"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-bold text-black bg-[#4ade80] px-3 py-1.5 hover:bg-[#22c55e] transition-colors whitespace-nowrap font-mono"
        >
          REPLACE MY APPS FREE →
        </a>
      </div>

      <!-- Mobile hamburger label -->
      <label
        for="mobile-nav-toggle"
        class="md:hidden flex flex-col gap-1.5 cursor-pointer p-2"
        aria-label="Toggle navigation"
      >
        <span class="w-5 h-px bg-white peer-checked/nav:rotate-45 transition-transform block"></span>
        <span class="w-5 h-px bg-white peer-checked/nav:opacity-0 transition-opacity block"></span>
        <span class="w-5 h-px bg-white peer-checked/nav:-rotate-45 transition-transform block"></span>
      </label>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden peer-checked/nav:block border-t border-[#1f1f1f] bg-black">
    <div class="px-4 py-4 space-y-1">
      <div class="text-xs text-[#52525b] uppercase tracking-widest pb-2 mb-2 border-b border-[#1f1f1f]">PRODUCTS</div>
      <a href="/capi-shield" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">CAPI_Shield</a>
      <a href="/stocky-swap" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">$0_Stocky_Swap</a>
      <a href="/tiktok-events-api-shopify" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">TikTok_Events_API</a>
      <a href="/replace-klaviyo-free" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">Replace_Klaviyo_Free</a>
      <a href="/shopify-profit-loss-automation" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">Shopify_P&amp;L_Auto</a>
      <a href="/autocrat-quota-fix" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">Autocrat_Quota_Fix</a>

      <div class="text-xs text-[#52525b] uppercase tracking-widest pt-4 pb-2 mb-2 border-b border-[#1f1f1f]">TOOLS</div>
      <a href="/tools" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">All Tools</a>
      <a href="/shopify-automation-scanner" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">Automation Scanner</a>
      <a href="/shopify-app-cost-calculator" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">App Cost Calculator</a>
      <a href="https://audit.stackarchitect.xyz" target="_blank" rel="noopener noreferrer" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">App Audit ↗</a>
      <a href="/best-ai-tools-shopify" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">Best AI Tools 2026</a>

      <div class="text-xs text-[#52525b] uppercase tracking-widest pt-4 pb-2 mb-2 border-b border-[#1f1f1f]">GUIDES</div>
      <a href="/shopify-automation-guides" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">All Guides</a>
      <a href="/ultimate-shopify-automation-guide" class="block text-xs text-gray-400 hover:text-white py-2 font-mono">Ultimate Automation Guide</a>

      <div class="pt-4">
        <a
          href="https://www.make.com/en/register?pc=techie123"
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full text-center text-xs font-bold text-black bg-[#4ade80] px-3 py-3 hover:bg-[#22c55e] transition-colors font-mono"
        >
          REPLACE MY APPS FREE →
        </a>
      </div>
    </div>
  </div>
</nav>
