---
/**
 * Evidence.astro — proof block for real screenshots / recordings.
 *
 * Purpose: the single biggest content gap flagged in the July 2026 audit is
 * that no page contains unfakeable proof (real Make.com scenario screenshots,
 * real EMQ scores, real deploy footage). This component gives every proof
 * asset a consistent, credible presentation + ImageObject/VideoObject schema
 * so Google and AI answer engines can attribute it to the site and author.
 *
 * Usage (image):
 *   import Evidence from '../components/Evidence.astro';
 *   import emqShot from '../assets/proof/emq-after-capi-shield.png';
 *
 *   <Evidence
 *     src={emqShot}
 *     alt="Meta Events Manager showing EMQ 7.2 on Purchase event after CAPI Shield deploy"
 *     caption="Meta Events Manager, live store, 14 days after deploying CAPI Shield. EMQ on Purchase: 7.2/10."
 *     capturedOn="2026-07-02"
 *     source="Meta Events Manager"
 *   />
 *
 * Usage (video): pass `videoSrc` (mp4 in /public/videos/) + `poster` instead of `src`.
 *
 * Rules for assets (do not break these — they are the point):
 *  - Real UI only. No mockups, no stock, no AI-generated screenshots.
 *  - Leave real timestamps/dates visible; blur only store names & PII.
 *  - Caption states WHAT tool, WHICH store context, WHEN captured.
 */
import { Image } from 'astro:assets';

interface Props {
  src?: ImageMetadata;
  videoSrc?: string;
  poster?: string;
  alt?: string;
  caption: string;
  capturedOn: string; // ISO date, e.g. "2026-07-02"
  source: string; // e.g. "Meta Events Manager", "Make.com scenario editor"
  width?: number;
}

const { src, videoSrc, poster, alt = '', caption, capturedOn, source, width = 860 } = Astro.props;

const prettyDate = new Date(capturedOn).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const schema = videoSrc
  ? {
      '@context': 'https://schema.org',
      '@type': 'VideoObject',
      name: caption,
      description: caption,
      contentUrl: new URL(videoSrc, 'https://stackarchitect.xyz').href,
      thumbnailUrl: poster ? new URL(poster, 'https://stackarchitect.xyz').href : undefined,
      uploadDate: capturedOn,
      author: { '@id': 'https://stackarchitect.xyz/#luke' },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'ImageObject',
      name: caption,
      description: `${caption} Captured from ${source} on ${prettyDate}.`,
      contentUrl: src ? new URL(src.src, 'https://stackarchitect.xyz').href : undefined,
      creditText: 'Stack Architect',
      creator: { '@id': 'https://stackarchitect.xyz/#luke' },
      copyrightNotice: 'Stack Architect',
      uploadDate: capturedOn,
    };
---

<figure class="evidence">
  <div class="evidence-media">
    {
      videoSrc ? (
        <video controls preload="none" poster={poster} width={width} playsinline>
          <source src={videoSrc} type="video/mp4" />
        </video>
      ) : src ? (
        <Image src={src} alt={alt} width={width} loading="lazy" decoding="async" />
      ) : null
    }
  </div>
  <figcaption class="evidence-caption">
    <span class="evidence-badge" title={`Captured from ${source} on ${prettyDate}`}>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 2l7 4v6c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <path d="M8.5 12l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Real capture · {source} · {prettyDate}
    </span>
    <span class="evidence-text">{caption}</span>
  </figcaption>
</figure>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  .evidence {
    margin: 2rem 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
  }
  .evidence-media :global(img),
  .evidence-media video {
    display: block;
    width: 100%;
    height: auto;
  }
  .evidence-caption {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.85rem 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .evidence-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #34d377;
  }
  .evidence-text {
    font-size: 0.85rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
  }
</style>
