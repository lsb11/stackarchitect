---
import '../styles/global.css';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
  pageType?: 'website' | 'article' | 'product';
  updatedDate?: string;
  publishDate?: string;
  breadcrumb?: BreadcrumbItem[];
}

const {
  title,
  description,
  canonical: _rawCanonical,
  ogTitle,
  ogDescription,
  ogImage,
  schema,
  noindex = false,
  pageType = 'website',
  updatedDate,
  publishDate,
  breadcrumb,
} = Astro.props;

// Always force canonical to the primary non-www domain.
// Matches astro.config.mjs `trailingSlash: 'always'` — every canonical
// ends with `/` to prevent duplicate-URL splits in GSC indexing.
// Corrects www., bare paths, and trailing-slash mismatches from any page.
const canonical = (() => {
  const raw = _rawCanonical ?? Astro.url.pathname;
  let path;
  try {
    path = raw.startsWith('http') ? new URL(raw).pathname : raw;
  } catch {
    path = Astro.url.pathname;
  }
  // Enforce trailing slash (unless it's a file path ending in an extension)
  if (!path.endsWith('/') && !/\.[a-z0-9]{2,5}$/i.test(path)) {
    path = path + '/';
  }
  // Collapse any accidental double slashes
  path = path.replace(/\/+/g, '/');
  return 'https://stackarchitect.xyz' + path;
})();

const schemaArray = schema
  ? Array.isArray(schema)
    ? schema
    : [schema]
  : [];

const siteNavSchema = {
  '@context': 'https://schema.org',
  '@type': 'SiteNavigationElement',
  name: [
    'Home',
    'CAPI Shield',
    'Stocky Swap',
    'TikTok Events API',
    'Replace Klaviyo Free',
    'Shopify P&L Automation',
    'All Guides',
    'Ultimate Automation Guide',
    'Shopify Automation Scanner',
    'App Cost Calculator',
    'Best AI Tools for Shopify',
  ],
  url: [
    'https://stackarchitect.xyz/',
    'https://stackarchitect.xyz/capi-shield',
    'https://stackarchitect.xyz/stocky-swap',
    'https://stackarchitect.xyz/tiktok-events-api-shopify',
    'https://stackarchitect.xyz/replace-klaviyo-free',
    'https://stackarchitect.xyz/shopify-profit-loss-automation',
    'https://stackarchitect.xyz/shopify-automation-guides',
    'https://stackarchitect.xyz/ultimate-shopify-automation-guide',
    'https://stackarchitect.xyz/shopify-automation-scanner',
    'https://stackarchitect.xyz/shopify-app-cost-calculator',
    'https://stackarchitect.xyz/best-ai-tools-shopify',
  ],
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://stackarchitect.xyz/#org',
  'name': 'Stack Architect',
  'url': 'https://stackarchitect.xyz',
  'logo': {
    '@type': 'ImageObject',
    'url': 'https://stackarchitect.xyz/StackArchitectUpdatedLogo.png',
    'width': 512,
    'height': 512,
  },
  'description': 'Free Shopify automation tools replacing $700+/month of paid apps. Server-side tracking, inventory management, email marketing, TikTok Events API, P&L reporting. No code required.',
  'contactPoint': {
    '@type': 'ContactPoint',
    'email': 'support@stackarchitect.xyz',
    'contactType': 'customer support',
  },
  'sameAs': ['https://www.linkedin.com/in/stack-architect-6766733b0'],
};


const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://stackarchitect.xyz/#luke',
  'name': 'Luke',
  'jobTitle': 'Shopify Automation Specialist',
  'url': 'https://stackarchitect.xyz/about',
  'sameAs': ['https://www.linkedin.com/in/stack-architect-6766733b0'],
  'worksFor': { '@type': 'Organization', '@id': 'https://stackarchitect.xyz/#org' },
  'knowsAbout': [
    'Shopify automation', 'server-side tracking', 'Meta Conversions API',
    'Google Enhanced Conversions', 'TikTok Events API', 'Make.com',
    'Google Sheets automation', 'Shopify app cost reduction',
    'email marketing automation', 'Shopify inventory management',
    'Shopify CAPI', 'Elevar alternative', 'Triple Whale alternative',
  ],
};
const allSchemas = [...schemaArray, siteNavSchema, orgSchema, personSchema];

const hasBreadcrumb = breadcrumb && breadcrumb.length > 0;
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    
    <!-- Speakable schema — voice assistants + AI voice summaries read these selectors aloud -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".hero-sub", ".sec-head h2", ".sec-head p", ".faq-ans-c p", ".seo-prose p:first-of-type"]
    })} />
    
    <!-- Performance: DNS prefetch for third-party scripts loaded later -->
    <link rel="dns-prefetch" href="//www.googletagmanager.com" />
    <link rel="dns-prefetch" href="//www.google-analytics.com" />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, nofollow'
        : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'}
    />

    <!-- Preconnect to affiliate domains -->
    <link rel="preconnect" href="https://www.make.com" />
    <link rel="preconnect" href="https://systeme.io" />

    <!-- Mobile browser chrome colour -->
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Article modified time -->
    <meta
      property="article:modified_time"
      content={updatedDate ?? publishDate ?? new Date().toISOString()}
    />

    <!-- Hreflang — UK English primary audience -->
    <link rel="alternate" hreflang="en-gb" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:type" content={pageType === 'article' ? 'article' : 'website'} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Stack Architect" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta
      name="twitter:image"
      content={ogImage ?? 'https://stackarchitect.xyz/og.png'}
    />

    <!-- JSON-LD Schema -->
    {allSchemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- GA4 + AttributionTracker — measurement ID G-TE6Z6CW514 -->
    <!-- GA4_PLACEHOLDER_START -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-TE6Z6CW514"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', 'G-TE6Z6CW514');

      // AttributionTracker — inlined directly to bypass Astro module bundling.
      // Captures landing/UTM, fires affiliate_click + kit_click GA4 events,
      // sets sa_attr cookie, stamps Stripe URLs with client_reference_id.
      (function() {
        'use strict';
        try {
          var LANDING_KEY = 'sa_landing';
          var ATTR_COOKIE = 'sa_attr';
          var NOW = Date.now();

          if (!sessionStorage.getItem(LANDING_KEY)) {
            var url = new URL(window.location.href);
            var refHost = 'direct';
            try {
              if (document.referrer) refHost = new URL(document.referrer).hostname;
            } catch (e) {}
            sessionStorage.setItem(LANDING_KEY, JSON.stringify({
              path:       url.pathname,
              ref:        refHost,
              utm_source: url.searchParams.get('utm_source')   || '',
              utm_medium: url.searchParams.get('utm_medium')   || '',
              utm_camp:   url.searchParams.get('utm_campaign') || '',
              gclid:      url.searchParams.get('gclid')        || '',
              fbclid:     url.searchParams.get('fbclid')       || '',
              ts:         NOW
            }));
          }

          function getLanding() {
            try { return JSON.parse(sessionStorage.getItem(LANDING_KEY) || '{}'); }
            catch (e) { return {}; }
          }
          function setAttrCookie(payload) {
            var expires = new Date(NOW + 30 * 24 * 60 * 60 * 1000).toUTCString();
            document.cookie = ATTR_COOKIE + '=' + encodeURIComponent(JSON.stringify(payload)) +
              '; path=/; expires=' + expires + '; SameSite=Lax; Secure';
          }
          function b64url(str) {
            return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
          }

          document.addEventListener('click', function(e) {
            var a = e.target.closest('a');
            if (!a || !a.href) return;
            var href = a.getAttribute('href') || '';
            var absHref = a.href;

            var isAffiliate = href.indexOf('/go/') === 0;
            var isKitPage   = (href === '/pro' || href === '/pro/' || href.indexOf('/pro#') === 0);
            var isStripe    = absHref.indexOf('buy.stripe.com') > -1;

            if (!isAffiliate && !isKitPage && !isStripe) return;

            var landing = getLanding();
            var sourcePage = window.location.pathname;

            setAttrCookie({
              s:   sourcePage,
              d:   isAffiliate ? href : (isStripe ? 'kit-stripe' : 'kit-page'),
              l:   landing.path || '',
              ref: landing.ref  || 'direct',
              src: landing.utm_source || '',
              cmp: landing.utm_camp   || '',
              ts:  NOW
            });

            if (typeof window.gtag === 'function') {
              window.gtag('event', isAffiliate ? 'affiliate_click' : 'kit_click', {
                source_page:  sourcePage,
                destination:  href,
                landing_path: landing.path || '',
                referrer:     landing.ref || 'direct',
                utm_source:   landing.utm_source || '',
                utm_campaign: landing.utm_camp || ''
              });
            }

            if (isStripe) {
              try {
                var stripeUrl = new URL(absHref);
                var payload = b64url(JSON.stringify({
                  s:   sourcePage.slice(0, 40),
                  l:   (landing.path || '').slice(0, 40),
                  ref: (landing.ref  || '').slice(0, 30),
                  src: (landing.utm_source || '').slice(0, 20),
                  cmp: (landing.utm_camp   || '').slice(0, 20),
                  ts:  NOW
                }));
                stripeUrl.searchParams.set('client_reference_id', payload);
                a.href = stripeUrl.toString();
              } catch (err) {}
            }
          }, true);
        } catch (err) {}
      })();
    </script>
    <!-- GA4_PLACEHOLDER_END -->

<style>
@media(hover:hover){.related-link-item:hover{border-bottom-color:rgba(0,200,100,.2) !important;}}
@media(max-width:640px){
  .related-link-item{padding:12px 0 !important;}
  .related-link-item > div:last-child{display:none;}
}
</style>
    <slot name="head" />
  </head>
  <body class="bg-black text-white font-mono min-h-screen flex flex-col">
    <!-- Named slot so child layouts can position Nav before breadcrumb -->
    <slot name="header" />

    {hasBreadcrumb && (
      <nav aria-label="Breadcrumb" class="breadcrumb border-b border-[#1f1f1f]">
        {breadcrumb!.map((item, i) => (
          <>
            {i > 0 && <span class="breadcrumb-separator">/</span>}
            {item.href
              ? <a href={item.href}>{item.label}</a>
              : <span class="text-white">{item.label}</span>
            }
          </>
        ))}
      </nav>
    )}

    <slot />
  
<!-- SA Sticky Conversion Bar -->
<div id="sa-sticky" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:99999;background:#0a0a0a;border-top:1px solid #1f1f1f;padding:12px 20px;box-shadow:0 -4px 24px rgba(0,0,0,.4);">
  <div style="max-width:1000px;margin:0 auto;display:flex;align-items:center;gap:12px;flex-wrap:wrap;justify-content:space-between;">
    <p style="margin:0;font-size:13px;color:#a1a1aa;font-family:system-ui,sans-serif;flex:1;min-width:160px;">Your store is leaking <strong style="color:#fff;">$700+/mo</strong> to paid apps.</p>
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
      <a href="/pro" style="display:inline-flex;align-items:center;gap:6px;background:#fbbf24;color:#000;font-weight:700;font-size:13px;padding:9px 18px;border-radius:6px;text-decoration:none;white-space:nowrap;" onclick="sessionStorage.setItem('sa-sticky-clicked','1')">Get the Kit — $29 &#8594;</a>
      <a href="/go/make" target="_blank" rel="noopener sponsored" style="display:inline-flex;align-items:center;gap:6px;background:transparent;color:#00c864;font-weight:600;font-size:13px;padding:9px 18px;border-radius:6px;text-decoration:none;border:1px solid rgba(0,200,100,.3);white-space:nowrap;" onclick="sessionStorage.setItem('sa-sticky-clicked','1')">Start Free &#8594;</a>
      <button id="sa-sticky-close" aria-label="Dismiss" style="background:transparent;border:none;color:#52525b;font-size:18px;cursor:pointer;padding:4px 8px;line-height:1;flex-shrink:0;">&#215;</button>
    </div>
  </div>
</div>
<script is:inline>
(function(){
  var bar = document.getElementById('sa-sticky');
  if (!bar) return;
  if (sessionStorage.getItem('sa-sticky-dismissed') || sessionStorage.getItem('sa-sticky-clicked')) return;
  if (window.location.pathname === '/pro' || window.location.pathname === '/pro/') return;
  var shown = false;
  window.addEventListener('scroll', function(){
    if (shown) return;
    var pct = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
    if (pct >= 55) { bar.style.display = 'block'; shown = true; }
  }, {passive: true});
  document.getElementById('sa-sticky-close').addEventListener('click', function(){
    bar.style.display = 'none';
    sessionStorage.setItem('sa-sticky-dismissed', '1');
  });
})();
</script>
  </body>
</html>