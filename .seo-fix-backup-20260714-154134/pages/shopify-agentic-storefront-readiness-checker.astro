<script is:inline>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
      bar.style.width = Math.min(pct, 100) + '%';
    }, { passive: true });
  }


  function calcAI() {
    const checked = [...document.querySelectorAll('#ai-checks input:checked')];
    const score = checked.reduce((sum, el) => sum + parseInt(el.dataset.weight || 0), 0);
    const unchecked = [...document.querySelectorAll('#ai-checks input:not(:checked)')];

    let grade, gradeColor, visibility;
    if (score >= 85) { grade = 'Excellent AI readiness'; gradeColor = '#34d377'; visibility = 'High'; }
    else if (score >= 65) { grade = 'Good — minor gaps only'; gradeColor = '#a3e635'; visibility = 'Moderate-High'; }
    else if (score >= 45) { grade = 'Moderate — significant gaps'; gradeColor = '#f5b64d'; visibility = 'Low-Moderate'; }
    else { grade = 'Low — AI search largely invisible'; gradeColor = '#f87171'; visibility = 'Low'; }

    // Find highest-weight unchecked item
    let topPriority = 'All checks complete';
    let topWeight = 0;
    unchecked.forEach(el => {
      const w = parseInt(el.dataset.weight || 0);
      if (w > topWeight) { topWeight = w; topPriority = el.parentElement.querySelector('span').textContent.split(' ').slice(0,5).join(' ') + '...'; }
    });

    document.getElementById('ai-score').textContent = score + '/100';
    document.getElementById('ai-score').style.color = gradeColor;
    document.getElementById('ai-grade').textContent = grade;
    document.getElementById('ai-visibility').textContent = visibility;
    document.getElementById('ai-priority').textContent = topPriority;

    const missingCount = unchecked.length;
    let insight = '<strong>' + (100 - score) + ' points of improvement available.</strong> ';
    if (missingCount > 0) insight += missingCount + ' checks not yet implemented. Start with the highest-weighted items first. ';
    if (score < 50) insight += 'Priority actions: implement Product + FAQPage schema, improve content depth on product pages, submit sitemap to Google Search Console.';
    document.getElementById('ai-insight').innerHTML = insight;
    document.getElementById('ai-result').classList.add('show');
  }
  
</script>
