---
interface Props {
  type: 'urgent' | 'warning' | 'info' | 'tip' | 'deadline';
  title?: string;
}

const { type, title } = Astro.props;

const styles: Record<string, { border: string; bg: string; icon: string; titleColor: string }> = {
  urgent: {
    border: 'border-red-700',
    bg: 'bg-red-950/30',
    icon: '🔴',
    titleColor: 'text-red-400',
  },
  warning: {
    border: 'border-amber-700',
    bg: 'bg-amber-950/30',
    icon: '⚠️',
    titleColor: 'text-amber-400',
  },
  info: {
    border: 'border-blue-700',
    bg: 'bg-blue-950/30',
    icon: 'ℹ️',
    titleColor: 'text-blue-400',
  },
  tip: {
    border: 'border-green-700',
    bg: 'bg-green-950/30',
    icon: '💡',
    titleColor: 'text-green-400',
  },
  deadline: {
    border: 'border-red-600',
    bg: 'bg-red-950/40',
    icon: '🔴',
    titleColor: 'text-red-400',
  },
};

const s = styles[type] ?? styles.info;
---

<div
  class={`border ${s.border} ${s.bg} p-4 my-5 ${type === 'deadline' ? 'animate-pulse' : ''}`}
>
  {
    title && (
      <div class={`font-bold text-sm uppercase tracking-wide mb-2 ${s.titleColor}`}>
        <span class="mr-2">{s.icon}</span>{title}
      </div>
    )
  }
  {
    !title && (
      <span class="mr-2">{s.icon}</span>
    )
  }
  <div class="text-sm text-gray-300">
    <slot />
  </div>
</div>
