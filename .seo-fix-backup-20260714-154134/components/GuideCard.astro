---
interface Props {
  badge?: string;
  badgeType?: 'urgent' | 'new' | 'comparison' | 'hot' | 'default';
  category: string;
  title: string;
  description: string;
  readTime: number;
  href: string;
}

const { badge, badgeType = 'default', category, title, description, readTime, href } = Astro.props;

const badgeStyles: Record<string, string> = {
  urgent: 'bg-red-900/50 text-red-400 border-red-700',
  new: 'bg-[#34d377]/10 text-[#34d377] border-[#34d377]/30',
  comparison: 'bg-blue-900/50 text-blue-400 border-blue-700',
  hot: 'bg-orange-900/50 text-orange-400 border-orange-700',
  default: 'bg-[#262c29] text-[#6b7671] border-[#222825]',
};
---

<a
  href={href}
  class="block border border-[#222825] bg-[#0c0f0d] p-5 hover:border-[#34d377]/30 hover:bg-[#121614] transition-all group relative"
>
  {
    badge && (
      <div
        class={`absolute top-3 right-3 text-xs px-2 py-0.5 border uppercase tracking-wide font-bold ${badgeStyles[badgeType]}`}
      >
        {badge}
      </div>
    )
  }
  <div class="text-xs text-[#6b7671] uppercase tracking-widest mb-2">{category}</div>
  <h3 class="text-sm font-bold text-white group-hover:text-[#34d377] transition-colors mb-2 pr-16">
    {title}
  </h3>
  <p class="text-xs text-gray-500 leading-relaxed mb-4">{description}</p>
  <div class="flex items-center justify-between">
    <span class="text-xs text-[#6b7671]">{readTime} min read</span>
    <span class="text-xs text-[#34d377] group-hover:translate-x-0.5 transition-transform">→</span>
  </div>
</a>
