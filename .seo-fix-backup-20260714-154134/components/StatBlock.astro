---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 my-8">
  {
    stats.map(({ value, label }) => (
      <div class="border border-[#222825] bg-[#0c0f0d] p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold text-[#34d377]">{value}</div>
        <div class="text-xs text-[#6b7671] mt-1 uppercase tracking-wider">{label}</div>
      </div>
    ))
  }
</div>
