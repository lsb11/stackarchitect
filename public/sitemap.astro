  .sitemap-logo{display:flex;align-items:center;gap:12px;text-decoration:none}
  .sitemap-logo img{height:48px;width:auto}
  .sitemap-logo-text{display:flex;flex-direction:column}
  .sitemap-logo-name{font-size:1.4rem;font-weight:700;color:#fff;letter-spacing:-.02em;font-family:'JetBrains Mono',monospace}
  .sitemap-logo-tag{font-size:.75rem;color:#00C896;font-family:'JetBrains Mono',monospace;letter-spacing:.05em}
  .sitemap-meta{margin-left:auto;font-size:.78rem;color:#555570;font-family:'JetBrains Mono',monospace;text-align:right}
  h1{font-size:1.6rem;font-weight:700;color:#fff;margin-bottom:8px}
  .sitemap-desc{font-size:.9rem;color:#8888aa;margin-bottom:48px;line-height:1.7}
  .sitemap-section{margin-bottom:40px}
  .section-label{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:#00C896;font-family:'JetBrains Mono',monospace;margin-bottom:14px;display:flex;align-items:center;gap:10px}
  .section-label::after{content:'';flex:1;height:1px;background:#2a2a42}
  .section-count{color:#555570;font-size:.7rem}
  .url-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:6px}
  .url-item{display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border:1px solid #2a2a42;border-radius:6px;background:#1a1a2e;transition:border-color .15s}
  .url-item:hover{border-color:#00C896}
  .url-item a{color:#e8e8f0;font-size:.85rem;text-decoration:none;line-height:1.4;flex:1}
  .url-item a:hover{color:#00C896}
  .url-path{display:block;font-size:.72rem;color:#555570;font-family:'JetBrains Mono',monospace;margin-top:3px}
  .badge{font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:10px;white-space:nowrap;flex-shrink:0;margin-top:2px;font-family:'JetBrains Mono',monospace}
  .badge-new{background:rgba(0,200,150,.12);color:#00C896;border:1px solid rgba(0,200,150,.25)}
  .badge-urgent{background:rgba(239,68,68,.12);color:#ef4444;border:1px solid rgba(239,68,68,.25)}
  .badge-tool{background:rgba(59,130,246,.12);color:#3b82f6;border:1px solid rgba(59,130,246,.25)}
  .sitemap-footer{margin-top:48px;padding-top:24px;border-top:1px solid #2a2a42;font-size:.8rem;color:#555570;font-family:'JetBrains Mono',monospace;display:flex;justify-content:space-between;flex-wrap:gap}
  .back-link{color:#8888aa;font-size:.85rem;display:inline-flex;align-items:center;gap:6px;margin-bottom:32px;text-decoration:none}
  .back-link:hover{color:#00C896}
  @media(max-width:600px){.url-grid{grid-template-columns:1fr}.sitemap-header{flex-wrap:wrap}.sitemap-meta{margin-left:0}}
</style>

