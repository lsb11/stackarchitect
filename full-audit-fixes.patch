@@ -28,7 +28,8 @@ const canonical = "https://stackarchitect.xyz/faq/how-do-i-set-up-tiktok-events-
 <script type="application/ld+json" set:html={JSON.stringify({"@context": "https://schema.org", "@graph": [{"@type": "WebPage", "@id": "https://stackarchitect.xyz/faq/how-do-i-set-up-tiktok-events-api-on-shopify-without-code#webpage", "url": "https://stackarchitect.xyz/faq/how-do-i-set-up-tiktok-events-api-on-shopify-without-code", "name": "How Do I Set Up TikTok Events API on Shopify Without Code? | Stack Architect", "description": "Set up TikTok Events API on Shopify without code in 6 minutes: create a Make.com webhook that fires a CompletePayment event server-side when a Shopify order is paid. Free on Make.com's free tier. Achieves EMQ scores of 6\u20138.", "datePublished": "2026-03-15", "dateModified": "2026-04-12", "inLanguage": "en-GB", "isPartOf": {"@id": "https://stackarchitect.xyz/#website"}, "speakable": {"@type": "SpeakableSpecification", "cssSelector": [".quick-answer p", "h1"]}, "author": {"@type": "Organization", "name": "Stack Architect", "url": "https://stackarchitect.xyz"}, "publisher": {"@type": "Organization", "name": "Stack Architect", "url": "https://stackarchitect.xyz"}}, {"@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://stackarchitect.xyz/"}, {"@type": "ListItem", "position": 2, "name": "FAQ Hub", "item": "https://stackarchitect.xyz/faq"}, {"@type": "ListItem", "position": 3, "name": "How Do I Set Up TikTok Events API on Shopify Without Code?", "item": "https://stackarchitect.xyz/faq/how-do-i-set-up-tiktok-events-api-on-shopify-without-code"}]}, {"@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How do I set up TikTok Events API on Shopify without code?", "acceptedAnswer": {"@type": "Answer", "text": "Create a Make.com scenario with a Webhook trigger, add an order-paid webhook in Shopify Admin pointing to your Make.com URL, then configure an HTTP POST in Make.com to send a CompletePayment event to TikTok's Events API endpoint with your access token. Takes 6 minutes, no code required, free on Make.com's free tier."}}, {"@type": "Question", "name": "What is TikTok Events API for Shopify?", "acceptedAnswer": {"@type": "Answer", "text": "TikTok Events API is TikTok's server-side tracking endpoint. For Shopify, it receives CompletePayment purchase events sent from your server (via Make.com) rather than from the customer's browser. This bypasses iOS ad tracking restrictions and ad blockers, recovering 20\u201340% of conversions that the browser-based TikTok Pixel misses."}}, {"@type": "Question", "name": "What is a good TikTok EMQ score for Shopify?", "acceptedAnswer": {"@type": "Answer", "text": "An EMQ (Event Match Quality) score of 6\u20138 is considered high-quality for Shopify implementations. Most Make.com + Shopify server-side setups achieve 6\u20138 by including hashed email, hashed phone, IP address, and user agent as match signals. Scores below 4 indicate missing match data."}}, {"@type": "Question", "name": "Does the TikTok Pixel and Events API work together?", "acceptedAnswer": {"@type": "Answer", "text": "Yes \u2014 running both together is best practice. The Pixel captures browser-side events for users who allow tracking. The Events API captures server-side events for all users regardless of iOS/ad blocker status. Use the same event_id in both to enable deduplication so TikTok counts each purchase only once."}}, {"@type": "Question", "name": "What event name does Shopify use for TikTok Events API?", "acceptedAnswer": {"@type": "Answer", "text": "TikTok's purchase event name is CompletePayment \u2014 not 'Purchase' as Meta uses. When configuring your Make.com scenario for TikTok Events API, the event_name field must be set to exactly 'CompletePayment' for the conversion to register correctly in TikTok Ads Manager."}}, {"@type": "Question", "name": "Is TikTok Events API free for Shopify?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. TikTok's Events API endpoint is free to use \u2014 there is no charge for sending events. The Make.com automation that routes Shopify webhook data to TikTok's API is also free on Make.com's 1,000 operations/month free tier. Total cost: $0/month."}}]}, {"@type": "HowTo", "name": "How to Set Up TikTok Events API on Shopify Without Code", "totalTime": "PT6M", "estimatedCost": {"@type": "MonetaryAmount", "currency": "USD", "value": "0"}, "step": [{"@type": "HowToStep", "position": 1, "name": "Get TikTok Access Token", "text": "In TikTok Ads Manager, go to Assets > Events > your Pixel > Settings > Generate Access Token."}, {"@type": "HowToStep", "position": 2, "name": "Create Make.com Webhook Scenario", "text": "Create a new Make.com scenario with a Webhook trigger module. Copy the webhook URL provided."}, {"@type": "HowToStep", "position": 3, "name": "Add Shopify Order Webhook", "text": "In Shopify Admin > Settings > Notifications, add an order-paid webhook pointing to your Make.com URL."}, {"@type": "HowToStep", "position": 4, "name": "Map and Hash Order Data", "text": "In Make.com, hash the customer email with SHA-256 and map order ID, value, currency, and content_id from the Shopify webhook payload."}, {"@type": "HowToStep", "position": 5, "name": "Configure HTTP POST to TikTok", "text": "Add an HTTP module in Make.com. POST to TikTok's Events API endpoint with your access token and CompletePayment event name."}, {"@type": "HowToStep", "position": 6, "name": "Test and Verify EMQ Score", "text": "Place a test order. Check your Event Match Quality score in TikTok Events Manager. A score of 6-8 confirms successful implementation."}]}]})}/>
